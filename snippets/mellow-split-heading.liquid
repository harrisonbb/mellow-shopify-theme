{% comment %}
  Mellow split-heading renderer for major homepage section h2 headlines.
  Pass `text` and this snippet will split known homepage headlines into
  Founders Grotesk main spans and Tiempos Headline Italic accent spans, with a plain fallback
  for customizer edits that do not match a supported phrase.
{% endcomment %}

{% assign heading_text = text | default: '' | strip %}

{% case heading_text %}
  {% when 'Reflux has a pattern.' %}
    <span class="mellow-heading-main">Reflux has</span>
    <span class="mellow-heading-accent">a pattern.</span>
  {% when "For the moments reflux keeps stealing." %}
    <span class="mellow-heading-main">For the moments reflux</span>
    <span class="mellow-heading-accent">keeps stealing.</span>
  {% when "You've got enough to think about. Let us handle the rest." %}
    <span class="mellow-heading-main">Relief that moves</span>
    <span class="mellow-heading-accent">with you.</span>
  {% when "Relief that moves with you." %}
    <span class="mellow-heading-main">Relief that moves</span>
    <span class="mellow-heading-accent">with you.</span>
  {% when 'Over 50,000 Satisfied Customers and Counting' %}
    <span class="mellow-heading-main">Real routines.</span>
    <span class="mellow-heading-accent">Real relief.</span>
  {% when 'Real routines. Real relief.' %}
    <span class="mellow-heading-main">Real routines.</span>
    <span class="mellow-heading-accent">Real relief.</span>
  {% when 'How Mellow fits into your routine.' %}
    <span class="mellow-heading-main">A physical barrier,</span>
    <span class="mellow-heading-accent">not another antacid.</span>
  {% when 'A physical barrier, not another antacid.' %}
    <span class="mellow-heading-main">A physical barrier,</span>
    <span class="mellow-heading-accent">not another antacid.</span>
  {% when 'Three ingredients that form a single protective barrier.' %}
    <span class="mellow-heading-main">Three ingredients.</span>
    <span class="mellow-heading-accent">One protective raft.</span>
  {% when 'Three active ingredients. One protective raft.' %}
    <span class="mellow-heading-main">Three ingredients.</span>
    <span class="mellow-heading-accent">One protective raft.</span>
  {% when 'Three ingredients. One protective raft.' %}
    <span class="mellow-heading-main">Three ingredients.</span>
    <span class="mellow-heading-accent">One protective raft.</span>
  {% when 'Reviewed by Physicians, Dietitians, & Real Reflux Sufferers' %}
    <span class="mellow-heading-main">Reviewed by Physicians, Dietitians,</span>
    <br class="mellow-heading-break">
    <span class="mellow-heading-accent">&amp; Real Reflux Sufferers</span>
  {% when 'Built to stop reflux. Not just neutralize it.' %}
    <span class="mellow-heading-main">Not just different.</span>
    <span class="mellow-heading-accent">Built differently.</span>
  {% when 'Not just different. Built differently.' %}
    <span class="mellow-heading-main">Not just different.</span>
    <span class="mellow-heading-accent">Built differently.</span>
  {% when 'Build your reflux routine.' %}
    <span class="mellow-heading-main">Build your</span>
    <span class="mellow-heading-accent">reflux routine.</span>
  {% when 'FAQs' %}
    <span class="mellow-heading-main">Questions,</span>
    <span class="mellow-heading-accent">answered.</span>
  {% when 'Questions, answered.' %}
    <span class="mellow-heading-main">Questions,</span>
    <span class="mellow-heading-accent">answered.</span>
  {% else %}
    {{ heading_text }}
{% endcase %}
