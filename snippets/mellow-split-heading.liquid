{% comment %}
  Mellow split-heading renderer for major homepage section h2 headlines.
  Pass `text` and this snippet will split only the approved selective italic accents
  into Founders Grotesk roman spans and Tiempos Headline italic accent spans, with a
  plain sans fallback for all other major headings.
{% endcomment %}

{% assign heading_text = text | default: '' | strip %}

{% case heading_text %}
  {% when 'Reflux has a pattern.' %}
    <span class="mellow-heading-main">Reflux has</span>
    <span class="mellow-heading-accent">a pattern.</span>
  {% when "You've got enough to think about. Let us handle the rest." %}
    <span class="mellow-heading-main">You've got enough to think about.</span>
    <span class="mellow-heading-accent">Let us handle the rest.</span>
  {% else %}
    <span class="mellow-heading-main">{{ heading_text }}</span>
{% endcase %}
