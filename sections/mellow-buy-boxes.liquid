{% comment %}
  Mellow buy boxes placeholder section.
  Dawn-compatible Online Store 2.0 section scaffold for the Mellow homepage.
{% endcomment %}

<style>
  .mellow-buy-boxes .mellow-eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
  }

  .mellow-buy-boxes .mellow-architecture-section__heading {
    margin: 0;
  }

  .mellow-buy-boxes .mellow-architecture-section__text {
    margin-top: var(--mellow-section-heading-gap);
  }

  .mellow-buy-boxes .mellow-buy-boxes__cta-wrap {
    justify-content: flex-start;
    margin-top: var(--mellow-section-content-gap);
  }

  .mellow-buy-boxes .mellow-buy-boxes__cta {
    --mellow-section-cta-bg: var(--mellow-forest, #003302);
    --mellow-section-cta-border: var(--mellow-forest, #003302);
    --mellow-section-cta-color: var(--mellow-cream, #F0EBE0);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #F0EBE0);
  }
</style>

<section class="mellow-section mellow-architecture-section mellow-buy-boxes color-{{ section.settings.color_scheme }}">
  <div class="mellow-section__inner">
    <div class="mellow-architecture-section__card">
      <div class="mellow-architecture-section__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-architecture-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-architecture-section__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="mellow-section-cta-wrap mellow-buy-boxes__cta-wrap">
            <a class="mellow-section-cta mellow-buy-boxes__cta" href="{{ section.settings.cta_link | default: '/products/mellow-reflux-relief-gel' }}">
              <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
              <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- assign planning_note = section.settings.note | strip -%}
      {%- assign scaffold_note = 'Ready for final ' | append: 'design replacement.' -%}
      {%- unless planning_note == blank or planning_note == scaffold_note -%}
        <div class="mellow-architecture-section__note">
          <span>{{ planning_note | escape }}</span>
        </div>
      {%- endunless -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow buy boxes",
  "tag": "section",
  "class": "section section-mellow-buy-boxes",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Buy boxes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Prepare the main conversion module."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Add subscription, bundle, one-time purchase, and offer details when ready."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Planning note",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Mellow buy boxes"
    }
  ]
}
{% endschema %}
