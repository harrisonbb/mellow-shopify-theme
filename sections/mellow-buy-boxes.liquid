{% comment %}
  Mellow buy boxes placeholder section.
  Dawn-compatible Online Store 2.0 section scaffold for the Mellow homepage.
{% endcomment %}

{%- liquid
  assign section_eyebrow = section.settings.eyebrow | strip
  assign section_heading = section.settings.heading | strip
  assign section_text = section.settings.text | strip
  assign planning_note = section.settings.note | strip
  assign has_customer_content = false

  if section_eyebrow != blank or section_heading != blank or section_text != blank
    assign has_customer_content = true
  endif

  assign scaffold_eyebrow = 'Buy ' | append: 'boxes'
  assign scaffold_heading = 'Prepare the main conversion ' | append: 'module.'
  assign scaffold_text = 'Add subscription, bundle, one-time ' | append: 'purchase, and offer details when ready.'
  assign is_scaffold_copy = false

  if section_eyebrow == scaffold_eyebrow and section_heading == scaffold_heading and section_text == scaffold_text
    assign is_scaffold_copy = true
  endif
-%}

{%- if has_customer_content and is_scaffold_copy == false -%}
<section class="mellow-section mellow-architecture-section mellow-buy-boxes color-{{ section.settings.color_scheme }}">
  <div class="mellow-section__inner">
    <div class="mellow-architecture-section__card">
      <div class="mellow-architecture-section__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-architecture-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-architecture-section__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      {%- assign scaffold_note = 'Ready for final ' | append: 'design replacement.' -%}
      {%- unless planning_note == blank or planning_note == scaffold_note -%}
        <div class="mellow-architecture-section__note">
          <span>{{ planning_note | escape }}</span>
        </div>
      {%- endunless -%}
    </div>
  </div>
</section>
{%- elsif request.design_mode -%}
  <section class="mellow-section mellow-architecture-section mellow-buy-boxes color-{{ section.settings.color_scheme }}">
    <div class="mellow-section__inner">
      <div class="mellow-architecture-section__card">
        <div class="mellow-architecture-section__content">
          <p class="mellow-eyebrow">Mellow buy boxes</p>
          <h2 class="mellow-architecture-section__heading">Configure this section to show it on the storefront.</h2>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}


{% schema %}
{
  "name": "Mellow buy boxes",
  "tag": "section",
  "class": "section section-mellow-buy-boxes",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": ""
    },
    {
      "type": "text",
      "id": "note",
      "label": "Planning note",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Mellow buy boxes"
    }
  ]
}
{% endschema %}
