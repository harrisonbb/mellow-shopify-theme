{% comment %}
  Mellow Comparison Section
  Premium horizontal comparison table
  Updated:
  - Header typography matched exactly to Mellow Hero / Ingredients system
  - Fraunces 550 heading, tight line-height, negative tracking
  - Responsive heading breakpoints matched to Ingredients section
  - Eyebrow locked to DM Sans 800 / orange / compact spacing
  - Background changed to match main site white #FBFCF7
{% endcomment %}

<section class="mellow-compare-premium mellow-compare-premium-{{ section.id }}" id="mellow-compare-premium-{{ section.id }}">
  <div class="mellow-compare-premium__container">

    <div class="mellow-compare-premium__header">
      <span class="mellow-compare-premium__eyebrow mellow-eyebrow">The Mellow difference</span>

      <h2 class="mellow-compare-premium__title mellow-compare-premium__heading mellow-heading-split">
        {% render 'mellow-split-heading', text: 'Built to stop reflux. Not just neutralize it.' %}
      </h2>

      <p class="mellow-compare-premium__subtitle">
        Most options treat reflux after you're already feeling it. Mellow is different.
      </p>
    </div>

    <div class="mellow-compare-premium__table-wrap">
      <table class="mellow-compare-premium__table" role="table">
        <colgroup>
          <col style="width: 16%;">
          <col style="width: 42%;">
          <col style="width: 42%;">
        </colgroup>

        <thead>
          <tr>
            <th class="mellow-compare-premium__corner" scope="col"></th>

            <th class="mellow-compare-premium__head mellow-compare-premium__head--mellow" scope="col">
              <div class="mellow-compare-premium__mellow-head-inner">
                <div>
                  <div class="mellow-compare-premium__head-title mellow-compare-premium__head-title--mellow">
                    Mellow
                  </div>
                  <div class="mellow-compare-premium__recommended">
                    <span class="mellow-compare-premium__recommended-icon">✓</span>
                    <span>Recommended</span>
                  </div>
                </div>
              </div>
            </th>

            <th class="mellow-compare-premium__head mellow-compare-premium__head--else" scope="col">
              <div class="mellow-compare-premium__head-title mellow-compare-premium__head-title--else">
                Everything Else
              </div>
            </th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <th class="mellow-compare-premium__label" scope="row">What it does</th>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--mellow">
              <span class="mellow-compare-premium__check">✓</span>
              <span>Raft-forming gel barrier</span>
            </td>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--else">
              <span class="mellow-compare-premium__x">×</span>
              <span>Neutralizes or suppresses acid</span>
            </td>
          </tr>

          <tr>
            <th class="mellow-compare-premium__label" scope="row">When it works</th>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--mellow">
              <span class="mellow-compare-premium__check">✓</span>
              <span>Works within minutes</span>
            </td>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--else">
              <span class="mellow-compare-premium__x">×</span>
              <span>Starts working after reflux has begun</span>
            </td>
          </tr>

          <tr>
            <th class="mellow-compare-premium__label" scope="row">Made for</th>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--mellow">
              <span class="mellow-compare-premium__check">✓</span>
              <span>People who eat, travel, and don't slow down</span>
            </td>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--else">
              <span class="mellow-compare-premium__x">×</span>
              <span>Symptoms after they interrupt you</span>
            </td>
          </tr>

          <tr>
            <th class="mellow-compare-premium__label" scope="row">What you take</th>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--mellow">
              <span class="mellow-compare-premium__check">✓</span>
              <span>Smooth single-serve gel pouch</span>
            </td>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--else">
              <span class="mellow-compare-premium__x">×</span>
              <span>Chalky tablets, liquids, or pills</span>
            </td>
          </tr>

          <tr>
            <th class="mellow-compare-premium__label" scope="row">How it feels</th>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--mellow">
              <span class="mellow-compare-premium__check">✓</span>
              <span>One squeeze. No measuring. No mess.</span>
            </td>
            <td class="mellow-compare-premium__cell mellow-compare-premium__cell--else">
              <span class="mellow-compare-premium__x">×</span>
              <span>Feels like medicine you’d rather not take</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="mellow-compare-premium__cta-wrap">
      <a href="/collections/all" class="mellow-compare-premium__cta">
        Try Mellow
      </a>
    </div>

  </div>
</section>

<style>

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > *,
  .shopify-section:has(.mellow-compare-premium-{{ section.id }}) {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    max-width: none !important;
  }

  #mellow-compare-premium-{{ section.id }},
  #mellow-compare-premium-{{ section.id }} *,
  #shopify-section-{{ section.id }} .mellow-compare-premium,
  #shopify-section-{{ section.id }} .mellow-compare-premium * {
    box-sizing: border-box !important;
  }

  #mellow-compare-premium-{{ section.id }} {
    --mellow-forest: #1A2D10;
    --mellow-forest-soft: #173326;
    --mellow-orange: #D04A2A;
    --mellow-ivory: #F0EBE0;
    --mellow-page: #FBFCF7;
    --mellow-warm-2: #F7F4EE;
    --mellow-warm-3: #F4F0E8;
    --mellow-line: #E5DED2;
    --mellow-line-strong: #C9CEC6;
    --mellow-green-a: #F0F5ED;
    --mellow-green-b: #EAF0E6;
    --mellow-muted-green: #63786B;
    --mellow-icon-green: #8AAE4A;
    --mellow-icon-bg: #D5E5C5;
    --mellow-x-bg: #E8E3D9;
    --mellow-x: #A3AEA6;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --compare-axis-pad: clamp(128px, 8.5vw, 164px);
    --compare-axis-max: 1500px;

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding-top: clamp(76px, 5.5vw, 104px) !important;
    padding-bottom: clamp(72px, 5.2vw, 96px) !important;
    padding-left: var(--compare-axis-pad) !important;
    padding-right: var(--compare-axis-pad) !important;
    background: var(--mellow-page) !important;
    background-color: var(--mellow-page) !important;
    background-image: none !important;
    color: var(--mellow-forest) !important;
    overflow: hidden !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__container {
    width: 100% !important;
    max-width: var(--compare-axis-max) !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    background: transparent !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__header {
    width: 100% !important;
    max-width: 920px !important;
    margin: 0 0 clamp(34px, 3.2vw, 48px) !important;
    text-align: left !important;
    background: transparent !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__eyebrow {
    display: inline-block !important;
    margin: 0 0 14px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title,
  #shopify-section-{{ section.id }} .mellow-compare-premium__title,
  #shopify-section-{{ section.id }} #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title {
    margin: 0 !important;
    max-width: 900px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__subtitle,
  #shopify-section-{{ section.id }} .mellow-compare-premium__subtitle,
  #shopify-section-{{ section.id }} #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__subtitle {
    max-width: 680px !important;
    margin: 20px 0 0 !important;

    font-family: var(--font-body) !important;
    font-size: clamp(1rem, 1.18vw, 1.18rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;

    color: rgba(26, 45, 16, 0.76) !important;
    text-align: left !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__table-wrap {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    overflow-x: auto !important;
    -webkit-overflow-scrolling: touch !important;
    border-radius: 22px !important;
    box-shadow:
      0 30px 80px rgba(26, 45, 16, 0.06),
      0 1px 0 rgba(26, 45, 16, 0.04) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__table {
    width: 100% !important;
    min-width: 680px !important;
    table-layout: fixed !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    overflow: hidden !important;
    border: 1px solid var(--mellow-line) !important;
    border-radius: 22px !important;
    background: #FBFCF7 !important;
  }

  #mellow-compare-premium-{{ section.id }} th,
  #mellow-compare-premium-{{ section.id }} td {
    text-align: left !important;
    vertical-align: middle !important;
  }

  #mellow-compare-premium-{{ section.id }} thead th {
    height: 74px !important;
  }

  #mellow-compare-premium-{{ section.id }} tbody th,
  #mellow-compare-premium-{{ section.id }} tbody td {
    height: 58px !important;
    border-top: 1px solid var(--mellow-line) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__corner {
    background: var(--mellow-warm-2) !important;
    border-right: 2px solid var(--mellow-line-strong) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head {
    padding: 14px 22px !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head--mellow {
    background:
      radial-gradient(circle at 9% 8%, rgba(240, 235, 224, 0.18), transparent 28%),
      linear-gradient(90deg, #2D4B22 0%, var(--mellow-forest) 58%) !important;
    color: var(--mellow-ivory) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head--else {
    background: #F8F3EC !important;
    color: rgba(99, 120, 107, 0.76) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__mellow-head-inner {
    display: flex !important;
    align-items: flex-start !important;
    justify-content: flex-start !important;
    gap: 0 !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head-title {
    font-family: var(--font-heading) !important;
    font-size: clamp(1.34rem, 1.6vw, 1.9rem) !important;
    line-height: 0.95 !important;
    letter-spacing: -0.035em !important;
    font-weight: 600 !important;
    text-transform: none !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head-title--mellow {
    color: var(--mellow-ivory) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__head-title--else {
    font-family: var(--font-body) !important;
    font-size: clamp(0.96rem, 1.08vw, 1.18rem) !important;
    line-height: 1 !important;
    letter-spacing: 0.06em !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    color: rgba(99, 120, 107, 0.82) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__recommended {
    display: inline-flex !important;
    align-items: center !important;
    gap: 8px !important;
    margin-top: 9px !important;
    font-family: var(--font-body) !important;
    font-size: clamp(0.76rem, 0.84vw, 0.9rem) !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.06em !important;
    color: var(--mellow-icon-green) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__recommended-icon {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 23px !important;
    height: 23px !important;
    border-radius: 999px !important;
    background: var(--mellow-icon-green) !important;
    color: var(--mellow-forest) !important;
    font-size: 0.78rem !important;
    font-weight: 900 !important;
    box-shadow: 0 0 0 7px rgba(138, 174, 74, 0.14) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__label {
    padding: 12px 16px 12px 20px !important;
    background: #F8F3EC !important;
    border-right: 2px solid var(--mellow-line-strong) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(0.66rem, 0.72vw, 0.78rem) !important;
    line-height: 1.15 !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    font-weight: 800 !important;
    color: rgba(99, 120, 107, 0.72) !important;
  }

  #mellow-compare-premium-{{ section.id }} tbody tr:nth-child(odd) .mellow-compare-premium__cell--mellow {
    background: #EAF0E6 !important;
  }

  #mellow-compare-premium-{{ section.id }} tbody tr:nth-child(even) .mellow-compare-premium__cell--mellow {
    background: #F0F5ED !important;
  }

  #mellow-compare-premium-{{ section.id }} tbody tr:nth-child(odd) .mellow-compare-premium__cell--else {
    background: #F8F3EC !important;
  }

  #mellow-compare-premium-{{ section.id }} tbody tr:nth-child(even) .mellow-compare-premium__cell--else {
    background: #FCFAF6 !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cell {
    padding: 12px 22px !important;
    font-family: var(--font-body) !important;
    font-size: clamp(0.9rem, 0.96vw, 1.04rem) !important;
    line-height: 1.3 !important;
    letter-spacing: -0.02em !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cell--mellow {
    color: var(--mellow-forest-soft) !important;
    font-weight: 850 !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cell--else {
    color: rgba(99, 120, 107, 0.72) !important;
    font-weight: 500 !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__check,
  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__x {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 23px !important;
    height: 23px !important;
    min-width: 23px !important;
    border-radius: 999px !important;
    margin-right: 10px !important;
    font-size: 0.78rem !important;
    line-height: 1 !important;
    font-weight: 900 !important;
    vertical-align: middle !important;
    flex-shrink: 0 !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__check {
    background: var(--mellow-icon-bg) !important;
    color: var(--mellow-icon-green) !important;
    box-shadow: 0 0 0 7px rgba(213, 229, 197, 0.32) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__x {
    background: var(--mellow-x-bg) !important;
    color: var(--mellow-x) !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cell > span:last-child {
    display: inline !important;
    vertical-align: middle !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cta-wrap {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    margin-top: 22px !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cta {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    min-height: 54px !important;
    padding: 0 38px !important;
    border-radius: 999px !important;

    background: var(--mellow-orange) !important;
    color: #FFFFFF !important;
    text-decoration: none !important;

    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;

    border: 1px solid var(--mellow-orange) !important;
    box-shadow:
      0 16px 34px rgba(208, 74, 42, 0.22),
      0 0 0 0 rgba(208, 74, 42, 0) !important;

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease !important;
  }

  #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__cta:hover {
    transform: translateY(-2px) !important;
    background: #BC4425 !important;
    border-color: #BC4425 !important;
    color: #FFFFFF !important;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.28),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
  }

  @media screen and (min-width: 1500px) {
    #mellow-compare-premium-{{ section.id }} {
      --compare-axis-pad: clamp(128px, 8.5vw, 168px);
      padding-top: 112px !important;
      padding-bottom: 104px !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__header {
      max-width: 980px !important;
      margin-bottom: 52px !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title {
      max-width: 980px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__subtitle {
      max-width: 720px !important;
    }

    #mellow-compare-premium-{{ section.id }} thead th {
      height: 76px !important;
    }

    #mellow-compare-premium-{{ section.id }} tbody th,
    #mellow-compare-premium-{{ section.id }} tbody td {
      height: 60px !important;
    }
  }

  @media (max-width: 1100px) {
    #mellow-compare-premium-{{ section.id }} {
      --compare-axis-pad: 32px;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__header {
      max-width: 820px !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title {
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__subtitle {
      max-width: 680px !important;
    }
  }

  @media (max-width: 640px) {
    #mellow-compare-premium-{{ section.id }} {
      --compare-axis-pad: 20px;
      padding-top: 58px !important;
      padding-bottom: 62px !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__header {
      max-width: 100% !important;
      margin-bottom: 30px !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__eyebrow {
      margin-bottom: 14px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.115em !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} .mellow-compare-premium__title,
    #shopify-section-{{ section.id }} #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__title {
      max-width: 100% !important;
      font-size: clamp(2.35rem, 10vw, 3.55rem) !important;
      line-height: 1.05 !important;
      letter-spacing: -0.03em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 48, "wght" 550 !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__subtitle {
      max-width: 100% !important;
      margin-top: 18px !important;
      font-size: 0.98rem !important;
      line-height: 1.55 !important;
    }

    #mellow-compare-premium-{{ section.id }} .mellow-compare-premium__table {
      min-width: 680px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow Comparison",
  "tag": "section",
  "presets": [
    {
      "name": "Mellow Comparison"
    }
  ]
}
{% endschema %}