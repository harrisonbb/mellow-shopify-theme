{% comment %}
  Premium Mellow comparison table.
  Built against the global Mellow section axis, typography, color, radius, and spacing tokens.
{% endcomment %}

<style>
  #MellowCompare-{{ section.id }} {
    --compare-forest: #123308;
    --compare-ivory: var(--mellow-ivory, #FCFBF7);
    --compare-accent: var(--mellow-orange-red, #D04A2A);
    --compare-check: #CDEB95;
    --compare-muted-icon: rgba(252, 251, 247, 0.46);
    --compare-line: rgba(252, 251, 247, 0.16);
    --compare-line-soft: rgba(252, 251, 247, 0.11);
    background: var(--compare-forest);
    color: var(--compare-ivory);
    padding-top: clamp(76px, 7vw, 118px);
    padding-bottom: clamp(42px, 4.8vw, 72px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__layout {
    display: grid;
    grid-template-columns: minmax(330px, 0.72fr) minmax(640px, 1.28fr);
    gap: clamp(42px, 7vw, 112px);
    align-items: start;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__header-grid {
    display: block;
    margin-bottom: 0;
    padding-top: clamp(46px, 5.2vw, 82px);
  }

  #MellowCompare-{{ section.id }} .mellow-section-header {
    max-width: 520px;
    text-align: left;
  }

  #MellowCompare-{{ section.id }} .mellow-eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
    color: var(--compare-accent);
    font-size: var(--mellow-eyebrow-size, clamp(12px, 0.8vw, 14px));
    letter-spacing: var(--mellow-eyebrow-tracking, 0.16em);
  }

  #MellowCompare-{{ section.id }} .mellow-section-heading {
    margin-bottom: 0;
    max-width: 560px;
    color: var(--compare-ivory);
    line-height: 1.04;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-section-heading em {
    font-family: inherit;
    font-style: italic;
    font-weight: inherit;
  }

  #MellowCompare-{{ section.id }} .mellow-section-text {
    max-width: 470px;
    margin-top: clamp(24px, 2.4vw, 38px);
    color: rgba(252, 251, 247, 0.88);
    font-size: clamp(17px, 1.35vw, 23px);
    letter-spacing: 0;
    line-height: 1.35;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table-wrap {
    width: 100%;
    min-width: 0;
    margin: 0;
    justify-self: end;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__scroll {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-color: rgba(252, 251, 247, 0.3) transparent;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table {
    width: 100%;
    min-width: 720px;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    background: transparent;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table th,
  #MellowCompare-{{ section.id }} .mellow-compare__table td {
    padding-right: clamp(18px, 2.2vw, 34px);
    padding-left: clamp(18px, 2.2vw, 34px);
    border-right: 1px solid var(--compare-line-soft);
    border-bottom: 1px solid var(--compare-line);
    vertical-align: middle;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table thead th {
    padding-top: 0;
    padding-bottom: clamp(24px, 2.2vw, 34px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table tbody th,
  #MellowCompare-{{ section.id }} .mellow-compare__table tbody td {
    padding-top: clamp(24px, 2.1vw, 34px);
    padding-bottom: clamp(24px, 2.1vw, 34px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table th:last-child,
  #MellowCompare-{{ section.id }} .mellow-compare__table td:last-child {
    border-right: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table tbody tr:last-child th,
  #MellowCompare-{{ section.id }} .mellow-compare__table tbody tr:last-child td {
    border-bottom: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__corner,
  #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
    width: 24%;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell,
  #MellowCompare-{{ section.id }} .mellow-compare__mellow-header {
    width: 37%;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-cell,
  #MellowCompare-{{ section.id }} .mellow-compare__else-header {
    width: 39%;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__brand {
    display: block;
    margin: 0 0 4px;
    color: var(--compare-ivory);
    font-family: var(--mellow-font-display, var(--font-heading-family));
    font-size: clamp(28px, 2.1vw, 38px);
    font-weight: var(--mellow-heading-weight, 600);
    letter-spacing: 0;
    line-height: 0.95;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__recommended {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--compare-check);
    font-size: clamp(14px, 1vw, 18px);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-title {
    display: block;
    color: rgba(252, 251, 247, 0.66);
    font-size: clamp(14px, 1.1vw, 19px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
    color: rgba(252, 251, 247, 0.88);
    font-size: clamp(13px, 0.95vw, 16px);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell {
    color: var(--compare-ivory);
    font-size: clamp(17px, 1.2vw, 21px);
    font-weight: 750;
    line-height: 1.25;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-cell {
    color: rgba(252, 251, 247, 0.68);
    font-size: clamp(16px, 1.08vw, 20px);
    font-weight: 520;
    line-height: 1.3;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__label {
    display: inline-flex;
    align-items: center;
    gap: clamp(14px, 1.6vw, 24px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__label-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(32px, 2.7vw, 44px);
    height: clamp(32px, 2.7vw, 44px);
    flex: 0 0 clamp(32px, 2.7vw, 44px);
    color: rgba(252, 251, 247, 0.92);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__label-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    stroke-width: 1.55;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__value {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1vw, 16px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(28px, 2vw, 36px);
    height: clamp(28px, 2vw, 36px);
    flex: 0 0 clamp(28px, 2vw, 36px);
    border-radius: var(--mellow-radius-pill, 999px);
    font-size: clamp(15px, 1.1vw, 20px);
    font-weight: 900;
    line-height: 1;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon--check {
    background: var(--compare-check);
    color: var(--compare-forest);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__recommended .mellow-compare__icon--check {
    width: 22px;
    height: 22px;
    flex-basis: 22px;
    background: var(--compare-check);
    color: var(--compare-forest);
    font-size: 13px;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon--x {
    background: var(--compare-muted-icon);
    color: rgba(18, 51, 8, 0.88);
    font-size: clamp(13px, 0.94vw, 17px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(14px, 2.4vw, 34px);
    margin-top: clamp(38px, 4.2vw, 64px);
    padding-top: clamp(24px, 2.4vw, 34px);
    border-top: 1px solid var(--compare-line);
    color: rgba(252, 251, 247, 0.9);
    font-size: clamp(14px, 1vw, 17px);
    font-weight: 560;
    line-height: 1.2;
    text-align: center;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__trust-icon {
    display: inline-flex;
    width: 28px;
    height: 28px;
    flex: 0 0 28px;
    color: var(--compare-ivory);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__trust-icon svg {
    display: block;
    width: 100%;
    height: 100%;
    stroke-width: 1.55;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__trust-dot {
    color: rgba(252, 251, 247, 0.72);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mobile-hint {
    display: none;
    margin: 12px 0 0;
    color: rgba(252, 251, 247, 0.66);
    font-size: 13px;
    line-height: 1.35;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    #MellowCompare-{{ section.id }} .mellow-compare__layout {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowCompare-{{ section.id }} .mellow-compare__header-grid {
      padding-top: 0;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table-wrap {
      width: 100%;
      max-width: 100%;
      justify-self: stretch;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table th,
    #MellowCompare-{{ section.id }} .mellow-compare__table td {
      padding-right: 24px;
      padding-left: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowCompare-{{ section.id }} .mellow-compare__layout {
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowCompare-{{ section.id }} {
      padding-top: clamp(58px, 14vw, 76px);
    }

    #MellowCompare-{{ section.id }} .mellow-compare__scroll {
      margin-inline: calc(var(--mellow-section-axis-pad, 28px) * -0.25);
      padding-bottom: 2px;
      scroll-snap-type: x proximity;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table {
      min-width: 650px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table th,
    #MellowCompare-{{ section.id }} .mellow-compare__table td {
      padding-right: 20px;
      padding-left: 20px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table tbody th,
    #MellowCompare-{{ section.id }} .mellow-compare__table tbody td {
      padding-top: 18px;
      padding-bottom: 18px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__corner,
    #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
      width: 24%;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell,
    #MellowCompare-{{ section.id }} .mellow-compare__mellow-header,
    #MellowCompare-{{ section.id }} .mellow-compare__else-cell,
    #MellowCompare-{{ section.id }} .mellow-compare__else-header {
      width: 38%;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__mobile-hint {
      display: block;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__trust {
      gap: 12px 18px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__trust-dot {
      display: none;
    }
  }
</style>

<section id="MellowCompare-{{ section.id }}" class="mellow-section-standard mellow-compare">
  <div class="mellow-section-axis mellow-compare__inner">
    <div class="mellow-compare__layout">
      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.text != blank -%}
        <div class="mellow-section-header-grid mellow-compare__header-grid">
          <div class="mellow-section-header">
            {%- if section.settings.eyebrow != blank -%}
              <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
            {%- endif -%}

            {%- if section.settings.heading != blank -%}
              {%- assign heading_lines = section.settings.heading | escape | split: '|' -%}
              <h2 class="mellow-section-heading">
                {%- for line in heading_lines -%}
                  {%- if line contains 'not just neutralize it.' -%}
                    <em>{{ line }}</em>
                  {%- else -%}
                    {{ line }}
                  {%- endif -%}
                  {%- unless forloop.last -%}<br>{%- endunless -%}
                {%- endfor -%}
              </h2>
            {%- endif -%}

            {%- if section.settings.text != blank -%}
              <p class="mellow-section-text">{{ section.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="mellow-compare__table-wrap">
        <div class="mellow-compare__scroll" tabindex="0" aria-label="Scrollable comparison table">
          <table class="mellow-compare__table">
            <caption class="visually-hidden">
              Mellow compared with everything else across what it does, when it works, who it is made for, what you take, and how it feels.
            </caption>
            <thead>
              <tr>
                <th class="mellow-compare__corner" scope="col"><span class="visually-hidden">Comparison point</span></th>
                <th class="mellow-compare__mellow-header" scope="col">
                  <span class="mellow-compare__brand">Mellow</span>
                  <span class="mellow-compare__recommended">
                    <span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span>
                    <span>Recommended</span>
                  </span>
                </th>
                <th class="mellow-compare__else-header" scope="col">
                  <span class="mellow-compare__else-title">EVERYTHING ELSE</span>
                </th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">
                  <span class="mellow-compare__label">
                    <span class="mellow-compare__label-icon" aria-hidden="true">
                      <svg viewBox="0 0 40 40" fill="none"><path d="M20 4.8 32 9.6v8.9c0 7.6-4.8 14.3-12 16.7-7.2-2.4-12-9.1-12-16.7V9.6l12-4.8Z" stroke="currentColor"/><path d="m15.2 19.9 3.3 3.3 6.7-7.1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    <span>What it<br>does</span>
                  </span>
                </th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Raft-forming gel barrier</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Neutralizes or suppresses acid</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">
                  <span class="mellow-compare__label">
                    <span class="mellow-compare__label-icon" aria-hidden="true">
                      <svg viewBox="0 0 40 40" fill="none"><circle cx="20" cy="20" r="14.5" stroke="currentColor"/><path d="M20 10.8v10h8.2" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                    <span>When it<br>works</span>
                  </span>
                </th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Works within minutes</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Starts working after reflux has begun</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">
                  <span class="mellow-compare__label">
                    <span class="mellow-compare__label-icon" aria-hidden="true">
                      <svg viewBox="0 0 40 40" fill="none"><circle cx="20" cy="13" r="5.4" stroke="currentColor"/><path d="M9.8 33.2v-4.1c0-4 3.3-7.3 7.3-7.3h5.8c4 0 7.3 3.3 7.3 7.3v4.1H9.8Z" stroke="currentColor" stroke-linejoin="round"/></svg>
                    </span>
                    <span>Made for</span>
                  </span>
                </th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>People who eat, travel, and don’t slow down</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Symptoms after they interrupt you</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">
                  <span class="mellow-compare__label">
                    <span class="mellow-compare__label-icon" aria-hidden="true">
                      <svg viewBox="0 0 40 40" fill="none"><path d="M15.4 7.8h9.2v5.4H15.4V7.8Z" stroke="currentColor" stroke-linejoin="round"/><path d="M12.8 15.5c0-1.3 1-2.3 2.3-2.3h9.8c1.3 0 2.3 1 2.3 2.3v17.2H12.8V15.5Z" stroke="currentColor" stroke-linejoin="round"/></svg>
                    </span>
                    <span>What you<br>take</span>
                  </span>
                </th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Smooth single-serve gel pouch</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Chalky tablets, liquids, or pills</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">
                  <span class="mellow-compare__label">
                    <span class="mellow-compare__label-icon" aria-hidden="true">
                      <svg viewBox="0 0 40 40" fill="none"><path d="M20 34.2S8.1 27 7.4 17.4c-.3-4.3 2.6-7.8 6.7-7.8 2.5 0 4.7 1.3 5.9 3.3 1.2-2 3.4-3.3 5.9-3.3 4.1 0 7 3.5 6.7 7.8C31.9 27 20 34.2 20 34.2Z" stroke="currentColor" stroke-linejoin="round"/></svg>
                    </span>
                    <span>How it<br>feels</span>
                  </span>
                </th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>One squeeze. No measuring. No mess.</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Feels like medicine you’d rather not take</span></span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mellow-compare__mobile-hint">Swipe to compare Mellow with everything else.</p>
      </div>
    </div>

    <div class="mellow-compare__trust" aria-label="Mellow checkout trust details">
      <span class="mellow-compare__trust-item">
        <span class="mellow-compare__trust-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none"><path d="M16 3.8 25.5 7.6v7.2c0 6.1-3.8 11.4-9.5 13.4-5.7-2-9.5-7.3-9.5-13.4V7.6L16 3.8Z" stroke="currentColor"/><path d="m12.6 16 2.5 2.5 5-5.4" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span>30-day guarantee</span>
      </span>
      <span class="mellow-compare__trust-dot" aria-hidden="true">•</span>
      <span class="mellow-compare__trust-item">
        <span class="mellow-compare__trust-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none"><rect x="7" y="13" width="18" height="13" rx="2" stroke="currentColor"/><path d="M11 13V9.8a5 5 0 0 1 10 0V13" stroke="currentColor"/><path d="M16 17.7v3.6" stroke="currentColor" stroke-linecap="round"/></svg>
        </span>
        <span>Secure checkout</span>
      </span>
      <span class="mellow-compare__trust-dot" aria-hidden="true">•</span>
      <span class="mellow-compare__trust-item">
        <span class="mellow-compare__trust-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none"><path d="M6.2 16a9.8 9.8 0 0 1 16.7-7l2.9 2.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/><path d="M25.8 6.7v5.1h-5.1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/><path d="M25.8 16a9.8 9.8 0 0 1-16.7 7l-2.9-2.8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.2 25.3v-5.1h5.1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span>Cancel anytime</span>
      </span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow compare",
  "tag": "section",
  "class": "section section-mellow-compare",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "COMPARE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built to block reflux,|not just neutralize it."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subheading",
      "default": "Most products wait for reflux to start — then try to quiet it down. Mellow forms a physical barrier before the burn reaches you."
    }
  ],
  "presets": [
    {
      "name": "Mellow compare"
    }
  ]
}
{% endschema %}
