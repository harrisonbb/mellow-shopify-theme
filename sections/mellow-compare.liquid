{% comment %}
  Premium Mellow comparison table.
  Built against the global Mellow section axis, typography, color, radius, and spacing tokens.
{% endcomment %}

{%- liquid
  assign compare_product_image = section.settings.product_image
  assign compare_product_image_alt = compare_product_image.alt | default: 'Mellow Reflux Calm single-serve pouch' | strip
-%}

<style>
  #MellowCompare-{{ section.id }} {
    --compare-forest: var(--mellow-forest, #003302);
    --compare-forest-soft: var(--mellow-forest, #003302);
    --compare-recommended: #D7F2A5;
    --compare-ivory: #FCFBF7;
    --compare-card: var(--mellow-card-cream, #F8F4EC);
    --compare-label: var(--mellow-cream, #FCFBF7);
    --compare-else: var(--mellow-cream, #FCFBF7);
    --compare-mellow: #F1F7E8;
    --compare-border: var(--mellow-card-border, rgba(0, 51, 2, 0.10));
    --compare-border-strong: var(--compare-border);
    --compare-muted: rgba(0, 51, 2, 0.66);
    --compare-muted-soft: rgba(20, 33, 17, 0.72);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--compare-forest);
    padding-top: clamp(44px, 4vw, 64px);
    padding-bottom: clamp(48px, 4vw, 72px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__layout {
    display: grid;
    grid-template-columns: minmax(400px, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(42px, 4.4vw, 72px);
    align-items: start;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__header-grid {
    display: block;
    margin-bottom: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-section-header {
    max-width: 620px;
    text-align: left;
  }

  #MellowCompare-{{ section.id }} .mellow-eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
    font-size: var(--mellow-eyebrow-size, clamp(12px, 0.8vw, 14px));
    letter-spacing: var(--mellow-eyebrow-tracking, 0.16em);
  }

  #MellowCompare-{{ section.id }} .mellow-section-heading {
    margin-bottom: 0;
    max-width: 620px;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-section-text {
    max-width: 390px;
    margin-top: var(--mellow-section-heading-gap);
    font-size: clamp(15px, 1vw, 17px);
    letter-spacing: 0;
    line-height: 1.35;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__support {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(18px, 1.8vw, 28px);
    max-width: 560px;
    margin-top: clamp(18px, 2vw, 28px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__product-cue {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: clamp(138px, 11vw, 176px);
    min-width: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__product-cue::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -8px;
    width: 76%;
    height: 18px;
    border-radius: 999px;
    background: rgba(0, 51, 2, 0.12);
    filter: blur(10px);
    transform: translateX(-50%);
    z-index: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__product-image,
  #MellowCompare-{{ section.id }} .mellow-compare__pouch {
    position: relative;
    z-index: 1;
    width: clamp(126px, 10vw, 164px);
    filter: drop-shadow(0 20px 26px rgba(0, 51, 2, 0.14));
  }

  #MellowCompare-{{ section.id }} .mellow-compare__product-image {
    border-radius: 22px;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    aspect-ratio: 0.62;
    padding: 18px 14px 16px;
    border: 1px solid rgba(0, 51, 2, 0.14);
    border-radius: 24px 24px 18px 18px;
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 42%),
      linear-gradient(180deg, #FCFBF7 0%, #ECF5DB 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.44),
      0 20px 42px rgba(0, 51, 2, 0.12);
    color: var(--compare-forest);
    overflow: hidden;
    transform: rotate(-5deg);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch > * {
    position: relative;
    z-index: 1;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 38%;
    background:
      radial-gradient(circle at 72% 30%, rgba(215, 242, 165, 0.28), transparent 34%),
      linear-gradient(145deg, var(--compare-forest), #0F4610);
    z-index: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch-seal {
    align-self: flex-end;
    width: 28px;
    height: 6px;
    border-radius: 999px;
    background: rgba(252, 251, 247, 0.72);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch-brand {
    color: var(--compare-ivory);
    font-family: var(--mellow-font-display, var(--font-heading-family));
    font-size: clamp(20px, 1.7vw, 25px);
    font-weight: var(--mellow-heading-weight, 600);
    letter-spacing: 0;
    line-height: 0.95;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch-detail {
    max-width: 82px;
    color: rgba(0, 51, 2, 0.7);
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.09em;
    line-height: 1.1;
    text-transform: uppercase;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__pouch-gel {
    position: absolute;
    right: -18px;
    bottom: 26px;
    width: 62px;
    height: 18px;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(215, 242, 165, 0), rgba(215, 242, 165, 0.8));
    transform: rotate(-17deg);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__proof-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__proof-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    color: rgba(0, 51, 2, 0.76);
    font-size: clamp(14px, 0.94vw, 16px);
    font-weight: 680;
    letter-spacing: 0;
    line-height: 1.25;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__proof-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 25px;
    height: 25px;
    flex: 0 0 25px;
    border-radius: 999px;
    background: rgba(215, 242, 165, 0.56);
    color: var(--compare-forest);
    box-shadow: inset 0 0 0 1px rgba(0, 51, 2, 0.10);
    font-size: 14px;
    font-weight: 900;
    line-height: 1;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table-wrap {
    width: min(100%, 1000px);
    max-width: 1000px;
    min-width: 0;
    margin: 0;
    justify-self: end;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__scroll {
    overflow-x: auto;
    overflow-y: hidden;
    border-radius: clamp(26px, 2.2vw, 30px);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
    -webkit-overflow-scrolling: touch;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table {
    width: 100%;
    min-width: 720px;
    table-layout: fixed;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    border: 1px solid var(--compare-border-strong);
    border-radius: clamp(26px, 2.2vw, 30px);
    background: var(--compare-card);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table th,
  #MellowCompare-{{ section.id }} .mellow-compare__table td {
    padding-right: clamp(20px, 2.2vw, 34px);
    padding-left: clamp(20px, 2.2vw, 34px);
    border-right: 1px solid var(--compare-border);
    border-bottom: 1px solid var(--compare-border);
    vertical-align: middle;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table thead th {
    padding-top: clamp(10px, 1vw, 14px);
    padding-bottom: clamp(10px, 1vw, 14px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table tbody th,
  #MellowCompare-{{ section.id }} .mellow-compare__table tbody td {
    padding-top: clamp(14px, 1.35vw, 21px);
    padding-bottom: clamp(14px, 1.35vw, 21px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table th:last-child,
  #MellowCompare-{{ section.id }} .mellow-compare__table td:last-child {
    border-right: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__table tbody tr:last-child th,
  #MellowCompare-{{ section.id }} .mellow-compare__table tbody tr:last-child td {
    border-bottom: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__corner,
  #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
    width: 22%;
    background:
      linear-gradient(180deg, rgba(248, 244, 236, 0.44), rgba(252, 251, 247, 0)),
      var(--compare-label);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell,
  #MellowCompare-{{ section.id }} .mellow-compare__mellow-header {
    width: 39%;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-cell,
  #MellowCompare-{{ section.id }} .mellow-compare__else-header {
    width: 39%;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__corner {
    border-top-left-radius: clamp(26px, 2.2vw, 30px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mellow-header {
    background:
      radial-gradient(circle at 18% 28%, rgba(252, 251, 247, 0.14), transparent 32%),
      linear-gradient(135deg, var(--compare-forest) 0%, var(--compare-forest-soft) 100%);
    color: var(--compare-ivory);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-header {
    border-top-right-radius: clamp(26px, 2.2vw, 30px);
    background:
      linear-gradient(180deg, rgba(248, 244, 236, 0.38), rgba(252, 251, 247, 0)),
      var(--compare-else);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__brand {
    display: block;
    margin: 0 0 4px;
    color: var(--compare-ivory);
    font-family: var(--mellow-font-display, var(--font-heading-family));
    font-size: clamp(26px, 2.4vw, 38px);
    font-weight: var(--mellow-heading-weight, 600);
    letter-spacing: 0;
    line-height: 0.95;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__recommended {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--compare-recommended);
    font-size: clamp(14px, 1vw, 17px);
    font-weight: 750;
    line-height: 1.1;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-title {
    display: block;
    color: rgba(0, 51, 2, 0.78);
    font-size: clamp(14px, 1.1vw, 19px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
    color: rgba(0, 51, 2, 0.7);
    font-size: clamp(13px, 0.95vw, 16px);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.06)),
      var(--compare-mellow);
    color: var(--compare-forest);
    font-size: clamp(17px, 1.24vw, 22px);
    font-weight: 750;
    line-height: 1.25;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__else-cell {
    background:
      linear-gradient(180deg, rgba(248, 244, 236, 0.22), rgba(252, 251, 247, 0)),
      var(--compare-else);
    color: var(--compare-muted-soft);
    font-size: clamp(16px, 1.14vw, 20px);
    font-weight: 520;
    line-height: 1.3;
    letter-spacing: 0;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__value {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1vw, 16px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(28px, 2vw, 36px);
    height: clamp(28px, 2vw, 36px);
    flex: 0 0 clamp(28px, 2vw, 36px);
    border-radius: var(--mellow-radius-pill, 999px);
    font-size: clamp(16px, 1.25vw, 22px);
    font-weight: 900;
    line-height: 1;
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon--check {
    background: #D7F2A5;
    color: var(--compare-forest);
    box-shadow: inset 0 0 0 1px rgba(0, 51, 2, 0.10);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__recommended .mellow-compare__icon--check {
    width: clamp(26px, 2vw, 34px);
    height: clamp(26px, 2vw, 34px);
    flex-basis: clamp(26px, 2vw, 34px);
    background: #D7F2A5;
    color: var(--compare-forest);
    box-shadow: 0 0 0 7px rgba(215, 242, 165, 0.18);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__icon--x {
    background: var(--mellow-card-cream, #F8F4EC);
    color: rgba(20, 33, 17, 0.58);
    font-size: clamp(14px, 1vw, 18px);
  }

  #MellowCompare-{{ section.id }} .mellow-compare__mobile-hint {
    display: none;
    margin: 12px 0 0;
    color: rgba(0, 51, 2, 0.62);
    font-size: 13px;
    line-height: 1.35;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    #MellowCompare-{{ section.id }} .mellow-compare__layout {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table-wrap {
      width: 100%;
      max-width: 100%;
      justify-self: stretch;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table th,
    #MellowCompare-{{ section.id }} .mellow-compare__table td {
      padding-right: 24px;
      padding-left: 24px;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowCompare-{{ section.id }} .mellow-compare__layout {
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowCompare-{{ section.id }} .mellow-compare__scroll {
      margin-inline: calc(var(--mellow-section-axis-pad, 28px) * -0.25);
      padding-bottom: 2px;
      scroll-snap-type: x proximity;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table {
      min-width: 650px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table th,
    #MellowCompare-{{ section.id }} .mellow-compare__table td {
      padding-right: 20px;
      padding-left: 20px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__table tbody th,
    #MellowCompare-{{ section.id }} .mellow-compare__table tbody td {
      padding-top: 16px;
      padding-bottom: 16px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__support {
      gap: 16px;
      max-width: 470px;
      margin-top: 20px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__product-cue {
      width: 108px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__product-image,
    #MellowCompare-{{ section.id }} .mellow-compare__pouch {
      width: 100px;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__corner,
    #MellowCompare-{{ section.id }} .mellow-compare__label-cell {
      width: 24%;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__mellow-cell,
    #MellowCompare-{{ section.id }} .mellow-compare__mellow-header,
    #MellowCompare-{{ section.id }} .mellow-compare__else-cell,
    #MellowCompare-{{ section.id }} .mellow-compare__else-header {
      width: 38%;
    }

    #MellowCompare-{{ section.id }} .mellow-compare__mobile-hint {
      display: block;
    }
  }
</style>

<section id="MellowCompare-{{ section.id }}" class="mellow-section-standard mellow-compare">
  <div class="mellow-section-axis mellow-compare__inner">
    <div class="mellow-compare__layout">
      {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.text != blank -%}
        <div class="mellow-section-header-grid mellow-compare__header-grid">
          <div class="mellow-section-header">
            {%- if section.settings.eyebrow != blank -%}
              <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
            {%- endif -%}

            {%- if section.settings.heading != blank -%}
              {%- assign heading_lines = section.settings.heading | escape | split: '|' -%}
              <h2 class="mellow-section-heading">
                {%- for line in heading_lines -%}
                  {{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}
                {%- endfor -%}
              </h2>
            {%- endif -%}

            {%- if section.settings.text != blank -%}
              <p class="mellow-section-text">{{ section.settings.text | escape }}</p>
            {%- endif -%}

            <div class="mellow-compare__support" aria-label="Mellow product highlights">
              <div class="mellow-compare__product-cue">
                {%- if compare_product_image != blank -%}
                  {{ compare_product_image | image_url: width: 480 | image_tag: loading: 'lazy', decoding: 'async', class: 'mellow-compare__product-image', sizes: '(min-width: 990px) 164px, 100px', widths: '200, 320, 420, 480', alt: compare_product_image_alt }}
                {%- else -%}
                  <img
                    class="mellow-compare__product-image"
                    src="{{ 'mellow-reflux-calm-pouch.png' | asset_url }}"
                    width="520"
                    height="649"
                    loading="lazy"
                    decoding="async"
                    alt="Mellow Reflux Calm single-serve pouch"
                  >
                {%- endif -%}
              </div>

              <ul class="mellow-compare__proof-list">
                <li><span class="mellow-compare__proof-icon" aria-hidden="true">✓</span><span>Works within minutes</span></li>
                <li><span class="mellow-compare__proof-icon" aria-hidden="true">✓</span><span>One pouch, no measuring</span></li>
                <li><span class="mellow-compare__proof-icon" aria-hidden="true">✓</span><span>Made for meals and travel</span></li>
              </ul>
            </div>
          </div>
        </div>
      {%- endif -%}

      <div class="mellow-compare__table-wrap">
        <div class="mellow-compare__scroll" tabindex="0" aria-label="Scrollable comparison table">
          <table class="mellow-compare__table">
            <caption class="visually-hidden">
              Mellow compared with everything else across what it does, when it works, who it is made for, what you take, and how it feels.
            </caption>
            <thead>
              <tr>
                <th class="mellow-compare__corner" scope="col"><span class="visually-hidden">Comparison point</span></th>
                <th class="mellow-compare__mellow-header" scope="col">
                  <span class="mellow-compare__brand">Mellow</span>
                  <span class="mellow-compare__recommended">
                    <span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span>
                    <span>Recommended</span>
                  </span>
                </th>
                <th class="mellow-compare__else-header" scope="col">
                  <span class="mellow-compare__else-title">EVERYTHING ELSE</span>
                </th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">What it does</th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Raft-forming gel barrier</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Neutralizes or suppresses acid</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">When it works</th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Works within minutes</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Starts working after reflux has begun</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">Made for</th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>People who eat, travel, and don’t slow down</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Symptoms after they interrupt you</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">What you take</th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>Smooth single-serve gel pouch</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Chalky tablets, liquids, or pills</span></span>
                </td>
              </tr>
              <tr>
                <th class="mellow-compare__label-cell" scope="row">How it feels</th>
                <td class="mellow-compare__mellow-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--check" aria-hidden="true">✓</span><span>One squeeze. No measuring. No mess.</span></span>
                </td>
                <td class="mellow-compare__else-cell">
                  <span class="mellow-compare__value"><span class="mellow-compare__icon mellow-compare__icon--x" aria-hidden="true">×</span><span>Feels like medicine you’d rather not take</span></span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mellow-compare__mobile-hint">Swipe to compare Mellow with everything else.</p>
      </div>
    </div>
  </div>
</section>

