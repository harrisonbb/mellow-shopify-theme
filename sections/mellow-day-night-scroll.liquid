{% comment %}
  Mellow — Day to Night Text Mood Section
  Purpose: left-aligned section header with smooth scroll color transition + diagonal cat visual + end-state CTA
  Update:
  - Header typography matched exactly to Mellow Hero / Ingredients system
  - Fraunces 550 heading, tight line-height, negative tracking
  - Responsive heading breakpoints matched to Ingredients section
  - Eyebrow locked to DM Sans 800 / compact spacing
{% endcomment %}

<section
  class="mellow-day-night-scroll mellow-day-night-scroll-{{ section.id }}"
  id="mellow-day-night-scroll-{{ section.id }}"
>
  <div class="mellow-day-night-scroll__sticky">
    <div class="mellow-day-night-scroll__atmosphere" aria-hidden="true"></div>
    <div class="mellow-day-night-scroll__night-wash" aria-hidden="true"></div>

    {% if section.settings.cat_image != blank %}
      <div class="mellow-day-night-scroll__cat-wrap" aria-hidden="true">
        {{
          section.settings.cat_image
          | image_url: width: 900
          | image_tag:
            class: 'mellow-day-night-scroll__cat',
            loading: 'lazy',
            widths: '240, 360, 520, 720, 900',
            sizes: '(max-width: 768px) 44vw, 28vw'
        }}
      </div>
    {% endif %}

    <div class="mellow-day-night-scroll__inner">
      <div class="mellow-day-night-scroll__copy">
        <p class="mellow-day-night-scroll__eyebrow mellow-eyebrow">FOR THE MOMENTS THAT MATTER</p>

        <h2 class="mellow-day-night-scroll__heading">
          From day to night,<br>
          Mellow has you covered.
        </h2>

        {% if section.settings.cta_text != blank %}
          <div class="mellow-day-night-scroll__cta-wrap">
            <a
              class="mellow-day-night-scroll__cta"
              href="{{ section.settings.cta_link | default: '#' }}"
              aria-label="{{ section.settings.cta_text | escape }}"
            >
              {{ section.settings.cta_text }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>

  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    background: #DDE8E6 !important;
    background-color: #DDE8E6 !important;
    background-image: none !important;
  }

  #mellow-day-night-scroll-{{ section.id }},
  #mellow-day-night-scroll-{{ section.id }} * {
    box-sizing: border-box;
  }

  #mellow-day-night-scroll-{{ section.id }} {
    --scroll-progress: 0;
    --scroll-boost: 0;
    --cta-reveal: 0;
    --cat-reveal: 0;

    --mellow-forest: #1A2D10;
    --mellow-ivory: #F0EBE0;
    --mellow-albers-blue: #3D6B8C;
    --mellow-red-orange: #D04A2A;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --dynamic-bg: #DDE8E6;
    --dynamic-text: #1A2D10;
    --dynamic-eyebrow: #3D6B8C;

    position: relative;
    min-height: 220vh;
    overflow: visible;
    background: var(--dynamic-bg) !important;
    background-color: var(--dynamic-bg) !important;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__sticky {
    position: sticky;
    top: 0;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    isolation: isolate;
    background: var(--dynamic-bg) !important;
    background-color: var(--dynamic-bg) !important;
    transition: background-color 40ms linear;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__atmosphere {
    position: absolute;
    inset: 0;
    z-index: -4;
    background:
      radial-gradient(circle at 18% 18%, rgba(240, 235, 224, calc(0.72 - (var(--scroll-boost) * 0.52))) 0%, rgba(240, 235, 224, 0) 42%),
      radial-gradient(circle at 18% 78%, rgba(127, 156, 175, calc(0.34 - (var(--scroll-boost) * 0.22))) 0%, rgba(127, 156, 175, 0) 54%),
      radial-gradient(circle at 82% 72%, rgba(61, 107, 140, calc(var(--scroll-boost) * 0.28)) 0%, rgba(61, 107, 140, 0) 48%);
    opacity: 1;
    transform: scale(calc(1 + (var(--scroll-boost) * 0.04)));
    pointer-events: none;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__night-wash {
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(
        180deg,
        rgba(21, 48, 68, calc(var(--scroll-boost) * 0.08)) 0%,
        rgba(21, 48, 68, calc(var(--scroll-boost) * 0.36)) 46%,
        rgba(9, 25, 33, calc(var(--scroll-boost) * 0.68)) 100%
      );
    pointer-events: none;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
    position: absolute;
    z-index: 1;
    left: clamp(780px, 60vw, 1020px);
    top: clamp(250px, 36vh, 380px);
    width: clamp(180px, 18vw, 310px);
    max-width: 28vw;
    opacity: var(--cat-reveal);
    transform:
      translateY(calc((1 - var(--cat-reveal)) * 22px))
      rotate(-3deg)
      scale(calc(0.96 + (var(--cat-reveal) * 0.04)));
    filter: blur(calc((1 - var(--cat-reveal)) * 5px));
    pointer-events: none;
    transition:
      opacity 120ms linear,
      transform 120ms linear,
      filter 120ms linear;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter:
      drop-shadow(0 26px 46px rgba(0, 0, 0, 0.18))
      drop-shadow(0 4px 10px rgba(0, 0, 0, 0.12));
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: none !important;
    margin: 0 !important;
    padding-top: clamp(72px, 7vw, 120px);
    padding-bottom: clamp(72px, 7vw, 120px);
    padding-left: clamp(108px, 8.5vw, 172px) !important;
    padding-right: clamp(24px, 4vw, 62px) !important;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__copy {
    width: 100%;
    max-width: 980px;
    margin: 0 !important;
    text-align: left !important;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__eyebrow,
  #shopify-section-{{ section.id }} .mellow-day-night-scroll__eyebrow {
    display: inline-block !important;
    margin: 0 0 14px !important;

    color: var(--dynamic-eyebrow) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;

    max-width: 100% !important;
    align-self: flex-start !important;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading,
  #shopify-section-{{ section.id }} .mellow-day-night-scroll__heading {
    margin: 0 !important;
    max-width: 980px !important;

    color: var(--dynamic-text) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading br {
    display: block;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta-wrap {
    margin-top: clamp(34px, 3.4vw, 52px);
    opacity: var(--cta-reveal);
    transform: translateY(calc((1 - var(--cta-reveal)) * 18px));
    filter: blur(calc((1 - var(--cta-reveal)) * 4px));
    pointer-events: none;
    transition:
      opacity 120ms linear,
      transform 120ms linear,
      filter 120ms linear;
  }

  #mellow-day-night-scroll-{{ section.id }}.is-cta-visible .mellow-day-night-scroll__cta-wrap {
    pointer-events: auto;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta,
  #shopify-section-{{ section.id }} .mellow-day-night-scroll__cta {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 38px !important;
    border-radius: 999px !important;
    background: var(--mellow-red-orange) !important;
    color: #FFFFFF !important;
    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;
    text-decoration: none !important;
    border: 1px solid var(--mellow-red-orange) !important;
    box-shadow:
      0 16px 34px rgba(208, 74, 42, 0.24),
      0 0 0 0 rgba(208, 74, 42, 0) !important;
    transform: translateY(0);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      background-color 220ms ease,
      border-color 220ms ease;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta:hover {
    transform: translateY(-2px);
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.28),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
    background: #B93F24 !important;
    border-color: #B93F24 !important;
  }

  #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta:focus-visible {
    outline: 3px solid rgba(240, 235, 224, 0.78);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    #mellow-day-night-scroll-{{ section.id }} {
      min-height: auto;
      --cta-reveal: 1;
      --cat-reveal: 1;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__sticky {
      position: relative;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta-wrap,
    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
      opacity: 1;
      transform: none;
      filter: none;
      pointer-events: auto;
      transition: none;
    }
  }

  @media (min-width: 1500px) {
    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__inner {
      padding-left: clamp(128px, 9vw, 196px) !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__copy {
      max-width: 1100px;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__heading {
      max-width: 1100px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }
  }

  @media (max-width: 1300px) {
    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
      left: auto;
      right: clamp(48px, 7vw, 110px);
      top: clamp(270px, 38vh, 390px);
      width: clamp(160px, 17vw, 260px);
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__copy {
      max-width: 860px;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__heading {
      max-width: 860px !important;
    }
  }

  @media (max-width: 1100px) {
    #mellow-day-night-scroll-{{ section.id }} {
      min-height: auto;
      --cta-reveal: 1;
      --cat-reveal: 1;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__sticky {
      position: relative;
      min-height: 78vh;
      background: #153044 !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__inner {
      padding-top: 86px;
      padding-bottom: 92px;
      padding-left: 32px !important;
      padding-right: 32px !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__copy {
      max-width: 760px;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
      right: clamp(30px, 5vw, 60px);
      top: 18vh;
      width: clamp(140px, 20vw, 220px);
      opacity: 0.82;
      transform: rotate(-3deg);
      filter: drop-shadow(0 20px 36px rgba(0, 0, 0, 0.18));
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__eyebrow,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__eyebrow {
      color: var(--mellow-ivory) !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__heading {
      color: var(--mellow-ivory) !important;
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta-wrap {
      opacity: 1;
      transform: none;
      filter: none;
      pointer-events: auto;
    }
  }

  @media (max-width: 768px) {
    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__sticky {
      min-height: 76vh;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__inner {
      padding: 72px 20px 78px !important;
      justify-content: flex-start;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__copy {
      width: 100%;
      max-width: 92vw;
      margin: 0 !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
      right: 18px;
      top: 58px;
      width: clamp(92px, 28vw, 140px);
      opacity: 0.78;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__eyebrow,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__eyebrow {
      color: var(--mellow-ivory) !important;
      margin-bottom: 14px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.115em !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__heading,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__heading {
      color: var(--mellow-ivory) !important;
      max-width: 92vw !important;
      font-size: clamp(2.35rem, 10vw, 3.55rem) !important;
      line-height: 1.05 !important;
      letter-spacing: -0.03em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 48, "wght" 550 !important;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta-wrap {
      margin-top: 30px;
    }

    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cta,
    #shopify-section-{{ section.id }} .mellow-day-night-scroll__cta {
      min-height: 52px;
      padding: 0 32px !important;
      font-size: 0.94rem !important;
    }
  }

  @media (max-width: 520px) {
    #mellow-day-night-scroll-{{ section.id }} .mellow-day-night-scroll__cat-wrap {
      display: none;
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById('mellow-day-night-scroll-{{ section.id }}');
    if (!section) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const hexToRgb = (hex) => {
      const clean = hex.replace('#', '');
      return {
        r: parseInt(clean.substring(0, 2), 16),
        g: parseInt(clean.substring(2, 4), 16),
        b: parseInt(clean.substring(4, 6), 16)
      };
    };

    const mix = (a, b, t) => ({
      r: Math.round(a.r + (b.r - a.r) * t),
      g: Math.round(a.g + (b.g - a.g) * t),
      b: Math.round(a.b + (b.b - a.b) * t)
    });

    const rgb = (c) => `rgb(${c.r}, ${c.g}, ${c.b})`;

    const startBg = hexToRgb('#DDE8E6');
    const midBg = hexToRgb('#7F9CAF');
    const endBg = hexToRgb('#153044');

    const darkText = hexToRgb('#1A2D10');
    const lightText = hexToRgb('#F0EBE0');
    const blueText = hexToRgb('#3D6B8C');

    let ticking = false;

    const setFinalState = () => {
      section.style.setProperty('--scroll-progress', '1');
      section.style.setProperty('--scroll-boost', '1');
      section.style.setProperty('--cta-reveal', '1');
      section.style.setProperty('--cat-reveal', '1');
      section.style.setProperty('--dynamic-bg', '#153044');
      section.style.setProperty('--dynamic-text', '#F0EBE0');
      section.style.setProperty('--dynamic-eyebrow', '#F0EBE0');
      section.classList.add('is-cta-visible');
    };

    if (reduceMotion) {
      setFinalState();
      return;
    }

    const updateProgress = () => {
      const rect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
      const scrollableDistance = Math.max(rect.height - viewportHeight, 1);

      const raw = clamp((-rect.top) / scrollableDistance, 0, 1);
      const boosted = clamp(raw * 1.85, 0, 1);
      const eased = boosted * boosted * (3 - 2 * boosted);

      const bgFirstHalf = raw < 0.5
        ? mix(startBg, midBg, raw / 0.5)
        : mix(midBg, endBg, (raw - 0.5) / 0.5);

      const finalBg = mix(bgFirstHalf, endBg, eased * 0.48);

      const textShift = clamp((eased - 0.14) / 0.46, 0, 1);
      const textEase = textShift * textShift * (3 - 2 * textShift);

      const eyebrowShift = clamp((eased - 0.08) / 0.42, 0, 1);
      const eyebrowEase = eyebrowShift * eyebrowShift * (3 - 2 * eyebrowShift);

      const textColor = mix(darkText, lightText, textEase);
      const eyebrowColor = mix(blueText, lightText, eyebrowEase);

      const ctaShift = clamp((raw - 0.74) / 0.22, 0, 1);
      const ctaEase = ctaShift * ctaShift * (3 - 2 * ctaShift);

      const catShift = clamp((raw - 0.58) / 0.28, 0, 1);
      const catEase = catShift * catShift * (3 - 2 * catShift);

      section.style.setProperty('--scroll-progress', raw.toFixed(4));
      section.style.setProperty('--scroll-boost', eased.toFixed(4));
      section.style.setProperty('--cta-reveal', ctaEase.toFixed(4));
      section.style.setProperty('--cat-reveal', catEase.toFixed(4));
      section.style.setProperty('--dynamic-bg', rgb(finalBg));
      section.style.setProperty('--dynamic-text', rgb(textColor));
      section.style.setProperty('--dynamic-eyebrow', rgb(eyebrowColor));

      if (ctaEase > 0.96) {
        section.classList.add('is-cta-visible');
      } else {
        section.classList.remove('is-cta-visible');
      }

      ticking = false;
    };

    const requestTick = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateProgress);
        ticking = true;
      }
    };

    updateProgress();

    window.addEventListener('scroll', requestTick, { passive: true });
    window.addEventListener('resize', requestTick);
  })();
</script>

{% schema %}
{
  "name": "Mellow Day Night Scroll",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "cat_image",
      "label": "Cat image"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "presets": [
    {
      "name": "Mellow Day Night Scroll"
    }
  ]
}
{% endschema %}