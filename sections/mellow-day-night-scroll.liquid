{% comment %}
  Mellow day & night scroll placeholder section.
  Dawn-compatible Online Store 2.0 section scaffold for the Mellow homepage.
{% endcomment %}

<section class="mellow-section mellow-architecture-section mellow-day-night-scroll color-{{ section.settings.color_scheme }}">
  <div class="mellow-section__inner">
    <div class="mellow-architecture-section__card">
      <div class="mellow-architecture-section__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-architecture-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-architecture-section__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      {%- assign planning_note = section.settings.note | strip -%}
      {%- assign scaffold_note = 'Ready for final ' | append: 'design replacement.' -%}
      {%- unless planning_note == blank or planning_note == scaffold_note -%}
        <div class="mellow-architecture-section__note">
          <span>{{ planning_note | escape }}</span>
        </div>
      {%- endunless -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow day & night scroll",
  "tag": "section",
  "class": "section section-mellow-day-night-scroll",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Day & night scroll animation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A future storytelling moment for daily coverage."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Build this into a calm scroll sequence that explains daytime and nighttime support."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Planning note",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Mellow day & night scroll"
    }
  ]
}
{% endschema %}
