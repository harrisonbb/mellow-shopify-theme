{% comment %}
  Mellow day-to-night scroll section.
  Premium scroll-linked storytelling moment using the global Mellow section system.
{% endcomment %}

<style>
  #MellowDayNight-{{ section.id }} {
    --day-night-cta-progress: 0;
    --day-night-bg: #DCECF2;
    --mellow-night-bg-current: #102A3A;
    --day-night-text: var(--mellow-forest, #003302);
    --day-night-muted: rgba(34, 50, 22, 0.74);
    --day-night-rule: rgba(34, 50, 22, 0.14);
    --day-night-sky-opacity: 0;
    --day-night-sky-background:
      radial-gradient(circle at 78% 18%, rgba(251, 250, 244, 0.08), transparent 16rem),
      radial-gradient(circle at 12% 82%, rgba(61, 107, 140, 0.12), transparent 32rem),
      var(--day-night-bg);
    --day-night-orb-shift-x: -32px;
    --day-night-orb-transform: translate3d(var(--day-night-orb-shift-x), 0, 0) scale(1);
    --day-night-orb-color: #F4B55D;
    --day-night-moon-opacity: 0;
    --day-night-sun-glow-opacity: 1;
    --day-night-moon-glow-opacity: 0;
    --moon-detail-opacity: 0;
    --day-night-stars-opacity: 0;
    --day-night-cta-y: 18px;
    position: relative;
    min-height: 210vh;
    width: 100%;
    max-width: 100%;
    overflow: clip;
    background: var(--day-night-bg);
    color: var(--day-night-text);
    isolation: isolate;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stage {
    position: sticky;
    top: 0;
    display: flex;
    align-items: center;
    min-height: 100svh;
    overflow: hidden;
    background: var(--day-night-sky-background);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stage::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: var(--day-night-sky-opacity);
    background:
      radial-gradient(circle at 60% 36%, rgba(251, 250, 244, 0.13), transparent 16rem),
      radial-gradient(circle at 12% 82%, rgba(61, 107, 140, 0.22), transparent 32rem),
      linear-gradient(180deg, #3D6B8C 0%, #102A3A 76%);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: none;
    margin: 0;
    padding: clamp(64px, 7vh, 92px) var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__grid {
    display: grid;
    grid-template-columns: minmax(0, var(--mellow-header-max, 760px)) minmax(220px, 0.66fr);
    align-items: center;
    gap: var(--mellow-feature-gap);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__copy {
    max-width: var(--mellow-header-max, 760px);
    text-align: left;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__eyebrow {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__heading {
    color: var(--day-night-text);
    text-wrap: balance;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__subheading {
    color: var(--day-night-muted);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__actions {
    margin-top: clamp(28px, 3.4vw, 46px);
    opacity: var(--day-night-cta-progress);
    pointer-events: none;
    transform: translate3d(0, var(--day-night-cta-y), 0);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__cta-wrap {
    justify-content: flex-start;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__cta {
    --mellow-section-cta-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-color: var(--mellow-ivory, #FBFAF4);
    --mellow-section-cta-hover-bg: var(--mellow-forest, #003302);
    --mellow-section-cta-hover-border: var(--mellow-forest, #003302);
    --mellow-section-cta-hover-color: var(--mellow-ivory, #FBFAF4);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__support {
    max-width: 340px;
    margin: clamp(14px, 1.4vw, 20px) 0 0;
    color: rgba(251, 250, 244, 0.78);
    font-size: var(--mellow-card-copy-size, clamp(16px, 1.03vw, 17px));
    line-height: var(--mellow-card-copy-line-height, 1.48);
    letter-spacing: var(--mellow-card-copy-tracking, -0.006em);
  }

  #MellowDayNight-{{ section.id }}.is-cta-visible .mellow-day-night__actions {
    pointer-events: auto;
  }

  #MellowDayNight-{{ section.id }}.is-night {
    --day-night-text: var(--mellow-ivory, #FBFAF4);
    --day-night-muted: rgba(251, 250, 244, 0.78);
    --day-night-rule: rgba(251, 250, 244, 0.2);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__visual {
    position: relative;
    min-height: clamp(300px, 42vw, 560px);
    border-left: 1px solid var(--day-night-rule);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__orb {
    position: absolute;
    top: clamp(20px, 5vw, 64px);
    right: clamp(18px, 5vw, 72px);
    width: clamp(118px, 13vw, 188px);
    aspect-ratio: 1;
    border-radius: 50%;
    transform: var(--day-night-orb-transform);
    will-change: transform;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 50%;
    pointer-events: none;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-glow::before,
  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-glow::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-glow::before {
    opacity: var(--day-night-sun-glow-opacity);
    box-shadow:
      0 0 30px rgba(246, 191, 99, 0.22),
      0 0 14px rgba(255, 223, 154, 0.12),
      0 18px 52px rgba(11, 30, 44, 0.1);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-glow::after {
    opacity: var(--day-night-moon-glow-opacity);
    box-shadow:
      0 0 44px rgba(246, 229, 190, 0.32),
      0 0 18px rgba(255, 247, 219, 0.17),
      0 18px 52px rgba(11, 30, 44, 0.1);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-core {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    border-radius: 50%;
    background:
      radial-gradient(circle at 36% 32%, rgba(255, 255, 255, 0.42), rgba(244, 181, 93, 0.22) 30%, transparent 56%),
      var(--day-night-orb-color);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-core::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    opacity: var(--day-night-moon-opacity);
    pointer-events: none;
    background:
      radial-gradient(circle at 36% 32%, rgba(255, 255, 255, 0.86), rgba(251, 250, 244, 0.56) 30%, transparent 56%),
      var(--mellow-ivory, #FBFAF4);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__moon-texture {
    position: absolute;
    inset: 0;
    z-index: 2;
    border-radius: inherit;
    pointer-events: none;
    opacity: var(--moon-detail-opacity);
    background:
      radial-gradient(circle at 32% 28%, rgba(48, 61, 67, 0.13) 0 8%, transparent 9.5%),
      radial-gradient(circle at 62% 40%, rgba(48, 61, 67, 0.1) 0 15%, transparent 17%),
      radial-gradient(circle at 44% 66%, rgba(57, 68, 70, 0.11) 0 11%, transparent 12.5%),
      radial-gradient(circle at 72% 70%, rgba(75, 68, 58, 0.09) 0 8%, transparent 9.5%),
      radial-gradient(circle at 24% 58%, rgba(75, 68, 58, 0.07) 0 13%, transparent 15%),
      radial-gradient(circle at 76% 26%, rgba(48, 61, 67, 0.06) 0 6%, transparent 7.5%),
      radial-gradient(ellipse at 52% 54%, rgba(35, 50, 60, 0.08) 0 24%, transparent 38%);
    filter: blur(0.4px);
    mix-blend-mode: multiply;
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__horizon {
    position: absolute;
    right: 0;
    bottom: clamp(30px, 8vw, 112px);
    width: min(520px, 78%);
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--day-night-rule));
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stars,
  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::before,
  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::after {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(251, 250, 244, 0.84);
    opacity: var(--day-night-stars-opacity);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stars {
    top: 22%;
    right: 38%;
    box-shadow: 94px 52px 0 rgba(251, 250, 244, 0.62), 164px -18px 0 rgba(251, 250, 244, 0.46), 218px 88px 0 rgba(251, 250, 244, 0.42);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::before,
  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::after {
    content: "";
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::before {
    transform: translate3d(-72px, 104px, 0) scale(0.72);
  }

  #MellowDayNight-{{ section.id }} .mellow-day-night__stars::after {
    transform: translate3d(132px, 156px, 0) scale(0.58);
  }

  @media screen and (max-width: 899px) {
    #MellowDayNight-{{ section.id }} {
      min-height: 190vh;
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__stage {
      align-items: flex-start;
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__inner {
      padding-top: clamp(64px, 10vh, 96px);
      padding-bottom: clamp(42px, 7vh, 72px);
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__grid {
      display: block;
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__visual {
      min-height: clamp(210px, 32vh, 320px);
      margin-top: var(--mellow-section-content-gap-compact);
      border-left: 0;
      border-top: 1px solid var(--day-night-rule);
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__orb {
      --day-night-orb-shift-x: 0px;
      top: clamp(28px, 5vh, 54px);
      right: clamp(16px, 8vw, 54px);
      width: clamp(86px, 24vw, 126px);
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__stars {
      right: 52%;
      top: 30%;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowDayNight-{{ section.id }} .mellow-day-night__support {
      max-width: 310px;
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowDayNight-{{ section.id }} {
      --day-night-cta-progress: 1;
      --day-night-bg: #102A3A;
      --mellow-night-bg-current: #102A3A;
      --day-night-text: var(--mellow-ivory, #FBFAF4);
      --day-night-muted: rgba(251, 250, 244, 0.78);
      --day-night-sky-opacity: 1;
      --day-night-moon-opacity: 1;
      --day-night-sun-glow-opacity: 0;
      --day-night-moon-glow-opacity: 1;
      --moon-detail-opacity: 0.38;
      --day-night-stars-opacity: 0.86;
      --day-night-cta-y: 0px;
      min-height: auto;
      background: var(--day-night-bg);
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__stage {
      position: relative;
      min-height: auto;
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__actions {
      opacity: 1;
      pointer-events: auto;
      transform: none;
    }

    #MellowDayNight-{{ section.id }} .mellow-day-night__orb {
      transform: none;
      will-change: auto;
    }
  }
</style>

<section id="MellowDayNight-{{ section.id }}" class="mellow-day-night" data-mellow-day-night>
  <div class="mellow-day-night__stage">
    <div class="mellow-day-night__inner">
      <div class="mellow-day-night__grid">
        <div class="mellow-day-night__copy">
          {%- if section.settings.eyebrow != blank -%}
            <p class="mellow-eyebrow mellow-day-night__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            {%- assign heading_lines = section.settings.heading | escape | split: '|' -%}
            <h2 class="mellow-section-heading mellow-day-night__heading">
              {%- for line in heading_lines -%}
                {{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}
              {%- endfor -%}
            </h2>
          {%- endif -%}

          {%- if section.settings.subheading != blank -%}
            <p class="mellow-section-text mellow-day-night__subheading">{{ section.settings.subheading | escape }}</p>
          {%- endif -%}

          {%- if section.settings.cta_label != blank -%}
            <div class="mellow-day-night__actions">
              <div class="mellow-section-cta-wrap mellow-day-night__cta-wrap">
                <a class="mellow-section-cta mellow-day-night__cta" href="{{ section.settings.cta_link | default: '#' }}">
                  <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                  <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
                </a>
              </div>

              {%- if section.settings.supporting_line != blank -%}
                <p class="mellow-day-night__support">{{ section.settings.supporting_line | escape }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        <div class="mellow-day-night__visual" aria-hidden="true">
          <span class="mellow-day-night__orb">
            <span class="mellow-day-night__moon-glow"></span>
            <span class="mellow-day-night__moon-core">
              <span class="mellow-day-night__moon-texture"></span>
            </span>
          </span>
          <span class="mellow-day-night__stars"></span>
          <span class="mellow-day-night__horizon"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowDayNight-{{ section.id }}');
    const releaseReadyHold = window.MellowReadyGate ? window.MellowReadyGate.hold() : null;

    const releaseSectionReady = () => {
      section.classList.add('is-mellow-section-ready');

      if (releaseReadyHold) {
        releaseReadyHold();
      }
    };

    if (!section) {
      if (releaseReadyHold) {
        releaseReadyHold();
      }
      return;
    }

    const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const compactQuery = window.matchMedia('(max-width: 899px)');
    const NIGHT_ENTER = 0.5;
    const NIGHT_EXIT = 0.46;
    const CTA_ENTER = 0.94;
    const CTA_EXIT = 0.88;
    let ticking = false;
    let cachedTop = 0;
    let cachedHeight = 1;
    let viewportWidth = window.innerWidth;
    let viewportHeight = window.innerHeight;
    let isCompact = compactQuery.matches;
    let isNight = section.classList.contains('is-night');
    let isCtaVisible = section.classList.contains('is-cta-visible');

    const clamp = (value, min = 0, max = 1) => Math.min(Math.max(value, min), max);

    const setVar = (name, value) => section.style.setProperty(name, value);

    const measureSection = () => {
      let top = 0;
      let node = section;

      while (node) {
        top += node.offsetTop || 0;
        node = node.offsetParent;
      }

      cachedTop = top;
      cachedHeight = Math.max(1, section.offsetHeight || 1);
      viewportWidth = window.innerWidth;
      viewportHeight = window.innerHeight;
      isCompact = compactQuery.matches;
    };

    const updateStateClasses = (progress, ctaProgress) => {
      const nextIsNight = isNight ? progress >= NIGHT_EXIT : progress >= NIGHT_ENTER;
      const nextIsCtaVisible = isCtaVisible ? ctaProgress > CTA_EXIT : ctaProgress > CTA_ENTER;

      if (nextIsNight !== isNight) {
        section.classList.toggle('is-night', nextIsNight);
        isNight = nextIsNight;
      }

      if (nextIsCtaVisible !== isCtaVisible) {
        section.classList.toggle('is-cta-visible', nextIsCtaVisible);
        isCtaVisible = nextIsCtaVisible;
      }
    };

    const renderProgress = (progress, ctaProgress) => {
      const orbX = progress * viewportWidth * (isCompact ? -0.34 : -0.18);
      const orbY = progress * viewportHeight * (isCompact ? 0.09 : 0.22);
      const orbScale = 1 - (progress * (isCompact ? 0.14 : 0.18));
      const moonDetailOpacity = clamp((progress - 0.5) / 0.42) * 0.38;
      const stars = clamp((progress - 0.48) / 0.4) * 0.86;
      const moonOpacity = clamp((progress - 0.26) / 0.54);

      setVar('--day-night-cta-progress', ctaProgress.toFixed(4));
      setVar('--day-night-sky-opacity', clamp(progress / 0.92).toFixed(4));
      setVar('--day-night-orb-transform', `translate3d(calc(${orbX.toFixed(2)}px + var(--day-night-orb-shift-x)), ${orbY.toFixed(2)}px, 0) scale(${orbScale.toFixed(4)})`);
      setVar('--day-night-moon-opacity', moonOpacity.toFixed(4));
      setVar('--day-night-sun-glow-opacity', (1 - moonOpacity).toFixed(4));
      setVar('--day-night-moon-glow-opacity', moonOpacity.toFixed(4));
      setVar('--moon-detail-opacity', moonDetailOpacity.toFixed(4));
      setVar('--day-night-stars-opacity', stars.toFixed(4));
      setVar('--day-night-cta-y', `${((1 - ctaProgress) * 18).toFixed(2)}px`);
      updateStateClasses(progress, ctaProgress);
    };

    const setProgress = () => {
      ticking = false;

      if (reduceMotionQuery.matches) {
        renderProgress(1, 1);
        return;
      }

      const scrollable = Math.max(1, cachedHeight - viewportHeight);
      const progress = clamp((window.scrollY - cachedTop) / scrollable);
      const ctaProgress = clamp((progress - 0.62) / 0.18);

      renderProgress(progress, ctaProgress);
    };

    const requestTick = () => {
      if (!ticking) {
        ticking = true;
        window.requestAnimationFrame(setProgress);
      }
    };

    const refreshMeasurements = () => {
      measureSection();
      requestTick();
    };

    measureSection();
    setProgress();
    window.addEventListener('scroll', requestTick, { passive: true });
    window.addEventListener('resize', refreshMeasurements, { passive: true });

    if (typeof ResizeObserver === 'function') {
      const resizeObserver = new ResizeObserver(refreshMeasurements);
      resizeObserver.observe(section);
    }

    if (typeof compactQuery.addEventListener === 'function') {
      compactQuery.addEventListener('change', refreshMeasurements);
    } else if (typeof compactQuery.addListener === 'function') {
      compactQuery.addListener(refreshMeasurements);
    }

    if (typeof reduceMotionQuery.addEventListener === 'function') {
      reduceMotionQuery.addEventListener('change', refreshMeasurements);
    } else if (typeof reduceMotionQuery.addListener === 'function') {
      reduceMotionQuery.addListener(refreshMeasurements);
    }

    requestAnimationFrame(releaseSectionReady);

    document.addEventListener('shopify:section:load', (event) => {
      if (event.target && event.target.contains(section)) refreshMeasurements();
    });
  })();
</script>

{% schema %}
{
  "name": "Mellow day to night",
  "tag": "section",
  "class": "section section-mellow-day-night",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "AFTER MEALS & BEFORE BED"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "After meals.|Before bed.|Covered."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Mellow is built for the two moments reflux hits hardest — after eating and before sleep. One pouch. Both covered."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "text",
      "id": "supporting_line",
      "label": "Supporting line",
      "default": "Built for daytime triggers and nighttime reflux."
    }
  ],
  "presets": [
    {
      "name": "Mellow day to night"
    }
  ]
}
{% endschema %}
