{% comment %}
  Mellow how to use section.
  Premium three-step ritual section aligned to the global Mellow header system.
{% endcomment %}

<style>
  #MellowHowToUse-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: var(--mellow-section-pad-top);
    padding-bottom: var(--mellow-section-pad-bottom);
    background: var(--mellow-section-green, #123308);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 780px) auto;
    align-items: end;
    gap: clamp(36px, 6vw, 96px);
    margin-bottom: var(--mellow-section-content-gap);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__header {
    max-width: var(--mellow-header-max);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__eyebrow {
    margin: 0 0 var(--mellow-section-header-gap);
    color: var(--mellow-orange-red);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__heading {
    max-width: var(--mellow-header-max);
    color: var(--mellow-ivory);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__text {
    max-width: var(--mellow-copy-max);
    margin: var(--mellow-section-heading-gap) 0 0;
    color: rgba(252, 251, 247, 0.82);
    font-size: var(--mellow-subhead-size);
    line-height: var(--mellow-subhead-line-height);
    font-weight: 400;
    letter-spacing: var(--mellow-subhead-tracking);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__header-actions {
    justify-self: end;
    align-self: center;
    transform: none;
    width: clamp(220px, 16vw, 280px);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__cta-wrap {
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__cta {
    --mellow-section-cta-bg: var(--mellow-ivory);
    --mellow-section-cta-border: var(--mellow-ivory);
    --mellow-section-cta-color: var(--mellow-forest, #123308);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red);
    --mellow-section-cta-hover-border: var(--mellow-orange-red);
    --mellow-section-cta-hover-color: var(--mellow-ivory);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(22px, 1.7vw, 28px);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step {
    min-width: 0;
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__image-card {
    position: relative;
    aspect-ratio: 1 / 1.02;
    min-height: clamp(300px, 30vw, 438px);
    border-radius: min(var(--mellow-radius-card), 24px);
    overflow: hidden;
    background: rgba(252, 251, 247, 0.08);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step-number {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(40px, 3vw, 46px);
    height: clamp(40px, 3vw, 46px);
    border-radius: 999px;
    background: var(--mellow-orange-red);
    color: var(--mellow-ivory);
    font-size: clamp(13px, 0.95vw, 15px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__caption {
    margin-top: clamp(20px, 2vw, 30px);
    padding-left: clamp(16px, 1.2vw, 22px);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__title-row {
    display: flex;
    align-items: center;
    gap: clamp(18px, 1.7vw, 26px);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step-title {
    margin: 0;
    color: var(--mellow-ivory);
    font-family: var(--mellow-font-display) !important;
    font-size: var(--mellow-card-title-size);
    font-weight: var(--mellow-card-title-weight);
    letter-spacing: var(--mellow-card-title-tracking);
    line-height: var(--mellow-card-title-line-height);
  }

  #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step-copy {
    max-width: 330px;
    margin: 8px 0 0;
    padding-left: calc(clamp(40px, 3vw, 46px) + clamp(18px, 1.7vw, 26px));
    color: rgba(252, 251, 247, 0.78);
    font-size: var(--mellow-card-copy-size);
    font-weight: var(--mellow-card-copy-weight);
    letter-spacing: var(--mellow-card-copy-tracking);
    line-height: var(--mellow-card-copy-line-height);
  }

  @media screen and (max-width: 989px) {
    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--mellow-card-gap);
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step:last-child {
      grid-column: 1 / -1;
      max-width: calc((100% - var(--mellow-card-gap)) / 2);
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__image-card {
      min-height: clamp(300px, 58vw, 440px);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__header-wrap {
      display: block;
      margin-bottom: var(--mellow-section-content-gap-compact);
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__text {
      max-width: 360px;
      font-size: 16px;
      line-height: 1.45;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__header-actions {
      width: 100%;
      margin-top: var(--mellow-section-content-gap-compact);
      transform: none;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__cta-wrap {
      width: 100%;
      justify-content: flex-start;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__image-card {
      min-height: 300px;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__steps {
      grid-template-columns: 1fr;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__step:last-child {
      grid-column: auto;
      max-width: none;
    }

    #MellowHowToUse-{{ section.id }} .mellow-how-to-use__caption {
      padding-left: 0;
    }
  }
</style>

<section
  id="MellowHowToUse-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-how-to-use color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-section-axis mellow-how-to-use__inner">
    <div class="mellow-section-header-grid mellow-how-to-use__header-wrap">
      <div class="mellow-section-header mellow-how-to-use__header">
        <p class="mellow-eyebrow mellow-how-to-use__eyebrow">A SIMPLE 3-STEP RITUAL</p>
        <h2 class="mellow-section-heading mellow-how-to-use__heading">How to use Mellow</h2>
        <p class="mellow-section-text mellow-how-to-use__text">A simple 3-step ritual after meals, before bed, or whenever reflux shows up.</p>
      </div>

      <div class="mellow-section-actions mellow-how-to-use__header-actions">
        <div class="mellow-section-cta-wrap mellow-how-to-use__cta-wrap">
          <a class="mellow-section-cta mellow-how-to-use__cta" href="/products/mellow">
            <span class="mellow-section-cta__label">Try Mellow</span>
            <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mellow-how-to-use__steps" aria-label="How to use Mellow in three steps">
      <article class="mellow-how-to-use__step">
        <div class="mellow-how-to-use__image-card">
          {%- if section.settings.step_1_image != blank -%}
            {{ section.settings.step_1_image | image_url: width: 1200 | image_tag: class: 'mellow-how-to-use__image', loading: 'lazy', widths: '420, 640, 860, 1200', sizes: '(min-width: 990px) 31vw, (min-width: 750px) 46vw, calc(100vw - 44px)', alt: 'Person opening a Mellow pouch at a desk' }}
          {%- else -%}
            <img class="mellow-how-to-use__image" src="{{ 'mellow-how-to-use-squeeze.jpg' | asset_url }}" alt="Person opening a Mellow pouch at a desk" loading="lazy" width="1536" height="1024">
          {%- endif -%}
        </div>
        <div class="mellow-how-to-use__caption">
          <div class="mellow-how-to-use__title-row">
            <span class="mellow-how-to-use__step-number">01</span>
            <h3 class="mellow-how-to-use__step-title">Squeeze</h3>
          </div>
          <p class="mellow-how-to-use__step-copy">Squeeze the gel directly into your mouth.</p>
        </div>
      </article>

      <article class="mellow-how-to-use__step">
        <div class="mellow-how-to-use__image-card">
          {%- if section.settings.step_2_image != blank -%}
            {{ section.settings.step_2_image | image_url: width: 1200 | image_tag: class: 'mellow-how-to-use__image', loading: 'lazy', widths: '420, 640, 860, 1200', sizes: '(min-width: 990px) 31vw, (min-width: 750px) 46vw, calc(100vw - 44px)', alt: 'Hiker taking Mellow outdoors' }}
          {%- else -%}
            <img class="mellow-how-to-use__image" src="{{ 'mellow-how-to-use-take.jpg' | asset_url }}" alt="Hiker taking Mellow outdoors" loading="lazy" width="1536" height="1024">
          {%- endif -%}
        </div>
        <div class="mellow-how-to-use__caption">
          <div class="mellow-how-to-use__title-row">
            <span class="mellow-how-to-use__step-number">02</span>
            <h3 class="mellow-how-to-use__step-title">Take</h3>
          </div>
          <p class="mellow-how-to-use__step-copy">Take it and let the raft form.</p>
        </div>
      </article>

      <article class="mellow-how-to-use__step">
        <div class="mellow-how-to-use__image-card">
          {%- if section.settings.step_3_image != blank -%}
            {{ section.settings.step_3_image | image_url: width: 1200 | image_tag: class: 'mellow-how-to-use__image', loading: 'lazy', widths: '420, 640, 860, 1200', sizes: '(min-width: 990px) 31vw, (min-width: 750px) 46vw, calc(100vw - 44px)', alt: 'Person relaxing at home after using Mellow' }}
          {%- else -%}
            <img class="mellow-how-to-use__image" src="{{ 'mellow-how-to-use-feel.jpg' | asset_url }}" alt="Person relaxing at home after using Mellow" loading="lazy" width="1536" height="1024">
          {%- endif -%}
        </div>
        <div class="mellow-how-to-use__caption">
          <div class="mellow-how-to-use__title-row">
            <span class="mellow-how-to-use__step-number">03</span>
            <h3 class="mellow-how-to-use__step-title">Feel mellow</h3>
          </div>
          <p class="mellow-how-to-use__step-copy">Feel relief and get back to what matters most.</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow how to use",
  "tag": "section",
  "class": "section section-mellow-how-to-use",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "step_1_image",
      "label": "Step 1 image"
    },
    {
      "type": "image_picker",
      "id": "step_2_image",
      "label": "Step 2 image"
    },
    {
      "type": "image_picker",
      "id": "step_3_image",
      "label": "Step 3 image"
    }
  ],
  "presets": [
    {
      "name": "Mellow how to use"
    }
  ]
}
{% endschema %}
