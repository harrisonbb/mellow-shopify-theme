{% comment %}
  Mellow clinical proof section.
  Warm before/after research proof module using the global Mellow brand system.
{% endcomment %}

<style>
  #MellowClinicalProof-{{ section.id }} {
    --mellow-clinical-pad-top: {{ section.settings.padding_top }}px;
    --mellow-clinical-pad-bottom: {{ section.settings.padding_bottom }}px;
    --mellow-clinical-border: rgba(18, 51, 8, 0.12);
    --mellow-clinical-border-soft: rgba(18, 51, 8, 0.08);
    --mellow-clinical-copy: rgba(18, 51, 8, 0.78);
    --mellow-clinical-muted: rgba(18, 51, 8, 0.62);
    --mellow-clinical-line: #AAB5A6;
    --mellow-clinical-card: color-mix(in srgb, var(--mellow-cream, #FCFBF7) 82%, var(--mellow-card-cream, #F8F4EC));
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    padding-top: var(--mellow-clinical-pad-top);
    padding-bottom: var(--mellow-clinical-pad-bottom);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-forest, #123308);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__inner {
    width: min(calc(100% - (var(--mellow-section-axis-pad, 22px) * 2)), var(--mellow-axis-max, 1200px));
    max-width: var(--mellow-axis-max, 1200px);
    margin-left: auto;
    margin-right: auto;
    padding-left: 0;
    padding-right: 0;
    box-sizing: border-box;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.76fr) minmax(620px, 1.36fr);
    gap: clamp(44px, 7vw, 112px);
    align-items: start;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__copy {
    max-width: 470px;
    padding-top: clamp(20px, 2.4vw, 34px);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__eyebrow {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading {
    max-width: 520px;
    color: var(--mellow-forest, #123308);
    text-wrap: balance;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading-line {
    display: block;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__text {
    max-width: 470px;
    color: var(--mellow-clinical-copy);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__actions {
    margin-top: clamp(24px, 2.2vw, 34px);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__cta-wrap {
    justify-content: flex-start;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__cta {
    --mellow-section-cta-bg: var(--mellow-forest, #123308);
    --mellow-section-cta-border: var(--mellow-forest, #123308);
    --mellow-section-cta-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-width: clamp(214px, 14vw, 248px);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__proof {
    display: grid;
    gap: clamp(14px, 1.4vw, 18px);
    min-width: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card,
  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stats {
    border: 1px solid var(--mellow-clinical-border);
    border-radius: min(var(--mellow-radius-card, 2.8rem), 30px);
    background: var(--mellow-clinical-card);
    box-shadow: 0 18px 44px rgba(18, 51, 8, 0.045);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(156px, 0.58fr) minmax(0, 1fr);
    align-items: stretch;
    min-height: clamp(390px, 34vw, 470px);
    overflow: hidden;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__panel {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    gap: clamp(14px, 1.4vw, 20px);
    min-width: 0;
    padding: clamp(28px, 2.8vw, 42px) clamp(20px, 2vw, 32px) clamp(24px, 2.4vw, 34px);
    text-align: center;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__panel + .mellow-clinical-proof__outcome,
  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome + .mellow-clinical-proof__panel {
    border-left: 1px solid var(--mellow-clinical-border-soft);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__label {
    display: grid;
    gap: 7px;
    min-height: 54px;
    color: var(--mellow-forest, #123308);
    font-size: clamp(12px, 0.86vw, 14px);
    line-height: 1.22;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__label strong {
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(13px, 0.95vw, 16px);
    font-weight: 760;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: uppercase;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__label span {
    color: var(--mellow-clinical-copy);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__figure {
    display: grid;
    place-items: center;
    min-height: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__anatomy {
    width: min(100%, 214px);
    height: auto;
    overflow: visible;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__caption {
    margin: 0;
    color: var(--mellow-clinical-copy);
    font-size: clamp(13px, 0.94vw, 15px);
    font-weight: 650;
    line-height: 1.25;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome {
    display: grid;
    place-items: center;
    padding: clamp(26px, 2.2vw, 36px) clamp(16px, 1.5vw, 24px);
    text-align: left;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome-inner {
    display: grid;
    gap: clamp(12px, 1vw, 16px);
    justify-items: start;
    max-width: 150px;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__multiplier {
    display: block;
    color: var(--mellow-forest, #123308);
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(54px, 4.8vw, 76px);
    font-weight: 720;
    letter-spacing: 0;
    line-height: 0.88;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome-copy {
    margin: 0;
    color: var(--mellow-forest, #123308);
    font-size: clamp(15px, 1.15vw, 18px);
    font-weight: 760;
    line-height: 1.2;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__source {
    margin: 0;
    color: var(--mellow-forest, #123308);
    font-size: clamp(12px, 0.88vw, 14px);
    font-weight: 760;
    letter-spacing: 0.05em;
    line-height: 1.22;
    text-transform: uppercase;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__arrow {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-forest, #123308);
    color: var(--mellow-cream, #FCFBF7);
    font-size: 23px;
    line-height: 1;
    box-shadow: 0 10px 22px rgba(18, 51, 8, 0.16);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    overflow: hidden;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(16px, 1.5vw, 22px);
    align-items: start;
    min-width: 0;
    padding: clamp(24px, 2.2vw, 34px) clamp(22px, 2vw, 34px);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat + .mellow-clinical-proof__stat::before {
    content: "";
    position: absolute;
    left: 0;
    top: 24px;
    bottom: 24px;
    width: 1px;
    background: var(--mellow-clinical-border-soft);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__icon {
    display: grid;
    place-items: center;
    width: clamp(42px, 3.4vw, 50px);
    height: clamp(42px, 3.4vw, 50px);
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-forest, #123308);
    color: var(--mellow-cream, #FCFBF7);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__icon svg {
    width: 58%;
    height: 58%;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-content {
    min-width: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-number {
    display: block;
    color: var(--mellow-forest, #123308);
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(44px, 4vw, 62px);
    font-weight: 720;
    letter-spacing: 0;
    line-height: 0.9;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-text {
    margin: 10px 0 0;
    color: var(--mellow-clinical-copy);
    font-size: clamp(15px, 1.1vw, 18px);
    font-weight: 540;
    line-height: 1.22;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-source {
    display: block;
    margin-top: 12px;
    color: var(--mellow-forest, #123308);
    font-size: clamp(10px, 0.78vw, 12px);
    font-weight: 760;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__citation {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 18px;
    align-items: start;
    margin-top: clamp(20px, 2vw, 28px);
    padding-top: clamp(20px, 2vw, 28px);
    border-top: 1px solid var(--mellow-clinical-border-soft);
    color: var(--mellow-clinical-copy);
    font-size: clamp(12px, 0.86vw, 14px);
    font-weight: 560;
    line-height: 1.45;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__citation-icon {
    width: 32px;
    height: 38px;
    color: var(--mellow-forest, #123308);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__citation p {
    margin: 0;
  }

  @media screen and (max-width: 1180px) {
    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__grid {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact, clamp(26px, 2.4vw, 40px));
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__copy {
      max-width: 720px;
      padding-top: 0;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowClinicalProof-{{ section.id }} {
      --mellow-clinical-pad-top: min({{ section.settings.padding_top }}px, 64px);
      --mellow-clinical-pad-bottom: min({{ section.settings.padding_bottom }}px, 64px);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__text {
      max-width: 420px;
      font-size: 16px;
      line-height: 1.45;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card {
      grid-template-columns: 1fr;
      min-height: 0;
      border-radius: 24px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__panel {
      padding: 26px 22px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__panel + .mellow-clinical-proof__outcome,
    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome + .mellow-clinical-proof__panel {
      border-top: 1px solid var(--mellow-clinical-border-soft);
      border-left: 0;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome {
      padding: 26px 22px;
      text-align: center;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__outcome-inner {
      justify-items: center;
      max-width: 240px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stats {
      grid-template-columns: 1fr;
      border-radius: 24px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat {
      grid-template-columns: auto minmax(0, 1fr);
      padding: 22px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat + .mellow-clinical-proof__stat::before {
      top: 0;
      bottom: auto;
      left: 22px;
      right: 22px;
      width: auto;
      height: 1px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-number {
      font-size: clamp(40px, 13vw, 56px);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__citation {
      grid-template-columns: 28px minmax(0, 1fr);
      gap: 14px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__citation-icon {
      width: 28px;
      height: 34px;
    }
  }
</style>

<section
  id="MellowClinicalProof-{{ section.id }}"
  class="mellow-section-standard mellow-clinical-proof color-{{ section.settings.color_scheme }}"
  aria-labelledby="MellowClinicalProofHeading-{{ section.id }}"
>
  <div class="mellow-section-axis mellow-clinical-proof__inner">
    <div class="mellow-clinical-proof__grid">
      <div class="mellow-clinical-proof__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-clinical-proof__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        <h2 id="MellowClinicalProofHeading-{{ section.id }}" class="mellow-section-heading mellow-clinical-proof__heading">
          {%- if section.settings.headline_line_1 != blank -%}
            <span class="mellow-clinical-proof__heading-line">{{ section.settings.headline_line_1 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.headline_line_2 != blank -%}
            <span class="mellow-clinical-proof__heading-line">{{ section.settings.headline_line_2 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.headline_line_3 != blank -%}
            <span class="mellow-clinical-proof__heading-line">{{ section.settings.headline_line_3 | escape }}</span>
          {%- endif -%}
        </h2>

        {%- if section.settings.body != blank -%}
          <p class="mellow-section-text mellow-clinical-proof__text">{{ section.settings.body | escape }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="mellow-clinical-proof__actions">
            <div class="mellow-section-cta-wrap mellow-clinical-proof__cta-wrap">
              <a class="mellow-section-cta mellow-clinical-proof__cta" href="{{ section.settings.cta_link | default: '#' }}">
                <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                <span class="mellow-section-cta__arrow" aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="mellow-clinical-proof__proof">
        <article class="mellow-clinical-proof__card" aria-label="Before and after alginate therapy illustration">
          <div class="mellow-clinical-proof__panel">
            <div class="mellow-clinical-proof__label">
              <strong>Before support</strong>
              <span>Placebo or antacid</span>
            </div>
            <div class="mellow-clinical-proof__figure" aria-hidden="true">
              <svg class="mellow-clinical-proof__anatomy" viewBox="0 0 210 250" role="img" focusable="false">
                <defs>
                  <radialGradient id="mellow-before-stomach-{{ section.id }}" cx="55%" cy="52%" r="64%">
                    <stop offset="0%" stop-color="#F5B08E" stop-opacity="0.72" />
                    <stop offset="100%" stop-color="#D04A2A" stop-opacity="0.52" />
                  </radialGradient>
                </defs>
                <path d="M79 13c-16 2-28 14-30 31-2 14 5 25 12 36 5 8 7 15 6 24-2 17-16 22-31 29-20 9-29 26-31 50l-3 42" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.5" stroke-linecap="round" />
                <path d="M130 14c16 4 27 17 27 33 0 14-8 22-10 32-2 9 4 16 16 22 31 15 42 35 43 79l1 44" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.5" stroke-linecap="round" />
                <path d="M55 169c-3 28-4 44-6 60" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.35" stroke-linecap="round" />
                <path d="M158 169c4 26 5 43 7 60" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.35" stroke-linecap="round" />
                <path d="M93 78c-8 20-7 64 0 84 4 10 12 15 18 20 8 7 6 23-7 31-18 12-41 5-47-13-5-15 4-27 19-27 11 0 17 7 20 18" fill="none" stroke="#D04A2A" stroke-width="2.2" stroke-linecap="round" />
                <path d="M107 98c-4 28-2 55 5 76 3 10 3 23-2 31-7 12-22 19-40 16 2 16 24 21 42 12 20-10 30-31 23-52-4-13-15-19-24-27-7-8-9-30-6-55z" fill="url(#mellow-before-stomach-{{ section.id }})" opacity="0.9" />
                <path d="M101 78c-7 22-6 59-1 78" fill="none" stroke="#D04A2A" stroke-width="1.35" stroke-linecap="round" opacity="0.72" />
                <circle cx="86" cy="107" r="1.6" fill="#D04A2A" opacity="0.56" />
                <circle cx="121" cy="113" r="1.8" fill="#D04A2A" opacity="0.5" />
                <circle cx="77" cy="128" r="1.3" fill="#D04A2A" opacity="0.48" />
                <circle cx="128" cy="132" r="1.4" fill="#D04A2A" opacity="0.48" />
                <circle cx="91" cy="145" r="1.2" fill="#D04A2A" opacity="0.42" />
                <circle cx="118" cy="151" r="1.2" fill="#D04A2A" opacity="0.42" />
                <circle cx="69" cy="95" r="1.1" fill="#D04A2A" opacity="0.36" />
                <circle cx="74" cy="80" r="1" fill="#D04A2A" opacity="0.22" />
              </svg>
            </div>
            <p class="mellow-clinical-proof__caption">Symptoms persist</p>
          </div>

          <div class="mellow-clinical-proof__outcome">
            <div class="mellow-clinical-proof__outcome-inner">
              <span class="mellow-clinical-proof__multiplier">4.4&times;</span>
              <p class="mellow-clinical-proof__outcome-copy">greater odds of reflux symptom resolution</p>
              <p class="mellow-clinical-proof__source">vs. placebo or antacids</p>
              <span class="mellow-clinical-proof__arrow" aria-hidden="true">&rarr;</span>
            </div>
          </div>

          <div class="mellow-clinical-proof__panel">
            <div class="mellow-clinical-proof__label">
              <strong>After alginate therapy</strong>
              <span>Alginate forms a barrier<br>to help stop reflux</span>
            </div>
            <div class="mellow-clinical-proof__figure" aria-hidden="true">
              <svg class="mellow-clinical-proof__anatomy" viewBox="0 0 210 250" role="img" focusable="false">
                <path d="M79 13c-16 2-28 14-30 31-2 14 5 25 12 36 5 8 7 15 6 24-2 17-16 22-31 29-20 9-29 26-31 50l-3 42" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.5" stroke-linecap="round" />
                <path d="M130 14c16 4 27 17 27 33 0 14-8 22-10 32-2 9 4 16 16 22 31 15 42 35 43 79l1 44" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.5" stroke-linecap="round" />
                <path d="M55 169c-3 28-4 44-6 60" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.35" stroke-linecap="round" />
                <path d="M158 169c4 26 5 43 7 60" fill="none" stroke="var(--mellow-clinical-line)" stroke-width="1.35" stroke-linecap="round" />
                <path d="M101 82c-4 27-3 63 4 87 3 11 7 16 15 20" fill="none" stroke="#87977F" stroke-width="3.2" stroke-linecap="round" opacity="0.82" />
                <path d="M111 170c13 12 20 28 12 43-8 14-28 20-48 16-17-3-24-13-22-27 2-13 12-22 25-22 10 0 17 5 21 13" fill="#E7EADF" stroke="#87977F" stroke-width="1.5" stroke-linecap="round" />
                <path d="M69 181c27 7 58 3 88-15 8-5 15-6 20-3 2 14-6 26-20 34-28 15-63 19-96 8 0-10 2-18 8-24z" fill="#123308" opacity="0.88" />
                <path d="M72 205c22 7 47 5 73-5" fill="none" stroke="#87977F" stroke-width="1.1" stroke-linecap="round" opacity="0.45" />
                <circle cx="88" cy="205" r="1.2" fill="#87977F" opacity="0.5" />
                <circle cx="111" cy="213" r="1.2" fill="#87977F" opacity="0.42" />
                <circle cx="132" cy="202" r="1.1" fill="#87977F" opacity="0.42" />
                <circle cx="101" cy="222" r="1" fill="#87977F" opacity="0.35" />
              </svg>
            </div>
            <p class="mellow-clinical-proof__caption">Symptoms improved</p>
          </div>
        </article>

        <div class="mellow-clinical-proof__stats" aria-label="Clinical research proof points">
          <article class="mellow-clinical-proof__stat">
            <span class="mellow-clinical-proof__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" focusable="false">
                <circle cx="12" cy="12" r="8.5" stroke="currentColor" stroke-width="1.5" />
                <path d="m8 12.3 2.6 2.7 5.8-6.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <div class="mellow-clinical-proof__stat-content">
              <span class="mellow-clinical-proof__stat-number">4.4&times;</span>
              <p class="mellow-clinical-proof__stat-text">greater odds of reflux symptom resolution</p>
              <span class="mellow-clinical-proof__stat-source">vs. placebo or antacids<sup>1</sup></span>
            </div>
          </article>

          <article class="mellow-clinical-proof__stat">
            <span class="mellow-clinical-proof__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" focusable="false">
                <path d="M9.5 11.2a3.2 3.2 0 1 0 0-6.4 3.2 3.2 0 0 0 0 6.4Z" stroke="currentColor" stroke-width="1.45" />
