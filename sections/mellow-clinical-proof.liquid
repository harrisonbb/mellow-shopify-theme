{% comment %}
  Mellow clinical proof section.
  Premium peer-reviewed research proof band using the global Mellow brand system.
{% endcomment %}

{%- liquid
  assign background_image = section.settings.background_image
-%}

<style>
  #MellowClinicalProof-{{ section.id }} {
    --mellow-clinical-pad-top: {{ section.settings.padding_top }}px;
    --mellow-clinical-pad-bottom: {{ section.settings.padding_bottom }}px;
    --mellow-clinical-divider: rgba(0, 51, 2, 0.16);
    --mellow-clinical-cream-muted: rgba(0, 51, 2, 0.72);
    --mellow-clinical-cream-soft: rgba(0, 51, 2, 0.54);
    --mellow-clinical-sage: color-mix(in srgb, var(--mellow-muted, #5E6B58) 72%, var(--mellow-forest, #003302));
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    padding-top: var(--mellow-clinical-pad-top);
    padding-bottom: var(--mellow-clinical-pad-bottom);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-forest, #003302);
  }

  #MellowClinicalProof-{{ section.id }}.has-background-image {
    position: relative;
    isolation: isolate;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  #MellowClinicalProof-{{ section.id }}.has-background-image::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(252, 251, 247, 0.18);
    pointer-events: none;
  }

  #MellowClinicalProof-{{ section.id }}.has-background-image > .mellow-section-axis {
    position: relative;
    z-index: 1;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: clamp(54px, 5.4vw, 78px);
    border-top: 1px solid var(--mellow-clinical-divider);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat {
    position: relative;
    min-width: 0;
    padding: clamp(34px, 4vw, 56px) clamp(20px, 2vw, 34px);
    text-align: left;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-copy {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(8px, 0.8vw, 12px) clamp(20px, 2vw, 34px);
    align-items: start;
    width: 100%;
    text-align: left;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat:first-child {
    padding-left: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat:last-child {
    padding-right: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat + .mellow-clinical-proof__stat::before {
    content: "";
    position: absolute;
    left: 0;
    top: clamp(34px, 4vw, 56px);
    bottom: clamp(34px, 4vw, 56px);
    width: 1px;
    background: var(--mellow-clinical-divider);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-number {
    display: block;
    grid-row: 1 / span 2;
    margin: 0;
    text-align: left;
    color: var(--mellow-forest, #003302);
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(70px, 6.6vw, 108px);
    font-weight: var(--mellow-heading-weight);
    letter-spacing: -0.06em;
    line-height: 0.86;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-plus {
    display: inline-block;
    margin-left: 0.02em;
    color: var(--mellow-clinical-sage);
    font-size: 0.42em;
    line-height: 1;
    transform: translateY(-0.72em);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-label {
    display: block;
    max-width: 360px;
    margin: 0;
    text-align: left;
    color: var(--mellow-clinical-sage);
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(21px, 1.8vw, 30px);
    font-weight: 600;
    line-height: 1.02;
    letter-spacing: -0.028em;
    text-transform: none;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-label::after {
    content: none;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-body {
    max-width: 380px;
    margin: 0;
    text-align: left;
    color: var(--mellow-clinical-cream-muted);
    font-size: clamp(15px, 1.1vw, 19px);
    line-height: 1.52;
    letter-spacing: -0.006em;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__content {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(340px, 0.72fr);
    gap: var(--mellow-feature-gap);
    align-items: center;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__copy {
    max-width: 760px;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__eyebrow {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading {
    max-width: 760px;
    color: var(--mellow-forest, #003302);
    text-wrap: balance;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading-line {
    display: block;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading-line--sage {
    color: var(--mellow-clinical-sage);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__heading-line--accent {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__text {
    max-width: 620px;
    color: var(--mellow-clinical-cream-muted);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__actions {
    margin-top: var(--mellow-section-content-gap-compact);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__cta-wrap {
    justify-content: flex-start;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__cta {
    --mellow-section-cta-bg: var(--mellow-forest, #003302);
    --mellow-section-cta-border: var(--mellow-forest, #003302);
    --mellow-section-cta-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__disclaimer {
    max-width: 560px;
    margin: clamp(18px, 1.8vw, 24px) 0 0;
    color: var(--mellow-clinical-cream-soft);
    font-size: clamp(12px, 0.9vw, 13px);
    line-height: 1.45;
    letter-spacing: 0;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card {
    position: relative;
    overflow: hidden;
    min-height: clamp(340px, 29vw, 430px);
    padding: var(--mellow-card-pad-airy);
    border: 1px solid var(--mellow-card-border, rgba(0, 51, 2, 0.10));
    border-radius: var(--mellow-radius-card);
    background: var(--mellow-card-cream, #F8F4EC);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
    isolation: isolate;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card::before {
    content: "";
    display: block;
    width: clamp(42px, 4vw, 58px);
    height: 3px;
    margin-bottom: clamp(24px, 2.8vw, 38px);
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-orange-red, #D04A2A);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card-copy {
    position: relative;
    z-index: 2;
    max-width: 430px;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card-title {
    max-width: 390px;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card-body {
    max-width: 420px;
    margin-top: 18px;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__evidence-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    max-width: 520px;
    margin-top: clamp(28px, 3vw, 40px);
    overflow: hidden;
    border: 1px solid rgba(0, 51, 2, 0.12);
    border-radius: min(var(--mellow-radius-card), 18px);
    background: rgba(0, 51, 2, 0.12);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__evidence-item {
    min-width: 0;
    padding: clamp(14px, 1.3vw, 18px);
    background: rgba(252, 251, 247, 0.56);
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__evidence-value {
    display: block;
    color: var(--mellow-forest, #003302);
    font-family: var(--mellow-font-display) !important;
    font-size: clamp(20px, 1.8vw, 28px);
    font-weight: var(--mellow-heading-weight);
    line-height: 0.96;
    letter-spacing: -0.035em;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__evidence-label {
    display: block;
    margin-top: 8px;
    color: var(--mellow-clinical-cream-muted);
    font-size: clamp(11px, 0.84vw, 13px);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card-note {
    max-width: 390px;
    margin: clamp(22px, 2.6vw, 32px) 0 0;
    color: var(--mellow-forest, #003302);
    font-size: clamp(14px, 1vw, 16px);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.004em;
  }

  @media screen and (max-width: 989px) {
    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stats {
      grid-template-columns: 1fr;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat,
    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat:first-child,
    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat:last-child {
      padding: clamp(30px, 5vw, 44px) 0;
      border-top: 1px solid var(--mellow-clinical-divider);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat:first-child {
      border-top: 0;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat + .mellow-clinical-proof__stat::before {
      content: none;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__content {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowClinicalProof-{{ section.id }} {
      --mellow-clinical-pad-top: min({{ section.settings.padding_top }}px, 64px);
      --mellow-clinical-pad-bottom: min({{ section.settings.padding_bottom }}px, 64px);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-number {
      font-size: clamp(60px, 16vw, 92px);
      line-height: 0.92;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-copy {
      display: block;
      max-width: 430px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-number {
      margin-bottom: clamp(8px, 2.5vw, 14px);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-label {
      max-width: 320px;
      font-size: clamp(22px, 6.6vw, 30px);
      line-height: 1.04;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__stat-body {
      max-width: 330px;
      margin-top: clamp(8px, 2.6vw, 12px);
      font-size: 16px;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__text {
      max-width: 360px;
      font-size: 16px;
      line-height: 1.45;
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__card {
      min-height: 330px;
      padding: var(--mellow-card-pad-airy);
      border-radius: min(var(--mellow-radius-card), 24px);
    }

    #MellowClinicalProof-{{ section.id }} .mellow-clinical-proof__evidence-list {
      grid-template-columns: 1fr;
    }

    #MellowClinicalProof-{{ section.id }}.has-background-image::before {
      background: rgba(252, 251, 247, 0.24);
    }

  }
</style>

<section
  id="MellowClinicalProof-{{ section.id }}"
  class="mellow-section-standard mellow-clinical-proof color-{{ section.settings.color_scheme }}{% if background_image != blank %} has-background-image{% endif %}"
  {% if background_image != blank %}style="background-image: url('{{ background_image | image_url: width: 2400 }}');"{% endif %}
  aria-labelledby="MellowClinicalProofHeading-{{ section.id }}"
>
  <div class="mellow-section-axis mellow-clinical-proof__inner">
    <div class="mellow-clinical-proof__content">
      <div class="mellow-clinical-proof__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-clinical-proof__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        <h2 id="MellowClinicalProofHeading-{{ section.id }}" class="mellow-section-heading mellow-clinical-proof__heading">
          {%- if section.settings.headline_line_1 != blank -%}
            <span class="mellow-clinical-proof__heading-line">{{ section.settings.headline_line_1 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.headline_line_2 != blank -%}
            <span class="mellow-clinical-proof__heading-line mellow-clinical-proof__heading-line--sage">{{ section.settings.headline_line_2 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.headline_line_3 != blank -%}
            <span class="mellow-clinical-proof__heading-line mellow-clinical-proof__heading-line--accent">{{ section.settings.headline_line_3 | escape }}</span>
          {%- endif -%}
        </h2>

        {%- if section.settings.body != blank -%}
          <p class="mellow-section-text mellow-clinical-proof__text">{{ section.settings.body | escape }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="mellow-clinical-proof__actions">
            <div class="mellow-section-cta-wrap mellow-clinical-proof__cta-wrap">
              <a class="mellow-section-cta mellow-clinical-proof__cta" href="{{ section.settings.cta_link | default: '#' }}">
                <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.disclaimer != blank -%}
          <p class="mellow-clinical-proof__disclaimer">{{ section.settings.disclaimer | escape | newline_to_br }}</p>
        {%- endif -%}
      </div>

      <article class="mellow-clinical-proof__card">
        <div class="mellow-clinical-proof__card-copy">
          <h3 class="mellow-card-title mellow-clinical-proof__card-title">{{ section.settings.card_title | escape }}</h3>
          <p class="mellow-card-copy mellow-clinical-proof__card-body">{{ section.settings.card_body | escape }}</p>
          <div class="mellow-clinical-proof__evidence-list" aria-label="Research categories">
            <div class="mellow-clinical-proof__evidence-item">
              <span class="mellow-clinical-proof__evidence-value">10+</span>
              <span class="mellow-clinical-proof__evidence-label">Studies</span>
            </div>
            <div class="mellow-clinical-proof__evidence-item">
              <span class="mellow-clinical-proof__evidence-value">25+</span>
              <span class="mellow-clinical-proof__evidence-label">Years</span>
            </div>
            <div class="mellow-clinical-proof__evidence-item">
              <span class="mellow-clinical-proof__evidence-value">RCT</span>
              <span class="mellow-clinical-proof__evidence-label">Evidence</span>
            </div>
          </div>
          <p class="mellow-clinical-proof__card-note">{{ section.settings.card_note | escape }}</p>
        </div>
      </article>
    </div>
  </div>

  <div class="mellow-section-axis mellow-clinical-proof__metrics-rail">
    <div class="mellow-clinical-proof__stats" aria-label="Clinical research proof points">
      <article class="mellow-clinical-proof__stat">
        <div class="mellow-clinical-proof__stat-copy">
          <span class="mellow-clinical-proof__stat-number">
            {%- if section.settings.stat_1_value contains '+' -%}
              {{ section.settings.stat_1_value | remove: '+' | escape }}<span class="mellow-clinical-proof__stat-plus">+</span>
            {%- else -%}
              {{ section.settings.stat_1_value | escape }}
            {%- endif -%}
          </span>
          <span class="mellow-clinical-proof__stat-label">{{ section.settings.stat_1_label | escape }}</span>
          <p class="mellow-clinical-proof__stat-body">{{ section.settings.stat_1_body | escape }}</p>
        </div>
      </article>

      <article class="mellow-clinical-proof__stat">
        <div class="mellow-clinical-proof__stat-copy">
          <span class="mellow-clinical-proof__stat-number">
            {%- if section.settings.stat_2_value contains '+' -%}
              {{ section.settings.stat_2_value | remove: '+' | escape }}<span class="mellow-clinical-proof__stat-plus">+</span>
            {%- else -%}
              {{ section.settings.stat_2_value | escape }}
            {%- endif -%}
          </span>
          <span class="mellow-clinical-proof__stat-label">{{ section.settings.stat_2_label | escape }}</span>
          <p class="mellow-clinical-proof__stat-body">{{ section.settings.stat_2_body | escape }}</p>
        </div>
      </article>

      <article class="mellow-clinical-proof__stat">
        <div class="mellow-clinical-proof__stat-copy">
          <span class="mellow-clinical-proof__stat-number">{{ section.settings.stat_3_value | escape }}</span>
          <span class="mellow-clinical-proof__stat-label">{{ section.settings.stat_3_label | escape }}</span>
          <p class="mellow-clinical-proof__stat-body">{{ section.settings.stat_3_body | escape }}</p>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow clinical proof",
  "tag": "section",
  "class": "section section-mellow-clinical-proof",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Full-section background image"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "10+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "studies in meta-analysis"
    },
    {
      "type": "textarea",
      "id": "stat_1_body",
      "label": "Stat 1 body",
      "default": "Supporting alginate for reflux relief."
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "25+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "years of published peer-reviewed research"
    },
    {
      "type": "textarea",
      "id": "stat_2_body",
      "label": "Stat 2 body",
      "default": "Alginate technology studied, refined, and validated for over two decades."
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "2023"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "recent RCT vs. antacid alone"
    },
    {
      "type": "textarea",
      "id": "stat_3_body",
      "label": "Stat 3 body",
      "default": "The latest randomized controlled trial shows alginate add-on therapy outperforms antacid alone."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PEER-REVIEWED RESEARCH"
    },
    {
      "type": "text",
      "id": "headline_line_1",
      "label": "Headline line 1",
      "default": "A simple barrier."
    },
    {
      "type": "text",
      "id": "headline_line_2",
      "label": "Headline line 2",
      "default": "Decades of research behind it."
    },
    {
      "type": "text",
      "id": "headline_line_3",
      "label": "Headline line 3",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "We didn’t invent alginate. We perfected its delivery in MellowRaft™. The science has been researched, replicated, and peer-reviewed for over 25 years."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Explore the research"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "Not evaluated by the FDA. Not intended to diagnose, treat, cure or prevent any disease.\nCitations refer to published research on alginate-based formulas, not this specific product."
    },
    {
      "type": "text",
      "id": "card_title",
      "label": "Trust card title",
      "default": "Published research, made practical"
    },
    {
      "type": "textarea",
      "id": "card_body",
      "label": "Trust card body",
      "default": "Alginate-based formulas have been studied across clinical trials, meta-analyses, and reflux research for more than two decades."
    },
    {
      "type": "text",
      "id": "card_note",
      "label": "Trust card bottom note",
      "default": "Citations available in the full research library."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 48,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 48,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 88
    }
  ],
  "presets": [
    {
      "name": "Mellow clinical proof"
    }
  ]
}
{% endschema %}
