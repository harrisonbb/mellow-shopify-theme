<script>
  (function () {
    function buildMellowRaftParticle(particleMount, index) {
      var colors = [
        'rgba(255,247,232,.68)',
        'rgba(228,184,90,.54)',
        'rgba(184,201,130,.56)',
        'rgba(255,247,232,.58)'
      ];
      var pb = document.createElement('div');
      var baseX = 30 + ((index * 37) % 41);
      var size = 2 + ((index * 3) % 4);
      var dx1 = -28 + ((index * 29) % 56);
      var dy1 = -38 - ((index * 17) % 28);
      var dx2 = -48 + ((index * 41) % 96);
      var dy2 = -92 - ((index * 11) % 11);
      var dx3 = -54 + ((index * 53) % 108);
      var dy3 = -132 - ((index * 7) % 4);
      var delay = ((index % 14) * 0.018).toFixed(3);

      pb.className = 'pb';
      pb.style.cssText = [
        '--x0:' + baseX + '%',
        '--s:' + size + 'px',
        '--dx1:' + dx1 + 'px',
        '--dy1:' + dy1 + 'px',
        '--dx2:' + dx2 + 'px',
        '--dy2:' + dy2 + 'px',
        '--dx3:' + dx3 + 'px',
        '--dy3:' + dy3 + 'px',
        '--c:' + colors[index % colors.length],
        'animation-delay:' + delay + 's'
      ].join(';');

      particleMount.appendChild(pb);
    }

    function initMellowRaftAnimation(root) {
      root = root || document;

      var sections = Array.prototype.slice.call(root.querySelectorAll('[data-mellow-raft-section]'));
      if (root.matches && root.matches('[data-mellow-raft-section]')) {
        sections.unshift(root);
      }

      sections.forEach(function (section) {
        if (section.dataset.mellowRaftInitialized === 'true') return;
        section.dataset.mellowRaftInitialized = 'true';

        var mechanism = section.querySelector('[data-mellow-raft-mechanism]');
        var particleMount = section.querySelector('[data-mellow-raft-particles]');
        var replay = section.querySelector('[data-mellow-raft-replay]');
        var pause = section.querySelector('[data-mellow-raft-pause]');
        var speed = section.querySelector('[data-mellow-raft-speed]');
        var paused = false;
        var speedIndex = 0;

        if (particleMount && !particleMount.dataset.generated) {
          if (!particleMount.querySelector('.pb')) {
            for (var i = 0; i < 72; i += 1) {
              buildMellowRaftParticle(particleMount, i);
            }
          }

          particleMount.dataset.generated = 'true';
        }

        var restartAnimation = function () {
          if (!mechanism) return;

          var device = mechanism.parentElement;
          device.classList.remove('restart');

          mechanism.style.display = 'none';
          void mechanism.offsetHeight;
          mechanism.style.display = '';

          device.classList.add('restart');

          window.setTimeout(function () {
            device.classList.remove('restart');
          }, 220);
        };

        if (replay) {
          replay.addEventListener('click', restartAnimation);
        }

        if (pause) {
          pause.addEventListener('click', function () {
            paused = !paused;
            section.classList.toggle('paused', paused);
            pause.textContent = paused ? 'Play' : 'Pause';
          });
        }

        if (speed) {
          speed.addEventListener('click', function () {
            speedIndex = (speedIndex + 1) % 3;

            if (speedIndex === 0) {
              section.style.setProperty('--duration', '10.6s');
              speed.textContent = 'Speed: normal';
            } else if (speedIndex === 1) {
              section.style.setProperty('--duration', '8.0s');
              speed.textContent = 'Speed: faster';
            } else {
              section.style.setProperty('--duration', '13.2s');
              speed.textContent = 'Speed: slower';
            }

            restartAnimation();
          });
        }
      });
    }

    document.addEventListener('DOMContentLoaded', function () {
      initMellowRaftAnimation();
    });

    document.addEventListener('shopify:section:load', function (event) {
      initMellowRaftAnimation(event.target);
    });

    initMellowRaftAnimation();
  })();
</script>

<script>
  (function () {
    var root = document.querySelector('.mellow-clinical-proof-{{ section.id }}[data-mellow-clinical-proof]');
    if (!root) return;

    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var revealItems = Array.prototype.slice.call(root.querySelectorAll('[data-mellow-reveal]'));
    var stepItems = Array.prototype.slice.call(root.querySelectorAll('[data-mellow-step]'));

    root.querySelectorAll('.mellow-reveal--stagger').forEach(function (group) {
      Array.prototype.slice.call(group.children).forEach(function (child, index) {
        child.style.setProperty('--mellow-stagger-index', index);
      });
    });

    root.querySelectorAll('.mellow-clinical-proof__symptom-grid, .mellow-clinical-proof__bar-visual, .mellow-clinical-proof__scale').forEach(function (group) {
      Array.prototype.slice.call(group.children).forEach(function (child, index) {
        child.style.setProperty('--mellow-stagger-index', index);
      });
    });

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      revealItems.forEach(function (item) { item.classList.add('is-visible'); });
      stepItems.forEach(function (item) { item.classList.add('is-active'); });
      return;
    }

    var revealObserver = new IntersectionObserver(function (entries, observer) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, {
      rootMargin: '0px 0px -12% 0px',
      threshold: 0.16
    });

    revealItems.forEach(function (item) { revealObserver.observe(item); });

    var stepObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
        } else {
          entry.target.classList.remove('is-active');
        }
      });
    }, {
      rootMargin: '-18% 0px -42% 0px',
      threshold: 0.32
    });

    stepItems.forEach(function (item) { stepObserver.observe(item); });
  })();
</script>

