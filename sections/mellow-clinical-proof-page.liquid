    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__evidence-strip span {
      border-right: 0;
      border-bottom: 1px solid var(--clinical-border);
    }

    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__evidence-strip span:last-child {
      border-bottom: 0;
    }
  }

  @keyframes mellowClinicalMobileDrift {
    from { transform: translate3d(0, 6px, 0) scale(0.99); }
    to { transform: translate3d(0, -6px, 0) scale(1.01); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mellow-clinical-proof-{{ section.id }} *,
    .mellow-clinical-proof-{{ section.id }} *::before,
    .mellow-clinical-proof-{{ section.id }} *::after {
      animation: none !important;
      scroll-behavior: auto !important;
      transition-duration: 0.001ms !important;
    }

    .mellow-clinical-proof-{{ section.id }} .mellow-reveal,
    .mellow-clinical-proof-{{ section.id }} .mellow-reveal--up,
    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__evidence-strip.mellow-reveal--stagger > span,
    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__symptom-grid > *,
    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__bar-row,
    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__scale-item {
      opacity: 1 !important;
      transform: none !important;
    }

    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__module:hover,
    .mellow-clinical-proof-{{ section.id }} .mellow-clinical-proof__button:hover {
      transform: none;
    }
  }

</style>

<script>
  (function () {
    var root = document.querySelector('.mellow-clinical-proof-{{ section.id }}[data-mellow-clinical-proof]');
    if (!root) return;

    var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var revealItems = Array.prototype.slice.call(root.querySelectorAll('[data-mellow-reveal]'));
    var stepItems = Array.prototype.slice.call(root.querySelectorAll('[data-mellow-step]'));

    root.querySelectorAll('.mellow-reveal--stagger').forEach(function (group) {
      Array.prototype.slice.call(group.children).forEach(function (child, index) {
        child.style.setProperty('--mellow-stagger-index', index);
      });
    });

    root.querySelectorAll('.mellow-clinical-proof__symptom-grid, .mellow-clinical-proof__bar-visual, .mellow-clinical-proof__scale').forEach(function (group) {
      Array.prototype.slice.call(group.children).forEach(function (child, index) {
        child.style.setProperty('--mellow-stagger-index', index);
      });
    });

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      revealItems.forEach(function (item) { item.classList.add('is-visible'); });
      stepItems.forEach(function (item) { item.classList.add('is-active'); });
      return;
    }

    var revealObserver = new IntersectionObserver(function (entries, observer) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      });
    }, {
      rootMargin: '0px 0px -12% 0px',
      threshold: 0.16
    });

    revealItems.forEach(function (item) { revealObserver.observe(item); });

    var stepObserver = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
        } else {
          entry.target.classList.remove('is-active');
        }
      });
    }, {
      rootMargin: '-18% 0px -42% 0px',
      threshold: 0.32
    });

    stepItems.forEach(function (item) { stepObserver.observe(item); });
  })();
</script>

