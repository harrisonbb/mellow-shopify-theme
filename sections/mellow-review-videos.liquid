{% comment %}
  Mellow review videos section.
  Hardcoded UGC testimonial cards using the locked Mellow global section system.
{% endcomment %}

<style>
  #MellowReviewVideos-{{ section.id }} {
    --mellow-review-forest: var(--mellow-forest, #123308);
    --mellow-review-forest-rgb: 18, 51, 8;
    padding-top: clamp(52px, 5vw, 76px);
    padding-bottom: clamp(52px, 5vw, 76px);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-ink, var(--mellow-review-forest));
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__layout {
    display: grid;
    grid-template-columns: minmax(360px, 0.72fr) minmax(0, 1fr);
    gap: clamp(44px, 4.4vw, 74px);
    align-items: start;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__left {
    max-width: 520px;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__heading {
    max-width: 520px;
    color: var(--mellow-review-forest);
    text-wrap: balance;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__text {
    max-width: 640px;
    margin-top: 22px;
    margin-bottom: clamp(20px, 2.1vw, 30px);
    color: rgba(var(--mellow-review-forest-rgb), 0.72);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-cue {
    display: flex;
    align-items: center;
    width: min(100%, 468px);
    margin: 0 0 clamp(24px, 2.4vw, 34px);
    padding: 12px 16px 12px 12px;
    gap: 14px;
    border: 1px solid rgba(var(--mellow-review-forest-rgb), 0.1);
    border-radius: 8px;
    background: rgba(252, 251, 247, 0.78);
    box-shadow: 0 14px 36px rgba(var(--mellow-review-forest-rgb), 0.06);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-frame {
    flex: 0 0 58px;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 8px;
    background: var(--mellow-card-cream, #F8F4EC);
    overflow: hidden;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-image {
    width: 38px;
    max-height: 54px;
    object-fit: contain;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-label {
    margin: 0 0 4px;
    color: var(--mellow-orange-red, #D04A2A);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-copy {
    margin: 0;
    color: rgba(var(--mellow-review-forest-rgb), 0.88);
    font-size: clamp(14px, 0.96vw, 15px);
    font-weight: 650;
    line-height: 1.35;
    text-wrap: balance;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__cta {
    --mellow-section-cta-width: clamp(230px, 14.5vw, 264px);
    box-shadow: 0 14px 30px rgba(var(--mellow-review-forest-rgb), 0.14);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__cta .mellow-section-cta__arrow {
    display: inline-flex;
    margin-left: 10px;
    transform: translateY(-1px);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__proof {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 600px;
    margin: 0;
    padding: 0;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__proof span {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    gap: 8px;
    border: 1px solid rgba(var(--mellow-review-forest-rgb), 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.6);
    color: rgba(var(--mellow-review-forest-rgb), 0.78);
    font-size: 12px;
    font-weight: 650;
    line-height: 1.2;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__proof span::before {
    content: "";
    flex: 0 0 auto;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--mellow-orange-red, #D04A2A);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__cta-note {
    margin: 0;
    color: rgba(var(--mellow-review-forest-rgb), 0.72);
    font-size: 14px;
    font-weight: 650;
    line-height: 1.35;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(24px, 2.2vw, 34px);
    align-items: start;
    width: 100%;
    margin: 0;
    padding: 0;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card {
    display: block;
    width: 100%;
    min-width: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    color: var(--mellow-review-forest);
    overflow: visible;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    height: clamp(360px, 33vw, 500px);
    overflow: hidden;
    border-radius: 8px;
    isolation: isolate;
    background:
      radial-gradient(circle at 34% 22%, rgba(248, 244, 236, 0.26), transparent 28%),
      linear-gradient(155deg, rgba(var(--mellow-review-forest-rgb), 0.98), rgba(var(--mellow-review-forest-rgb), 0.88) 54%, rgba(248, 244, 236, 0.2));
    box-shadow: 0 18px 46px rgba(var(--mellow-review-forest-rgb), 0.11);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media::before,
  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    border-radius: inherit;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media::before {
    background:
      linear-gradient(180deg, rgba(0, 35, 2, 0.16) 0%, rgba(0, 35, 2, 0.02) 40%, rgba(0, 28, 1, 0.42) 100%),
      linear-gradient(0deg, rgba(var(--mellow-review-forest-rgb), 0.18), transparent 58%);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media::after {
    inset: auto 0 0;
    height: 32%;
    border-radius: 0 0 8px 8px;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 28, 1, 0.38) 100%);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__image {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 42%;
    filter: saturate(0.95) contrast(1.03);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card:nth-child(2) .mellow-review-videos__image {
    object-position: center 38%;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card:nth-child(3) .mellow-review-videos__image {
    object-position: center 44%;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card:nth-child(2) .mellow-review-videos__media {
    background:
      radial-gradient(circle at 72% 24%, rgba(208, 74, 42, 0.2), transparent 30%),
      linear-gradient(145deg, rgba(248, 244, 236, 0.2), rgba(var(--mellow-review-forest-rgb), 0.96) 48%, rgba(var(--mellow-review-forest-rgb), 0.72));
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card:nth-child(3) .mellow-review-videos__media {
    background:
      radial-gradient(circle at 28% 26%, rgba(248, 244, 236, 0.28), transparent 30%),
      linear-gradient(155deg, rgba(23, 55, 18, 0.96), rgba(61, 107, 140, 0.34) 58%, rgba(208, 74, 42, 0.18));
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__play {
    position: relative;
    z-index: 3;
    display: inline-flex;
    width: clamp(62px, 5vw, 78px);
    height: clamp(62px, 5vw, 78px);
    align-items: center;
    justify-content: center;
    border: 2px solid rgba(248, 244, 236, 0.9);
    border-radius: 999px;
    background: rgba(var(--mellow-review-forest-rgb), 0.22);
    color: var(--mellow-card-cream, #F8F4EC);
    box-shadow: 0 12px 34px rgba(0, 28, 1, 0.22);
    backdrop-filter: blur(2px);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__play svg {
    width: 24px;
    height: 24px;
    margin-left: 4px;
    fill: currentColor;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__duration {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 11px;
    border-radius: 999px;
    background: rgba(var(--mellow-review-forest-rgb), 0.82);
    color: var(--mellow-card-cream, #F8F4EC);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__content {
    padding: 20px 0 0;
    color: var(--mellow-review-forest);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__kicker {
    margin: 0 0 10px;
    color: rgba(var(--mellow-review-forest-rgb), 0.78);
    font-size: 15px;
    line-height: 1.25;
    font-weight: 500;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__divider {
    display: block;
    width: 26px;
    height: 2px;
    margin-bottom: 14px;
    background: var(--mellow-orange-red, #D04A2A);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__content .mellow-card-title {
    color: var(--mellow-review-forest);
    margin-bottom: 12px;
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__quote {
    color: rgba(var(--mellow-review-forest-rgb), 0.86);
    font-size: clamp(16px, 1.06vw, 18px);
  }

  #MellowReviewVideos-{{ section.id }} .mellow-review-videos__meta {
    margin: 16px 0 0;
    color: rgba(var(--mellow-review-forest-rgb), 0.66);
    font-size: 13px;
    font-weight: 650;
    line-height: 1.35;
  }

  @media screen and (max-width: 989px) {
    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__layout {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__grid {
      display: flex;
      gap: clamp(18px, 4vw, 28px);
      margin-inline: calc(-1 * var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px)));
      padding-inline: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
      padding-bottom: 12px;
      overflow-x: auto;
      overflow-y: visible;
      scroll-padding-inline: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
      scroll-snap-type: x proximity;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__grid::-webkit-scrollbar {
      display: none;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card {
      flex: 0 0 min(74vw, 310px);
      scroll-snap-align: start;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__media {
      height: auto;
      aspect-ratio: 9 / 16;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-cue {
      width: min(100%, 560px);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__cta {
      width: 100%;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__product-cue {
      align-items: flex-start;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__proof span {
      min-height: 30px;
      padding-inline: 10px;
    }

    #MellowReviewVideos-{{ section.id }} .mellow-review-videos__card {
      flex-basis: min(82vw, 300px);
    }
  }
</style>

<section
  id="MellowReviewVideos-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-review-videos color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-section-axis mellow-review-videos__inner">
    <div class="mellow-review-videos__layout">
      <div class="mellow-review-videos__left">
        <p class="mellow-eyebrow mellow-review-videos__eyebrow">REAL PEOPLE. REAL ROUTINES.</p>
        <h2 class="mellow-section-heading mellow-review-videos__heading">For anyone who<br>thinks twice<br>before eating.</h2>
        <p class="mellow-section-text mellow-review-videos__text">Short, honest moments from people using Mellow after meals, before bed, and when reflux tends to show up.</p>

        <div class="mellow-review-videos__product-cue" aria-label="Mellow single-serve pouch">
          <span class="mellow-review-videos__product-frame" aria-hidden="true">
            <img
              src="{{ 'mellow-reflux-calm-pouch.png' | asset_url }}"
              alt=""
              class="mellow-review-videos__product-image"
              width="520"
              height="649"
              loading="lazy"
              decoding="async"
            >
          </span>
          <div class="mellow-review-videos__product-content">
            <p class="mellow-review-videos__product-label">Single-serve pouch</p>
            <p class="mellow-review-videos__product-copy">One pouch after meals or before bed. No bottle, no chalky chew.</p>
          </div>
        </div>

        <div class="mellow-review-videos__actions">
          <a class="mellow-section-cta mellow-section-cta--primary-forest mellow-review-videos__cta" href="/products/mellow-reflux-relief-gel">
            <span class="mellow-section-cta__label">Try Mellow</span>
            <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
          </a>
          <p class="mellow-review-videos__cta-note">30 single-serve pouches. No subscription to cancel.</p>
          <p class="mellow-review-videos__proof" aria-label="Mellow purchase details">
            <span>30-day guarantee</span>
            <span>Secure checkout</span>
            <span>HSA/FSA eligible</span>
          </p>
        </div>
      </div>

      <div class="mellow-review-videos__grid">
        {%- liquid
          assign review_cards = 'After dinner relief|Easy after meals|“One pouch after dinner. It became automatic fast.”|Rachel B. · After-meal reflux|0:18|mellow-ugc-after-dinner.jpg||Before bed routine|Simple before sleep|“Before bed is simple now: one pouch, no measuring.”|Priya N. · Nighttime reflux|0:22|mellow-ugc-before-bed.jpg||On-the-go support|Fits real life|“It fits in my bag, so I can keep moving.”|Michael T. · Travel & workdays|0:15|mellow-ugc-on-the-go.jpg' | split: '||'
        -%}

        {%- for card in review_cards -%}
          {%- liquid
            assign card_parts = card | split: '|'
            assign card_kicker = card_parts[0]
            assign card_title = card_parts[1]
            assign card_quote = card_parts[2]
            assign card_meta = card_parts[3]
            assign card_duration = card_parts[4]
            assign card_fallback = card_parts[5]
            assign image_key = 'card_' | append: forloop.index | append: '_image'
            assign card_image = section.settings[image_key]
            assign card_image_alt = card_image.alt | default: card_title | strip
          -%}
          <article class="mellow-review-videos__card">
            <div class="mellow-review-videos__media{% if card_image != blank %} mellow-review-videos__media--has-image{% endif %}" aria-label="Video still for {{ card_title | escape }}">
              {%- if card_image != blank -%}
                {{ card_image | image_url: width: 1000 | image_tag: loading: 'lazy', decoding: 'async', class: 'mellow-review-videos__image', sizes: '(min-width: 990px) 24vw, 100vw', widths: '360, 520, 720, 900, 1000', alt: card_image_alt }}
              {%- else -%}
                <img
                  src="{{ card_fallback | asset_url }}"
                  alt="{{ card_title | escape }}"
                  class="mellow-review-videos__image"
                  width="941"
                  height="1672"
                  loading="lazy"
                  decoding="async"
                >
              {%- endif -%}
              <span class="mellow-review-videos__duration">{{ card_duration | escape }}</span>
              <span class="mellow-review-videos__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                  <path d="M8 5v14l11-7L8 5Z" />
                </svg>
              </span>
            </div>

            <div class="mellow-review-videos__content">
              <p class="mellow-review-videos__kicker">{{ card_kicker | escape }}</p>
              <span class="mellow-review-videos__divider" aria-hidden="true"></span>
              <h3 class="mellow-card-title">{{ card_title | escape }}</h3>
              <p class="mellow-card-copy mellow-review-videos__quote">{{ card_quote | escape }}</p>
              <p class="mellow-review-videos__meta">{{ card_meta | escape }}</p>
            </div>
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow review videos",
  "tag": "section",
  "class": "section section-mellow-review-videos",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Video stills"
    },
    {
      "type": "image_picker",
      "id": "card_1_image",
      "label": "After dinner relief image"
    },
    {
      "type": "image_picker",
      "id": "card_2_image",
      "label": "Before bed routine image"
    },
    {
      "type": "image_picker",
      "id": "card_3_image",
      "label": "On-the-go support image"
    }
  ],
  "presets": [
    {
      "name": "Mellow review videos"
    }
  ]
}
{% endschema %}
