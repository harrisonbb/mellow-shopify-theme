{% comment %}
  Mellow PPI support section.
  Educational barrier-support editorial section using the global Mellow section system.
{% endcomment %}

{%- liquid
  assign cta_link = section.settings.cta_link | default: '/products/mellow-reflux-relief-gel'
-%}

<style>
  #MellowPpiSupport-{{ section.id }} {
    --mellow-ppi-forest: var(--mellow-forest, #223216);
    --mellow-ppi-ivory: var(--mellow-ivory, #F0EBE0);
    --mellow-ppi-card: var(--mellow-card-cream, #F8F4EC);
    --mellow-ppi-border: var(--mellow-card-border, rgba(34, 50, 22, 0.12));
    --mellow-ppi-muted: color-mix(in srgb, var(--mellow-ppi-forest) 68%, transparent);
    --mellow-ppi-soft: color-mix(in srgb, var(--mellow-ppi-forest) 50%, transparent);
    background: var(--mellow-ppi-ivory);
    color: var(--mellow-ppi-forest);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.62fr);
    gap: var(--mellow-feature-gap, clamp(42px, 7vw, 112px));
    align-items: center;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__copy {
    max-width: 790px;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__eyebrow {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__heading {
    max-width: 760px;
    color: var(--mellow-ppi-forest);
    text-wrap: balance;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__body {
    max-width: 650px;
    color: var(--mellow-ppi-muted);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__emphasis {
    max-width: 560px;
    margin: clamp(24px, 2.2vw, 34px) 0 0;
    padding: clamp(18px, 1.7vw, 24px) 0 clamp(18px, 1.7vw, 24px) clamp(18px, 1.7vw, 26px);
    border-left: 3px solid var(--mellow-orange-red, #D04A2A);
    color: var(--mellow-ppi-forest);
    font-family: var(--mellow-font-display, var(--font-heading-family)) !important;
    font-size: clamp(26px, 2.2vw, 36px);
    font-weight: var(--mellow-heading-weight, 600);
    line-height: 1.02;
    letter-spacing: var(--mellow-heading-tracking, -0.028em);
    text-wrap: balance;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__actions {
    margin-top: clamp(24px, 2.2vw, 34px);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__cta-wrap {
    justify-content: flex-start;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__cta {
    --mellow-section-cta-bg: var(--mellow-ppi-forest);
    --mellow-section-cta-border: var(--mellow-ppi-forest);
    --mellow-section-cta-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__disclaimer {
    max-width: 620px;
    margin: clamp(18px, 1.6vw, 22px) 0 0;
    padding-top: clamp(10px, 1vw, 14px);
    border-top: 1px solid color-mix(in srgb, var(--mellow-ppi-forest) 12%, transparent);
    color: var(--mellow-ppi-soft);
    font-size: clamp(12px, 0.9vw, 13px);
    line-height: 1.5;
    letter-spacing: 0;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__cards {
    display: grid;
    gap: clamp(14px, 1.3vw, 20px);
    min-width: 0;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(72px, 0.24fr) minmax(0, 1fr);
    gap: clamp(16px, 1.6vw, 24px);
    align-items: start;
    min-width: 0;
    padding: clamp(22px, 2.1vw, 32px);
    overflow: hidden;
    border: 1px solid var(--mellow-ppi-border);
    border-radius: min(var(--mellow-radius-card, 28px), 26px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.34), transparent 42%),
      var(--mellow-ppi-card);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
    isolation: isolate;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(2) {
    margin-left: clamp(20px, 3vw, 46px);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(3) {
    margin-left: clamp(8px, 1.5vw, 24px);
    margin-right: clamp(16px, 2vw, 34px);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: color-mix(in srgb, var(--mellow-orange-red, #D04A2A) 82%, var(--mellow-ppi-ivory));
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(2)::before {
    background: color-mix(in srgb, var(--mellow-science-blue, #3D6B8C) 82%, var(--mellow-ppi-ivory));
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(3)::before {
    background: var(--mellow-ppi-forest);
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    min-height: 36px;
    padding: 10px 12px;
    border: 1px solid color-mix(in srgb, var(--mellow-ppi-forest) 13%, transparent);
    border-radius: var(--mellow-radius-pill, 999px);
    background: rgba(252, 251, 247, 0.54);
    color: var(--mellow-ppi-forest);
    font-size: clamp(10px, 0.72vw, 12px);
    font-weight: 750;
    line-height: 1;
    letter-spacing: 0.12em;
    text-align: center;
    text-transform: uppercase;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-copy {
    min-width: 0;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-title {
    color: var(--mellow-ppi-forest);
    font-size: clamp(23px, 1.75vw, 30px);
    text-wrap: balance;
  }

  #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-body {
    max-width: 440px;
    margin-top: clamp(8px, 0.85vw, 12px);
    color: var(--mellow-ppi-muted);
  }

  @media screen and (max-width: 989px) {
    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__layout {
      grid-template-columns: 1fr;
      gap: var(--mellow-section-content-gap-compact, clamp(26px, 2.4vw, 40px));
      align-items: start;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__copy {
      max-width: 760px;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__cards {
      max-width: 760px;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card,
    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(2),
    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card:nth-child(3) {
      margin-left: 0;
      margin-right: 0;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__body {
      max-width: 360px;
      font-size: 16px;
      line-height: 1.45;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__emphasis {
      max-width: 360px;
      font-size: clamp(25px, 7vw, 31px);
      line-height: 1.04;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card {
      grid-template-columns: 1fr;
      gap: clamp(12px, 3vw, 16px);
      padding: clamp(22px, 5.8vw, 28px);
      border-radius: min(var(--mellow-radius-card, 28px), 24px);
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-label {
      justify-self: start;
    }

    #MellowPpiSupport-{{ section.id }} .mellow-ppi-support__card-body {
      max-width: 100%;
    }
  }
</style>

<section
  id="MellowPpiSupport-{{ section.id }}"
  class="mellow-section-standard mellow-ppi-support color-{{ section.settings.color_scheme }}"
  {% if section.settings.heading != blank %}aria-labelledby="MellowPpiSupportHeading-{{ section.id }}"{% endif %}
>
  <div class="mellow-section-axis mellow-ppi-support__inner">
    <div class="mellow-ppi-support__layout">
      <div class="mellow-ppi-support__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-ppi-support__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 id="MellowPpiSupportHeading-{{ section.id }}" class="mellow-section-heading mellow-ppi-support__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <p class="mellow-section-text mellow-ppi-support__body">{{ section.settings.body | escape }}</p>
        {%- endif -%}

        {%- if section.settings.emphasis_line != blank -%}
          <p class="mellow-ppi-support__emphasis">{{ section.settings.emphasis_line | escape | newline_to_br }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="mellow-ppi-support__actions">
            <div class="mellow-section-cta-wrap mellow-ppi-support__cta-wrap">
              <a class="mellow-section-cta mellow-ppi-support__cta" href="{{ cta_link }}">
                <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.disclaimer != blank -%}
          <p class="mellow-ppi-support__disclaimer">{{ section.settings.disclaimer | escape | newline_to_br }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-ppi-support__cards" aria-label="How acid reduction and barrier support work differently">
        <article class="mellow-ppi-support__card" aria-labelledby="MellowPpiSupportCard1-{{ section.id }}">
          <span class="mellow-ppi-support__card-label">PPI</span>
          <div class="mellow-ppi-support__card-copy">
            <h3 id="MellowPpiSupportCard1-{{ section.id }}" class="mellow-card-title mellow-ppi-support__card-title">{{ section.settings.card_1_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ppi-support__card-body">{{ section.settings.card_1_body | escape }}</p>
          </div>
        </article>

        <article class="mellow-ppi-support__card" aria-labelledby="MellowPpiSupportCard2-{{ section.id }}">
          <span class="mellow-ppi-support__card-label">Barrier</span>
          <div class="mellow-ppi-support__card-copy">
            <h3 id="MellowPpiSupportCard2-{{ section.id }}" class="mellow-card-title mellow-ppi-support__card-title">{{ section.settings.card_2_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ppi-support__card-body">{{ section.settings.card_2_body | escape }}</p>
          </div>
        </article>

        <article class="mellow-ppi-support__card" aria-labelledby="MellowPpiSupportCard3-{{ section.id }}">
          <span class="mellow-ppi-support__card-label">Together</span>
          <div class="mellow-ppi-support__card-copy">
            <h3 id="MellowPpiSupportCard3-{{ section.id }}" class="mellow-card-title mellow-ppi-support__card-title">{{ section.settings.card_3_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ppi-support__card-body">{{ section.settings.card_3_body | escape }}</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PPI Support / Barrier Support",
  "tag": "section",
  "class": "section section-mellow-ppi-support",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "ACID REDUCTION + BARRIER SUPPORT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Taking a PPI? Think barrier, not replacement."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "PPIs help lower acid production over time. MellowRaft™ works differently: it forms a floating alginate barrier designed to help keep reflux from rising when symptoms still break through."
    },
    {
      "type": "textarea",
      "id": "emphasis_line",
      "label": "Emphasis line",
      "default": "Less acid is one strategy.\nA better barrier is another."
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Card 1 title",
      "default": "PPIs reduce acid"
    },
    {
      "type": "textarea",
      "id": "card_1_body",
      "label": "Card 1 body",
      "default": "Proton pump inhibitors help lower how much acid your stomach produces — but they can take time to reach their full effect."
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Card 2 title",
      "default": "Mellow forms a barrier"
    },
    {
      "type": "textarea",
      "id": "card_2_body",
      "label": "Card 2 body",
      "default": "MellowRaft™ uses alginate raft technology to create a floating physical barrier above stomach contents."
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Card 3 title",
      "default": "Different jobs, same goal"
    },
    {
      "type": "textarea",
      "id": "card_3_body",
      "label": "Card 3 body",
      "default": "One approach reduces acid production. The other supports the moments after meals, at night, or when reflux still breaks through."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Mellow is not a replacement for prescribed medication. Do not stop or change reflux medication without speaking with your clinician."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/products/mellow-reflux-relief-gel"
    }
  ],
  "presets": [
    {
      "name": "PPI Support / Barrier Support"
    }
  ]
}
{% endschema %}
