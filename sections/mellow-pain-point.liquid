{% comment %}
  Mellow — Plans / Pain Points Grid
  Rebuilt:
  - Same rounded cinematic background/panel system as How It Works
  - Header left axis matched to Science page
  - Header font size matched to How It Works/global major header scale
  - Unique class namespace so it won't collide with How It Works or Science
  - 6 centered icon benefits
{% endcomment %}

<section
  class="mellow-plans-grid mellow-plans-grid-{{ section.id }}"
  id="mellow-plans-grid-{{ section.id }}"
>
  <div class="mellow-plans-grid__inner">

    <header class="mellow-plans-grid__header">
      <div class="mellow-plans-grid__header-copy">
        <p class="mellow-plans-grid__eyebrow">
          {{ section.settings.eyebrow | default: "Reflux again?" }}
        </p>

        <h2 class="mellow-plans-grid__heading mellow-section-heading">
          {{ section.settings.heading | default: "Reflux doesn’t have to ruin your plans." }}
        </h2>

        <p class="mellow-plans-grid__subheading">
          {{ section.settings.subheading | default: "Most reflux relief is reactive. Mellow is designed to form a protective raft before acid has a chance to rise." }}
        </p>
      </div>
    </header>

    <div class="mellow-plans-grid__items" aria-label="Mellow benefits">

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <circle cx="12" cy="12" r="3"></circle>
            <path d="M12 2.5v3"></path>
            <path d="M12 18.5v3"></path>
            <path d="M4.6 4.6l2.1 2.1"></path>
            <path d="M17.3 17.3l2.1 2.1"></path>
            <path d="M2.5 12h3"></path>
            <path d="M18.5 12h3"></path>
            <path d="M4.6 19.4l2.1-2.1"></path>
            <path d="M17.3 6.7l2.1-2.1"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>Forms in minutes</h3>
        <p>A protective raft begins forming shortly after contact with stomach acid.</p>
      </article>

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M5 8h14"></path>
            <path d="M7.5 11h9"></path>
            <path d="M10 14h4"></path>
            <path d="M11.4 17h1.2"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>Stops acid from rising</h3>
        <p>Creates a floating barrier at the top of stomach contents, where reflux starts.</p>
      </article>

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <circle cx="12" cy="12" r="7"></circle>
            <path d="M12 8v4l3 2"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>Holds for hours</h3>
        <p>Designed to support the post-meal and nighttime reflux window.</p>
      </article>

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <rect x="8" y="4" width="8" height="16" rx="1.6"></rect>
            <path d="M10 8h4"></path>
            <path d="M10 12h4"></path>
            <path d="M10 16h4"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>No chalky tablets</h3>
        <p>A smooth single-serve pouch. No chewing, measuring, or mess.</p>
      </article>

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M7 4v16"></path>
            <path d="M12 4v16"></path>
            <path d="M17 4v16"></path>
            <path d="M7 8h4"></path>
            <path d="M13 8h4"></path>
            <path d="M7 14h4"></path>
            <path d="M13 14h4"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>Made for real moments</h3>
        <p>After dinner, before bed, restaurants, travel, and late nights.</p>
      </article>

      <article class="mellow-plans-grid__item">
        <div class="mellow-plans-grid__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path d="M12 3.5 18 6v5.5c0 4-2.4 7-6 9-3.6-2-6-5-6-9V6l6-2.5Z"></path>
            <path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <span class="mellow-plans-grid__accent"></span>
        <h3>Non-PPI support</h3>
        <p>Mechanical raft-forming support without relying on acid suppression alone.</p>
      </article>

    </div>

    {% if section.settings.button_label != blank %}
      <div class="mellow-plans-grid__cta-row">
        <a href="{{ section.settings.button_link }}" class="mellow-plans-grid__button">
          <span>{{ section.settings.button_label }}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* =========================================================
     MELLOW PLANS GRID — ROUNDED CINEMATIC PANEL
     Left axis matched to Science page
     ========================================================= */

  #shopify-section-{{ section.id }},
  .shopify-section:has(#mellow-plans-grid-{{ section.id }}) {
    background: #FFFFFF !important;
    background-color: #FFFFFF !important;
    background-image: none !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    overflow: visible !important;
  }

  #mellow-plans-grid-{{ section.id }},
  #mellow-plans-grid-{{ section.id }} * {
    box-sizing: border-box;
  }

  #mellow-plans-grid-{{ section.id }} {
    --mellow-forest: #1A2D10;
    --mellow-orange: #D04A2A;
    --mellow-orange-hover: #B93E24;
    --mellow-ivory: #F0EBE0;
    --mellow-page: #FFFFFF;
    --mellow-blue: #3D6B8C;

    --plans-body: rgba(240, 235, 224, 0.76);

    /* MATCHES SCIENCE PAGE LEFT AXIS */
    --plans-side-pad: clamp(108px, 8.5vw, 172px);

    /* SAME ROUNDED PANEL SYSTEM AS HOW IT WORKS */
    --plans-frame-y: 10px;
    --plans-radius: 20px;

    width: 100vw !important;
    max-width: 100vw !important;
    margin-left: calc(50% - 50vw) !important;
    margin-right: calc(50% - 50vw) !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;

    position: relative !important;
    overflow: hidden !important;
    isolation: isolate !important;
    color: var(--mellow-ivory) !important;

    background: #FFFFFF !important;
    background-color: #FFFFFF !important;
    background-image: none !important;

    min-height: calc(100vh + 90px) !important;

    padding-top: calc(var(--plans-frame-y) + clamp(66px, 5vw, 92px)) !important;
    padding-bottom: calc(var(--plans-frame-y) + clamp(76px, 8vh, 126px)) !important;
    padding-left: var(--plans-side-pad) !important;
    padding-right: var(--plans-side-pad) !important;
  }

  #mellow-plans-grid-{{ section.id }}::before {
    content: "" !important;
    display: block !important;
    position: absolute !important;
    z-index: 0 !important;
    pointer-events: none !important;

    top: var(--plans-frame-y) !important;
    right: 0 !important;
    bottom: var(--plans-frame-y) !important;
    left: 0 !important;

    border-radius: var(--plans-radius) !important;

    background:
      radial-gradient(circle at 14% 26%, rgba(61, 107, 140, 0.42) 0%, rgba(61, 107, 140, 0.22) 26%, rgba(61, 107, 140, 0.04) 56%, rgba(61, 107, 140, 0) 72%),
      radial-gradient(circle at 80% 36%, rgba(208, 74, 42, 0.13) 0%, rgba(208, 74, 42, 0.055) 28%, rgba(208, 74, 42, 0) 62%),
      radial-gradient(circle at 50% 92%, rgba(208, 74, 42, 0.11) 0%, rgba(208, 74, 42, 0.035) 26%, rgba(208, 74, 42, 0) 60%),
      linear-gradient(112deg, #143F32 0%, #123A24 34%, #102F1D 62%, #0B2416 100%) !important;
  }

  #mellow-plans-grid-{{ section.id }}::after {
    content: "" !important;
    display: block !important;
    position: absolute !important;
    z-index: 1 !important;
    pointer-events: none !important;

    top: var(--plans-frame-y) !important;
    right: 0 !important;
    bottom: var(--plans-frame-y) !important;
    left: 0 !important;

    border-radius: var(--plans-radius) !important;

    background:
      linear-gradient(90deg, rgba(9, 35, 27, 0.10) 0%, rgba(9, 35, 27, 0) 34%, rgba(5, 20, 12, 0.16) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035) 0%, rgba(255, 255, 255, 0) 38%),
      radial-gradient(circle at 50% 118%, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0) 62%) !important;
  }

  #mellow-plans-grid-{{ section.id }} > * {
    position: relative !important;
    z-index: 2 !important;
  }

  /* MATCHES SCIENCE PAGE: no centered max-width inner, left starts at section padding */
  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__inner {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    opacity: 1 !important;
    filter: none !important;
    box-shadow: none !important;
  }

  /* MATCHES SCIENCE PAGE TOP LEFT AXIS */
  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header {
    display: block !important;
    width: 100% !important;
    max-width: 980px !important;

    margin-top: 0 !important;
    margin-right: auto !important;
    margin-bottom: clamp(70px, 7.4vh, 104px) !important;
    margin-left: 0 !important;

    padding: 0 !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    opacity: 1 !important;
    filter: none !important;
    box-shadow: none !important;
    text-align: left !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header-copy {
    display: block !important;
    width: 100% !important;
    max-width: 880px !important;
    margin: 0 !important;
    padding: 0 !important;
    text-align: left !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__eyebrow {
    display: block !important;
    margin: 0 0 14px !important;
    padding: 0 !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body, system-ui, sans-serif) !important;
    font-size: 0.74rem !important;
    line-height: 1 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    font-weight: 850 !important;

    text-align: left !important;
    max-width: none !important;
  }

  /* Header size matched to How It Works / global major header scale */
  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__heading {
    display: block !important;
    margin: 0 !important;
    padding: 0 !important;

    width: 100% !important;
    max-width: 980px !important;

    color: var(--mellow-ivory) !important;
    font-family: var(--font-heading, Georgia, serif) !important;
    font-size: var(--mellow-major-header-size, clamp(2.55rem, 3.65vw, 4.2rem)) !important;
    line-height: var(--mellow-major-header-line, 1.16) !important;
    letter-spacing: var(--mellow-major-header-track, 0.012em) !important;
    font-weight: var(--mellow-major-header-weight, 400) !important;
    font-variation-settings: "opsz" 72, "wght" 400 !important;

    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__subheading {
    display: block !important;

    max-width: 620px !important;
    margin: 16px 0 0 !important;
    padding: 0 !important;

    color: var(--plans-body) !important;
    font-family: var(--font-body, system-ui, sans-serif) !important;
    font-size: clamp(1rem, 1.05vw, 1.12rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.01em !important;

    text-align: left !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__items {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    column-gap: clamp(76px, 9vw, 150px) !important;
    row-gap: clamp(70px, 7.8vw, 104px) !important;
    align-items: start !important;
    justify-items: center !important;
    width: 100% !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__item {
    width: 100% !important;
    max-width: 370px !important;
    margin: 0 auto !important;
    padding: 0 !important;

    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: flex-start !important;

    text-align: center !important;
    background: transparent !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__icon {
    width: 78px !important;
    height: 78px !important;
    border-radius: 999px !important;

    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    margin: 0 auto 22px !important;

    color: rgba(240, 235, 224, 0.88) !important;
    background: rgba(240, 235, 224, 0.09) !important;
    border: 1px solid rgba(240, 235, 224, 0.20) !important;

    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.10),
      0 18px 40px rgba(0, 0, 0, 0.14) !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__icon svg {
    width: 31px !important;
    height: 31px !important;
    display: block !important;
    fill: none !important;
    stroke: currentColor !important;
    stroke-width: 1.75 !important;
    stroke-linecap: round !important;
    stroke-linejoin: round !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__accent {
    display: block !important;
    width: 40px !important;
    height: 5px !important;
    border-radius: 999px !important;
    background: var(--mellow-orange) !important;
    margin: 0 auto 22px !important;
    box-shadow: 0 0 18px rgba(208, 74, 42, 0.14) !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__item h3 {
    margin: 0 0 12px !important;
    font-family: var(--font-heading, Georgia, serif) !important;
    font-size: clamp(1.34rem, 1.5vw, 1.72rem) !important;
    line-height: 1.12 !important;
    letter-spacing: -0.035em !important;
    font-weight: 500 !important;
    color: var(--mellow-ivory) !important;
    text-align: center !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__item p {
    max-width: 360px !important;
    margin: 0 auto !important;
    font-family: var(--font-body, system-ui, sans-serif) !important;
    font-size: clamp(0.98rem, 1.05vw, 1.1rem) !important;
    line-height: 1.5 !important;
    letter-spacing: -0.01em !important;
    color: var(--plans-body) !important;
    text-align: center !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__cta-row {
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    margin-top: clamp(66px, 7vh, 104px) !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 11px !important;

    min-height: 56px !important;
    padding: 0 34px !important;

    border-radius: 999px !important;
    border: 2px solid var(--mellow-orange) !important;

    background: var(--mellow-orange) !important;
    background-image: none !important;
    color: #FFFFFF !important;

    text-decoration: none !important;
    font-family: var(--font-body, system-ui, sans-serif) !important;
    font-size: 0.98rem !important;
    font-weight: 850 !important;
    letter-spacing: 0.01em !important;
    line-height: 1 !important;
    white-space: nowrap !important;

    box-shadow: 0 22px 58px rgba(208, 74, 42, 0.24) !important;

    transition:
      background 180ms ease,
      transform 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__button:hover {
    transform: translateY(-2px) !important;
    background: var(--mellow-orange-hover) !important;
    border-color: var(--mellow-orange-hover) !important;
    color: #FFFFFF !important;
    box-shadow: 0 28px 72px rgba(208, 74, 42, 0.30) !important;
  }

  @media screen and (min-width: 1500px) {
    #mellow-plans-grid-{{ section.id }} {
      /* MATCHES SCIENCE LARGE DESKTOP AXIS */
      --plans-side-pad: clamp(128px, 9vw, 196px) !important;

      min-height: calc(100vh + 130px) !important;

      padding-top: calc(var(--plans-frame-y) + 94px) !important;
      padding-bottom: calc(var(--plans-frame-y) + 118px) !important;
      padding-left: var(--plans-side-pad) !important;
      padding-right: var(--plans-side-pad) !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header {
      max-width: 980px !important;
      margin-left: 0 !important;
      margin-right: auto !important;
      margin-bottom: 104px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__items {
      column-gap: clamp(96px, 9vw, 170px) !important;
      row-gap: 112px !important;
    }
  }

  @media (max-width: 989px) {
    #mellow-plans-grid-{{ section.id }} {
      /* MATCHES SCIENCE TABLET AXIS */
      --plans-side-pad: 32px;
      --plans-frame-y: 10px;
      --plans-radius: 18px;

      min-height: calc(100vh + 120px) !important;

      padding-left: var(--plans-side-pad) !important;
      padding-right: var(--plans-side-pad) !important;
      padding-bottom: calc(var(--plans-frame-y) + 96px) !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header {
      max-width: 100% !important;
      margin-left: 0 !important;
      margin-right: auto !important;
      margin-bottom: 66px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header-copy {
      max-width: 100% !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__items {
      column-gap: 48px !important;
      row-gap: 70px !important;
    }
  }

  @media (max-width: 749px) {
    #mellow-plans-grid-{{ section.id }} {
      /* MATCHES SCIENCE MOBILE AXIS */
      --plans-side-pad: 20px;
      --plans-frame-y: 8px;
      --plans-radius: 16px;

      min-height: auto !important;

      padding-top: calc(var(--plans-frame-y) + 58px) !important;
      padding-bottom: calc(var(--plans-frame-y) + 80px) !important;
      padding-left: var(--plans-side-pad) !important;
      padding-right: var(--plans-side-pad) !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__header {
      max-width: 100% !important;
      margin-left: 0 !important;
      margin-right: auto !important;
      margin-bottom: 56px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__items {
      grid-template-columns: 1fr !important;
      gap: 52px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__item {
      max-width: 380px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__heading {
      font-size: var(--mellow-major-header-size, clamp(2.15rem, 8.5vw, 3.15rem)) !important;
      line-height: var(--mellow-major-header-line, 1.14) !important;
      letter-spacing: var(--mellow-major-header-track, 0.006em) !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__subheading {
      font-size: 1rem !important;
      line-height: 1.55 !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__icon {
      width: 70px !important;
      height: 70px !important;
      margin-bottom: 18px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__icon svg {
      width: 28px !important;
      height: 28px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__accent {
      margin-bottom: 18px !important;
    }

    #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__cta-row {
      margin-top: 56px !important;
    }
  }


  /* Use the approved hero heading typography for this major section headline. */
  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__heading {
    font-family: var(--mellow-heading-font) !important;
    font-size: var(--mellow-major-header-size) !important;
    font-weight: var(--mellow-major-header-weight, 500) !important;
    letter-spacing: var(--mellow-heading-letter-spacing) !important;
    line-height: var(--mellow-heading-line-height) !important;
    font-style: normal !important;
    font-variation-settings: var(--mellow-heading-font-variation-settings) !important;
  }

  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__heading em,
  #mellow-plans-grid-{{ section.id }} .mellow-plans-grid__heading i {
    font-family: var(--mellow-heading-italic-font) !important;
    font-style: italic !important;
    font-weight: var(--mellow-heading-italic-weight) !important;
    letter-spacing: var(--mellow-heading-italic-letter-spacing) !important;
    line-height: var(--mellow-heading-italic-line-height) !important;
    font-variation-settings: var(--mellow-heading-italic-font-variation-settings) !important;
  }
</style>

{% schema %}
{
  "name": "Mellow Plans Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Reflux again?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reflux doesn’t have to ruin your plans."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Most reflux relief is reactive. Mellow is designed to form a protective raft before acid has a chance to rise."
    },
