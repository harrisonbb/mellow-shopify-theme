<script>
  document.addEventListener('DOMContentLoaded', function () {
    var section = document.getElementById('mellow-science-clean-{{ section.id }}');
    if (!section) return;

    var cards = section.querySelectorAll('[data-science-card]');

    function closeCard(card) {
      if (!card) return;
      card.classList.remove('is-open');

      var toggle = card.querySelector('[data-science-toggle]');
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
    }

    function openCard(card) {
      if (!card) return;
      card.classList.add('is-open');

      var toggle = card.querySelector('[data-science-toggle]');
      if (toggle) toggle.setAttribute('aria-expanded', 'true');
    }

    function closeAllCards(exceptCard) {
      cards.forEach(function(card) {
        if (card !== exceptCard) {
          closeCard(card);
        }
      });
    }

    cards.forEach(function(card) {
      var toggle = card.querySelector('[data-science-toggle]');
      if (!toggle) return;

      toggle.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        var isOpen = card.classList.contains('is-open');

        closeAllCards(card);

        if (isOpen) {
          closeCard(card);
        } else {
          openCard(card);
        }
      });

      card.addEventListener('mouseleave', function () {
        closeCard(card);
      });
    });
  });
</script>

