{% comment %}
  Mellow Science — Clean Cards
  Updated:
  - Text is now INSIDE the image-wrap
  - Removed separate white content panel structurally
  - Full-image editorial cards
  - Strong scoped CSS with !important to beat mellow.css
{% endcomment %}

<section id="mellow-science-clean-{{ section.id }}" class="mellow-science-clean">
  <div class="mellow-science-clean__inner">

    <div class="mellow-science-clean__top">
      <div class="mellow-science-clean__top-left">
        <p class="mellow-science-clean__eyebrow">
          {{ section.settings.eyebrow | default: "The science" }}
        </p>

        <h2 class="mellow-science-clean__heading">
          {{ section.settings.heading | default: "The science behind raft-forming reflux relief." }}
        </h2>
      </div>

      <div class="mellow-science-clean__top-right">
        <p class="mellow-science-clean__subheading">
          {{ section.settings.subheading | default: "Mellow is built around alginate raft technology — a mechanical approach designed to help reduce reflux by forming a floating barrier in the stomach." }}
        </p>

        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: '/pages/science' }}"
            class="mellow-science-clean__button"
          >
            <span>{{ section.settings.button_label }}</span>
            <span aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="mellow-science-clean__cards">

      <article class="mellow-science-clean__card mellow-science-clean__card--step-1" data-science-card>
        <div class="mellow-science-clean__image-wrap">
          {% if section.settings.card_1_image != blank %}
            {{
              section.settings.card_1_image
              | image_url: width: 1400
              | image_tag:
                class: 'mellow-science-clean__image',
                loading: 'lazy',
                alt: 'Activate step illustration'
            }}
          {% else %}
            <div class="mellow-science-clean__image mellow-science-clean__image--placeholder"></div>
          {% endif %}

          <div class="mellow-science-clean__content">
            <div class="mellow-science-clean__meta">STEP 01</div>
            <h3 class="mellow-science-clean__card-title">Activate</h3>
            <p class="mellow-science-clean__card-subtitle">MEETS STOMACH ACID</p>

            <div class="mellow-science-clean__divider"></div>

            <button type="button" class="mellow-science-clean__toggle" data-science-toggle aria-expanded="false">
              <span>Learn more</span>
              <span class="mellow-science-clean__toggle-icon">+</span>
            </button>

            <div class="mellow-science-clean__expand" data-science-expand>
              <p>Stomach acid activates alginate gel formation and the carbonate/bicarbonate reaction.</p>
            </div>
          </div>
        </div>
      </article>

      <article class="mellow-science-clean__card mellow-science-clean__card--step-2" data-science-card>
        <div class="mellow-science-clean__image-wrap">
          {% if section.settings.card_2_image != blank %}
            {{
              section.settings.card_2_image
              | image_url: width: 1400
              | image_tag:
                class: 'mellow-science-clean__image',
                loading: 'lazy',
                alt: 'Form step illustration'
            }}
          {% else %}
            <div class="mellow-science-clean__image mellow-science-clean__image--placeholder"></div>
          {% endif %}

          <div class="mellow-science-clean__content">
            <div class="mellow-science-clean__meta">STEP 02</div>
            <h3 class="mellow-science-clean__card-title">Form</h3>
            <p class="mellow-science-clean__card-subtitle">BUILDS THE GEL RAFT</p>

            <div class="mellow-science-clean__divider"></div>

            <button type="button" class="mellow-science-clean__toggle" data-science-toggle aria-expanded="false">
              <span>Learn more</span>
              <span class="mellow-science-clean__toggle-icon">+</span>
            </button>

            <div class="mellow-science-clean__expand" data-science-expand>
              <p>Alginate forms a smooth gel layer, while calcium helps strengthen the network.</p>
            </div>
          </div>
        </div>
      </article>

      <article class="mellow-science-clean__card mellow-science-clean__card--step-3" data-science-card>
        <div class="mellow-science-clean__image-wrap">
          {% if section.settings.card_3_image != blank %}
            {{
              section.settings.card_3_image
              | image_url: width: 1400
              | image_tag:
                class: 'mellow-science-clean__image',
                loading: 'lazy',
                alt: 'Float and block step illustration'
            }}
          {% else %}
            <div class="mellow-science-clean__image mellow-science-clean__image--placeholder"></div>
          {% endif %}

          <div class="mellow-science-clean__content">
            <div class="mellow-science-clean__meta">STEP 03</div>
            <h3 class="mellow-science-clean__card-title">Shield</h3>
            <p class="mellow-science-clean__card-subtitle">BLOCKS REFLUX AT THE SOURCE</p>

            <div class="mellow-science-clean__divider"></div>

            <button type="button" class="mellow-science-clean__toggle" data-science-toggle aria-expanded="false">
              <span>Learn more</span>
              <span class="mellow-science-clean__toggle-icon">+</span>
            </button>

            <div class="mellow-science-clean__expand" data-science-expand>
              <p>The raft floats at the top, helping create a barrier where reflux starts.</p>
            </div>
          </div>
        </div>
      </article>

    </div>

    <div class="mellow-science-clean__footnote">
      {{ section.settings.footnote | default: "Based on published studies of alginate raft-forming formulations." }}
    </div>
  </div>
</section>

