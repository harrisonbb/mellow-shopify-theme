{% comment %}
  Mellow Expert Proof Carousel
  Remade to use global Mellow settings:
  - Uses global color, typography, spacing, radius, and CTA variables where available
  - Falls back to locked Mellow brand values
  - Keeps carousel, cards, images, quotes, arrows, JS, and schema intact
{% endcomment %}

<section class="mellow-expert-proof mellow-expert-proof-{{ section.id }}">
  <div class="mellow-expert-proof__inner">

    <div class="mellow-expert-proof__top">
      <div class="mellow-expert-proof__header-copy">
        <div class="mellow-expert-proof__rating">
          <span class="mellow-expert-proof__stars">★★★★★</span>
          <span>{{ section.settings.microproof }}</span>
        </div>

        <h2 class="mellow-expert-proof__heading mellow-heading-split">
          {% render 'mellow-split-heading', text: section.settings.heading %}
        </h2>
      </div>

      <div class="mellow-expert-proof__actions">
        {% if section.settings.cta_label != blank %}
          <a href="{{ section.settings.cta_link | default: '/pages/reviews' }}" class="mellow-expert-proof__button">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}

        <div class="mellow-expert-proof__arrows" aria-label="Review carousel controls">
          <button class="mellow-expert-proof__arrow mellow-expert-proof__arrow--prev" type="button" aria-label="Previous reviews">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="mellow-expert-proof__arrow mellow-expert-proof__arrow--next" type="button" aria-label="Next reviews">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="mellow-expert-proof__viewport">
      <div class="mellow-expert-proof__scroll" data-mellow-expert-carousel>

        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <article class="mellow-expert-proof__card" {{ block.shopify_attributes }}>
              <div class="mellow-expert-proof__image-wrap">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 900 | image_tag:
                    class: 'mellow-expert-proof__image',
                    loading: 'lazy',
                    alt: block.settings.name
                  }}
                {% else %}
                  <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--{{ forloop.index }}">
                    <span>{{ block.settings.initials }}</span>
                  </div>
                {% endif %}

                <div class="mellow-expert-proof__name">
                  {{ block.settings.name }}
                </div>
              </div>

              <div class="mellow-expert-proof__quote">
                <p>“{{ block.settings.quote }}”</p>
                <div class="mellow-expert-proof__meta">
                  {{ block.settings.role }}
                </div>
              </div>
            </article>
          {% endfor %}
        {% else %}

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--1"><span>MD</span></div>
              <div class="mellow-expert-proof__name">DR. FIRST LAST</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“Alginate raft technology is a useful mechanical approach because it focuses on helping reduce upward movement of stomach contents.”</p>
              <div class="mellow-expert-proof__meta">Licensed Physician</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--2"><span>RD</span></div>
              <div class="mellow-expert-proof__name">REGISTERED DIETITIAN</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that Mellow is built around a clear mechanism instead of just asking people to take another chalky tablet.”</p>
              <div class="mellow-expert-proof__meta">Digestive Health Nutrition</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--3"><span>GI</span></div>
              <div class="mellow-expert-proof__name">DIGESTIVE HEALTH REVIEW</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“A raft-forming gel format makes sense for people who want support after meals or before bed.”</p>
              <div class="mellow-expert-proof__meta">Claims Review</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--4"><span>AK</span></div>
              <div class="mellow-expert-proof__name">AFTER-DINNER USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I wanted something after dinner that did not feel like chewing through another chalky tablet.”</p>
              <div class="mellow-expert-proof__meta">Early Feedback</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--5"><span>NT</span></div>
              <div class="mellow-expert-proof__name">NIGHTTIME USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“The raft idea made more sense to me than just hoping another antacid would last through the night.”</p>
              <div class="mellow-expert-proof__meta">Before-Bed Routine</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--6"><span>TR</span></div>
              <div class="mellow-expert-proof__name">TRAVEL USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that it is a single pouch. It feels easier to keep in a bag than a bottle of tablets.”</p>
              <div class="mellow-expert-proof__meta">On-The-Go Relief</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--7"><span>PM</span></div>
              <div class="mellow-expert-proof__name">POST-MEAL USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“It fits the moment I actually need it: after eating, before reflux has a chance to ruin the night.”</p>
              <div class="mellow-expert-proof__meta">Real Routine</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--8"><span>RS</span></div>
              <div class="mellow-expert-proof__name">REFLUX ROUTINE USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that Mellow explains what it is doing. The physical barrier idea is easy to understand.”</p>
              <div class="mellow-expert-proof__meta">Early Feedback</div>
            </div>
          </article>

        {% endif %}

      </div>
    </div>

  </div>
</section>

<style>
  #shopify-section-{{ section.id }},
  .shopify-section:has(.mellow-expert-proof-{{ section.id }}) {
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    overflow: hidden !important;
    background: var(--mellow-color-page, var(--mellow-page, #F0EBE0)) !important;
  }

  .mellow-expert-proof-{{ section.id }},
  .mellow-expert-proof-{{ section.id }} * {
    box-sizing: border-box;
  }

  .mellow-expert-proof-{{ section.id }} {
    --expert-forest: var(--mellow-color-forest, var(--mellow-forest, #1A2D10));
    --expert-orange: var(--mellow-color-orange, var(--mellow-orange, #D04A2A));
    --expert-ivory: var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0));
    --expert-blue: var(--mellow-color-blue, var(--mellow-blue, #3D6B8C));
    --expert-page: var(--mellow-color-page, var(--mellow-page, #F0EBE0));
    --expert-card: var(--mellow-color-card, #FFFFFF);

    --expert-axis-pad: var(--mellow-axis-pad, clamp(28px, 4vw, 64px));
    --expert-axis-max: var(--mellow-axis-max, 1440px);

    --expert-section-pad-top: var(--mellow-section-padding-top, clamp(72px, 6vw, 112px));
    --expert-section-pad-bottom: var(--mellow-section-padding-bottom, clamp(72px, 6vw, 112px));

    --expert-heading-font: var(--mellow-heading-font, var(--font-heading-family, inherit));
    --expert-body-font: var(--mellow-body-font, var(--font-body-family, inherit));

    --expert-heading-size: var(--mellow-major-header-size, clamp(3rem, 5.2vw, 5.85rem));
    --expert-heading-weight: var(--mellow-major-header-weight, 500);
    --expert-heading-line-height: var(--mellow-heading-line-height, 0.98);
    --expert-heading-letter-spacing: var(--mellow-heading-letter-spacing, -0.045em);
    --expert-heading-font-variation-settings: var(--mellow-heading-font-variation-settings, normal);

    --expert-heading-italic-font: var(--mellow-heading-italic-font, var(--expert-heading-font));
    --expert-heading-italic-weight: var(--mellow-heading-italic-weight, 400);
    --expert-heading-italic-letter-spacing: var(--mellow-heading-italic-letter-spacing, -0.035em);
    --expert-heading-italic-line-height: var(--mellow-heading-italic-line-height, var(--expert-heading-line-height));
    --expert-heading-italic-font-variation-settings: var(--mellow-heading-italic-font-variation-settings, normal);

    --expert-eyebrow-size: var(--mellow-eyebrow-size, 0.72rem);
    --expert-eyebrow-weight: var(--mellow-eyebrow-weight, 800);
    --expert-eyebrow-letter-spacing: var(--mellow-eyebrow-letter-spacing, 0.12em);

    --expert-body-size: var(--mellow-body-size, clamp(1rem, 1.05vw, 1.08rem));
    --expert-body-line-height: var(--mellow-body-line-height, 1.5);
    --expert-body-letter-spacing: var(--mellow-body-letter-spacing, -0.02em);

    --expert-radius-card: var(--mellow-card-radius, 24px);
    --expert-radius-pill: var(--mellow-pill-radius, 999px);

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    overflow: hidden;

    background: var(--expert-page) !important;
    color: var(--expert-forest);

    padding-top: var(--expert-section-pad-top) !important;
    padding-bottom: var(--expert-section-pad-bottom) !important;
    padding-left: var(--expert-axis-pad) !important;
    padding-right: var(--expert-axis-pad) !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__inner {
    width: 100%;
    max-width: var(--expert-axis-max);
    margin-left: auto;
    margin-right: auto;
    padding: 0;
    background: transparent;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__top {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: clamp(28px, 4.5vw, 72px);
    width: 100%;
    margin: 0 0 clamp(34px, 3.2vw, 54px);
    padding: 0;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__header-copy {
    max-width: min(980px, 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__rating {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 clamp(12px, 1vw, 16px);

    color: var(--expert-orange);
    font-family: var(--expert-body-font);
    font-size: var(--expert-eyebrow-size);
    line-height: 1;
    font-weight: var(--expert-eyebrow-weight);
    letter-spacing: var(--expert-eyebrow-letter-spacing);
    text-transform: uppercase;
    text-align: left;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__stars {
    color: var(--expert-orange);
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    line-height: 1;
    white-space: nowrap;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading .mellow-heading-main {
    margin: 0;
    max-width: 980px;

    color: var(--expert-forest);
    font-family: var(--expert-heading-font);
    font-size: var(--expert-heading-size);
    line-height: var(--expert-heading-line-height);
    letter-spacing: var(--expert-heading-letter-spacing);
    font-weight: var(--expert-heading-weight);
    font-style: normal;
    font-variation-settings: var(--expert-heading-font-variation-settings);
    text-align: left;
    text-wrap: balance;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading .mellow-heading-accent {
    font-family: var(--expert-heading-italic-font);
    font-style: italic;
    font-weight: var(--expert-heading-italic-weight);
    letter-spacing: var(--expert-heading-italic-letter-spacing);
    line-height: var(--expert-heading-italic-line-height);
    font-variation-settings: var(--expert-heading-italic-font-variation-settings);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: clamp(22px, 2vw, 34px);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--mellow-button-height, 54px);
    padding: var(--mellow-button-padding, 0 34px);
    border-radius: var(--expert-radius-pill);

    background: var(--mellow-button-bg, var(--expert-forest));
    color: var(--mellow-button-color, var(--expert-ivory));
    text-decoration: none;

    font-family: var(--expert-body-font);
    font-size: var(--mellow-button-font-size, 0.96rem);
    font-weight: var(--mellow-button-font-weight, 800);
    line-height: 1;
    letter-spacing: var(--mellow-button-letter-spacing, -0.01em);
    white-space: nowrap;

    border: 1px solid var(--mellow-button-border, rgba(26, 45, 16, 0.98));
    box-shadow: var(--mellow-button-shadow, 0 16px 34px rgba(26, 45, 16, 0.16));

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__button:hover {
    transform: translateY(-2px);
    background: var(--mellow-button-hover-bg, var(--expert-orange));
    border-color: var(--mellow-button-hover-border, var(--expert-orange));
    color: var(--mellow-button-hover-color, #FFFFFF);
    box-shadow: var(--mellow-button-hover-shadow, 0 20px 46px rgba(208, 74, 42, 0.24), 0 0 0 6px rgba(208, 74, 42, 0.08));
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrows {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow {
    width: 50px;
    height: 50px;
    border-radius: var(--expert-radius-pill);
    border: 1px solid rgba(26, 45, 16, 0.2);
    background: rgba(255, 255, 255, 0.58);
    color: var(--expert-forest);

    display: inline-flex;
    align-items: center;
    justify-content: center;

    cursor: pointer;
    transition:
      background 180ms ease,
      transform 180ms ease,
      opacity 180ms ease,
      border-color 180ms ease;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow:hover {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(26, 45, 16, 0.34);
    transform: translateY(-1px);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow:disabled {
    opacity: 0.35;
    cursor: default;
    transform: none;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__viewport {
    width: calc(100% + var(--expert-axis-pad));
    margin-left: 0;
    margin-right: calc(var(--expert-axis-pad) * -1);
    padding: 0;
    overflow: hidden;
    background: transparent;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(310px, 23.5vw);
    gap: clamp(16px, 1.4vw, 22px);

    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;

    width: 100%;
    padding-left: 0;
    padding-right: var(--expert-axis-pad);
    padding-bottom: 8px;
    scroll-padding-left: 0;

    background: transparent;
    isolation: isolate;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__scroll::-webkit-scrollbar {
    display: none;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__card {
    min-height: clamp(480px, 34vw, 520px);
    border-radius: var(--expert-radius-card);
    overflow: hidden;
    background: var(--expert-card);
    border: 1px solid rgba(26, 45, 16, 0.12);
    scroll-snap-align: start;

    display: grid;
    grid-template-rows: auto minmax(220px, 1fr);

    box-shadow: var(--mellow-card-shadow, 0 18px 44px rgba(26, 45, 16, 0.08));
    position: relative;
    z-index: 2;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__image-wrap {
    position: relative;
    height: clamp(230px, 21vw, 310px);
    overflow: hidden;
    background: color-mix(in srgb, var(--expert-forest) 10%, var(--expert-ivory));
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder {
    width: 100%;
    height: 100%;

    display: flex;
    align-items: center;
    justify-content: center;

    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.24), transparent 34%),
      linear-gradient(135deg, rgba(240, 235, 224, 1) 0%, rgba(26, 45, 16, 0.22) 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--2,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--5,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--8 {
    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.22), transparent 34%),
      linear-gradient(135deg, rgba(240, 235, 224, 0.92) 0%, rgba(61, 107, 140, 0.62) 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--3,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--6 {
    background:
      radial-gradient(circle at 50% 38%, rgba(26,45,16,0.12), transparent 34%),
      linear-gradient(135deg, rgba(255,255,255,0.96) 0%, rgba(240,235,224,0.86) 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 {
    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.14), transparent 34%),
      linear-gradient(135deg, var(--expert-forest) 0%, rgba(26,45,16,0.82) 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder span {
    width: 96px;
    height: 96px;
    border-radius: var(--expert-radius-pill);
    background: rgba(255, 255, 255, 0.36);
    border: 1px solid rgba(26, 45, 16, 0.16);

    display: flex;
    align-items: center;
    justify-content: center;

    font-family: var(--expert-heading-font);
    font-size: 1.9rem;
    line-height: 1;
    font-weight: var(--expert-heading-weight);
    letter-spacing: -0.05em;
    color: var(--expert-forest);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4 span,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 span {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(240, 235, 224, 0.28);
    color: var(--expert-ivory);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__name {
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;

    font-family: var(--expert-body-font);
    font-size: clamp(0.8rem, 0.9vw, 0.96rem);
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--expert-forest);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4 + .mellow-expert-proof__name,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 + .mellow-expert-proof__name {
    color: var(--expert-ivory);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__quote {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;

    background: var(--expert-card);
    border-top: 1px solid rgba(26, 45, 16, 0.10);
    padding: clamp(22px, 1.8vw, 28px);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__quote p {
    display: block;
    margin: 0;

    font-family: var(--expert-body-font);
    font-size: var(--expert-body-size);
    line-height: var(--expert-body-line-height);
    letter-spacing: var(--expert-body-letter-spacing);
    color: rgba(26, 45, 16, 0.78);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__meta {
    display: block;
    margin-top: 18px;

    font-family: var(--expert-body-font);
    font-size: 0.74rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(26, 45, 16, 0.52);
  }

  @media screen and (min-width: 1500px) {
