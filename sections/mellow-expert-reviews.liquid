{% comment %}
  Mellow Expert Proof carousel section.
  Aligned to the global Mellow design system with scoped carousel layout CSS only.
{% endcomment %}

{%- liquid
  assign default_cards = 'A|Dr. Lena Ortiz|Integrative gastroenterologist|Mellow takes a thoughtful approach to digestive comfort: recognizable ingredients, a calming format, and a ritual people can actually stay consistent with.||B|Maya C.|Registered dietitian|What stands out is the balance. It feels premium without feeling clinical, and the copy is easy for customers to understand at a glance.||C|Noah R.|Wellness practitioner|For people building better evening routines, proof and simplicity matter. This section gives shoppers the confidence to keep exploring.' | split: '||'
-%}

<style>
  #MellowExpertProof-{{ section.id }} {
    position: relative;
    overflow-x: hidden;
    padding-top: var(--mellow-section-padding-top, clamp(72px, 6vw, 104px));
    padding-bottom: var(--mellow-section-padding-bottom, clamp(72px, 6vw, 104px));
    background: var(--mellow-color-page, var(--mellow-page, #F0EBE0));
    color: var(--mellow-color-forest, var(--mellow-forest, #1A2D10));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
    grid-template-columns: minmax(0, .62fr) auto;
    margin-bottom: clamp(28px, 3vw, 44px);
    align-items: start;
    gap: clamp(24px, 3vw, 48px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header {
    max-width: 830px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-eyebrow {
    margin-bottom: clamp(8px, .7vw, 12px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading {
    max-width: 720px;
    font-size: clamp(44px, 4.6vw, 76px);
    line-height: .9;
    letter-spacing: -0.055em;
    margin: 0;
    color: var(--mellow-forest, #1A2D10);
    text-wrap: balance;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading .mellow-heading-main,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading .mellow-heading-accent {
    display: inline;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    line-height: inherit;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading .mellow-heading-accent {
    color: var(--mellow-heading-accent-color, var(--mellow-color-orange, var(--mellow-orange, #D04A2A)));
    font-style: var(--mellow-heading-accent-style, italic);
    font-weight: var(--mellow-heading-accent-weight, inherit);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions {
    align-self: start;
    justify-self: end;
    width: auto;
    min-width: clamp(220px, 17vw, 286px);
    padding-top: clamp(8px, .8vw, 12px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions .mellow-section-cta-wrap {
    align-items: center;
    gap: clamp(12px, 1.2vw, 18px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--mellow-button-height, var(--mellow-cta-height, 56px));
    padding: var(--mellow-button-padding, 0 34px);
    border: var(--mellow-button-border, 1px solid var(--mellow-button-bg, var(--mellow-color-forest, #1A2D10)));
    border-radius: var(--mellow-pill-radius, var(--mellow-radius-pill, 999px));
    background: var(--mellow-button-bg, var(--mellow-color-forest, #1A2D10));
    color: var(--mellow-button-color, var(--mellow-color-ivory, #F0EBE0));
    font-family: var(--mellow-body-font, var(--font-body-family, inherit));
    font-size: var(--mellow-button-font-size, var(--mellow-cta-font-size, clamp(15px, 1vw, 17px)));
    font-weight: var(--mellow-button-font-weight, var(--mellow-cta-font-weight, 650));
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta:hover,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta:focus-visible {
    border-color: var(--mellow-button-hover-border, var(--mellow-button-hover-bg, var(--mellow-color-orange, var(--mellow-orange, #D04A2A))));
    background: var(--mellow-button-hover-bg, var(--mellow-cta-hover-bg, var(--mellow-color-orange, var(--mellow-orange, #D04A2A))));
    color: var(--mellow-button-hover-color, var(--mellow-color-ivory, #F0EBE0));
    transform: translateY(-1px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrows {
    display: flex;
    gap: 8px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow {
    display: inline-grid;
    place-items: center;
    width: var(--mellow-arrow-size, 52px);
    height: var(--mellow-arrow-size, 52px);
    border: 1px solid color-mix(in srgb, var(--mellow-color-forest, var(--mellow-forest, #1A2D10)) 18%, transparent);
    border-radius: var(--mellow-pill-radius, var(--mellow-radius-pill, 999px));
    background: color-mix(in srgb, var(--mellow-card-background, #FFFFFF) 82%, transparent);
    color: var(--mellow-color-forest, var(--mellow-forest, #1A2D10));
    cursor: pointer;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:hover,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:focus-visible {
    border-color: var(--mellow-color-orange, var(--mellow-orange, #D04A2A));
    background: var(--mellow-color-orange, var(--mellow-orange, #D04A2A));
    color: var(--mellow-color-ivory, #F0EBE0);
    transform: translateY(-1px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow svg {
    width: 18px;
    height: 18px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__carousel-wrap {
    width: 100%;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__carousel {
    display: flex;
    gap: var(--mellow-card-gap, clamp(18px, 2vw, 32px));
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-padding-left: 0;
    scroll-snap-type: x mandatory;
    padding: 0 0 8px;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__carousel::-webkit-scrollbar {
    display: none;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
    flex: 0 0 clamp(360px, 31vw, 470px);
    overflow: hidden;
    border: 1px solid var(--mellow-card-border, rgba(26, 45, 16, 0.14));
    border-radius: var(--mellow-card-radius, var(--mellow-radius-card, clamp(24px, 2vw, 36px)));
    background: var(--mellow-card-background, #FFFFFF);
    box-shadow: var(--mellow-card-shadow, 0 24px 60px rgba(26, 45, 16, 0.08));
    scroll-snap-align: start;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__image-panel {
    position: relative;
    aspect-ratio: 16 / 10;
    min-height: clamp(210px, 20vw, 280px);
    overflow: hidden;
    background:
      radial-gradient(circle at 78% 18%, color-mix(in srgb, var(--mellow-color-orange, var(--mellow-orange, #D04A2A)) 20%, transparent), transparent 34%),
      linear-gradient(135deg, color-mix(in srgb, var(--mellow-color-blue, var(--mellow-blue, #3D6B8C)) 24%, var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0))), var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0)));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__image {
    display: block;
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: color-mix(in srgb, var(--mellow-color-forest, var(--mellow-forest, #1A2D10)) 84%, var(--mellow-color-blue, var(--mellow-blue, #3D6B8C)));
    font-family: var(--mellow-heading-font, var(--font-heading-family, inherit));
    font-size: clamp(3.4rem, 5vw, 5.5rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 1;
    opacity: 0.9;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__name-tag {
    position: absolute;
    right: clamp(16px, 1.4vw, 22px);
    bottom: clamp(16px, 1.4vw, 22px);
    left: clamp(16px, 1.4vw, 22px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 11px 16px;
    border: 1px solid color-mix(in srgb, var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0)) 62%, transparent);
    border-radius: var(--mellow-pill-radius, var(--mellow-radius-pill, 999px));
    background: color-mix(in srgb, var(--mellow-color-forest, var(--mellow-forest, #1A2D10)) 82%, transparent);
    color: var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__name {
    font-family: var(--mellow-body-font, var(--font-body-family, inherit));
    font-size: clamp(0.82rem, 0.85vw, 0.95rem);
    font-weight: 700;
    line-height: 1.1;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__initials {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--mellow-color-ivory, var(--mellow-ivory, #F0EBE0));
    color: var(--mellow-color-forest, var(--mellow-forest, #1A2D10));
    font-family: var(--mellow-body-font, var(--font-body-family, inherit));
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__quote-panel {
    display: grid;
    gap: 16px;
    padding: clamp(24px, 2.2vw, 32px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__role {
    margin: 0;
    color: var(--mellow-color-orange, var(--mellow-orange, #D04A2A));
    font-family: var(--mellow-body-font, var(--font-body-family, inherit));
    font-size: clamp(0.78rem, 0.82vw, 0.9rem);
    font-weight: var(--mellow-eyebrow-weight, 800);
    letter-spacing: var(--mellow-eyebrow-letter-spacing, 0.12em);
    line-height: 1.25;
    text-transform: uppercase;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__quote {
    margin: 0;
    color: rgba(26, 45, 16, 0.86);
    font-family: var(--mellow-body-font, var(--font-body-family, inherit));
    font-size: var(--mellow-card-body-size, clamp(1.02rem, 1.05vw, 1.14rem));
    line-height: 1.52;
    letter-spacing: -0.015em;
  }

  @media screen and (max-width: 989px) {
    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      grid-template-columns: 1fr;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions,
    #MellowExpertProof-{{ section.id }} .mellow-section-cta-wrap {
      justify-self: start;
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      gap: 24px;
      margin-bottom: 24px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading {
      font-size: var(--mellow-section-heading-size-mobile, clamp(2.35rem, 10vw, 3.25rem));
      line-height: 1.02;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions .mellow-section-cta-wrap {
      flex-wrap: wrap;
      gap: 14px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta {
      flex: 1 1 220px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrows {
      margin-left: auto;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
      flex-basis: min(86vw, 390px);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__image-panel {
      min-height: 220px;
    }
  }
</style>

<section
  id="MellowExpertProof-{{ section.id }}"
  class="mellow-section-standard mellow-expert-proof color-{{ section.settings.color_scheme }}"
  data-mellow-expert-proof
>
  <div class="mellow-section-axis">
    <div class="mellow-section-header-grid mellow-expert-proof__header-grid">
      <div class="mellow-section-header mellow-expert-proof__header">
        {%- if section.settings.microproof != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.microproof | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-section-heading mellow-expert-proof__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>

      <div class="mellow-section-actions mellow-expert-proof__actions">
        <div class="mellow-section-cta-wrap">
          {%- if section.settings.cta_label != blank -%}
            <a class="mellow-section-cta mellow-expert-proof__cta" href="{{ section.settings.cta_link | default: '#' }}">
              <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
              <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
            </a>
          {%- endif -%}

          <div class="mellow-expert-proof__arrows" aria-label="Expert proof carousel controls">
            <button class="mellow-expert-proof__arrow" type="button" aria-label="Previous expert proof" data-mellow-expert-proof-prev>
              <svg aria-hidden="true" viewBox="0 0 20 20" fill="none">
                <path d="M12.5 4.5 7 10l5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="mellow-expert-proof__arrow" type="button" aria-label="Next expert proof" data-mellow-expert-proof-next>
              <svg aria-hidden="true" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 4.5 13 10l-5.5 5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="mellow-expert-proof__carousel-wrap">
      <div class="mellow-expert-proof__carousel" data-mellow-expert-proof-track>
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <article class="mellow-expert-proof__card" {{ block.shopify_attributes }}>
              <div class="mellow-expert-proof__image-panel">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1100 | image_tag: class: 'mellow-expert-proof__image', loading: 'lazy', decoding: 'async', sizes: '(min-width: 990px) 520px, 84vw', widths: '360, 520, 720, 900, 1100', alt: block.settings.name }}
                {%- else -%}
                  <div class="mellow-expert-proof__placeholder" aria-hidden="true">{{ block.settings.initials | default: block.settings.name | default: 'M' | slice: 0, 2 | upcase }}</div>
                {%- endif -%}

                <div class="mellow-expert-proof__name-tag">
                  <span class="mellow-expert-proof__name">{{ block.settings.name | escape }}</span>
                  <span class="mellow-expert-proof__initials">{{ block.settings.initials | default: block.settings.name | default: 'M' | slice: 0, 2 | upcase }}</span>
                </div>
              </div>

              <div class="mellow-expert-proof__quote-panel">
                {%- if block.settings.role != blank -%}
                  <p class="mellow-expert-proof__role">{{ block.settings.role | escape }}</p>
                {%- endif -%}
                {%- if block.settings.quote != blank -%}
                  <p class="mellow-expert-proof__quote">“{{ block.settings.quote | escape }}”</p>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for card in default_cards -%}
            {%- liquid
              assign card_parts = card | split: '|'
              assign fallback_initials = card_parts[0]
              assign fallback_name = card_parts[1]
              assign fallback_role = card_parts[2]
              assign fallback_quote = card_parts[3]
            -%}
            <article class="mellow-expert-proof__card">
              <div class="mellow-expert-proof__image-panel">
                <div class="mellow-expert-proof__placeholder" aria-hidden="true">{{ fallback_initials | escape }}</div>
                <div class="mellow-expert-proof__name-tag">
                  <span class="mellow-expert-proof__name">{{ fallback_name | escape }}</span>
                  <span class="mellow-expert-proof__initials">{{ fallback_initials | escape }}</span>
                </div>
              </div>
              <div class="mellow-expert-proof__quote-panel">
                <p class="mellow-expert-proof__role">{{ fallback_role | escape }}</p>
                <p class="mellow-expert-proof__quote">“{{ fallback_quote | escape }}”</p>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const initExpertProof = (section) => {
      const track = section.querySelector('[data-mellow-expert-proof-track]');
      const prev = section.querySelector('[data-mellow-expert-proof-prev]');
      const next = section.querySelector('[data-mellow-expert-proof-next]');

      if (!track || !prev || !next || track.dataset.mellowExpertProofReady === 'true') return;

      track.dataset.mellowExpertProofReady = 'true';

      const getScrollAmount = () => {
        const card = track.querySelector('.mellow-expert-proof__card');
        const gap = parseFloat(window.getComputedStyle(track).columnGap || window.getComputedStyle(track).gap) || 0;
        return card ? card.getBoundingClientRect().width + gap : track.clientWidth * 0.86;
      };

      prev.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      next.addEventListener('click', () => {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
    };

    const section = document.getElementById('MellowExpertProof-{{ section.id }}');
    if (section) initExpertProof(section);

    document.addEventListener('shopify:section:load', (event) => {
      const loadedSection = event.target.querySelector('[data-mellow-expert-proof]');
      if (loadedSection) initExpertProof(loadedSection);
    });
  })();
</script>

{% schema %}
{
  "name": "Mellow expert proof",
  "tag": "section",
  "class": "section section-mellow-expert-reviews",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "microproof",
      "label": "Microproof",
      "default": "Practitioner-backed proof"
    },
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "Expert voices for a calmer daily ritual."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "initials",
          "label": "Initials",
          "default": "LO"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Dr. Lena Ortiz"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Integrative gastroenterologist"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Mellow takes a thoughtful approach to digestive comfort: recognizable ingredients, a calming format, and a ritual people can actually stay consistent with."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mellow expert proof",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "initials": "LO",
            "name": "Dr. Lena Ortiz",
            "role": "Integrative gastroenterologist",
            "quote": "Mellow takes a thoughtful approach to digestive comfort: recognizable ingredients, a calming format, and a ritual people can actually stay consistent with."
          }
        },
        {
          "type": "review",
          "settings": {
            "initials": "MC",
            "name": "Maya C.",
            "role": "Registered dietitian",
            "quote": "What stands out is the balance. It feels premium without feeling clinical, and the copy is easy for customers to understand at a glance."
          }
        },
        {
          "type": "review",
          "settings": {
            "initials": "NR",
            "name": "Noah R.",
            "role": "Wellness practitioner",
            "quote": "For people building better evening routines, proof and simplicity matter. This section gives shoppers the confidence to keep exploring."
          }
        }
      ]
    }
  ]
}
{% endschema %}
