{% comment %}
  Mellow — What to Expect Timeline
  Standalone scroll-animated timeline section for expectation-setting.
{% endcomment %}

<section
  id="mellow-expectations-timeline-{{ section.id }}"
  class="mellow-expectations-timeline"
  data-section-id="{{ section.id }}"
>
  <div class="mellow-expectations-timeline__container">
    <header class="mellow-expectations-timeline__header">
      {% if section.settings.eyebrow != blank %}
        <p class="mellow-expectations-timeline__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="mellow-expectations-timeline__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="mellow-expectations-timeline__subheading rte">
          {{ section.settings.subheading }}
        </div>
      {% endif %}
    </header>

    <div class="mellow-expectations-timeline__timeline-wrap">
      <div class="mellow-expectations-timeline__line" aria-hidden="true">
        <span class="mellow-expectations-timeline__line-fill"></span>
      </div>

      <div class="mellow-expectations-timeline__items">
        {% for block in section.blocks %}
          <article
            class="mellow-expectations-timeline__item"
            data-expectation-item
            {{ block.shopify_attributes }}
          >
            <span class="mellow-expectations-timeline__dot" aria-hidden="true"></span>

            <div class="mellow-expectations-timeline__content">
              {% if block.settings.label != blank %}
                <span class="mellow-expectations-timeline__pill">{{ block.settings.label | escape }}</span>
              {% endif %}

              {% if block.settings.headline != blank %}
                <h3 class="mellow-expectations-timeline__item-heading">{{ block.settings.headline | escape }}</h3>
              {% endif %}

              <ul class="mellow-expectations-timeline__bullets">
                {% if block.settings.bullet_1 != blank %}
                  <li>{{ block.settings.bullet_1 | escape }}</li>
                {% endif %}
                {% if block.settings.bullet_2 != blank %}
                  <li>{{ block.settings.bullet_2 | escape }}</li>
                {% endif %}
                {% if block.settings.bullet_3 != blank %}
                  <li>{{ block.settings.bullet_3 | escape }}</li>
                {% endif %}
              </ul>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>

    <aside class="mellow-expectations-timeline__usage" aria-label="{{ section.settings.usage_heading | escape }}">
      <div class="mellow-expectations-timeline__usage-media" aria-hidden="{% if section.settings.pouch_image == blank %}true{% else %}false{% endif %}">
        {% if section.settings.pouch_image != blank %}
          {{
            section.settings.pouch_image
            | image_url: width: 760
            | image_tag:
              class: 'mellow-expectations-timeline__usage-image',
              loading: 'lazy',
              widths: '240, 360, 520, 760',
              sizes: '(max-width: 749px) 70vw, 260px',
              alt: section.settings.usage_heading
          }}
        {% else %}
          <div class="mellow-expectations-timeline__pouch-placeholder">
            <span class="mellow-expectations-timeline__pouch-mark">Mellow</span>
            <span class="mellow-expectations-timeline__pouch-wave"></span>
          </div>
        {% endif %}
      </div>

      <div class="mellow-expectations-timeline__usage-copy">
        {% if section.settings.usage_heading != blank %}
          <h3 class="mellow-expectations-timeline__usage-heading">{{ section.settings.usage_heading | escape }}</h3>
        {% endif %}

        {% if section.settings.usage_text != blank %}
          <div class="mellow-expectations-timeline__usage-text rte">
            {{ section.settings.usage_text }}
          </div>
        {% endif %}

        {% if section.settings.footnote != blank %}
          <p class="mellow-expectations-timeline__footnote">{{ section.settings.footnote | escape }}</p>
        {% endif %}
      </div>
    </aside>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  #mellow-expectations-timeline-{{ section.id }},
  #mellow-expectations-timeline-{{ section.id }} * {
    box-sizing: border-box;
  }

  #mellow-expectations-timeline-{{ section.id }} {
    --mellow-page: #FBFCF7;
    --mellow-ivory: #F0EBE0;
    --mellow-forest: #1A2D10;
    --mellow-orange: #D04A2A;
    --mellow-blue: #3D6B8C;
    --mellow-sage: #C9CEC3;
    --mellow-black: #111111;
    --timeline-fill: 0%;
    --timeline-side: clamp(26px, 4vw, 48px);
    --timeline-gutter: clamp(28px, 4.2vw, 56px);

    position: relative;
    overflow: hidden;
    width: 100%;
    background: var(--mellow-page);
    color: var(--mellow-forest);
    font-family: var(--font-body-family, 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__container {
    width: min(100% - clamp(36px, 8vw, 128px), 1180px);
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__header {
    max-width: 900px;
    margin: 0 0 clamp(54px, 8vw, 104px);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__eyebrow {
    margin: 0 0 18px;
    color: var(--mellow-blue);
    font-size: clamp(1.1rem, 0.9vw, 1.3rem);
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__heading {
    max-width: 840px;
    margin: 0;
    color: var(--mellow-black);
    font-family: var(--font-heading-family, 'Fraunces', Georgia, serif);
    font-size: clamp(4.2rem, 7vw, 9.4rem);
    font-weight: var(--font-heading-weight, 550);
    letter-spacing: -0.055em;
    line-height: 0.94;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__subheading {
    max-width: 680px;
    margin-top: clamp(22px, 3vw, 34px);
    color: rgba(26, 45, 16, 0.78);
    font-size: clamp(1.65rem, 1.45vw, 2.05rem);
    line-height: 1.55;
    letter-spacing: -0.015em;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__subheading > * {
    margin: 0;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__timeline-wrap {
    position: relative;
    max-width: 920px;
    margin: 0 auto;
    padding-left: calc(var(--timeline-side) + var(--timeline-gutter));
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__line {
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: var(--timeline-side);
    width: 2px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(201, 206, 195, 0.72);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__line-fill {
    position: absolute;
    inset: 0 0 auto;
    display: block;
    height: var(--timeline-fill);
    min-height: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, var(--mellow-forest) 0%, var(--mellow-blue) 58%, var(--mellow-orange) 100%);
    transition: height 180ms linear;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__items {
    display: grid;
    gap: clamp(34px, 6vw, 78px);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item {
    position: relative;
    min-height: 180px;
    opacity: 0.48;
    color: var(--mellow-sage);
    transform: translateY(14px);
    transition:
      opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
      color 700ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-active,
  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-complete {
    opacity: 0.82;
    color: rgba(26, 45, 16, 0.78);
    transform: translateY(0);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-current {
    opacity: 1;
    color: var(--mellow-forest);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__dot {
    position: absolute;
    top: 14px;
    left: calc((var(--timeline-gutter) * -1) - 8px);
    width: 18px;
    height: 18px;
    border: 2px solid var(--mellow-sage);
    border-radius: 50%;
    background: var(--mellow-page);
    box-shadow: 0 0 0 8px var(--mellow-page);
    transform: none;
    transition:
      background-color 650ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 650ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-active .mellow-expectations-timeline__dot,
  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-complete .mellow-expectations-timeline__dot {
    border-color: var(--mellow-forest);
    background: var(--mellow-forest);
    box-shadow: 0 0 0 8px var(--mellow-page), 0 0 0 11px rgba(26, 45, 16, 0.1);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-current .mellow-expectations-timeline__dot {
    border-color: var(--mellow-orange);
    background: var(--mellow-orange);
    transform: scale(1.08);
    box-shadow: 0 0 0 8px var(--mellow-page), 0 0 0 14px rgba(208, 74, 42, 0.13);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__content {
    max-width: 690px;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pill {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    margin-bottom: 18px;
    padding: 9px 18px 10px;
    border: 1px solid rgba(201, 206, 195, 0.78);
    border-radius: 999px;
    background: rgba(240, 235, 224, 0.38);
    color: rgba(26, 45, 16, 0.44);
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    line-height: 1;
    text-transform: uppercase;
    transition:
      color 650ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 650ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 650ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-active .mellow-expectations-timeline__pill,
  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-complete .mellow-expectations-timeline__pill {
    border-color: rgba(26, 45, 16, 0.14);
    background: var(--mellow-forest);
    color: var(--mellow-ivory);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-current .mellow-expectations-timeline__pill {
    transform: translateY(-2px);
    box-shadow: 0 16px 34px rgba(26, 45, 16, 0.12);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item-heading {
    max-width: 650px;
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family, 'Fraunces', Georgia, serif);
    font-size: clamp(3rem, 4vw, 5.8rem);
    font-weight: var(--font-heading-weight, 550);
    letter-spacing: -0.045em;
    line-height: 0.98;
    transition: color 650ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__bullets {
    display: grid;
    gap: 10px;
    max-width: 620px;
    margin: clamp(18px, 2.5vw, 26px) 0 0;
    padding: 0;
    list-style: none;
    color: currentColor;
    font-size: clamp(1.55rem, 1.3vw, 1.85rem);
    line-height: 1.55;
    letter-spacing: -0.01em;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__bullets li {
    position: relative;
    padding-left: 24px;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__bullets li::before {
    content: '';
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.68;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage {
    display: grid;
    grid-template-columns: minmax(180px, 300px) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 70px);
    align-items: center;
    max-width: 980px;
    margin: clamp(70px, 10vw, 130px) auto 0;
    padding: clamp(28px, 5vw, 56px);
    border: 1px solid rgba(26, 45, 16, 0.08);
    border-radius: clamp(26px, 4vw, 44px);
    background: var(--mellow-ivory);
    box-shadow: 0 28px 74px rgba(26, 45, 16, 0.08);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-media {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 250px;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-image {
    display: block;
    width: min(100%, 280px);
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 36px rgba(26, 45, 16, 0.12));
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pouch-placeholder {
    position: relative;
    width: min(100%, 210px);
    aspect-ratio: 0.72;
    overflow: hidden;
    border: 1px solid rgba(26, 45, 16, 0.11);
    border-radius: 22px 22px 30px 30px;
    background:
      radial-gradient(circle at 28% 18%, rgba(251, 252, 247, 0.86) 0 18%, transparent 19%),
      linear-gradient(145deg, rgba(251, 252, 247, 0.96) 0%, rgba(240, 235, 224, 0.95) 46%, rgba(201, 206, 195, 0.68) 100%);
    box-shadow: 0 26px 48px rgba(26, 45, 16, 0.13);
    transform: rotate(-3deg);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pouch-placeholder::before {
    content: '';
    position: absolute;
    inset: 18px 24px auto;
    height: 4px;
    border-radius: 999px;
    background: rgba(26, 45, 16, 0.16);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pouch-mark {
    position: absolute;
    top: 36%;
    left: 50%;
    color: var(--mellow-forest);
    font-family: var(--font-heading-family, 'Fraunces', Georgia, serif);
    font-size: clamp(2.8rem, 3vw, 4rem);
    letter-spacing: -0.06em;
    transform: translate(-50%, -50%);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pouch-wave {
    position: absolute;
    right: -28%;
    bottom: -15%;
    width: 108%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(61, 107, 140, 0.18);
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-copy {
    max-width: 570px;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-heading {
    margin: 0 0 14px;
    color: var(--mellow-forest);
    font-family: var(--font-heading-family, 'Fraunces', Georgia, serif);
    font-size: clamp(3.2rem, 4.2vw, 5.6rem);
    font-weight: var(--font-heading-weight, 550);
    letter-spacing: -0.05em;
    line-height: 0.98;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-text {
    color: rgba(26, 45, 16, 0.86);
    font-size: clamp(1.65rem, 1.35vw, 2rem);
    line-height: 1.55;
    letter-spacing: -0.01em;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-text > * {
    margin: 0;
  }

  #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__footnote {
    max-width: 520px;
    margin: 24px 0 0;
    color: rgba(26, 45, 16, 0.56);
    font-size: 1.25rem;
    line-height: 1.45;
  }

  @media screen and (min-width: 750px) {
    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__container {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 749px) {
    #mellow-expectations-timeline-{{ section.id }} {
      --timeline-side: 15px;
      --timeline-gutter: 26px;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__container {
      width: min(100% - 36px, 100%);
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__header {
      margin-bottom: 44px;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__heading {
      font-size: clamp(3.8rem, 12.5vw, 5.8rem);
      letter-spacing: -0.052em;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__timeline-wrap {
      max-width: none;
      padding-left: calc(var(--timeline-side) + var(--timeline-gutter));
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__items {
      gap: 46px;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item {
      min-height: auto;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__dot {
      top: 10px;
      width: 16px;
      height: 16px;
      transform: none;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item.is-current .mellow-expectations-timeline__dot {
      transform: scale(1.06);
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pill {
      min-height: 34px;
      margin-bottom: 14px;
      padding: 8px 14px 9px;
      font-size: 1.1rem;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item-heading {
      font-size: clamp(2.75rem, 8vw, 3.8rem);
      line-height: 1.02;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__bullets {
      gap: 8px;
      font-size: 1.52rem;
      line-height: 1.48;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 64px;
      padding: 26px;
      border-radius: 28px;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__usage-media {
      min-height: 190px;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pouch-placeholder {
      width: 155px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #mellow-expectations-timeline-{{ section.id }} {
      --timeline-fill: 100%;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item,
    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pill,
    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__dot,
    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__line-fill {
      transition: none !important;
      transform: none !important;
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__item {
      opacity: 1;
      color: var(--mellow-forest);
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__pill {
      border-color: rgba(26, 45, 16, 0.14);
      background: var(--mellow-forest);
      color: var(--mellow-ivory);
    }

    #mellow-expectations-timeline-{{ section.id }} .mellow-expectations-timeline__dot {
      border-color: var(--mellow-forest);
      background: var(--mellow-forest);
    }
  }
{% endstyle %}

<script>
  (() => {
    const section = document.getElementById('mellow-expectations-timeline-{{ section.id }}');

    if (!section) return;

    const items = Array.from(section.querySelectorAll('[data-expectation-item]'));
    const timeline = section.querySelector('.mellow-expectations-timeline__timeline-wrap');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (!items.length || !timeline) return;

    const activateAll = () => {
      section.style.setProperty('--timeline-fill', '100%');
      items.forEach((item, index) => {
        item.classList.add('is-active', 'is-complete');
        item.classList.toggle('is-current', index === items.length - 1);
      });
    };

    if (reduceMotion.matches) {
      activateAll();
      return;
    }

    let ticking = false;

    const clamp = (value, min, max) => Math.min(Math.max(value, min), max);

    const updateTimeline = () => {
      ticking = false;

      const viewportCenter = window.innerHeight * 0.52;
      const firstDot = items[0].querySelector('.mellow-expectations-timeline__dot');
      const lastDot = items[items.length - 1].querySelector('.mellow-expectations-timeline__dot');
      const firstDotRect = firstDot ? firstDot.getBoundingClientRect() : items[0].getBoundingClientRect();
      const lastDotRect = lastDot ? lastDot.getBoundingClientRect() : items[items.length - 1].getBoundingClientRect();
      const start = firstDotRect.top + (firstDotRect.height / 2);
      const end = lastDotRect.top + (lastDotRect.height / 2);
      const progress = end === start ? 1 : clamp((viewportCenter - start) / (end - start), 0, 1);

      section.style.setProperty('--timeline-fill', `${progress * 100}%`);

      let currentIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      items.forEach((item, index) => {
        const rect = item.getBoundingClientRect();
        const itemFocusPoint = rect.top + Math.min(rect.height * 0.42, 120);
        const distance = Math.abs(itemFocusPoint - viewportCenter);

        if (distance < closestDistance) {
          closestDistance = distance;
          currentIndex = index;
        }
      });

      items.forEach((item, index) => {
        const rect = item.getBoundingClientRect();
        const itemFocusPoint = rect.top + Math.min(rect.height * 0.42, 120);
        const isActive = itemFocusPoint <= window.innerHeight * 0.66;

        item.classList.toggle('is-active', isActive || index === 0);
        item.classList.toggle('is-complete', index < currentIndex);
        item.classList.toggle('is-current', index === currentIndex);
      });
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateTimeline);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) requestUpdate();
      });
    }, {
      root: null,
      rootMargin: '-35% 0px -35% 0px',
      threshold: 0
    });

    items.forEach((item) => observer.observe(item));

    updateTimeline();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });

    document.addEventListener('shopify:section:unload', (event) => {
      if (!event.detail || event.detail.sectionId !== '{{ section.id }}') return;
      observer.disconnect();
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', requestUpdate);
    });
  })();
</script>

