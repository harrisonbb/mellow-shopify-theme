{% comment %}
  Mellow who it’s for section.
  Full-bleed forest green carousel for real-life reflux moments.
{% endcomment %}

<style>
  #MellowWhoItsFor-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: var(--mellow-section-pad-top);
    padding-bottom: var(--mellow-section-pad-bottom);
    background: var(--mellow-section-green, #003302);
    color: var(--mellow-cream, #F0EBE0);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 760px) auto;
    align-items: center;
    gap: clamp(40px, 6vw, 96px);
    margin-bottom: var(--mellow-section-content-gap);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header {
    max-width: var(--mellow-header-max);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__eyebrow {
    margin: 0 0 var(--mellow-section-header-gap);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
    max-width: var(--mellow-header-max);
    color: var(--mellow-cream, #F0EBE0);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
    max-width: var(--mellow-copy-max);
    margin: var(--mellow-section-heading-gap) 0 0;
    color: rgba(240, 235, 224, 0.86);
    font-size: var(--mellow-subhead-size);
    line-height: var(--mellow-subhead-line-height);
    font-weight: 400;
    letter-spacing: var(--mellow-subhead-tracking);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
    justify-self: end;
    align-self: center;
    transform: none;
    width: clamp(220px, 16vw, 280px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-action {
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }

  #MellowWhoItsFor-{{ section.id }}.is-reduced-motion .mellow-who-its-for__carousel-wrap,
  #MellowWhoItsFor-{{ section.id }}.is-reduced-motion .mellow-who-its-for__carousel {
    overflow-x: auto;
    scroll-behavior: auto;
  }

  #MellowWhoItsFor-{{ section.id }}.is-reduced-motion .mellow-who-its-for__track {
    transform: none !important;
    will-change: auto;
  }

  #MellowWhoItsFor-{{ section.id }}.is-reduced-motion .mellow-who-its-for__card-set[data-mellow-who-card-set-duplicate] {
    display: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-bottom: 70px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    position: relative;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__track {
    display: flex;
    width: max-content;
    max-width: none;
    gap: var(--mellow-carousel-card-gap);
    align-items: center;
    will-change: transform;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-set {
    display: flex;
    gap: var(--mellow-carousel-card-gap);
    align-items: center;
    flex: 0 0 auto;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
    flex: 0 0 auto;
    position: relative;
    width: clamp(330px, 28vw, 430px);
    height: clamp(300px, 24vw, 370px);
    padding: var(--mellow-card-pad-standard);

    background: #f4ede0 !important;
    background-image: none !important;
    border: 1px solid rgba(180, 130, 72, 0.22) !important;
    border-radius: var(--mellow-radius-card) !important;
    outline: 0 !important;
    box-shadow: none;
    background-clip: border-box;

    overflow: hidden;
    transform: none !important;
    backface-visibility: visible;
    will-change: auto;
    z-index: 1;

    transition:
      opacity 260ms ease,
      border-color 260ms ease;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
    transform: none !important;
    z-index: 20;

    background: #f4ede0 !important;
    background-image: none !important;
    border: 1px solid rgba(180, 130, 72, 0.26) !important;
    border-radius: var(--mellow-radius-card) !important;
    outline: 0 !important;
    box-shadow: none;
    background-clip: border-box;
    filter: none;
    opacity: 1;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card:not(.is-active) {
    opacity: 0.96;
    filter: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner {
    position: static;
    height: 100%;
    width: 100%;
    padding: 0;
    overflow: visible;

    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active .mellow-who-its-for__card-inner {
    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::after,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::after {
    content: none !important;
    display: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
    position: absolute;
    top: 22px;
    right: 22px;
    margin: 0;
    transform: none;
    letter-spacing: 0.13em;
    z-index: 3;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy {
    margin-top: 28px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy h3 {
    margin: 0;
    font-size: var(--mellow-card-title-size);
    line-height: 1.04;
    font-weight: var(--mellow-card-title-weight);
    letter-spacing: var(--mellow-card-title-tracking);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__divider {
    display: block;
    width: 48px;
    height: 2px;
    margin-top: 12px;
    margin-bottom: 18px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy p {
    margin: 0;
    max-width: 94%;
    font-size: var(--mellow-card-copy-size);
    line-height: 1.48;
    font-weight: 400;
    letter-spacing: var(--mellow-card-copy-tracking);
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      transition: none;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
      display: block;
      margin-bottom: var(--mellow-section-content-gap-compact);
    }


    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
      font-size: 16px;
      line-height: 1.45;
      max-width: 360px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
      width: 100%;
      margin-top: var(--mellow-section-content-gap-compact);
      transform: none;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-action {
      width: 100%;
      justify-content: flex-start;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
      padding-bottom: 52px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      width: 320px;
      height: 300px;
      padding: var(--mellow-card-pad-standard);
      transform: none !important;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
      transform: none !important;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
      top: 18px;
      right: 18px;
    }
  }
</style>

<section
  id="MellowWhoItsFor-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-who-its-for color-{{ section.settings.color_scheme }}"
  data-mellow-who-carousel
>
  <div class="mellow-section-axis mellow-who-its-for__inner">
    <div class="mellow-section-header-grid mellow-who-its-for__header-wrap">
      <div class="mellow-section-header mellow-who-its-for__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-who-its-for__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-section-heading mellow-who-its-for__heading">
            {{ section.settings.heading | escape | replace: 'more moments', 'more<br>moments' | replace: 'think.', 'think' }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-section-text mellow-who-its-for__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-section-actions mellow-who-its-for__header-actions">
        <div class="mellow-section-cta-wrap mellow-who-its-for__quiz-action">
          <a class="mellow-section-cta mellow-section-cta--primary-forest mellow-who-its-for__quiz-button" href="/pages/quiz">
            <span class="mellow-section-cta__label mellow-who-its-for__quiz-label">Take the reflux quiz</span>
            <span class="mellow-section-cta__arrow mellow-who-its-for__quiz-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-who-its-for__carousel-wrap" aria-label="Real-life reflux moments carousel">
    <div class="mellow-who-its-for__carousel" data-mellow-who-carousel-stage>
      <div class="mellow-who-its-for__track" data-mellow-who-track>
        {%- liquid
          assign cards = 'Big meal lovers|Large portions and rich foods can put extra pressure on your digestive system.|fork-knife|Most Common||Nighttime reflux|When symptoms hit right as you’re trying to fall asleep.|moon|Bedtime Use||Chronic reflux|When it keeps coming back — day after day, night after night.|droplet|Most Searched||During pregnancy|Hormonal shifts and added pressure can bring reflux when you least expect it.|pregnancy||Active lifestyles|You love to move. Reflux shouldn’t slow you down.|bolt||Stress & pressure|Life gets stressful. Reflux often follows.|target||After surgery|Your new normal deserves real, comfortable relief.|shield||Smokers & vapers|Smoking and vaping can make reflux worse. Relief still matters.|smoke' | split: '||'
        -%}

        {%- for card_loop in (1..3) -%}
          {%- assign is_original_set = false -%}
          {%- if card_loop == 2 -%}
            {%- assign is_original_set = true -%}
          {%- endif -%}

          <div
            class="mellow-who-its-for__card-set"
            {% if is_original_set %}
              data-mellow-who-card-set
            {% else %}
              data-mellow-who-card-set-duplicate
              aria-hidden="true"
            {% endif %}
          >
            {%- for card in cards -%}
              {%- liquid
                assign card_parts = card | split: '|'
                assign card_title = card_parts[0]
                assign card_text = card_parts[1]
                assign card_icon = card_parts[2]
                assign card_tag = card_parts[3]
              -%}

              <article
                class="mellow-who-its-for__card"
                {% if is_original_set %}
                  data-mellow-who-card
                {% endif %}
                data-mellow-who-index="{{ forloop.index0 }}"
              >
                <div class="mellow-who-its-for__card-inner">
                  {%- if card_tag != blank -%}
                    <span class="mellow-card-tag mellow-who-its-for__tag">{{ card_tag | escape }}</span>
                  {%- endif -%}

                  <div class="mellow-who-its-for__icon mellow-who-its-for__icon--{{ card_icon }}" aria-hidden="true">
                    {%- case card_icon -%}
                      {%- when 'fork-knife' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M15 7v14M9 7v12c0 4 3 7 6 7s6-3 6-7V7M15 26v15"/><path d="M33 7c4 4 6 9 6 15 0 5-3 8-6 8V7Zm0 23v11"/></svg>
                      {%- when 'droplet' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6S12 20 12 30c0 7 5 12 12 12s12-5 12-12C36 20 24 6 24 6Z"/><path d="M19 31c1 3 3 5 6 5"/></svg>
                      {%- when 'moon' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M32 39c-12 0-22-10-22-22 0-3 1-6 2-9 3 7 10 12 18 12 4 0 7-1 10-3-1 12-7 22-8 22Z"/></svg>
                      {%- when 'pregnancy' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M25 9a5 5 0 1 1-10 0 5 5 0 0 1 10 0Z"/><path d="M20 15c-5 3-8 8-8 15 0 8 5 12 12 12 6 0 11-4 11-10 0-7-5-13-12-13"/><path d="M18 28c3-2 8-2 11 1"/></svg>
                      {%- when 'bolt' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M28 5 12 27h12l-4 16 16-23H24l4-15Z"/></svg>
                      {%- when 'target' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><circle cx="24" cy="24" r="17"/><circle cx="24" cy="24" r="9"/><path d="M24 24h.1"/></svg>
                      {%- when 'shield' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6 38 12v10c0 9-5 16-14 20-9-4-14-11-14-20V12l14-6Z"/><path d="M18 24l4 4 8-9"/></svg>
                      {%- when 'smoke' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M9 32h18M31 32h8"/><path d="M11 23c4-5 11 2 15-4 2-3-1-6-4-8"/><path d="M31 24c3-3 9 0 8-7"/></svg>
                    {%- endcase -%}
                  </div>

                  <div class="mellow-who-its-for__card-copy">
                    <h3 class="mellow-card-title">{{ card_title | escape }}</h3>
                    <span class="mellow-who-its-for__divider" aria-hidden="true"></span>
                    <p class="mellow-card-copy">{{ card_text | escape }}</p>
                  </div>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowWhoItsFor-{{ section.id }}');
    const releaseReadyHold = window.MellowReadyGate ? window.MellowReadyGate.hold() : null;
    const releaseSectionReady = () => {
      section.classList.add('is-mellow-section-ready');

      if (releaseReadyHold) {
        releaseReadyHold();
      }
    };

    if (!section) {
      if (releaseReadyHold) {
        releaseReadyHold();
      }
      return;
    }

    const scroller = section.querySelector('[data-mellow-who-carousel-stage]');
    const track = section.querySelector('[data-mellow-who-track]');
    const cardSet = section.querySelector('[data-mellow-who-card-set]');
    const momentCards = cardSet ? Array.from(cardSet.querySelectorAll('[data-mellow-who-card]')) : [];
    const allMomentCards = Array.from(section.querySelectorAll('.mellow-who-its-for__card'));

    if (!scroller || !track || !cardSet || !momentCards.length) {
      return;
    }

    const marqueeDuration = 90000;
    const activeUpdateIntervalMs = 180;
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let setWidth = 0;
    let cardWidth = 0;
    let cardPitch = 0;
    let scrollerCenterX = 0;
    let offset = 0;
    let animationFrame = null;
    let lastFrameTime = null;
    let resizeObserver = null;
    let activeUpdateFrame = null;
    let activeCardIndex = null;
    let lastActiveUpdateTime = 0;
    let ticking = false;
    let isReducedMotion = reducedMotionQuery.matches;

    const setReducedMotionState = () => {
      section.classList.toggle('is-reduced-motion', isReducedMotion);
    };

    const applySafeOffset = () => {
      if (setWidth <= 0) {
        return false;
      }

      let didWrap = false;

      while (offset <= setWidth * -1.5) {
        offset += setWidth;
        didWrap = true;
      }

      while (offset >= setWidth * -0.5) {
        offset -= setWidth;
        didWrap = true;
      }

      return didWrap;
    };

    const updateTrackPosition = () => {
      track.style.transform = isReducedMotion ? 'none' : `translate3d(${offset}px, 0, 0)`;
    };

    const wrapSetPosition = (position) => {
      if (setWidth <= 0) {
        return 0;
      }

      return ((position % setWidth) + setWidth) % setWidth;
    };

    const getCircularDistance = (positionA, positionB) => {
      const directDistance = Math.abs(positionA - positionB);

      return Math.min(directDistance, setWidth - directDistance);
    };

    const getCenteredCardIndex = () => {
      if (setWidth <= 0 || cardPitch <= 0 || cardWidth <= 0) {
        return 0;
      }

      const centerInTrack = scrollerCenterX - offset;
      const centerInSet = wrapSetPosition(centerInTrack);
      const approximateIndex = Math.round((centerInSet - cardWidth / 2) / cardPitch);
      const candidateIndexes = [approximateIndex - 1, approximateIndex, approximateIndex + 1];

      return candidateIndexes.reduce((closestIndex, candidateIndex) => {
        const normalizedCandidateIndex = ((candidateIndex % momentCards.length) + momentCards.length) % momentCards.length;
        const normalizedClosestIndex = ((closestIndex % momentCards.length) + momentCards.length) % momentCards.length;
        const candidateCenter = wrapSetPosition(cardWidth / 2 + normalizedCandidateIndex * cardPitch);
        const closestCenter = wrapSetPosition(cardWidth / 2 + normalizedClosestIndex * cardPitch);
        const candidateDistance = getCircularDistance(centerInSet, candidateCenter);
        const closestDistance = getCircularDistance(centerInSet, closestCenter);

        return candidateDistance < closestDistance ? candidateIndex : closestIndex;
      }, approximateIndex);
    };

    const clearInactiveCards = (nextActiveIndex) => {
      allMomentCards.forEach((card) => {
        const cardIndex = Number(card.dataset.mellowWhoIndex);

        if (cardIndex !== nextActiveIndex && card.classList.contains('is-active')) {
          card.classList.remove('is-active');
        }
      });
    };

    const setActiveCardByIndex = (nextActiveIndex) => {
      clearInactiveCards(nextActiveIndex);

      allMomentCards.forEach((card) => {
        if (Number(card.dataset.mellowWhoIndex) === nextActiveIndex) {
          card.classList.add('is-active');
        }
      });

      activeCardIndex = nextActiveIndex;
    };

    const setStableReducedMotionCard = () => {
      setActiveCardByIndex(0);
    };

    const updateActiveMomentCard = (timestamp = performance.now()) => {
      if (isReducedMotion) {
        setStableReducedMotionCard();
        return;
      }

      const nextActiveIndex = ((getCenteredCardIndex() % momentCards.length) + momentCards.length) % momentCards.length;
      lastActiveUpdateTime = timestamp;

      if (nextActiveIndex !== activeCardIndex) {
        setActiveCardByIndex(nextActiveIndex);
      }
    };

    const requestActiveCardUpdate = () => {
      if (isReducedMotion) {
        setStableReducedMotionCard();
        return;
      }

      if (ticking) {
        return;
      }

      ticking = true;

      activeUpdateFrame = requestAnimationFrame((timestamp) => {
        updateActiveMomentCard(timestamp);
        ticking = false;
        activeUpdateFrame = null;
      });
    };

    const stopMarquee = () => {
      if (animationFrame) {
        cancelAnimationFrame(animationFrame);
        animationFrame = null;
      }

      if (activeUpdateFrame) {
        cancelAnimationFrame(activeUpdateFrame);
        activeUpdateFrame = null;
      }

      ticking = false;
      lastFrameTime = null;
    };

    const measureScrollerCenter = () => {
      scrollerCenterX = scroller.clientWidth / 2;
    };

    const measureCarousel = () => {
      const trackStyles = window.getComputedStyle(track);
      const cardSetStyles = window.getComputedStyle(cardSet);
      const trackGap = parseFloat(trackStyles.columnGap) || 0;
      const cardGap = parseFloat(cardSetStyles.columnGap) || 0;
      const firstCard = momentCards[0];

      cardWidth = firstCard ? firstCard.getBoundingClientRect().width : 0;
      cardPitch = cardWidth + cardGap;
      setWidth = cardSet.getBoundingClientRect().width + trackGap;
      measureScrollerCenter();

      if (setWidth <= 0) {
        return;
      }

      offset = isReducedMotion ? 0 : setWidth * -1;
      track.style.setProperty('--who-track-width', `${setWidth}px`);
      updateTrackPosition();
      requestActiveCardUpdate();
    };

    const animate = (timestamp) => {
      if (isReducedMotion) {
        stopMarquee();
        updateTrackPosition();
        setStableReducedMotionCard();
        return;
      }

      if (setWidth > 0) {
        if (lastFrameTime === null) {
          lastFrameTime = timestamp;
        }

        const elapsed = timestamp - lastFrameTime;
        const pixelsPerMillisecond = setWidth / marqueeDuration;

        offset -= pixelsPerMillisecond * elapsed;
        const didWrap = applySafeOffset();
        updateTrackPosition();

        if (didWrap) {
          activeCardIndex = null;
          requestActiveCardUpdate();
        } else if (timestamp - lastActiveUpdateTime >= activeUpdateIntervalMs) {
          updateActiveMomentCard(timestamp);
        }

        lastFrameTime = timestamp;
      }

      animationFrame = requestAnimationFrame(animate);
    };

    const startMarquee = () => {
      if (isReducedMotion || animationFrame) {
        return;
      }

      requestActiveCardUpdate();
      animationFrame = requestAnimationFrame(animate);
    };

    const normalizeWheelDelta = (delta, deltaMode) => {
      if (deltaMode === WheelEvent.DOM_DELTA_LINE) {
        return delta * 16;
      }

      if (deltaMode === WheelEvent.DOM_DELTA_PAGE) {
        return delta * scroller.clientWidth;
      }

      return delta;
    };

    const handleResize = () => {
      lastFrameTime = null;
      measureCarousel();
    };

    const handleMotionPreferenceChange = (event) => {
      isReducedMotion = event.matches;
      setReducedMotionState();
      stopMarquee();
      measureCarousel();
      startMarquee();
    };

    setReducedMotionState();
    measureCarousel();

    if ('ResizeObserver' in window) {
      resizeObserver = new ResizeObserver(handleResize);
      resizeObserver.observe(cardSet);
      resizeObserver.observe(scroller);
    } else {
      window.addEventListener('resize', handleResize);
    }

    scroller.addEventListener(
      'wheel',
      (event) => {
        if (isReducedMotion) {
          return;
        }

        const horizontalDelta = normalizeWheelDelta(event.deltaX, event.deltaMode);
        const verticalDelta = normalizeWheelDelta(event.deltaY, event.deltaMode);
        const isIntentionalHorizontalScroll = Math.abs(horizontalDelta) > Math.abs(verticalDelta) * 1.05;

        if (!isIntentionalHorizontalScroll || setWidth <= 0) {
          return;
        }

        event.preventDefault();
        offset -= horizontalDelta;
        applySafeOffset();
        updateTrackPosition();
        requestActiveCardUpdate();
        lastFrameTime = null;
      },
      { passive: false }
    );

    window.addEventListener('resize', requestActiveCardUpdate, { passive: true });

    if (typeof reducedMotionQuery.addEventListener === 'function') {
      reducedMotionQuery.addEventListener('change', handleMotionPreferenceChange);
    } else if (typeof reducedMotionQuery.addListener === 'function') {
      reducedMotionQuery.addListener(handleMotionPreferenceChange);
    }

    startMarquee();

    requestAnimationFrame(releaseSectionReady);

    document.addEventListener('shopify:section:unload', (event) => {
      if (!event.target.contains(section)) {
        return;
      }

      stopMarquee();
      window.removeEventListener('resize', requestActiveCardUpdate, { passive: true });

      if (!resizeObserver) {
        window.removeEventListener('resize', handleResize);
      }

      if (typeof reducedMotionQuery.removeEventListener === 'function') {
        reducedMotionQuery.removeEventListener('change', handleMotionPreferenceChange);
      } else if (typeof reducedMotionQuery.removeListener === 'function') {
        reducedMotionQuery.removeListener(handleMotionPreferenceChange);
      }

      if (resizeObserver) {
        resizeObserver.disconnect();
      }
    });
  })();
