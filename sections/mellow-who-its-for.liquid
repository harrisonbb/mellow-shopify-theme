{% comment %}
  Mellow who it’s for section.
  Split editorial intro and warm carousel shelf for real-life reflux moments.
{% endcomment %}

<style>
  #MellowWhoItsFor-{{ section.id }} {
    --mellow-who-intro-pad-top: clamp(64px, 5.4vw, 84px);
    --mellow-who-intro-pad-bottom: clamp(64px, 5.4vw, 84px);
    --mellow-who-shelf-pad-top: clamp(42px, 3.7vw, 58px);
    --mellow-who-shelf-pad-bottom: clamp(56px, 4.8vw, 78px);
    --mellow-who-card-gap: clamp(24px, 2.2vw, 36px);
    --mellow-who-icon-size: clamp(70px, 5.2vw, 86px);
    --mellow-who-icon-svg-size: clamp(31px, 2.2vw, 40px);
    --mellow-who-card-surface: var(--mellow-card-cream, #FAF7EF);
    --mellow-who-card-border: rgba(18, 51, 8, 0.12);
    --mellow-who-card-shadow:
      0 1px 0 rgba(255, 255, 255, 0.82) inset,
      0 18px 42px rgba(47, 33, 16, 0.10);
    --mellow-who-axis-pad: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    --mellow-who-card-width: calc((100vw - (var(--mellow-who-axis-pad) * 2) - (var(--mellow-who-card-gap) * 3)) / 4);

    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding: 0 !important;
    background: var(--mellow-ivory, #FCFBF7);
    color: var(--mellow-forest, #003302);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__intro {
    background:
      radial-gradient(circle at 58% 48%, rgba(255, 255, 255, 0.045) 0%, rgba(255, 255, 255, 0.018) 32%, rgba(255, 255, 255, 0) 58%),
      var(--mellow-section-green, var(--mellow-forest, #003302));
    color: var(--mellow-cream, #FCFBF7);
    padding-top: var(--mellow-who-intro-pad-top);
    padding-bottom: var(--mellow-who-intro-pad-bottom);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__shelf {
    position: relative;
    overflow: hidden;
    background: var(--mellow-ivory, #FCFBF7);
    padding-top: var(--mellow-who-shelf-pad-top);
    padding-bottom: var(--mellow-who-shelf-pad-bottom);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-left: var(--mellow-who-axis-pad);
    padding-right: var(--mellow-who-axis-pad);
    box-sizing: border-box;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(1px, auto) minmax(340px, 0.74fr);
    align-items: center;
    gap: clamp(42px, 5vw, 82px);
    margin-bottom: 0;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header {
    max-width: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__eyebrow {
    margin: 0 0 var(--mellow-section-header-gap);
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
    max-width: min(760px, 58vw);
    color: var(--mellow-cream, #FCFBF7);
    font-size: clamp(56px, 5.4vw, 88px);
    line-height: 0.98;
    font-weight: var(--mellow-section-heading-weight, var(--mellow-heading-weight, 600));
    letter-spacing: var(--mellow-section-heading-letter-spacing, var(--mellow-heading-tracking, -0.055em));
    text-wrap: balance;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__intro-divider {
    width: 1px;
    align-self: stretch;
    min-height: clamp(190px, 16vw, 260px);
    background: rgba(240, 235, 224, 0.30);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
    justify-self: stretch;
    align-self: center;
    width: auto;
    margin: 0;
    transform: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
    max-width: 520px;
    margin: 0;
    color: rgba(252, 251, 247, 0.93);
    font-size: clamp(22px, 1.65vw, 30px);
    line-height: 1.45;
    font-weight: var(--mellow-section-subhead-weight, var(--mellow-subhead-weight, 400));
    letter-spacing: var(--mellow-section-subhead-letter-spacing, var(--mellow-subhead-tracking, -0.02em));
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-action {
    display: flex;
    justify-content: flex-start;
    width: 100%;
    margin-top: clamp(30px, 2.7vw, 44px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button {
    --mellow-section-cta-bg: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-border: rgba(252, 251, 247, 0.72);
    --mellow-section-cta-color: var(--mellow-forest, #003302);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-width: clamp(280px, 21vw, 320px);
    min-height: clamp(58px, 4.4vw, 66px);
    letter-spacing: 0;
    box-shadow: 0 10px 24px rgba(0, 20, 1, 0.12);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button .mellow-section-cta__arrow {
    display: inline-flex;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
    position: relative;
    isolation: isolate;
    width: 100%;
    max-width: 100%;
    overflow: visible;
    padding-top: 0;
    padding-bottom: clamp(10px, 1.4vw, 18px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel {
    box-sizing: border-box;
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
    overflow-y: visible;
    margin: 0;
    padding: 0 var(--mellow-who-axis-pad);
    position: relative;
    z-index: 1;
    scroll-padding-inline: var(--mellow-who-axis-pad);
    scroll-snap-type: x proximity;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    touch-action: pan-x pan-y;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel::-webkit-scrollbar {
    display: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__track {
    display: flex;
    width: max-content;
    max-width: none;
    gap: 0;
    align-items: stretch;
    will-change: auto;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-set {
    display: flex;
    gap: var(--mellow-who-card-gap);
    align-items: stretch;
    flex: 0 0 auto;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
    flex: 0 0 var(--mellow-who-card-width);
    position: relative;
    display: flex;
    box-sizing: border-box;
    width: var(--mellow-who-card-width);
    min-height: clamp(430px, 31vw, 470px);
    padding: clamp(34px, 2.6vw, 42px);
    scroll-snap-align: start;

    background: var(--mellow-who-card-surface, #FAF7EF) !important;
    background-image: none !important;
    border: 1px solid var(--mellow-who-card-border, rgba(0, 51, 2, 0.14)) !important;
    border-radius: min(var(--mellow-radius-card, 28px), 26px) !important;
    outline: 0 !important;
    box-shadow: var(--mellow-who-card-shadow);
    background-clip: border-box;

    overflow: hidden;
    transform: none !important;
    backface-visibility: visible;
    will-change: auto;
    z-index: 1;

    transition:
      opacity 260ms ease,
      border-color 260ms ease,
      box-shadow 260ms ease;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
    transform: none !important;
    z-index: 20;

    background: var(--mellow-who-card-surface, #FAF7EF) !important;
    background-image: none !important;
    border: 1px solid rgba(208, 74, 42, 0.48) !important;
    border-radius: min(var(--mellow-radius-card, 28px), 26px) !important;
    outline: 0 !important;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.82) inset,
      0 20px 48px rgba(47, 33, 16, 0.12),
      0 0 0 1px rgba(208, 74, 42, 0.08);
    background-clip: border-box;
    filter: none;
    opacity: 1;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card:not(.is-active) {
    opacity: 1;
    filter: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    justify-content: flex-start;
    height: 100%;
    width: 100%;
    padding: 0;
    overflow: visible;

    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--mellow-who-icon-size);
    height: var(--mellow-who-icon-size);
    border: 1px solid rgba(0, 51, 2, 0.08);
    border-radius: 999px;
    color: var(--mellow-forest, #003302);
    background: color-mix(in srgb, var(--mellow-card-cream, #F8F4EC) 78%, var(--mellow-section-green, #003302) 10%);
    box-shadow:
      inset 0 0 0 0.58rem rgba(255, 253, 247, 0.38),
      0 0.8rem 1.8rem rgba(47, 33, 16, 0.07);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__icon svg {
    width: var(--mellow-who-icon-svg-size);
    height: var(--mellow-who-icon-svg-size);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active .mellow-who-its-for__card-inner {
    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::after,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::after {
    content: none !important;
    display: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
    position: static;
    display: block;
    margin: clamp(34px, 2.6vw, 46px) 0 0;
    transform: none;
    color: var(--mellow-orange-red, #D04A2A);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    z-index: 3;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy {
    margin-top: clamp(14px, 1.1vw, 18px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy h3 {
    margin: 0;
    color: var(--mellow-forest, #003302);
    font-size: clamp(26px, 1.8vw, 34px);
    line-height: var(--mellow-card-title-line-height, 1.05);
    font-weight: var(--mellow-card-title-weight, 560);
    letter-spacing: var(--mellow-card-title-letter-spacing, var(--mellow-card-title-tracking, -0.035em));
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__divider {
    display: block;
    width: 40px;
    height: 2px;
    margin-top: 15px;
    margin-bottom: 22px;
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-forest, #003302);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy p {
    margin: 0;
    max-width: 92%;
    color: rgba(20, 33, 17, 0.82);
    font-size: clamp(17px, 1.08vw, 19px);
    line-height: 1.5;
    font-weight: var(--mellow-card-body-weight, var(--mellow-card-copy-weight, 400));
    letter-spacing: var(--mellow-card-body-letter-spacing, var(--mellow-card-copy-tracking, -0.006em));
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-arrow {
    position: absolute;
    right: 0;
    bottom: 0;
    color: var(--mellow-forest, #003302);
    font-size: clamp(30px, 2vw, 38px);
    line-height: 1;
    opacity: 0.95;
  }

  @media screen and (min-width: 990px) and (max-height: 820px) {
    #MellowWhoItsFor-{{ section.id }} {
      --mellow-who-intro-pad-top: clamp(52px, 4.5vw, 64px);
      --mellow-who-intro-pad-bottom: clamp(52px, 4.5vw, 64px);
      --mellow-who-shelf-pad-top: clamp(34px, 3vw, 46px);
      --mellow-who-shelf-pad-bottom: clamp(44px, 4vw, 60px);
      --mellow-who-icon-size: clamp(66px, 4.6vw, 78px);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
      font-size: clamp(52px, 5vw, 76px);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
      font-size: clamp(20px, 1.45vw, 26px);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      min-height: clamp(400px, 29vw, 440px);
      padding: clamp(30px, 2.3vw, 38px);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
      margin-top: clamp(28px, 2.2vw, 38px);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy p {
      font-size: clamp(16px, 1vw, 18px);
      line-height: 1.46;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      transition: none;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel {
      scroll-behavior: auto;
    }
  }

  @media screen and (max-width: 989px) {
    #MellowWhoItsFor-{{ section.id }} {
      --mellow-who-card-width: clamp(300px, 44vw, 360px);
      --mellow-who-card-gap: 20px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
      display: block;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
      width: 100%;
      margin-top: clamp(28px, 4vw, 40px);
      padding-left: 0;
      border-left: 0;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__intro-divider {
      display: none;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
      max-width: 760px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
      max-width: 640px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      width: var(--mellow-who-card-width);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWhoItsFor-{{ section.id }} {
      --mellow-who-intro-pad-top: clamp(40px, 10vw, 52px);
      --mellow-who-intro-pad-bottom: clamp(38px, 10vw, 54px);
      --mellow-who-shelf-pad-top: 22px;
      --mellow-who-shelf-pad-bottom: 48px;
      --mellow-who-card-gap: 16px;
      --mellow-who-card-width: min(84vw, 340px);
      --mellow-who-icon-size: 62px;
      --mellow-who-icon-svg-size: 28px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
      display: block;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
      max-width: 620px;
      font-size: clamp(38px, 10.8vw, 52px);
      line-height: 0.98;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
      margin-top: clamp(20px, 6vw, 30px);
      font-size: 17px;
      line-height: 1.5;
      max-width: 360px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
      width: 100%;
      margin-top: 0;
      margin-bottom: 0;
      padding-left: 0;
      border-left: 0;
      transform: none;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-action {
      width: 100%;
      justify-content: flex-start;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button {
      --mellow-section-cta-width: min(100%, 280px);
      min-height: 54px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
      padding-bottom: 8px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      width: var(--mellow-who-card-width);
      min-height: 360px;
      padding: 24px;
      transform: none !important;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
      transform: none !important;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
      margin-top: 22px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy h3 {
      font-size: 25px;
      line-height: 1.06;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy p {
      font-size: 15.5px;
      line-height: 1.42;
      letter-spacing: 0;
    }
  }
</style>

<section
  id="MellowWhoItsFor-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-who-its-for color-{{ section.settings.color_scheme }}"
  data-mellow-who-carousel
>
  <div class="mellow-who-its-for__intro">
    <div class="mellow-section-axis mellow-who-its-for__inner">
      <div class="mellow-section-header-grid mellow-who-its-for__header-wrap">
        <div class="mellow-section-header mellow-who-its-for__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="mellow-eyebrow mellow-who-its-for__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            {%- assign heading_lines = section.settings.heading | escape | split: '|' -%}
            <h2 class="mellow-section-heading mellow-who-its-for__heading">
              {%- for line in heading_lines -%}
                {{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}
              {%- endfor -%}
            </h2>
          {%- endif -%}
        </div>

        <span class="mellow-who-its-for__intro-divider" aria-hidden="true"></span>

        <div class="mellow-section-actions mellow-who-its-for__header-actions">
          {%- if section.settings.text != blank -%}
            <p class="mellow-section-text mellow-who-its-for__text">{{ section.settings.text | escape }}</p>
          {%- endif -%}

          <div class="mellow-section-cta-wrap mellow-who-its-for__quiz-action">
            <a class="mellow-section-cta mellow-section-cta--primary-forest mellow-who-its-for__quiz-button" href="/pages/quiz">
              <span class="mellow-section-cta__label mellow-who-its-for__quiz-label">Take the reflux quiz</span>
              <span class="mellow-section-cta__arrow mellow-who-its-for__quiz-arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-who-its-for__shelf">
    <div class="mellow-who-its-for__carousel-wrap" aria-label="Real-life reflux moments carousel">
      <div class="mellow-who-its-for__carousel" data-mellow-who-carousel-stage>
        <div class="mellow-who-its-for__track" data-mellow-who-track>
          {%- liquid
            assign cards = 'After dinner|Rich foods can put pressure on your digestive system.|fork-knife|Most Common||Nighttime reflux|When symptoms hit right as you’re trying to fall asleep.|moon|Bedtime Use||Chronic reflux|When it keeps coming back — day after day, night after night.|droplet|Most Searched||During pregnancy|Hormonal shifts and added pressure can bring reflux when you least expect it.|pregnancy|Common Trigger||Active lifestyles|You love to move. Reflux shouldn’t slow you down.|bolt|Active Lifestyle||Stress & pressure|Life gets stressful. Reflux often follows.|target|Stress Trigger' | split: '||'
          -%}

          <div class="mellow-who-its-for__card-set" data-mellow-who-card-set>
            {%- for card in cards -%}
              {%- liquid
                assign card_parts = card | split: '|'
                assign card_title = card_parts[0]
                assign card_text = card_parts[1]
                assign card_icon = card_parts[2]
                assign card_tag = card_parts[3]
              -%}

              <article
                class="mellow-who-its-for__card{% if forloop.index0 == 2 %} is-active{% endif %}"
                data-mellow-who-card
                data-mellow-who-index="{{ forloop.index0 }}"
              >
                <div class="mellow-who-its-for__card-inner">
                  <div class="mellow-who-its-for__icon" aria-hidden="true">
                    {%- case card_icon -%}
                      {%- when 'fork-knife' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3v8"/><path d="M4.5 3v5.5A2.5 2.5 0 0 0 7 11a2.5 2.5 0 0 0 2.5-2.5V3"/><path d="M7 11v10"/><path d="M16.5 3c2 1.7 3 4 3 7 0 2.4-1.2 4-3 4V3Z"/><path d="M16.5 14v7"/></svg>
                      {%- when 'droplet' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5s-6 7.1-6 11.4a6 6 0 0 0 12 0C18 10.6 12 3.5 12 3.5Z"/><path d="M9.5 15.5c.5 1.3 1.4 2.1 2.8 2.3"/></svg>
                      {%- when 'moon' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M18.5 15.8A7.8 7.8 0 0 1 8.2 5.5a8.2 8.2 0 1 0 10.3 10.3Z"/></svg>
                      {%- when 'pregnancy' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0Z"/><path d="M8.7 8c-2.7 1.7-4.2 4.3-4.2 7.5 0 3.7 2.4 5.8 5.8 5.8 3 0 5.3-1.9 5.3-4.8 0-3.3-2.4-6.1-5.8-6.4"/><path d="M8 15c1.5-.9 3.9-.9 5.4.3"/></svg>
                      {%- when 'bolt' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m13 2.8-7.5 11h5.8L9.8 21.2l8.7-12h-6L13 2.8Z"/></svg>
                      {%- when 'target' -%}
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="4"/><path d="M12 12h.1"/></svg>
                    {%- endcase -%}
                  </div>

                  {%- if card_tag != blank -%}
                    <span class="mellow-card-tag mellow-who-its-for__tag">{{ card_tag | escape }}</span>
                  {%- endif -%}

                  <div class="mellow-who-its-for__card-copy">
                    <h3 class="mellow-card-title">{{ card_title | escape }}</h3>
                    <span class="mellow-who-its-for__divider" aria-hidden="true"></span>
                    <p class="mellow-card-copy">{{ card_text | escape }}</p>
                  </div>

                  <span class="mellow-who-its-for__card-arrow" aria-hidden="true">→</span>
                </div>
              </article>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowWhoItsFor-{{ section.id }}');
    const releaseReadyHold = window.MellowReadyGate ? window.MellowReadyGate.hold() : null;

    if (!section) {
      if (releaseReadyHold) releaseReadyHold();
      return;
    }

    requestAnimationFrame(() => {
      const carousel = section.querySelector('[data-mellow-who-carousel-stage]');

      if (carousel) {
        carousel.scrollLeft = 0;
      }

      section.classList.add('is-mellow-section-ready');

      if (releaseReadyHold) releaseReadyHold();
    });
  })();
</script>

