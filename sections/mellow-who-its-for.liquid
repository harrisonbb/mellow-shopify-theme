{% comment %}
  Mellow who it’s for section.
  Full-bleed forest green carousel for real-life reflux moments.
{% endcomment %}

<section
  id="MellowWhoItsFor-{{ section.id }}"
  class="mellow-section mellow-who-its-for color-{{ section.settings.color_scheme }}"
  data-mellow-who-carousel
>
  <div class="mellow-who-its-for__inner">
    <div class="mellow-who-its-for__header-wrap">
      <div class="mellow-who-its-for__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-who-its-for__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-who-its-for__heading">{{ section.settings.heading | escape | replace: 'more moments', 'more<br>moments' }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-who-its-for__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-who-its-for__header-actions">
        <div class="mellow-who-its-for__quiz-action">
          <a class="mellow-who-its-for__quiz-button" href="/pages/quiz">Take the reflux quiz</a>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-who-its-for__carousel-wrap" aria-label="Real-life reflux moments carousel">
    <div class="mellow-who-its-for__carousel" data-mellow-who-carousel-stage>
      <div class="mellow-who-its-for__track" data-mellow-who-track>
        {%- liquid
          assign cards = 'Big meal lovers|Large portions and rich foods can put extra pressure on your digestive system.|fork-knife|Most Common||Nighttime reflux|When symptoms hit right as you’re trying to fall asleep.|moon|Bedtime Use||Chronic reflux|When it keeps coming back — day after day, night after night.|droplet|Most Searched||During pregnancy|Hormonal shifts and added pressure can bring reflux when you least expect it.|pregnancy||Active lifestyles|You love to move. Reflux shouldn’t slow you down.|bolt||Stress & pressure|Life gets stressful. Reflux often follows.|target||After bariatric surgery|Your new normal deserves real, comfortable relief.|shield||Smokers & vapers|Smoking and vaping can make reflux worse. Relief still matters.|smoke' | split: '||'
        -%}

        {%- for card_loop in (1..3) -%}
          {%- assign is_original_set = false -%}
          {%- if card_loop == 2 -%}
            {%- assign is_original_set = true -%}
          {%- endif -%}

          <div
            class="mellow-who-its-for__card-set"
            {% if is_original_set %}
              data-mellow-who-card-set
            {% else %}
              data-mellow-who-card-set-duplicate
              aria-hidden="true"
            {% endif %}
          >
            {%- for card in cards -%}
              {%- liquid
                assign card_parts = card | split: '|'
                assign card_title = card_parts[0]
                assign card_text = card_parts[1]
                assign card_icon = card_parts[2]
                assign card_tag = card_parts[3]
              -%}
              <article
                class="mellow-who-its-for__card"
                {% if is_original_set %}
                  data-mellow-who-card
                {% endif %}
                data-mellow-who-index="{{ forloop.index0 }}"
              >
                {%- if card_tag != blank -%}
                  <span class="mellow-who-its-for__tag">{{ card_tag | escape }}</span>
                {%- endif -%}
                <div class="mellow-who-its-for__icon" aria-hidden="true">
                  {%- case card_icon -%}
                    {%- when 'fork-knife' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M15 7v14M9 7v12c0 4 3 7 6 7s6-3 6-7V7M15 26v15M33 7c4 4 6 9 6 15 0 5-3 8-6 8V7Zm0 23v11"/></svg>
                    {%- when 'droplet' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6S12 20 12 30c0 7 5 12 12 12s12-5 12-12C36 20 24 6 24 6Z"/><path d="M19 31c1 3 3 5 6 5"/></svg>
                    {%- when 'moon' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M32 39c-12 0-22-10-22-22 0-3 1-6 2-9 3 7 10 12 18 12 4 0 7-1 10-3-1 12-7 22-8 22Z"/></svg>
                    {%- when 'pregnancy' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M25 9a5 5 0 1 1-10 0 5 5 0 0 1 10 0Z"/><path d="M20 15c-5 3-8 8-8 15 0 8 5 12 12 12 6 0 11-4 11-10 0-7-5-13-12-13"/><path d="M18 28c3-2 8-2 11 1"/></svg>
                    {%- when 'bolt' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M28 5 12 27h12l-4 16 16-23H24l4-15Z"/></svg>
                    {%- when 'target' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><circle cx="24" cy="24" r="17"/><circle cx="24" cy="24" r="9"/><path d="M24 24h.1"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6 38 12v10c0 9-5 16-14 20-9-4-14-11-14-20V12l14-6Z"/><path d="M18 24l4 4 8-9"/></svg>
                    {%- when 'smoke' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M9 32h18M31 32h8M11 23c4-5 11 2 15-4 2-3-1-6-4-8M31 24c3-3 9 0 8-7"/></svg>
                  {%- endcase -%}
                </div>

                <div class="mellow-who-its-for__card-copy">
                  <h3>{{ card_title | escape }}</h3>
                  <span class="mellow-who-its-for__divider" aria-hidden="true"></span>
                  <p>{{ card_text | escape }}</p>
                </div>

              </article>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>
<script>
  (() => {
    const section = document.getElementById('MellowWhoItsFor-{{ section.id }}');

    if (!section) {
      return;
    }

    const scroller = section.querySelector('[data-mellow-who-carousel-stage]');
    const track = section.querySelector('[data-mellow-who-track]');
    const cardSet = section.querySelector('[data-mellow-who-card-set]');

    if (!scroller || !track || !cardSet) {
      return;
    }

    const marqueeDuration = 90000;
    let setWidth = 0;
    let offset = 0;
    let animationFrame = null;
    let lastFrameTime = null;

    const applySafeOffset = () => {
      if (setWidth <= 0) {
        return;
      }

      while (offset <= setWidth * -2) {
        offset += setWidth;
      }

      while (offset >= 0) {
        offset -= setWidth;
      }
    };

    const updateTrackPosition = () => {
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    const measureCarousel = () => {
      setWidth = cardSet.getBoundingClientRect().width;

      if (setWidth <= 0) {
        return;
      }

      offset = setWidth * -1;
      track.style.setProperty('--who-track-width', `${setWidth}px`);
      updateTrackPosition();
    };

    const animate = (timestamp) => {
      if (setWidth > 0) {
        if (lastFrameTime === null) {
          lastFrameTime = timestamp;
        }

        const elapsed = timestamp - lastFrameTime;
        const pixelsPerMillisecond = setWidth / marqueeDuration;

        offset -= pixelsPerMillisecond * elapsed;
        applySafeOffset();
        updateTrackPosition();
        lastFrameTime = timestamp;
      }

      animationFrame = requestAnimationFrame(animate);
    };

    const normalizeWheelDelta = (delta, deltaMode) => {
      if (deltaMode === WheelEvent.DOM_DELTA_LINE) {
        return delta * 16;
      }

      if (deltaMode === WheelEvent.DOM_DELTA_PAGE) {
        return delta * scroller.clientWidth;
      }

      return delta;
    };

    const handleResize = () => {
      lastFrameTime = null;
      measureCarousel();
    };

    measureCarousel();

    if ('ResizeObserver' in window) {
      const resizeObserver = new ResizeObserver(handleResize);
      resizeObserver.observe(cardSet);
      resizeObserver.observe(scroller);
    } else {
      window.addEventListener('resize', handleResize);
    }

    scroller.addEventListener(
      'wheel',
      (event) => {
        const horizontalDelta = normalizeWheelDelta(event.deltaX, event.deltaMode);
        const verticalDelta = normalizeWheelDelta(event.deltaY, event.deltaMode);
        const isIntentionalHorizontalScroll = Math.abs(horizontalDelta) > Math.abs(verticalDelta) * 1.35;

        if (!isIntentionalHorizontalScroll || setWidth <= 0) {
          return;
        }

        event.preventDefault();
        offset -= horizontalDelta;
        applySafeOffset();
        updateTrackPosition();
        lastFrameTime = null;
      },
      { passive: false }
    );

    animationFrame = requestAnimationFrame(animate);

    document.addEventListener('shopify:section:unload', (event) => {
      if (!event.target.contains(section)) {
        return;
      }

      cancelAnimationFrame(animationFrame);
    });
  })();
</script>
{% schema %}
{
  "name": "Mellow who it’s for",
  "tag": "section",
  "class": "section section-mellow-who-its-for",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL-LIFE REFLUX MOMENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reflux shows up in more moments than you think."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Mellow was designed for the real-life moments that trigger reflux — not just the symptom."
    }
  ],
  "presets": [
    {
      "name": "Mellow who it’s for"
    }
  ]
}
{% endschema %}
