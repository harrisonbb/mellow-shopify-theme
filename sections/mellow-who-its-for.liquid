{% comment %}
  Mellow who it’s for section.
  Full-bleed forest green carousel for real-life reflux moments.
{% endcomment %}

<style>
  #MellowWhoItsFor-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: clamp(64px, 5.5vw, 92px);
    padding-bottom: clamp(52px, 5vw, 76px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    --mellow-who-edge-pad: clamp(28px, 4vw, 64px);
    padding-left: var(--mellow-who-edge-pad);
    padding-right: var(--mellow-who-edge-pad);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 760px) auto;
    align-items: center;
    gap: clamp(40px, 6vw, 96px);
    margin-bottom: clamp(22px, 2.6vw, 36px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header {
    max-width: 760px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__eyebrow {
    margin: 0 0 18px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
    margin: 0;
    max-width: 760px;
    font-size: clamp(44px, 4.1vw, 62px);
    line-height: 0.98;
    font-weight: 600;
    letter-spacing: -0.032em;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
    max-width: 620px;
    margin: 22px 0 0;
    font-size: clamp(18px, 1.32vw, 20px);
    line-height: 1.46;
    font-weight: 400;
    letter-spacing: -0.005em;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
    justify-self: end;
    align-self: center;
    transform: none;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    overflow: hidden;
    position: relative;
    white-space: nowrap;
    transition:
      padding 260ms cubic-bezier(0.22, 1, 0.36, 1),
      gap 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button::after {
    content: none !important;
    display: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-label {
    display: inline-block;
    transition: transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-arrow {
    display: inline-block;
    width: 0;
    max-width: 0;
    margin-left: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateX(-8px);
    transition:
      width 260ms cubic-bezier(0.22, 1, 0.36, 1),
      max-width 260ms cubic-bezier(0.22, 1, 0.36, 1),
      margin-left 260ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button:hover .mellow-who-its-for__quiz-arrow,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button:focus-visible .mellow-who-its-for__quiz-arrow {
    width: 0.9em;
    max-width: 0.9em;
    margin-left: 8px;
    transform: translateX(0);
    opacity: 1;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button:hover .mellow-who-its-for__quiz-label,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button:focus-visible .mellow-who-its-for__quiz-label {
    transform: translateX(-1px);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: 10px;
    padding-bottom: 70px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    position: relative;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__track {
    display: flex;
    width: max-content;
    max-width: none;
    gap: clamp(28px, 2.6vw, 42px);
    align-items: center;
    will-change: transform;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-set {
    display: flex;
    gap: clamp(28px, 2.6vw, 42px);
    align-items: center;
    flex: 0 0 auto;
  }

  /*
    IMPORTANT:
    The visible cream surface now lives on the OUTER article.
    This avoids the sharp corner artifact caused by expanding/scaling an inner rounded rectangle.
  */
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
    flex: 0 0 auto;
    position: relative;
    width: clamp(330px, 28vw, 430px);
    height: clamp(300px, 24vw, 370px);
    padding: 52px 36px 36px;

    background: #f4ede0 !important;
    background-image: none !important;
    border: 1px solid rgba(180, 130, 72, 0.22) !important;
    border-radius: 24px !important;
    outline: 0 !important;
    box-shadow: none;
    background-clip: padding-box;

    overflow: hidden;
    transform: scale(0.98) translate3d(0, 0, 0);
    transform-origin: center center;
    backface-visibility: hidden;
    will-change: transform, box-shadow, filter;
    z-index: 1;

    -webkit-mask-image: -webkit-radial-gradient(white, black);
    transition:
      transform 650ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 650ms ease,
      filter 650ms ease;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
    transform: scale(1.09) translate3d(0, 0, 0);
    z-index: 20;

    background: #f4ede0 !important;
    background-image: none !important;
    border: 1px solid rgba(180, 130, 72, 0.22) !important;
    border-radius: 24px !important;
    outline: 0 !important;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.2);
    background-clip: padding-box;
    filter: none;

    -webkit-mask-image: -webkit-radial-gradient(white, black);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card:not(.is-active) {
    opacity: 1;
    filter: brightness(0.96) saturate(0.98);
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner {
    position: relative;
    height: 100%;
    width: 100%;
    padding: 0;
    overflow: visible;

    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active .mellow-who-its-for__card-inner {
    background: transparent !important;
    background-image: none !important;
    border: 0 !important;
    border-radius: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    transform: none !important;
    filter: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card::after,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::before,
  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-inner::after {
    content: none !important;
    display: none !important;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__tag {
    position: absolute;
    top: 22px;
    right: 22px;
    margin: 0;
    transform: none;
    letter-spacing: 0.13em;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy {
    margin-top: 28px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy h3 {
    margin: 0;
    font-size: clamp(25px, 1.8vw, 30px);
    line-height: 1.04;
    font-weight: 560;
    letter-spacing: -0.032em;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__divider {
    display: block;
    width: 48px;
    height: 2px;
    margin-top: 12px;
    margin-bottom: 18px;
  }

  #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card-copy p {
    margin: 0;
    max-width: 94%;
    font-size: clamp(16px, 1.03vw, 17px);
    line-height: 1.48;
    font-weight: 400;
    letter-spacing: -0.006em;
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-button,
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-label,
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__quiz-arrow,
    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      transition: none;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWhoItsFor-{{ section.id }} {
      padding-top: 56px;
      padding-bottom: 56px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__inner {
      --mellow-who-edge-pad: 22px;
      padding-left: var(--mellow-who-edge-pad);
      padding-right: var(--mellow-who-edge-pad);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-wrap {
      display: block;
      margin-bottom: 24px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__heading {
      font-size: clamp(38px, 10vw, 48px);
      line-height: 1;
      letter-spacing: -0.034em;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__text {
      font-size: 16px;
      line-height: 1.45;
      max-width: 360px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__header-actions {
      margin-top: 28px;
      transform: none;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__carousel-wrap {
      padding-top: 14px;
      padding-bottom: 52px;
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card {
      width: 320px;
      height: 300px;
      padding: 44px 28px 30px;
      border-radius: 22px !important;
      transform: scale(0.98) translate3d(0, 0, 0);
    }

    #MellowWhoItsFor-{{ section.id }} .mellow-who-its-for__card.is-active {
      transform: scale(1.05) translate3d(0, 0, 0);
      border-radius: 22px !important;
    }
  }
</style>

<section
  id="MellowWhoItsFor-{{ section.id }}"
  class="mellow-section mellow-who-its-for color-{{ section.settings.color_scheme }}"
  data-mellow-who-carousel
>
  <div class="mellow-who-its-for__inner">
    <div class="mellow-who-its-for__header-wrap">
      <div class="mellow-who-its-for__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-who-its-for__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-who-its-for__heading">
            {{ section.settings.heading | escape | replace: 'more moments', 'more<br>moments' | replace: 'think.', 'think' }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-who-its-for__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-who-its-for__header-actions">
        <div class="mellow-who-its-for__quiz-action">
          <a class="mellow-who-its-for__quiz-button" href="/pages/quiz">
            <span class="mellow-who-its-for__quiz-label">Take the reflux quiz</span>
            <span class="mellow-who-its-for__quiz-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-who-its-for__carousel-wrap" aria-label="Real-life reflux moments carousel">
    <div class="mellow-who-its-for__carousel" data-mellow-who-carousel-stage>
      <div class="mellow-who-its-for__track" data-mellow-who-track>
        {%- liquid
          assign cards = 'Big meal lovers|Large portions and rich foods can put extra pressure on your digestive system.|fork-knife|Most Common||Nighttime reflux|When symptoms hit right as you’re trying to fall asleep.|moon|Bedtime Use||Chronic reflux|When it keeps coming back — day after day, night after night.|droplet|Most Searched||During pregnancy|Hormonal shifts and added pressure can bring reflux when you least expect it.|pregnancy||Active lifestyles|You love to move. Reflux shouldn’t slow you down.|bolt||Stress & pressure|Life gets stressful. Reflux often follows.|target||After surgery|Your new normal deserves real, comfortable relief.|shield||Smokers & vapers|Smoking and vaping can make reflux worse. Relief still matters.|smoke' | split: '||'
        -%}

        {%- for card_loop in (1..3) -%}
          {%- assign is_original_set = false -%}
          {%- if card_loop == 2 -%}
            {%- assign is_original_set = true -%}
          {%- endif -%}

          <div
            class="mellow-who-its-for__card-set"
            {% if is_original_set %}
              data-mellow-who-card-set
            {% else %}
              data-mellow-who-card-set-duplicate
              aria-hidden="true"
            {% endif %}
          >
            {%- for card in cards -%}
              {%- liquid
                assign card_parts = card | split: '|'
                assign card_title = card_parts[0]
                assign card_text = card_parts[1]
                assign card_icon = card_parts[2]
                assign card_tag = card_parts[3]
              -%}

              <article
                class="mellow-who-its-for__card"
                {% if is_original_set %}
                  data-mellow-who-card
                {% endif %}
                data-mellow-who-index="{{ forloop.index0 }}"
              >
                <div class="mellow-who-its-for__card-inner">
                  {%- if card_tag != blank -%}
                    <span class="mellow-who-its-for__tag">{{ card_tag | escape }}</span>
                  {%- endif -%}

                  <div class="mellow-who-its-for__icon mellow-who-its-for__icon--{{ card_icon }}" aria-hidden="true">
                    {%- case card_icon -%}
                      {%- when 'fork-knife' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M15 7v14M9 7v12c0 4 3 7 6 7s6-3 6-7V7M15 26v15"/><path d="M33 7c4 4 6 9 6 15 0 5-3 8-6 8V7Zm0 23v11"/></svg>
                      {%- when 'droplet' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6S12 20 12 30c0 7 5 12 12 12s12-5 12-12C36 20 24 6 24 6Z"/><path d="M19 31c1 3 3 5 6 5"/></svg>
                      {%- when 'moon' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M32 39c-12 0-22-10-22-22 0-3 1-6 2-9 3 7 10 12 18 12 4 0 7-1 10-3-1 12-7 22-8 22Z"/></svg>
                      {%- when 'pregnancy' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M25 9a5 5 0 1 1-10 0 5 5 0 0 1 10 0Z"/><path d="M20 15c-5 3-8 8-8 15 0 8 5 12 12 12 6 0 11-4 11-10 0-7-5-13-12-13"/><path d="M18 28c3-2 8-2 11 1"/></svg>
                      {%- when 'bolt' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M28 5 12 27h12l-4 16 16-23H24l4-15Z"/></svg>
                      {%- when 'target' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><circle cx="24" cy="24" r="17"/><circle cx="24" cy="24" r="9"/><path d="M24 24h.1"/></svg>
                      {%- when 'shield' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6 38 12v10c0 9-5 16-14 20-9-4-14-11-14-20V12l14-6Z"/><path d="M18 24l4 4 8-9"/></svg>
                      {%- when 'smoke' -%}
                        <svg viewBox="0 0 48 48" focusable="false"><path d="M9 32h18M31 32h8"/><path d="M11 23c4-5 11 2 15-4 2-3-1-6-4-8"/><path d="M31 24c3-3 9 0 8-7"/></svg>
                    {%- endcase -%}
                  </div>

                  <div class="mellow-who-its-for__card-copy">
                    <h3>{{ card_title | escape }}</h3>
                    <span class="mellow-who-its-for__divider" aria-hidden="true"></span>
                    <p>{{ card_text | escape }}</p>
                  </div>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowWhoItsFor-{{ section.id }}');

    if (!section) {
      return;
    }

    const scroller = section.querySelector('[data-mellow-who-carousel-stage]');
    const track = section.querySelector('[data-mellow-who-track]');
    const cardSet = section.querySelector('[data-mellow-who-card-set]');
    const getMomentCards = () => Array.from(section.querySelectorAll('.mellow-who-its-for__card'));

    if (!scroller || !track || !cardSet || !getMomentCards().length) {
      return;
    }

    const marqueeDuration = 90000;
    let setWidth = 0;
    let offset = 0;
    let animationFrame = null;
    let lastFrameTime = null;
    let resizeObserver = null;

    const applySafeOffset = () => {
      if (setWidth <= 0) {
        return false;
      }

      let didWrap = false;

      while (offset <= setWidth * -1.5) {
        offset += setWidth;
        didWrap = true;
      }

      while (offset >= setWidth * -0.5) {
        offset -= setWidth;
        didWrap = true;
      }

      return didWrap;
    };

    const updateTrackPosition = () => {
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    let activeCard = null;
    let activeUpdateFrame = null;
    let ticking = false;

    const getDistanceFromCenter = (card) => {
      const rect = card.getBoundingClientRect();
      const cardCenter = rect.left + rect.width / 2;
      const viewportCenter = window.innerWidth / 2;

      return Math.abs(cardCenter - viewportCenter);
    };

    const getVisibleCards = () => getMomentCards().filter((card) => {
      const rect = card.getBoundingClientRect();

      return (
        card.offsetParent !== null &&
        rect.width > 0 &&
        rect.height > 0 &&
        rect.right > 0 &&
        rect.left < window.innerWidth
      );
    });

    const clearInactiveCards = (nextActiveCard) => {
      getMomentCards().forEach((card) => {
        if (card !== nextActiveCard && card.classList.contains('is-active')) {
          card.classList.remove('is-active');
        }
      });
    };

    const setActiveCard = (nextActiveCard) => {
      clearInactiveCards(nextActiveCard);
      nextActiveCard.classList.add('is-active');
      activeCard = nextActiveCard;
    };

    const updateActiveMomentCard = () => {
      const visibleCards = getVisibleCards();

      if (!visibleCards.length) {
        return;
      }

      let closestCard = visibleCards[0];
      let closestDistance = getDistanceFromCenter(closestCard);

      visibleCards.forEach((card) => {
        const distance = getDistanceFromCenter(card);

        if (distance < closestDistance) {
          closestDistance = distance;
          closestCard = card;
        }
      });

      if (!activeCard || !visibleCards.includes(activeCard)) {
        setActiveCard(closestCard);
        return;
      }

      const activeDistance = getDistanceFromCenter(activeCard);
      const switchThreshold = 48;

      if (closestCard !== activeCard && closestDistance + switchThreshold < activeDistance) {
        setActiveCard(closestCard);
      }
    };

    const requestActiveCardUpdate = () => {
      if (ticking) {
        return;
      }

      ticking = true;

      activeUpdateFrame = requestAnimationFrame(() => {
        updateActiveMomentCard();
        ticking = false;
        activeUpdateFrame = null;
      });
    };

    const measureCarousel = () => {
      const trackGap = parseFloat(window.getComputedStyle(track).columnGap) || 0;
      setWidth = cardSet.getBoundingClientRect().width + trackGap;

      if (setWidth <= 0) {
        return;
      }

      offset = setWidth * -1;
      track.style.setProperty('--who-track-width', `${setWidth}px`);
      updateTrackPosition();
      requestActiveCardUpdate();
    };

    const animate = (timestamp) => {
      if (setWidth > 0) {
        if (lastFrameTime === null) {
          lastFrameTime = timestamp;
        }

        const elapsed = timestamp - lastFrameTime;
        const pixelsPerMillisecond = setWidth / marqueeDuration;

        offset -= pixelsPerMillisecond * elapsed;
        const didWrap = applySafeOffset();
        updateTrackPosition();

        if (didWrap) {
          activeCard = null;

          getMomentCards().forEach((card) => {
            card.classList.remove('is-active');
          });

          requestActiveCardUpdate();
        }

        lastFrameTime = timestamp;
      }

      animationFrame = requestAnimationFrame(animate);
    };

    const normalizeWheelDelta = (delta, deltaMode) => {
      if (deltaMode === WheelEvent.DOM_DELTA_LINE) {
        return delta * 16;
      }

      if (deltaMode === WheelEvent.DOM_DELTA_PAGE) {
        return delta * scroller.clientWidth;
      }

      return delta;
    };

    const handleResize = () => {
      lastFrameTime = null;
      measureCarousel();
      requestActiveCardUpdate();
    };

    measureCarousel();

    if ('ResizeObserver' in window) {
      resizeObserver = new ResizeObserver(handleResize);
      resizeObserver.observe(cardSet);
      resizeObserver.observe(scroller);
    } else {
      window.addEventListener('resize', handleResize);
    }

    scroller.addEventListener(
      'wheel',
      (event) => {
        const horizontalDelta = normalizeWheelDelta(event.deltaX, event.deltaMode);
        const verticalDelta = normalizeWheelDelta(event.deltaY, event.deltaMode);
        const isIntentionalHorizontalScroll = Math.abs(horizontalDelta) > Math.abs(verticalDelta) * 1.05;

        if (!isIntentionalHorizontalScroll || setWidth <= 0) {
          return;
        }

        event.preventDefault();
        offset -= horizontalDelta;
        applySafeOffset();
        updateTrackPosition();
        requestActiveCardUpdate();
        lastFrameTime = null;
      },
      { passive: false }
    );

    const activeUpdateInterval = setInterval(requestActiveCardUpdate, 140);

    requestActiveCardUpdate();

    window.addEventListener('resize', requestActiveCardUpdate, { passive: true });
    window.addEventListener('scroll', requestActiveCardUpdate, { passive: true });

    animationFrame = requestAnimationFrame(animate);

    document.addEventListener('shopify:section:unload', (event) => {
      if (!event.target.contains(section)) {
        return;
      }

      cancelAnimationFrame(animationFrame);
      clearInterval(activeUpdateInterval);
      window.removeEventListener('resize', requestActiveCardUpdate, { passive: true });
      window.removeEventListener('scroll', requestActiveCardUpdate, { passive: true });

      if (activeUpdateFrame) {
        cancelAnimationFrame(activeUpdateFrame);
      }

      if (resizeObserver) {
        resizeObserver.disconnect();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Mellow who it’s for",
