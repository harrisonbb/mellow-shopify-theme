{% comment %}
  Mellow who it’s for section.
  Full-bleed forest green carousel for real-life reflux moments.
{% endcomment %}

<section
  id="MellowWhoItsFor-{{ section.id }}"
  class="mellow-section mellow-who-its-for color-{{ section.settings.color_scheme }}"
  data-mellow-who-carousel
>
  <div class="mellow-who-its-for__inner">
    <div class="mellow-who-its-for__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="mellow-eyebrow mellow-who-its-for__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <div class="mellow-who-its-for__wave" aria-hidden="true">
          <svg viewBox="0 0 88 18" focusable="false">
            <path d="M2 9c7-8 15-8 22 0s15 8 22 0 15-8 22 0 12 8 18 0" />
          </svg>
        </div>
        <h2 class="mellow-who-its-for__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <p class="mellow-who-its-for__text">{{ section.settings.text | escape }}</p>
      {%- endif -%}

    </div>
  </div>

  <div class="mellow-who-its-for__carousel-wrap" aria-label="Real-life reflux moments carousel">
    <div class="mellow-who-its-for__carousel" data-mellow-who-scroller tabindex="0">
      <div class="mellow-who-its-for__track" data-mellow-who-track>
        {%- liquid
            assign cards = 'Large meals & rich foods|Heavy meals and late dinners can add pressure.|fork-knife||Chronic reflux|When reflux keeps coming back.|droplet||Nighttime reflux|When symptoms hit before sleep.|moon||During pregnancy|Shifts and pressure can trigger reflux.|heart||Active lifestyles|Reflux shouldn’t slow you down.|bolt||Stress & pressure|Life gets stressful. Reflux often follows.|target||After bariatric surgery|Your new normal deserves comfortable relief.|shield||Smokers & vapers|Smoking and vaping can make reflux worse.|smoke' | split: '||'
        -%}

        {%- for duplicate_index in (1..2) -%}
            {%- for card in cards -%}
              {%- liquid
                assign card_parts = card | split: '|'
                assign card_title = card_parts[0]
                assign card_text = card_parts[1]
                assign card_icon = card_parts[2]
              -%}
              <article class="mellow-who-its-for__card" data-mellow-who-card{% if duplicate_index == 2 %} aria-hidden="true"{% endif %}>
                <div class="mellow-who-its-for__icon" aria-hidden="true">
                  {%- case card_icon -%}
                    {%- when 'fork-knife' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M15 7v14M9 7v12c0 4 3 7 6 7s6-3 6-7V7M15 26v15M33 7c4 4 6 9 6 15 0 5-3 8-6 8V7Zm0 23v11"/></svg>
                    {%- when 'droplet' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6S12 20 12 30c0 7 5 12 12 12s12-5 12-12C36 20 24 6 24 6Z"/><path d="M19 31c1 3 3 5 6 5"/></svg>
                    {%- when 'moon' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M32 39c-12 0-22-10-22-22 0-3 1-6 2-9 3 7 10 12 18 12 4 0 7-1 10-3-1 12-7 22-8 22Z"/></svg>
                    {%- when 'heart' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M24 40S10 31 10 19c0-5 4-9 9-9 3 0 5 1 5 4 0-3 3-4 6-4 5 0 8 4 8 9 0 12-14 21-14 21Z"/><path d="M18 25c3 2 9 2 12 0"/></svg>
                    {%- when 'bolt' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M28 5 12 27h12l-4 16 16-23H24l4-15Z"/></svg>
                    {%- when 'target' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><circle cx="24" cy="24" r="17"/><circle cx="24" cy="24" r="9"/><path d="M24 24h.1"/></svg>
                    {%- when 'shield' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M24 6 38 12v10c0 9-5 16-14 20-9-4-14-11-14-20V12l14-6Z"/><path d="M18 24l4 4 8-9"/></svg>
                    {%- when 'smoke' -%}
                      <svg viewBox="0 0 48 48" focusable="false"><path d="M9 32h18M31 32h8M11 23c4-5 11 2 15-4 2-3-1-6-4-8M31 24c3-3 9 0 8-7"/></svg>
                  {%- endcase -%}
                </div>

                <div class="mellow-who-its-for__card-copy">
                  <h3>{{ card_title | escape }}</h3>
                  <span class="mellow-who-its-for__divider" aria-hidden="true"></span>
                  <p>{{ card_text | escape }}</p>
                </div>
              </article>
            {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="mellow-who-its-for__dots" aria-label="Carousel pagination" data-mellow-who-dots></div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowWhoItsFor-{{ section.id }}');

    if (!section || section.dataset.mellowWhoInitialized === 'true') return;
    section.dataset.mellowWhoInitialized = 'true';

    const scroller = section.querySelector('[data-mellow-who-scroller]');
    const track = section.querySelector('[data-mellow-who-track]');
    const dotsContainer = section.querySelector('[data-mellow-who-dots]');
    const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (!scroller || !track || !dotsContainer) return;

    let dots = [];
    let rafId;
    let lastTime;
    let x = 0;
    let setWidth = 0;
    let cardStep = 0;
    let cardsPerPage = 1;
    let pagePositions = [0];
    let hasMeasured = false;
    let isPointerDown = false;
    let isHovering = false;
    let pointerStartX = 0;
    let pointerStartXOffset = 0;
    let softPauseUntil = performance.now() + 1200;
    const baseSpeed = 30;
    const cardCount = Math.max(1, Math.floor(track.children.length / 2));

    const normalizePosition = () => {
      if (!setWidth) return;

      while (x <= -setWidth) x += setWidth;
      while (x > 0) x -= setWidth;
    };

    const currentCardIndex = () => {
      if (!cardStep) return 0;
      return Math.round(Math.abs(x) / cardStep) % cardCount;
    };

    const activePageIndex = () => {
      const current = currentCardIndex();
      let closestIndex = 0;
      let closestDistance = cardCount;

      pagePositions.forEach((position, index) => {
        const distance = Math.min(
          Math.abs(current - position),
          cardCount - Math.abs(current - position)
        );

        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    const updateDots = () => {
      const current = activePageIndex();
      dots.forEach((dot, index) => {
        const isActive = index === current;
        dot.classList.toggle('is-active', isActive);
        dot.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const render = () => {
      track.style.transform = `translate3d(${x}px, 0, 0)`;
      updateDots();
    };

    const buildDots = () => {
      dotsContainer.textContent = '';

      pagePositions.forEach((position, index) => {
        const dot = document.createElement('button');
        dot.className = `mellow-who-its-for__dot${index === 0 ? ' is-active' : ''}`;
        dot.type = 'button';
        dot.setAttribute('aria-label', `Go to carousel page ${index + 1}`);
        dot.setAttribute('aria-current', index === 0 ? 'true' : 'false');
        dot.dataset.mellowWhoPosition = String(position);

        dot.addEventListener('click', () => {
          x = -(position * cardStep);
          normalizePosition();
          render();
          softenAutoplay(1800);
        });

        dotsContainer.appendChild(dot);
      });

      dots = Array.from(dotsContainer.children);
    };

    const measure = () => {
      const firstCard = track.children[0];
      const firstDuplicate = track.children[cardCount];
      const styles = window.getComputedStyle(track);
      const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;

      cardStep = firstCard ? firstCard.getBoundingClientRect().width + gap : 0;
      setWidth = firstDuplicate ? firstDuplicate.offsetLeft : cardStep * cardCount;
      cardsPerPage = cardStep ? Math.max(1, Math.floor((scroller.clientWidth + gap) / cardStep)) : 1;
      pagePositions = [];

      for (let position = 0; position < cardCount; position += cardsPerPage) {
        pagePositions.push(position);
      }

      if (!pagePositions.length) pagePositions = [0];

      if (!hasMeasured) {
        x = 0;
        hasMeasured = true;
      } else {
        normalizePosition();
      }

      buildDots();
      render();
    };

    const moveBy = (amount) => {
      x -= amount;
      normalizePosition();
      render();
    };

    const softenAutoplay = (duration = 1200) => {
      softPauseUntil = Math.max(softPauseUntil, performance.now() + duration);
    };

    const tick = (time) => {
      if (lastTime === undefined) lastTime = time;
      const delta = Math.min(time - lastTime, 64) / 1000;
      lastTime = time;

      if (!mediaQuery.matches && !isPointerDown && !isHovering && time > softPauseUntil) {
        moveBy(baseSpeed * delta);
      }

      rafId = window.requestAnimationFrame(tick);
    };

    const endDrag = (event) => {
      if (!isPointerDown) return;
      isPointerDown = false;
      scroller.classList.remove('is-dragging');
      if (event.pointerId && scroller.hasPointerCapture(event.pointerId)) {
        scroller.releasePointerCapture(event.pointerId);
      }
      softenAutoplay(1400);
    };

    scroller.addEventListener('wheel', (event) => {
      const horizontalIntent = Math.abs(event.deltaX) > Math.abs(event.deltaY);
      const scrollAmount = horizontalIntent ? event.deltaX : event.deltaY;

      if (scrollAmount !== 0) {
        event.preventDefault();
        moveBy(scrollAmount);
        softenAutoplay();
      }
    }, { passive: false });

    scroller.addEventListener('pointerdown', (event) => {
      isPointerDown = true;
      pointerStartX = event.clientX;
      pointerStartXOffset = x;
      scroller.classList.add('is-dragging');
      scroller.setPointerCapture(event.pointerId);
      softenAutoplay(1800);
    });

    scroller.addEventListener('pointermove', (event) => {
      if (!isPointerDown) return;
      event.preventDefault();
      x = pointerStartXOffset + event.clientX - pointerStartX;
      normalizePosition();
      render();
    });

    scroller.addEventListener('pointerup', endDrag);
    scroller.addEventListener('pointercancel', endDrag);
    scroller.addEventListener('pointerleave', endDrag);
    scroller.addEventListener('mouseenter', () => {
      isHovering = true;
    });
    scroller.addEventListener('mouseleave', () => {
      isHovering = false;
      softenAutoplay(700);
    });
    scroller.addEventListener('focusin', () => softenAutoplay(1200));

    scroller.addEventListener('keydown', (event) => {
      if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
      event.preventDefault();
      moveBy(event.key === 'ArrowRight' ? cardStep : -cardStep);
      softenAutoplay(1600);
    });

    window.addEventListener('resize', measure, { passive: true });
    measure();
    rafId = window.requestAnimationFrame(tick);

    document.addEventListener('shopify:section:unload', (event) => {
      if (event.target.contains(section) && rafId) {
        window.cancelAnimationFrame(rafId);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Mellow who it’s for",
  "tag": "section",
  "class": "section section-mellow-who-its-for",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL-LIFE REFLUX MOMENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reflux shows up in more moments than you think."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Mellow was designed for the real-life moments that trigger reflux — not just the symptom."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Small pill text",
      "default": "Swipe, drag, or scroll to explore"
    }
  ],
  "presets": [
    {
      "name": "Mellow who it’s for"
    }
  ]
}
{% endschema %}
