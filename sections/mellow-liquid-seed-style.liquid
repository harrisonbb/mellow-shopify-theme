{% comment %}
  Mellow Liquid — Seed-Inspired Premium Hero Section
  EDITED:
  - Fixed illegibility over photo
  - Stronger dark overlay
  - White/ivory text
  - Darker frosted benefit panel
  - Better contrast for icons and copy
{% endcomment %}

<section
  class="mellow-liquid mellow-liquid-{{ section.id }}"
  id="mellow-liquid-{{ section.id }}"
>
  <div class="mellow-liquid__page">

    <div class="mellow-liquid__hero">

      {% if section.settings.hero_image != blank %}
        <img
          class="mellow-liquid__hero-img"
          src="{{ section.settings.hero_image | image_url: width: 2400 }}"
          alt="{{ section.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
        >
      {% else %}
        <div class="mellow-liquid__hero-placeholder"></div>
      {% endif %}

      <div class="mellow-liquid__shade"></div>
      <div class="mellow-liquid__left-scrim"></div>

      <div class="mellow-liquid__hero-content">
        <div class="mellow-liquid__copy">
          {% if section.settings.eyebrow != blank %}
            <p class="mellow-liquid__eyebrow">{{ section.settings.eyebrow }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="mellow-liquid__heading mellow-section-heading">
              {{ section.settings.heading }}
            </h2>
          {% endif %}

          {% if section.settings.subheading != blank %}
            <p class="mellow-liquid__subheading">
              {{ section.settings.subheading }}
            </p>
          {% endif %}
        </div>

        <div class="mellow-liquid__product-lockup">
          {% if section.settings.product_label != blank %}
            <p class="mellow-liquid__new">{{ section.settings.product_label }}</p>
          {% endif %}

          {% if section.settings.product_name != blank %}
            <h3 class="mellow-liquid__product-name">
              {{ section.settings.product_name }}
            </h3>
          {% endif %}

          {% if section.settings.product_tagline != blank %}
            <p class="mellow-liquid__product-tagline">
              {{ section.settings.product_tagline }}
            </p>
          {% endif %}
        </div>
      </div>

      <div class="mellow-liquid__benefit-panel">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="mellow-liquid__benefit" {{ block.shopify_attributes }}>
              <div class="mellow-liquid__icon">
                {% case block.settings.icon %}
                  {% when 'drop' %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <path d="M32 6C22 19 14 29 14 40c0 11 8 18 18 18s18-7 18-18C50 29 42 19 32 6Z"/>
                      <path d="M25 47c3 3 8 4 13 1"/>
                    </svg>
                  {% when 'leaf' %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <path d="M52 12C31 12 15 26 15 45c0 5 3 9 8 9 20 0 31-19 29-42Z"/>
                      <path d="M16 52c9-13 20-23 34-32"/>
                    </svg>
                  {% when 'stomach' %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <path d="M28 8c0 10 8 12 8 21"/>
                      <path d="M36 29c0 6-6 7-11 6-8-1-13 5-13 12 0 8 7 13 17 13 13 0 24-9 24-22 0-10-7-18-17-18"/>
                      <path d="M17 45c4 4 10 5 16 2"/>
                    </svg>
                  {% when 'shield' %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <path d="M32 7l20 8v15c0 14-8 24-20 29C20 54 12 44 12 30V15l20-8Z"/>
                      <path d="M22 33l7 7 15-17"/>
                    </svg>
                  {% when 'thumb' %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <path d="M23 28v27H11V28h12Z"/>
                      <path d="M23 52h22c5 0 7-4 7-8l3-15c1-5-2-8-7-8H38l2-8c1-5-2-8-5-8-2 0-3 1-4 4l-4 10-4 9"/>
                    </svg>
                  {% else %}
                    <svg viewBox="0 0 64 64" aria-hidden="true">
                      <circle cx="32" cy="32" r="22"/>
                      <path d="M22 33l7 7 15-17"/>
                    </svg>
                {% endcase %}
              </div>

              {% if block.settings.title != blank %}
                <h4 class="mellow-liquid__benefit-title">
                  {{ block.settings.title }}
                </h4>
              {% endif %}

              {% if block.settings.text != blank %}
                <p class="mellow-liquid__benefit-text">
                  {{ block.settings.text }}
                </p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

    </div>

    <div class="mellow-liquid__lower-grid">
      <div class="mellow-liquid__texture-card">
        {% if section.settings.texture_image != blank %}
          <img
            src="{{ section.settings.texture_image | image_url: width: 1000 }}"
            alt="{{ section.settings.texture_image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.texture_image.width }}"
            height="{{ section.settings.texture_image.height }}"
          >
        {% else %}
          <div class="mellow-liquid__texture-placeholder"></div>
        {% endif %}
      </div>

      <div class="mellow-liquid__statement-card">
        {% if section.settings.statement_heading != blank %}
          <h3>{{ section.settings.statement_heading }}</h3>
        {% endif %}

        {% if section.settings.statement_text != blank %}
          <p>{{ section.settings.statement_text }}</p>
        {% endif %}
      </div>
    </div>

  </div>

  {% if section.settings.show_sticky_bar %}
    <div class="mellow-liquid__sticky">
      <div class="mellow-liquid__sticky-product">
        <div class="mellow-liquid__sticky-thumb">
          {% if section.settings.product_image != blank %}
            <img
              src="{{ section.settings.product_image | image_url: width: 120 }}"
              alt="{{ section.settings.product_image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.product_image.width }}"
              height="{{ section.settings.product_image.height }}"
            >
          {% else %}
            <div class="mellow-liquid__mini-bottle"></div>
          {% endif %}
        </div>

        <span>{{ section.settings.sticky_product_name }}</span>
      </div>

      {% if section.settings.button_label != blank %}
        <a class="mellow-liquid__button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  {% endif %}
</section>

<style>
  .mellow-liquid-{{ section.id }} {
    --mellow-page: #F5F3EA;
    --mellow-forest: #1A2D10;
    --mellow-forest-deep: #102307;
    --mellow-ivory: #F0EBE0;
    --mellow-white: #FFFFFF;
    --mellow-orange: #D04A2A;

    position: relative;
    display: block;
    background: var(--mellow-page);
    color: var(--mellow-white);
    padding: {{ section.settings.section_padding_top }}px 24px {{ section.settings.section_padding_bottom }}px;
    overflow: hidden;
  }

  .mellow-liquid-{{ section.id }} * {
    box-sizing: border-box;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__page {
    width: min(100%, {{ section.settings.max_width }}px);
    margin: 0 auto;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__hero {
    position: relative;
    min-height: {{ section.settings.hero_height }}px;
    border-radius: {{ section.settings.hero_radius }}px;
    overflow: hidden;
    isolation: isolate;
    background: var(--mellow-forest);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__hero-img,
  .mellow-liquid-{{ section.id }} .mellow-liquid__hero-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__hero-img {
    object-fit: cover;
    object-position: {{ section.settings.hero_image_position }};
    transform: scale(1.01);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__hero-placeholder {
    background:
      radial-gradient(circle at 65% 35%, rgba(240, 235, 224, 0.18), transparent 30%),
      linear-gradient(135deg, #274D30, #102307);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        90deg,
        rgba(8, 20, 10, 0.86) 0%,
        rgba(8, 20, 10, 0.62) 33%,
        rgba(8, 20, 10, 0.30) 58%,
        rgba(8, 20, 10, 0.70) 100%
      ),
      linear-gradient(
        180deg,
        rgba(8, 20, 10, 0.35) 0%,
        rgba(8, 20, 10, 0.18) 42%,
        rgba(8, 20, 10, 0.84) 100%
      );
    pointer-events: none;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__left-scrim {
    position: absolute;
    z-index: 1;
    left: 0;
    top: 0;
    bottom: 0;
    width: 54%;
    background:
      radial-gradient(
        circle at 18% 28%,
        rgba(8, 20, 10, 0.70) 0%,
        rgba(8, 20, 10, 0.56) 32%,
        rgba(8, 20, 10, 0.18) 62%,
        transparent 100%
      );
    pointer-events: none;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 32px;
    align-items: start;
    padding: clamp(34px, 5vw, 70px);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__copy {
    max-width: 600px;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__eyebrow {
    margin: 0 0 18px;
    font-family: inherit;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 800;
    color: var(--mellow-orange);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.42);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__heading {
    margin: 0;
    max-width: 620px;
    font-family: inherit;
    font-size: clamp(42px, 4.8vw, 74px);
    line-height: 0.98;
    letter-spacing: -0.055em;
    font-weight: 500;
    color: var(--mellow-white);
    text-shadow: 0 3px 30px rgba(0, 0, 0, 0.48);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__subheading {
    margin: 26px 0 0;
    max-width: 460px;
    font-family: inherit;
    font-size: clamp(17px, 1.45vw, 23px);
    line-height: 1.32;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__product-lockup {
    min-width: 220px;
    text-align: right;
    color: var(--mellow-ivory);
    padding-top: 4px;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__new {
    margin: 0 0 12px;
    font-family: inherit;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 900;
    color: var(--mellow-ivory);
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.5);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__product-name {
    margin: 0;
    font-family: inherit;
    font-size: clamp(30px, 3vw, 52px);
    line-height: 0.98;
    letter-spacing: -0.05em;
    font-weight: 600;
    color: var(--mellow-ivory);
    text-shadow: 0 3px 24px rgba(0, 0, 0, 0.52);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__product-tagline {
    margin: 18px 0 0;
    font-family: inherit;
    font-size: 17px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 800;
    color: rgba(240, 235, 224, 0.96);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__benefit-panel {
    position: absolute;
    left: clamp(20px, 2vw, 32px);
    right: clamp(20px, 2vw, 32px);
    bottom: clamp(20px, 2vw, 32px);
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(22px, 3vw, 58px);
    padding: clamp(28px, 4vw, 52px);
    border-radius: 22px;
    background: rgba(18, 31, 15, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__benefit {
    min-width: 0;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__icon {
    width: 54px;
    height: 54px;
    margin-bottom: 24px;
    color: var(--mellow-white);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__icon svg {
    display: block;
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    color: var(--mellow-white);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__benefit-title {
    margin: 0 0 12px;
    font-family: inherit;
    font-size: clamp(17px, 1.25vw, 22px);
    line-height: 1.08;
    letter-spacing: -0.035em;
    font-weight: 850;
    color: var(--mellow-white);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__benefit-text {
    margin: 0;
    font-family: inherit;
    font-size: clamp(14px, 0.98vw, 17px);
    line-height: 1.36;
    letter-spacing: -0.02em;
    font-weight: 550;
    color: rgba(255, 255, 255, 0.78);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__lower-grid {
    display: grid;
    grid-template-columns: 0.85fr 2.15fr;
    gap: 18px;
    margin-top: 18px;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-card,
  .mellow-liquid-{{ section.id }} .mellow-liquid__statement-card {
    min-height: 250px;
    border-radius: 28px;
    overflow: hidden;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-card {
    position: relative;
    background: #D6B25E;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-card img,
  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-placeholder {
    width: 100%;
    height: 100%;
    min-height: 250px;
    display: block;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-card img {
    object-fit: cover;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__texture-placeholder {
    background:
      radial-gradient(circle at 25% 20%, rgba(255, 255, 255, 0.24), transparent 20%),
      radial-gradient(circle at 75% 45%, rgba(26, 45, 16, 0.24), transparent 24%),
      linear-gradient(135deg, #D2A444, #F0D795);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__statement-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(32px, 4vw, 56px);
    background:
      radial-gradient(circle at 75% 20%, rgba(240, 235, 224, 0.12), transparent 30%),
      linear-gradient(135deg, var(--mellow-forest), var(--mellow-forest-deep));
    color: var(--mellow-white);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__statement-card h3 {
    margin: 0;
    max-width: 640px;
    font-family: inherit;
    font-size: clamp(34px, 4vw, 64px);
    line-height: 0.95;
    letter-spacing: -0.055em;
    font-weight: 500;
    color: var(--mellow-white);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__statement-card p {
    margin: 22px 0 0;
    max-width: 560px;
    font-family: inherit;
    font-size: clamp(16px, 1.3vw, 21px);
    line-height: 1.35;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__sticky {
    position: sticky;
    z-index: 20;
    bottom: 0;
    width: min(100%, {{ section.settings.max_width }}px);
    margin: 18px auto 0;
    min-height: 76px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 24px;
    padding: 10px 34px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(26, 45, 16, 0.08);
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.06);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__sticky-product {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
    color: var(--mellow-forest);
    font-family: inherit;
    font-size: 19px;
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 700;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__sticky-thumb {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: var(--mellow-page);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__sticky-thumb img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__mini-bottle {
    width: 18px;
    height: 34px;
    border-radius: 4px 4px 6px 6px;
    background: var(--mellow-forest);
    position: relative;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__mini-bottle::before {
    content: "";
    position: absolute;
    left: 5px;
    right: 5px;
    top: -5px;
    height: 6px;
    border-radius: 3px 3px 0 0;
    background: var(--mellow-forest);
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 260px;
    min-height: 58px;
    padding: 16px 34px;
    border-radius: 999px;
    background: var(--mellow-forest);
    color: var(--mellow-white);
    text-decoration: none;
    font-family: inherit;
    font-size: 15px;
    line-height: 1;
    font-weight: 850;
    letter-spacing: -0.01em;
    transition: transform 180ms ease, background 180ms ease;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__button:hover {
    transform: translateY(-1px);
    background: var(--mellow-forest-deep);
  }

  @media screen and (max-width: 1100px) {
    .mellow-liquid-{{ section.id }} .mellow-liquid__hero {
      min-height: 860px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__hero-content {
      grid-template-columns: 1fr;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__product-lockup {
      text-align: left;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__benefit-panel {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 760px) {
    .mellow-liquid-{{ section.id }} {
      padding-left: 12px;
      padding-right: 12px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__hero {
      min-height: 980px;
      border-radius: 26px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__hero-content {
      padding: 28px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__heading {
      font-size: clamp(42px, 13vw, 58px);
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__subheading {
      font-size: 18px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__product-name {
      font-size: 38px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__benefit-panel {
      grid-template-columns: 1fr;
      padding: 28px;
      border-radius: 18px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__icon {
      width: 44px;
      height: 44px;
      margin-bottom: 16px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__lower-grid {
      grid-template-columns: 1fr;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__texture-card,
    .mellow-liquid-{{ section.id }} .mellow-liquid__statement-card {
      border-radius: 24px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__sticky {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 14px;
    }

    .mellow-liquid-{{ section.id }} .mellow-liquid__button {
      width: 100%;
      min-width: 0;
    }
  }


  /* Use the approved hero heading typography for this major section headline. */
  .mellow-liquid-{{ section.id }} .mellow-liquid__heading {
    font-family: var(--mellow-heading-font) !important;
    font-weight: var(--mellow-heading-weight) !important;
    letter-spacing: var(--mellow-heading-letter-spacing) !important;
    line-height: var(--mellow-heading-line-height) !important;
    font-style: normal !important;
    font-variation-settings: var(--mellow-heading-font-variation-settings) !important;
  }

  .mellow-liquid-{{ section.id }} .mellow-liquid__heading em,
  .mellow-liquid-{{ section.id }} .mellow-liquid__heading i {
    font-family: var(--mellow-heading-italic-font) !important;
    font-style: italic !important;
    font-weight: var(--mellow-heading-italic-weight) !important;
    letter-spacing: var(--mellow-heading-italic-letter-spacing) !important;
    line-height: var(--mellow-heading-italic-line-height) !important;
    font-variation-settings: var(--mellow-heading-italic-font-variation-settings) !important;
  }
</style>

{% schema %}
{
  "name": "Mellow Liquid Hero",
  "tag": "section",
  "class": "section-mellow-liquid",
  "settings": [
    {
      "type": "header",
      "content": "Hero Image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Happy person hero image"
    },
    {
      "type": "select",
      "id": "hero_image_position",
      "label": "Hero image position",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "center top",
          "label": "Top"
        },
        {
          "value": "center bottom",
          "label": "Bottom"
        },
        {
          "value": "left center",
          "label": "Left"
        },
        {
          "value": "right center",
          "label": "Right"
        }
      ]
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 560,
      "max": 980,
      "step": 20,
      "unit": "px",
      "label": "Hero height",
