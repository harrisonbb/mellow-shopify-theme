{% comment %}
  Mellow PPI support page.
  Standalone educational page for barrier-support messaging.
{% endcomment %}

{%- liquid
  assign cta_link = section.settings.cta_link | default: '/products/mellow-reflux-relief-gel'
  assign close_cta_label = section.settings.close_cta_label | default: section.settings.cta_label
  assign close_cta_link = section.settings.close_cta_link | default: cta_link
-%}

<style>
  #MellowPpiSupportPage-{{ section.id }} {
    --mellow-ppi-page-forest: #223216;
    --mellow-ppi-page-forest-deep: #223315;
    --mellow-ppi-page-ivory: #F0EBE0;
    --mellow-ppi-page-ivory-soft: rgba(240, 235, 224, 0.78);
    --mellow-ppi-page-card: rgba(255, 252, 245, 0.72);
    --mellow-ppi-page-card-solid: #F8F4EC;
    --mellow-ppi-page-border: rgba(34, 50, 22, 0.14);
    --mellow-ppi-page-muted: rgba(34, 50, 22, 0.72);
    --mellow-ppi-page-soft: rgba(34, 50, 22, 0.52);
    --mellow-ppi-page-orange: var(--mellow-orange-red, #D04A2A);
    --mellow-ppi-page-blue: var(--mellow-science-blue, #3D6B8C);
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    background: var(--mellow-ppi-page-ivory);
    color: var(--mellow-ppi-page-forest);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-section-heading,
  #MellowPpiSupportPage-{{ section.id }} .mellow-card-title,
  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-heading {
    letter-spacing: 0;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__band {
    padding-top: var(--mellow-section-pad-top, clamp(64px, 5.5vw, 92px));
    padding-bottom: var(--mellow-section-pad-bottom, clamp(52px, 5vw, 76px));
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero {
    padding-top: clamp(76px, 8vw, 124px);
    padding-bottom: clamp(64px, 7vw, 104px);
    background: linear-gradient(145deg, var(--mellow-ppi-page-forest) 0%, var(--mellow-ppi-page-forest-deep) 100%);
    color: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.96fr) minmax(340px, 0.64fr);
    gap: var(--mellow-feature-gap, clamp(42px, 7vw, 112px));
    align-items: center;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-copy {
    max-width: 840px;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__eyebrow {
    color: var(--mellow-ppi-page-orange);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-heading {
    max-width: 880px;
    margin: 0;
    color: var(--mellow-ppi-page-ivory);
    font-family: var(--mellow-font-display, var(--font-heading-family)) !important;
    font-size: clamp(46px, 5.7vw, 76px);
    font-weight: var(--mellow-heading-weight, 600);
    line-height: 0.96;
    text-wrap: balance;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-body {
    max-width: 680px;
    color: var(--mellow-ppi-page-ivory-soft);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__actions {
    margin-top: clamp(26px, 2.4vw, 36px);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__cta-wrap {
    justify-content: flex-start;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__cta {
    --mellow-section-cta-bg: var(--mellow-ppi-page-orange);
    --mellow-section-cta-border: var(--mellow-ppi-page-orange);
    --mellow-section-cta-color: var(--mellow-ppi-page-ivory);
    --mellow-section-cta-hover-bg: var(--mellow-ppi-page-ivory);
    --mellow-section-cta-hover-border: var(--mellow-ppi-page-ivory);
    --mellow-section-cta-hover-color: var(--mellow-ppi-page-forest);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__note {
    max-width: 620px;
    margin: clamp(18px, 1.6vw, 22px) 0 0;
    padding-top: clamp(12px, 1.2vw, 16px);
    border-top: 1px solid rgba(240, 235, 224, 0.2);
    color: rgba(240, 235, 224, 0.66);
    font-size: clamp(12px, 0.9vw, 13px);
    line-height: 1.5;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel {
    position: relative;
    min-height: clamp(360px, 34vw, 500px);
    overflow: hidden;
    border: 1px solid rgba(240, 235, 224, 0.22);
    border-radius: min(var(--mellow-radius-card, 28px), 28px);
    background: rgba(240, 235, 224, 0.08);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel::before,
  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel::after {
    content: "";
    position: absolute;
    left: clamp(26px, 3vw, 42px);
    right: clamp(26px, 3vw, 42px);
    pointer-events: none;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel::before {
    top: 34%;
    height: 1px;
    background: rgba(240, 235, 224, 0.24);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel::after {
    bottom: 27%;
    height: clamp(54px, 6vw, 82px);
    border-top: 4px solid var(--mellow-ppi-page-orange);
    border-radius: 48% 48% 0 0;
    background:
      linear-gradient(180deg, rgba(208, 74, 42, 0.18) 0%, transparent 62%),
      linear-gradient(180deg, rgba(240, 235, 224, 0.06) 0%, rgba(240, 235, 224, 0.02) 100%);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-label {
    position: absolute;
    left: clamp(26px, 3vw, 42px);
    right: clamp(26px, 3vw, 42px);
    display: flex;
    justify-content: space-between;
    gap: 18px;
    color: rgba(240, 235, 224, 0.72);
    font-size: clamp(12px, 0.9vw, 14px);
    line-height: 1.35;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-label--top {
    top: clamp(26px, 3vw, 42px);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-label--bottom {
    bottom: clamp(26px, 3vw, 42px);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-kicker {
    color: var(--mellow-ppi-page-orange);
    font-weight: 750;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-meter {
    position: absolute;
    left: clamp(26px, 3vw, 42px);
    right: clamp(26px, 3vw, 42px);
    top: 47%;
    display: grid;
    grid-template-columns: 0.54fr 0.26fr 0.2fr;
    gap: 8px;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-meter span {
    display: block;
    height: 8px;
    border-radius: var(--mellow-radius-pill, 999px);
    background: rgba(240, 235, 224, 0.2);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-meter span:first-child {
    background: var(--mellow-ppi-page-blue);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__explain {
    background: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__explain-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--mellow-card-gap, clamp(28px, 2.6vw, 42px));
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__info-card {
    position: relative;
    min-width: 0;
    padding: var(--mellow-card-pad-standard, clamp(28px, 2.5vw, 42px));
    border: 1px solid var(--mellow-ppi-page-border);
    border-radius: min(var(--mellow-radius-card, 28px), 28px);
    background: var(--mellow-ppi-page-card);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__info-card::before {
    content: "";
    display: block;
    width: clamp(46px, 4vw, 62px);
    height: 3px;
    margin-bottom: clamp(22px, 2vw, 28px);
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-ppi-page-blue);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__info-card--raft::before {
    background: var(--mellow-ppi-page-orange);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__card-kicker {
    display: block;
    margin-bottom: clamp(12px, 1vw, 16px);
    color: var(--mellow-ppi-page-soft);
    font-size: clamp(11px, 0.82vw, 13px);
    font-weight: 750;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__card-title {
    max-width: 560px;
    color: var(--mellow-ppi-page-forest);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__card-body {
    max-width: 620px;
    margin-top: clamp(12px, 1.2vw, 18px);
    color: var(--mellow-ppi-page-muted);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-band {
    border-top: 1px solid rgba(34, 50, 22, 0.1);
    border-bottom: 1px solid rgba(34, 50, 22, 0.1);
    background: rgba(255, 252, 245, 0.44);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(22px, 3vw, 48px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline::before {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 22px;
    height: 1px;
    background: rgba(34, 50, 22, 0.16);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-item {
    position: relative;
    min-width: 0;
    padding-top: clamp(54px, 5vw, 72px);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-marker {
    position: absolute;
    top: 0;
    left: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(34, 50, 22, 0.2);
    border-radius: var(--mellow-radius-pill, 999px);
    background: var(--mellow-ppi-page-ivory);
    color: var(--mellow-ppi-page-forest);
    font-size: 13px;
    font-weight: 750;
    line-height: 1;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-item:last-child .mellow-ppi-support-page__timeline-marker {
    border-color: var(--mellow-ppi-page-orange);
    background: var(--mellow-ppi-page-orange);
    color: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-label {
    display: block;
    margin-bottom: clamp(12px, 1vw, 16px);
    color: var(--mellow-ppi-page-blue);
    font-size: clamp(11px, 0.82vw, 13px);
    font-weight: 750;
    letter-spacing: 0.14em;
    line-height: 1;
    text-transform: uppercase;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-copy {
    max-width: 390px;
    margin: 0;
    color: var(--mellow-ppi-page-forest);
    font-family: var(--mellow-font-display, var(--font-heading-family)) !important;
    font-size: clamp(24px, 2vw, 32px);
    font-weight: var(--mellow-card-title-weight, 560);
    line-height: 1.08;
    text-wrap: balance;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout {
    background: var(--mellow-ppi-page-forest);
    color: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(300px, 0.62fr);
    gap: var(--mellow-feature-gap, clamp(42px, 7vw, 112px));
    align-items: start;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout-heading {
    max-width: 820px;
    color: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout-body {
    max-width: 600px;
    margin-top: 0;
    color: var(--mellow-ppi-page-ivory-soft);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout-rule {
    display: block;
    width: 100%;
    height: 1px;
    margin-top: clamp(30px, 3vw, 44px);
    background: rgba(240, 235, 224, 0.2);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close {
    background: var(--mellow-ppi-page-ivory);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) auto;
    gap: clamp(32px, 5vw, 80px);
    align-items: end;
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-heading {
    color: var(--mellow-ppi-page-forest);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-body {
    max-width: 720px;
    color: var(--mellow-ppi-page-muted);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-actions {
    min-width: clamp(220px, 16vw, 280px);
  }

  #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-cta {
    --mellow-section-cta-bg: var(--mellow-ppi-page-forest);
    --mellow-section-cta-border: var(--mellow-ppi-page-forest);
    --mellow-section-cta-color: var(--mellow-ppi-page-ivory);
    --mellow-section-cta-hover-bg: var(--mellow-ppi-page-orange);
    --mellow-section-cta-hover-border: var(--mellow-ppi-page-orange);
    --mellow-section-cta-hover-color: var(--mellow-ppi-page-ivory);
  }

  @media screen and (max-width: 989px) {
    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-inner,
    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__callout-inner,
    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-inner {
      grid-template-columns: 1fr;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel {
      max-width: 720px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-inner {
      align-items: start;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-actions {
      min-width: 0;
      width: 100%;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-actions .mellow-section-cta-wrap {
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero {
      padding-top: 64px;
      padding-bottom: 56px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-heading {
      font-size: clamp(40px, 11vw, 54px);
      line-height: 1;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-body,
    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__close-body {
      max-width: 380px;
      font-size: 16px;
      line-height: 1.45;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__hero-panel {
      min-height: 320px;
      border-radius: 24px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__panel-label {
      display: grid;
      gap: 8px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__explain-grid {
      grid-template-columns: 1fr;
      gap: clamp(16px, 4vw, 22px);
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__info-card {
      padding: clamp(24px, 7vw, 30px);
      border-radius: 24px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline {
      grid-template-columns: 1fr;
      gap: 0;
      padding-left: 28px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline::before {
      left: 21px;
      right: auto;
      top: 0;
      bottom: 0;
      width: 1px;
      height: auto;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-item {
      padding-top: 0;
      padding-bottom: clamp(28px, 7vw, 40px);
      padding-left: 32px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-item:last-child {
      padding-bottom: 0;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-marker {
      left: -28px;
      width: 42px;
      height: 42px;
    }

    #MellowPpiSupportPage-{{ section.id }} .mellow-ppi-support-page__timeline-copy {
      max-width: 340px;
      font-size: clamp(23px, 7vw, 30px);
    }
  }
</style>

<section
  id="MellowPpiSupportPage-{{ section.id }}"
  class="mellow-ppi-support-page color-{{ section.settings.color_scheme }}"
  {% if section.settings.hero_heading != blank %}aria-labelledby="MellowPpiSupportPageHeading-{{ section.id }}"{% endif %}
>
  <div class="mellow-ppi-support-page__hero">
    <div class="mellow-section-axis mellow-ppi-support-page__hero-inner">
      <div class="mellow-ppi-support-page__hero-copy">
        {%- if section.settings.hero_eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-ppi-support-page__eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.hero_heading != blank -%}
          <h1 id="MellowPpiSupportPageHeading-{{ section.id }}" class="mellow-ppi-support-page__hero-heading">{{ section.settings.hero_heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.hero_body != blank -%}
          <p class="mellow-section-text mellow-ppi-support-page__hero-body">{{ section.settings.hero_body | escape | newline_to_br }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <div class="mellow-ppi-support-page__actions">
            <div class="mellow-section-cta-wrap mellow-ppi-support-page__cta-wrap">
              <a class="mellow-section-cta mellow-ppi-support-page__cta" href="{{ cta_link }}">
                <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                <span class="mellow-section-cta__arrow" aria-hidden="true">-&gt;</span>
              </a>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.disclaimer != blank -%}
          <p class="mellow-ppi-support-page__note">{{ section.settings.disclaimer | escape | newline_to_br }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-ppi-support-page__hero-panel" aria-hidden="true">
        <div class="mellow-ppi-support-page__panel-label mellow-ppi-support-page__panel-label--top">
          <span><span class="mellow-ppi-support-page__panel-kicker">PPI</span><br>Acid reduction builds over time</span>
          <span>Less acid production</span>
        </div>
        <div class="mellow-ppi-support-page__panel-meter">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="mellow-ppi-support-page__panel-label mellow-ppi-support-page__panel-label--bottom">
          <span><span class="mellow-ppi-support-page__panel-kicker">MellowRaft</span><br>Physical barrier after eating</span>
          <span>Floating alginate raft</span>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-ppi-support-page__band mellow-ppi-support-page__explain">
    <div class="mellow-section-axis">
      <div class="mellow-ppi-support-page__explain-grid">
        <article class="mellow-ppi-support-page__info-card" aria-labelledby="MellowPpiSupportPagePpiCard-{{ section.id }}">
          <span class="mellow-ppi-support-page__card-kicker">{{ section.settings.ppi_card_kicker | escape }}</span>
          <h2 id="MellowPpiSupportPagePpiCard-{{ section.id }}" class="mellow-card-title mellow-ppi-support-page__card-title">{{ section.settings.ppi_card_title | escape }}</h2>
          <p class="mellow-card-copy mellow-ppi-support-page__card-body">{{ section.settings.ppi_card_body | escape | newline_to_br }}</p>
        </article>

        <article class="mellow-ppi-support-page__info-card mellow-ppi-support-page__info-card--raft" aria-labelledby="MellowPpiSupportPageRaftCard-{{ section.id }}">
          <span class="mellow-ppi-support-page__card-kicker">{{ section.settings.raft_card_kicker | escape }}</span>
          <h2 id="MellowPpiSupportPageRaftCard-{{ section.id }}" class="mellow-card-title mellow-ppi-support-page__card-title">{{ section.settings.raft_card_title | escape }}</h2>
          <p class="mellow-card-copy mellow-ppi-support-page__card-body">{{ section.settings.raft_card_body | escape | newline_to_br }}</p>
        </article>
      </div>
    </div>
  </div>

  <div class="mellow-ppi-support-page__band mellow-ppi-support-page__timeline-band">
    <div class="mellow-section-axis">
      <ol class="mellow-ppi-support-page__timeline" aria-label="PPI and alginate barrier timing">
        <li class="mellow-ppi-support-page__timeline-item">
          <span class="mellow-ppi-support-page__timeline-marker">1</span>
          <span class="mellow-ppi-support-page__timeline-label">{{ section.settings.timeline_1_label | escape }}</span>
          <p class="mellow-ppi-support-page__timeline-copy">{{ section.settings.timeline_1_text | escape }}</p>
        </li>

        <li class="mellow-ppi-support-page__timeline-item">
          <span class="mellow-ppi-support-page__timeline-marker">2</span>
          <span class="mellow-ppi-support-page__timeline-label">{{ section.settings.timeline_2_label | escape }}</span>
          <p class="mellow-ppi-support-page__timeline-copy">{{ section.settings.timeline_2_text | escape }}</p>
        </li>

        <li class="mellow-ppi-support-page__timeline-item">
          <span class="mellow-ppi-support-page__timeline-marker">3</span>
          <span class="mellow-ppi-support-page__timeline-label">{{ section.settings.timeline_3_label | escape }}</span>
          <p class="mellow-ppi-support-page__timeline-copy">{{ section.settings.timeline_3_text | escape }}</p>
        </li>
      </ol>
    </div>
  </div>

  <div class="mellow-ppi-support-page__band mellow-ppi-support-page__callout">
    <div class="mellow-section-axis">
      <div class="mellow-ppi-support-page__callout-inner">
        <div>
          {%- if section.settings.callout_eyebrow != blank -%}
            <p class="mellow-eyebrow mellow-ppi-support-page__eyebrow">{{ section.settings.callout_eyebrow | escape }}</p>
          {%- endif -%}

          <h2 class="mellow-section-heading mellow-ppi-support-page__callout-heading">{{ section.settings.callout_heading | escape }}</h2>
        </div>

        <div>
          <p class="mellow-section-text mellow-ppi-support-page__callout-body">{{ section.settings.callout_body | escape | newline_to_br }}</p>
          <span class="mellow-ppi-support-page__callout-rule" aria-hidden="true"></span>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-ppi-support-page__band mellow-ppi-support-page__close">
    <div class="mellow-section-axis">
      <div class="mellow-ppi-support-page__close-inner">
        <div>
          <h2 class="mellow-section-heading mellow-ppi-support-page__close-heading">{{ section.settings.close_heading | escape }}</h2>
          <p class="mellow-section-text mellow-ppi-support-page__close-body">{{ section.settings.close_body | escape | newline_to_br }}</p>
        </div>

        {%- if close_cta_label != blank -%}
          <div class="mellow-ppi-support-page__close-actions">
            <div class="mellow-section-cta-wrap">
              <a class="mellow-section-cta mellow-ppi-support-page__close-cta" href="{{ close_cta_link }}">
                <span class="mellow-section-cta__label">{{ close_cta_label | escape }}</span>
                <span class="mellow-section-cta__arrow" aria-hidden="true">-&gt;</span>
              </a>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

