</section>

<script>
  (() => {
    const initExpertProof = (section) => {
      if (!section || section.dataset.mellowExpertProofReady === 'true') return;

      const scroller = section.querySelector('[data-expert-scroller]');
      const track = section.querySelector('[data-expert-track]');
      const prev = section.querySelector('[data-expert-prev]');
      const next = section.querySelector('[data-expert-next]');

      if (!scroller || !track || !prev || !next) return;

      const originals = Array.from(track.children);
      if (!originals.length) return;

      const prepareClone = (card, clonePosition) => {
        const clone = card.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.inert = true;
        clone.setAttribute('inert', '');
        clone.dataset.clone = clonePosition;
        clone.querySelectorAll('a, button, input, select, textarea, [tabindex]').forEach((element) => {
          element.setAttribute('tabindex', '-1');
        });
        return clone;
      };

      const cloneBefore = originals.map((card) => prepareClone(card, 'before'));
      const cloneAfter = originals.map((card) => prepareClone(card, 'after'));

      track.prepend(...cloneBefore);
      track.append(...cloneAfter);

      const getStep = () => {
        const firstCard = track.querySelector('.mellow-expert-proof__card');
        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap) || 0;

        return firstCard ? firstCard.getBoundingClientRect().width + gap : scroller.clientWidth;
      };

      const getPeekOffset = () => getStep() * 0.45;
      const realStart = () => originals[0].offsetLeft;
      const realEnd = () => realStart() + getStep() * originals.length;
      const visualStart = () => realStart() - getPeekOffset();
      const visualEnd = () => realEnd() - getPeekOffset();

      let activeIndex = 0;

      const jumpWithoutSnap = (left) => {
        const previousSnap = scroller.style.scrollSnapType;
        scroller.style.scrollSnapType = 'none';
        scroller.scrollLeft = left;
        requestAnimationFrame(() => {
          scroller.style.scrollSnapType = previousSnap;
        });
      };

      const updateActiveIndex = () => {
        const step = getStep();
        if (!step) return;

        activeIndex = ((Math.round((scroller.scrollLeft - visualStart()) / step) % originals.length) + originals.length) % originals.length;
      };

      const jumpToStart = () => {
        jumpWithoutSnap(visualStart());
        activeIndex = 0;
      };

      const normalizeLoop = () => {
        const step = getStep();
        const start = visualStart();
        const end = visualEnd();

        if (scroller.scrollLeft < start - step / 2) {
          jumpWithoutSnap(scroller.scrollLeft + originals.length * step);
        }

        if (scroller.scrollLeft >= end - step / 2) {
          jumpWithoutSnap(scroller.scrollLeft - originals.length * step);
        }

        updateActiveIndex();
      };

      requestAnimationFrame(jumpToStart);

      next.addEventListener('click', () => {
        scroller.scrollBy({ left: getStep(), behavior: 'smooth' });
        window.setTimeout(normalizeLoop, 450);
      });

      prev.addEventListener('click', () => {
        scroller.scrollBy({ left: -getStep(), behavior: 'smooth' });
        window.setTimeout(normalizeLoop, 450);
      });

      let scrollTimer;
      scroller.addEventListener('scroll', () => {
        window.clearTimeout(scrollTimer);
        scrollTimer = window.setTimeout(normalizeLoop, 120);
      });

      window.addEventListener('resize', () => {
        requestAnimationFrame(() => {
          jumpWithoutSnap(visualStart() + activeIndex * getStep());
          normalizeLoop();
        });
      });

      section.dataset.mellowExpertProofReady = 'true';
    };

    const initCurrentSection = () => {
      initExpertProof(document.getElementById('MellowExpertProof-{{ section.id }}'));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCurrentSection, { once: true });
    } else {
      initCurrentSection();
    }

    document.addEventListener('shopify:section:load', (event) => {
      initExpertProof(event.target.querySelector('[data-mellow-expert-proof]'));
    });
  })();
</script>

