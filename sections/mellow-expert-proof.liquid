{% comment %}
  Mellow Expert Proof section.
  Built on the global Mellow section system with a simple scroll row.
{% endcomment %}

<style>
  #MellowExpertProof-{{ section.id }} {
    --expert-gap: clamp(14px, 1.2vw, 20px);
    --expert-axis-pad: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    --mellow-orange: var(--mellow-orange-red, #D04A2A);
    background: var(--mellow-section-green, #223216);
    color: var(--mellow-cream, #F0EBE0);
    overflow: hidden;
    padding-top: clamp(36px, 4vw, 64px);
    padding-bottom: clamp(36px, 4vw, 64px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
    grid-template-columns: minmax(0, .62fr) auto;
    margin-bottom: clamp(18px, 2vw, 28px);
    align-items: start;
    gap: clamp(18px, 2.4vw, 36px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header {
    max-width: 760px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-eyebrow {
    margin-bottom: clamp(5px, .45vw, 8px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading {
    max-width: 680px;
    color: var(--mellow-cream, #F0EBE0);
    font-size: clamp(38px, 3.3vw, 52px);
    text-wrap: balance;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__text {
    max-width: 500px;
    margin-top: clamp(7px, .65vw, 10px);
    font-size: clamp(15px, 1.05vw, 18px);
    line-height: 1.32;
    color: rgba(240, 235, 224, 0.86);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions {
    align-self: start;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: clamp(12px, 1vw, 16px);
    width: auto;
    padding-top: clamp(4px, .5vw, 8px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta {
    border: 1px solid var(--mellow-cream, #F0EBE0);
    background: var(--mellow-cream, #F0EBE0);
    color: var(--mellow-forest, #223216);
    text-decoration: none;
    box-shadow: 0 16px 34px rgba(34, 50, 22, 0.14);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrows {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(44px, 3.25vw, 52px);
    height: clamp(44px, 3.25vw, 52px);
    padding: 0;
    border: 1px solid rgba(240, 235, 224, 0.42);
    border-radius: 999px;
    background: rgba(240, 235, 224, 0.12);
    color: var(--mellow-cream, #F0EBE0);
    cursor: pointer;
    box-shadow: 0 14px 28px rgba(34, 50, 22, 0.07);
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:hover,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:focus-visible {
    border-color: var(--mellow-cream, #F0EBE0);
    background: var(--mellow-cream, #F0EBE0);
    color: var(--mellow-forest, #223216);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow svg {
    width: 16px;
    height: 16px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    overflow: hidden;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__scroller {
    width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    box-sizing: border-box;
    padding-left: var(--expert-axis-pad);
    padding-right: var(--expert-axis-pad);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__scroller::-webkit-scrollbar {
    display: none;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(300px, 28vw, 390px);
    gap: var(--expert-gap);
    align-items: stretch;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
    scroll-snap-align: center;
    min-width: 0;
    overflow: hidden;
    border-radius: clamp(24px, 2vw, 28px);
    border: 1px solid rgba(34, 50, 22, 0.12);
    background: rgba(255, 252, 244, 0.92);
    box-shadow:
      0 22px 48px rgba(34, 50, 22, 0.075),
      0 1px 0 rgba(255, 255, 255, 0.48) inset;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual {
    position: relative;
    display: flex;
    min-height: clamp(138px, 12.5vw, 182px);
    aspect-ratio: 16 / 7.5;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(circle at 22% 20%, rgba(208, 74, 42, 0.34), transparent 28%),
      radial-gradient(circle at 76% 30%, rgba(61, 107, 140, 0.34), transparent 30%),
      linear-gradient(135deg, #F9E1BE 0%, #DCE4DF 52%, #E49D75 100%);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual::before,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual::after {
    content: "";
    position: absolute;
    pointer-events: none;
    border-radius: 999px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual::before {
    inset: 16%;
    border: 1px solid rgba(255, 252, 244, 0.34);
    background: rgba(255, 252, 244, 0.12);
    box-shadow: 0 28px 72px rgba(34, 50, 22, 0.12);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual::after {
    width: 62%;
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(255, 252, 244, 0.32), transparent 66%);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__image {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__letter {
    position: relative;
    z-index: 2;
    color: rgba(255, 252, 244, 0.84);
    font-family: var(--mellow-font-display);
    font-size: clamp(66px, 7vw, 108px);
    font-weight: 650;
    line-height: .78;
    letter-spacing: -0.08em;
    text-shadow: 0 18px 38px rgba(34, 50, 22, 0.18);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__content {
    display: flex;
    flex-direction: column;
    min-height: clamp(178px, 15vw, 226px);
    padding: clamp(20px, 2vw, 28px);
    background:
      radial-gradient(circle at 94% 6%, rgba(61, 107, 140, 0.08), transparent 30%),
      rgba(255, 252, 244, 0.92);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__role {
    display: block;
    margin: 0 0 clamp(7px, .7vw, 10px);
    color: var(--mellow-orange, #D04A2A);
    font-size: clamp(10px, .65vw, 12px);
    font-weight: var(--mellow-eyebrow-weight, 700);
    line-height: var(--mellow-eyebrow-line-height, 1);
    letter-spacing: var(--mellow-eyebrow-tracking, 0.16em);
    text-transform: uppercase;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__quote {
    margin: 0;
    color: var(--mellow-forest, #223216);
    font-size: clamp(20px, 1.6vw, 26px);
    line-height: 1.1;
    letter-spacing: -0.028em;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__person {
    margin-top: auto;
    padding-top: clamp(14px, 1.4vw, 22px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__name {
    color: var(--mellow-forest, #223216);
    font-size: clamp(18px, 1.25vw, 22px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__title {
    margin-top: 3px;
    color: rgba(34, 50, 22, 0.62);
  }

  @media screen and (max-width: 989px) {
    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      grid-template-columns: 1fr;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions,
    #MellowExpertProof-{{ section.id }} .mellow-section-cta-wrap {
      justify-self: start;
      justify-content: flex-start;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__scroller {
      padding-left: var(--expert-axis-pad);
      padding-right: var(--expert-axis-pad);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__track {
      grid-auto-columns: min(54vw, 390px);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      gap: 18px;
      margin-bottom: 20px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions {
      flex-wrap: wrap;
      width: 100%;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__track {
      grid-auto-columns: min(84vw, 340px);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
      border-radius: 24px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual {
      min-height: 150px;
      aspect-ratio: 16 / 8;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__content {
      min-height: 0;
      padding: 20px;
    }
  }
</style>

<section id="MellowExpertProof-{{ section.id }}" class="mellow-section-standard mellow-expert-proof color-{{ section.settings.color_scheme }}" data-mellow-expert-proof>
