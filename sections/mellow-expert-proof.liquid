{% comment %}
  Mellow Expert Proof section.
  Built on the global Mellow section system with a simple scroll row.
{% endcomment %}

<style>
  #MellowExpertProof-{{ section.id }} {
    --mellow-orange: var(--mellow-orange-red, #D04A2A);
    --mellow-expert-proof-bg: var(--mellow-section-green, #123308);
    --mellow-expert-proof-shelf: var(--mellow-cream, #FCFBF7);
    --mellow-expert-proof-card-width: clamp(300px, calc((100vw - (var(--mellow-section-axis-pad) * 2) - (var(--mellow-carousel-card-gap) * 3)) / 4), 340px);
    --mellow-expert-proof-card-pad: var(--mellow-carousel-card-pad, clamp(18px, 1.5vw, 24px));
    --mellow-carousel-card-gap: clamp(24px, 2vw, 32px);
    background: var(--mellow-expert-proof-shelf);
    color: var(--mellow-forest, #123308);
    overflow-x: hidden;
    overflow-y: visible;
    padding: 0;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__band {
    width: 100%;
    background: var(--mellow-expert-proof-bg);
    color: var(--mellow-cream, #FCFBF7);
    padding-top: clamp(44px, 4vw, 64px);
    padding-bottom: clamp(44px, 4vw, 64px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__shelf {
    width: 100%;
    background: var(--mellow-expert-proof-shelf);
    padding-top: clamp(28px, 2.8vw, 40px);
    padding-bottom: var(--mellow-section-pad-bottom);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.58fr);
    align-items: center;
    gap: clamp(44px, 5.4vw, 84px);
    margin-bottom: 0;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header {
    max-width: none;
  }

  #MellowExpertProof-{{ section.id }} .mellow-eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading {
    max-width: 720px;
    color: var(--mellow-cream, #FCFBF7);
    font-size: var(--mellow-section-heading-size, var(--mellow-heading-size, clamp(40px, 3.7vw, 56px)));
    line-height: var(--mellow-section-heading-line-height, var(--mellow-heading-line-height, 0.98));
    letter-spacing: var(--mellow-section-heading-letter-spacing, var(--mellow-heading-tracking, -0.028em));
    text-wrap: balance;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions {
    align-self: center;
    justify-self: end;
    width: 100%;
    padding-left: clamp(36px, 4.6vw, 64px);
    border-left: 1px solid rgba(240, 235, 224, 0.30);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__text {
    max-width: 520px;
    margin: 0;
    font-size: var(--mellow-section-subhead-size, var(--mellow-subhead-size, clamp(18px, 1.32vw, 20px)));
    line-height: var(--mellow-section-subhead-line-height, var(--mellow-subhead-line-height, 1.46));
    letter-spacing: var(--mellow-section-subhead-letter-spacing, var(--mellow-subhead-tracking, -0.005em));
    color: rgba(252, 251, 247, 0.88);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__action-row {
    display: flex;
    align-items: center;
    gap: clamp(18px, 2vw, 30px);
    width: auto;
    margin-top: var(--mellow-section-content-gap-compact, clamp(26px, 2.4vw, 40px));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__cta {
    --mellow-section-cta-bg: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-border: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-color: var(--mellow-forest, #123308);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
  }

  #MellowExpertProof-{{ section.id }} .mellow-section-cta-wrap {
    flex: 0 0 auto;
    width: auto;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrows {
    display: flex;
    align-items: center;
    gap: var(--mellow-card-gap-tight, clamp(12px, 1vw, 18px));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    padding: 0;
    border: 1px solid rgba(252, 251, 247, 0.72);
    border-radius: 999px;
    background: transparent;
    color: var(--mellow-cream, #FCFBF7);
    cursor: pointer;
    box-shadow: none;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:not(:disabled):hover,
  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:not(:disabled):focus-visible {
    border-color: var(--mellow-cream, #FCFBF7);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-forest, #123308);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow:disabled {
    cursor: default;
    opacity: 0.42;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow svg {
    width: 16px;
    height: 16px;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    overflow-x: hidden;
    overflow-y: visible;
    background: var(--mellow-expert-proof-shelf);
  }

  #MellowExpertProof-{{ section.id }}.is-reduced-motion .mellow-expert-proof__scroller {
    overflow-x: auto;
    scroll-behavior: auto;
  }

  #MellowExpertProof-{{ section.id }}.is-native-scroll .mellow-expert-proof__scroller {
    overflow-x: auto;
    scroll-behavior: smooth;
  }

  #MellowExpertProof-{{ section.id }}.is-reduced-motion .mellow-expert-proof__track {
    transform: none !important;
    will-change: auto;
  }

  #MellowExpertProof-{{ section.id }}.is-native-scroll .mellow-expert-proof__track {
    transform: none !important;
    will-change: auto;
  }

  #MellowExpertProof-{{ section.id }}.is-native-scroll .mellow-expert-proof__card-set[data-expert-card-set-duplicate] {
    display: none;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__scroller {
    width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    scrollbar-width: none;
    box-sizing: border-box;
    padding-left: var(--mellow-section-axis-pad);
    padding-right: var(--mellow-section-axis-pad);
    scroll-padding-inline: var(--mellow-section-axis-pad);
    background: var(--mellow-expert-proof-shelf);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__scroller::-webkit-scrollbar {
    display: none;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__track {
    display: flex;
    gap: var(--mellow-carousel-card-gap);
    align-items: stretch;
    width: max-content;
    max-width: none;
    will-change: transform;
    background: var(--mellow-expert-proof-shelf);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card-set {
    display: flex;
    gap: var(--mellow-carousel-card-gap);
    align-items: stretch;
    flex: 0 0 auto;
    background: var(--mellow-expert-proof-shelf);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
    flex: 0 0 var(--mellow-expert-proof-card-width);
    width: var(--mellow-expert-proof-card-width);
    display: flex;
    flex-direction: column;
    min-height: clamp(520px, 35vw, 568px);
    min-width: 0;
    overflow: hidden;
    isolation: isolate;
    border-radius: var(--mellow-radius-card, 28px);
    border: 1px solid var(--mellow-card-border, rgba(18, 51, 8, 0.10));
    background: var(--mellow-card-cream, #F8F4EC);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: clamp(180px, 12vw, 216px);
    overflow: hidden;
    border-radius: var(--mellow-radius-card, 28px) var(--mellow-radius-card, 28px) 0 0;
    background:
      radial-gradient(circle at 24% 14%, rgba(208, 74, 42, 0.18), transparent 32%),
      linear-gradient(135deg, #DCE4DF 0%, #F8F4EC 58%, #E8D5C2 100%);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center 38%;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__letter {
    color: rgba(18, 51, 8, 0.34);
    font-family: var(--mellow-font-display);
    display: block;
    font-size: clamp(44px, 4.5vw, 72px);
    font-weight: 650;
    line-height: .78;
    letter-spacing: 0;
    opacity: 0;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__content {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    padding: var(--mellow-expert-proof-card-pad);
    border-radius: 0 0 var(--mellow-radius-card, 28px) var(--mellow-radius-card, 28px);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__role {
    display: block;
    margin: 0 0 clamp(10px, .85vw, 14px);
    color: var(--mellow-orange, #D04A2A);
    font-size: clamp(10px, .58vw, 11px);
    font-weight: var(--mellow-eyebrow-weight, 700);
    line-height: var(--mellow-eyebrow-line-height, 1);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__quote {
    margin: 0;
    color: var(--mellow-forest, #123308);
    font-size: clamp(14px, 0.86vw, 15px);
    line-height: 1.44;
    letter-spacing: var(--mellow-card-copy-tracking, -0.006em);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__person {
    margin-top: auto;
    padding-top: clamp(18px, 1.4vw, 22px);
    border-top: 1px solid rgba(18, 51, 8, 0.13);
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__name {
    margin: 0;
    color: var(--mellow-forest, #123308);
    font-size: clamp(16px, 1vw, 18px);
    line-height: 1.02;
  }

  #MellowExpertProof-{{ section.id }} .mellow-expert-proof__title {
    margin-top: 3px;
    color: rgba(18, 51, 8, 0.64);
    font-size: clamp(12px, .86vw, 14px);
    line-height: 1.22;
  }

  @media screen and (max-width: 989px) {
    #MellowExpertProof-{{ section.id }} {
      --mellow-expert-proof-card-width: clamp(300px, 44vw, 340px);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      grid-template-columns: 1fr;
      gap: clamp(24px, 4vw, 36px);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__actions {
      padding-left: 0;
      border-left: 0;
      justify-self: start;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__action-row,
    #MellowExpertProof-{{ section.id }} .mellow-section-cta-wrap {
      justify-content: flex-start;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowExpertProof-{{ section.id }} {
      --mellow-expert-proof-card-width: min(82vw, 330px);
      --mellow-expert-proof-card-pad: var(--mellow-carousel-card-pad, 18px);
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__band {
      padding-top: 42px;
      padding-bottom: 42px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__header-grid {
      gap: 22px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__heading {
      font-size: clamp(36px, 9.5vw, 46px);
      line-height: 1;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__action-row {
      flex-wrap: wrap;
      width: 100%;
      gap: 16px;
      margin-top: 22px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__arrow {
      width: 50px;
      height: 50px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__shelf {
      padding-top: 22px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__card {
      min-height: 512px;
    }

    #MellowExpertProof-{{ section.id }} .mellow-expert-proof__visual {
      height: 178px;
    }
  }
</style>

<section id="MellowExpertProof-{{ section.id }}" class="mellow-section-standard mellow-expert-proof color-{{ section.settings.color_scheme }}" data-mellow-expert-proof>
  <div class="mellow-expert-proof__band">
    <div class="mellow-section-axis">
      <div class="mellow-section-header-grid mellow-expert-proof__header-grid">
        <div class="mellow-section-header mellow-expert-proof__header">
          {%- if section.settings.eyebrow != blank -%}
            <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            {%- assign heading_lines = section.settings.heading | escape | split: '|' -%}
            <h2 class="mellow-section-heading mellow-expert-proof__heading">
              {%- for line in heading_lines -%}
                {{ line }}{%- unless forloop.last -%}<br>{%- endunless -%}
              {%- endfor -%}
            </h2>
          {%- endif -%}

        </div>

        <div class="mellow-section-actions mellow-expert-proof__actions">
          {%- if section.settings.text != blank -%}
            <p class="mellow-section-text mellow-expert-proof__text">{{ section.settings.text | escape }}</p>
          {%- endif -%}

          <div class="mellow-expert-proof__action-row">
            {%- if section.settings.cta_label != blank -%}
              <div class="mellow-section-cta-wrap">
                <a class="mellow-section-cta mellow-expert-proof__cta" href="{{ section.settings.cta_link | default: '#' }}">
                  <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
                  <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
                </a>
              </div>
            {%- endif -%}

            <div class="mellow-expert-proof__arrows" aria-label="Expert proof scroll controls">
              <button class="mellow-expert-proof__arrow" type="button" aria-label="Previous expert quote" aria-disabled="false" data-expert-prev>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                  <path d="M10 3.5 5.5 8 10 12.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="mellow-expert-proof__arrow" type="button" aria-label="Next expert quote" data-expert-next>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
                  <path d="m6 3.5 4.5 4.5L6 12.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mellow-expert-proof__shelf">
    <div class="mellow-section-axis">
      <div class="mellow-expert-proof__bleed">
        <div class="mellow-expert-proof__scroller" data-expert-scroller>
          <div class="mellow-expert-proof__track" data-expert-track>
            {%- for card_loop in (1..3) -%}
              {%- assign is_original_set = false -%}
              {%- if card_loop == 2 -%}
                {%- assign is_original_set = true -%}
              {%- endif -%}

              <div
                class="mellow-expert-proof__card-set"
                {% if is_original_set %}
                  data-expert-card-set
                {% else %}
                  data-expert-card-set-duplicate
                  aria-hidden="true"
                {% endif %}
              >
                {%- for card_index in (1..4) -%}
                  {%- liquid
                    assign image_key = 'card_' | append: card_index | append: '_image'
                    assign letter_key = 'card_' | append: card_index | append: '_letter'
                    assign role_key = 'card_' | append: card_index | append: '_role'
                    assign quote_key = 'card_' | append: card_index | append: '_quote'
                    assign name_key = 'card_' | append: card_index | append: '_name'
                    assign title_key = 'card_' | append: card_index | append: '_title'
                    assign fallback_letters = 'A,B,C,D,E,F' | split: ','
                    assign fallback_letter = fallback_letters[forloop.index0]
                    assign image_loading = 'lazy'
                    if card_index <= 3 and card_loop <= 2
                      assign image_loading = 'eager'
                    endif
                  -%}

                  <article
                    class="mellow-expert-proof__card"
                    {% if is_original_set %}
                      data-expert-card
                    {% endif %}
                    data-expert-index="{{ forloop.index0 }}"
                  >
                    <div class="mellow-expert-proof__visual">
                      {%- if section.settings[image_key] != blank -%}
                        {{ section.settings[image_key] | image_url: width: 1000 | image_tag: decoding: 'async', class: 'mellow-expert-proof__image', loading: image_loading, sizes: '(min-width: 1480px) 340px, (min-width: 990px) 23vw, (min-width: 815px) 44vw, (min-width: 750px) 304px, 84vw', widths: '320, 480, 640, 800, 1000', alt: section.settings[name_key] }}
                      {%- else -%}
                        <span class="mellow-expert-proof__letter" aria-hidden="true">{{ section.settings[letter_key] | default: fallback_letter | escape }}</span>
                      {%- endif -%}
                    </div>
                    <div class="mellow-expert-proof__content">
                      <span class="mellow-expert-proof__role">{{ section.settings[role_key] | escape }}</span>
                      <p class="mellow-card-copy mellow-expert-proof__quote">{{ section.settings[quote_key] | escape }}</p>
                      <div class="mellow-expert-proof__person">
                        <h3 class="mellow-card-title mellow-expert-proof__name">{{ section.settings[name_key] | escape }}</h3>
                        <p class="mellow-card-copy mellow-expert-proof__title">{{ section.settings[title_key] | default: section.settings[role_key] | escape }}</p>
                      </div>
                    </div>
                  </article>
                {%- endfor -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const initExpertProof = (section) => {
      const releaseReadyHold = window.MellowReadyGate ? window.MellowReadyGate.hold() : null;

      const releaseSectionReady = () => {
        if (section) {
          section.classList.add('is-mellow-section-ready');
        }

        if (releaseReadyHold) {
          releaseReadyHold();
        }
      };

      if (!section || section.dataset.mellowExpertProofReady === 'true') {
        releaseSectionReady();
        return;
      }

      const scroller = section.querySelector('[data-expert-scroller]');
      const track = section.querySelector('[data-expert-track]');
      const cardSet = section.querySelector('[data-expert-card-set]');
      const cards = cardSet ? Array.from(cardSet.querySelectorAll('[data-expert-card]')) : [];
      const prev = section.querySelector('[data-expert-prev]');
      const next = section.querySelector('[data-expert-next]');

      if (!scroller || !track || !cardSet || !cards.length || !prev || !next) {
        releaseSectionReady();
        return;
      }

      const marqueeDuration = 84000;
      const nudgeDuration = 420;
      const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      const nativeScrollQuery = window.matchMedia('(max-width: 749px)');
      let setWidth = 0;
      let cardWidth = 0;
      let cardPitch = 0;
      let offset = 0;
      let animationFrame = null;
      let nudgeFrame = null;
      let lastFrameTime = null;
      let resizeObserver = null;
      let isReducedMotion = reducedMotionQuery.matches;
      let isNativeScroll = isReducedMotion || nativeScrollQuery.matches;

      const setCarouselMode = () => {
        isNativeScroll = isReducedMotion || nativeScrollQuery.matches;
        section.classList.toggle('is-reduced-motion', isReducedMotion);
        section.classList.toggle('is-native-scroll', isNativeScroll);
        prev.disabled = false;
        next.disabled = false;
        prev.setAttribute('aria-disabled', 'false');
        next.setAttribute('aria-disabled', 'false');
      };

      const applySafeOffset = () => {
        if (setWidth <= 0) {
          return;
        }

        while (offset <= setWidth * -1.5) {
          offset += setWidth;
        }

        while (offset >= setWidth * -0.5) {
          offset -= setWidth;
        }
      };

      const updateTrackPosition = () => {
        track.style.transform = isNativeScroll ? 'none' : `translate3d(${offset}px, 0, 0)`;
      };

      const stopNudge = () => {
        if (nudgeFrame) {
          cancelAnimationFrame(nudgeFrame);
          nudgeFrame = null;
        }
      };

      const stopMarquee = () => {
        if (animationFrame) {
          cancelAnimationFrame(animationFrame);
          animationFrame = null;
        }

        stopNudge();
        lastFrameTime = null;
      };

      const measureCarousel = () => {
        const trackStyles = window.getComputedStyle(track);
        const cardSetStyles = window.getComputedStyle(cardSet);
        const trackGap = parseFloat(trackStyles.columnGap || trackStyles.gap) || 0;
        const cardGap = parseFloat(cardSetStyles.columnGap || cardSetStyles.gap) || 0;
        const firstCard = cards[0];

        cardWidth = firstCard ? firstCard.getBoundingClientRect().width : 0;
        cardPitch = cardWidth + cardGap;
        setWidth = cardSet.getBoundingClientRect().width + trackGap;

        if (setWidth <= 0) {
          return;
        }

        offset = isNativeScroll ? 0 : setWidth * -1;
        track.style.setProperty('--expert-track-width', `${setWidth}px`);
        updateTrackPosition();
      };

      const animate = (timestamp) => {
        if (isNativeScroll) {
          stopMarquee();
          updateTrackPosition();
          return;
        }

        if (setWidth > 0 && !nudgeFrame) {
          if (lastFrameTime === null) {
            lastFrameTime = timestamp;
          }

          const elapsed = timestamp - lastFrameTime;
          const pixelsPerMillisecond = setWidth / marqueeDuration;

          offset -= pixelsPerMillisecond * elapsed;
          applySafeOffset();
          updateTrackPosition();
          lastFrameTime = timestamp;
        } else if (nudgeFrame) {
          lastFrameTime = timestamp;
        }

        animationFrame = requestAnimationFrame(animate);
      };

      const startMarquee = () => {
        if (isNativeScroll || animationFrame) {
          return;
        }

        animationFrame = requestAnimationFrame(animate);
      };

      const easeInOutCubic = (progress) => {
        return progress < 0.5
          ? 4 * progress * progress * progress
          : 1 - Math.pow(-2 * progress + 2, 3) / 2;
      };

      const nudgeMarquee = (direction) => {
        if (cardPitch <= 0) {
          return;
        }

        if (isNativeScroll) {
          scroller.scrollBy({ left: cardPitch * direction, behavior: isReducedMotion ? 'auto' : 'smooth' });
          return;
        }

        stopNudge();

        const startOffset = offset;
        const targetOffset = startOffset - cardPitch * direction;
        const startTime = performance.now();

        const step = (timestamp) => {
          const progress = Math.min(1, (timestamp - startTime) / nudgeDuration);
          const easedProgress = easeInOutCubic(progress);

          offset = startOffset + (targetOffset - startOffset) * easedProgress;
          applySafeOffset();
          updateTrackPosition();

          if (progress < 1) {
            nudgeFrame = requestAnimationFrame(step);
            return;
          }

          nudgeFrame = null;
          lastFrameTime = null;
        };

        nudgeFrame = requestAnimationFrame(step);
      };

      const normalizeWheelDelta = (delta, deltaMode) => {
        if (deltaMode === WheelEvent.DOM_DELTA_LINE) {
          return delta * 16;
        }

        if (deltaMode === WheelEvent.DOM_DELTA_PAGE) {
          return delta * scroller.clientWidth;
        }

        return delta;
      };

      const handleWheel = (event) => {
        if (isNativeScroll) {
          return;
        }

        const horizontalDelta = normalizeWheelDelta(event.deltaX, event.deltaMode);
        const verticalDelta = normalizeWheelDelta(event.deltaY, event.deltaMode);
        const isIntentionalHorizontalScroll = Math.abs(horizontalDelta) > Math.abs(verticalDelta) * 1.05;

        if (!isIntentionalHorizontalScroll || setWidth <= 0) {
          return;
        }

        event.preventDefault();
        stopNudge();
        offset -= horizontalDelta;
        applySafeOffset();
        updateTrackPosition();
        lastFrameTime = null;
      };

      const handleResize = () => {
        lastFrameTime = null;
        measureCarousel();
      };

      const handleMotionPreferenceChange = (event) => {
        isReducedMotion = event.matches;
        setCarouselMode();
        stopMarquee();
        measureCarousel();
        startMarquee();
      };

      const handleNativeScrollPreferenceChange = () => {
        setCarouselMode();
        stopMarquee();
        measureCarousel();
        startMarquee();
      };

      const handleNextClick = () => nudgeMarquee(1);
      const handlePrevClick = () => nudgeMarquee(-1);

      next.addEventListener('click', handleNextClick);
      prev.addEventListener('click', handlePrevClick);
      scroller.addEventListener('wheel', handleWheel, { passive: false });

      setCarouselMode();
      measureCarousel();

      if ('ResizeObserver' in window) {
        resizeObserver = new ResizeObserver(handleResize);
        resizeObserver.observe(cardSet);
        resizeObserver.observe(scroller);
      } else {
        window.addEventListener('resize', handleResize);
      }

      if (typeof reducedMotionQuery.addEventListener === 'function') {
        reducedMotionQuery.addEventListener('change', handleMotionPreferenceChange);
      } else if (typeof reducedMotionQuery.addListener === 'function') {
        reducedMotionQuery.addListener(handleMotionPreferenceChange);
      }

      if (typeof nativeScrollQuery.addEventListener === 'function') {
        nativeScrollQuery.addEventListener('change', handleNativeScrollPreferenceChange);
      } else if (typeof nativeScrollQuery.addListener === 'function') {
        nativeScrollQuery.addListener(handleNativeScrollPreferenceChange);
      }

      startMarquee();
      section.dataset.mellowExpertProofReady = 'true';
      window.requestAnimationFrame(releaseSectionReady);

      section.mellowExpertProofCleanup = () => {
        stopMarquee();
        scroller.removeEventListener('wheel', handleWheel);
        next.removeEventListener('click', handleNextClick);
        prev.removeEventListener('click', handlePrevClick);

        if (!resizeObserver) {
          window.removeEventListener('resize', handleResize);
        }

        if (typeof reducedMotionQuery.removeEventListener === 'function') {
          reducedMotionQuery.removeEventListener('change', handleMotionPreferenceChange);
        } else if (typeof reducedMotionQuery.removeListener === 'function') {
          reducedMotionQuery.removeListener(handleMotionPreferenceChange);
        }

        if (typeof nativeScrollQuery.removeEventListener === 'function') {
          nativeScrollQuery.removeEventListener('change', handleNativeScrollPreferenceChange);
        } else if (typeof nativeScrollQuery.removeListener === 'function') {
          nativeScrollQuery.removeListener(handleNativeScrollPreferenceChange);
        }

        if (resizeObserver) {
          resizeObserver.disconnect();
        }
      };
    };

    const initCurrentSection = () => {
      initExpertProof(document.getElementById('MellowExpertProof-{{ section.id }}'));
    };

    initCurrentSection();

    document.addEventListener('shopify:section:load', (event) => {
      initExpertProof(event.target.querySelector('[data-mellow-expert-proof]'));
    });

    document.addEventListener('shopify:section:unload', (event) => {
      const section = event.target.querySelector('[data-mellow-expert-proof]');

      if (section && typeof section.mellowExpertProofCleanup === 'function') {
        section.mellowExpertProofCleanup();
      }
    });
  })();
</script>

