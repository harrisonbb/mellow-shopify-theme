<script>
  (() => {
    const initExpertProof = (section) => {
      if (!section || section.dataset.mellowExpertProofReady === 'true') return;

      const scroller = section.querySelector('[data-expert-scroller]');
      const track = section.querySelector('[data-expert-track]');
      const prev = section.querySelector('[data-expert-prev]');
      const next = section.querySelector('[data-expert-next]');

      if (!scroller || !track || !prev || !next) return;

      const cards = Array.from(track.querySelectorAll('.mellow-expert-proof__card'));
      if (!cards.length) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

      const getStep = () => {
        const firstCard = cards[0];
        const styles = window.getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap) || 0;

        return firstCard ? firstCard.getBoundingClientRect().width + gap : scroller.clientWidth;
      };

      const getMaxScroll = () => Math.max(0, scroller.scrollWidth - scroller.clientWidth);

      const updateControls = () => {
        const maxScroll = getMaxScroll();
        const atStart = scroller.scrollLeft <= 1;
        const atEnd = scroller.scrollLeft >= maxScroll - 1;

        prev.disabled = atStart;
        next.disabled = atEnd;
        prev.setAttribute('aria-disabled', String(atStart));
        next.setAttribute('aria-disabled', String(atEnd));
      };

      const scrollByCard = (direction) => {
        const maxScroll = getMaxScroll();
        const target = Math.min(maxScroll, Math.max(0, scroller.scrollLeft + getStep() * direction));
        const behavior = prefersReducedMotion.matches ? 'auto' : 'smooth';

        scroller.scrollTo({ left: target, behavior });
      };

      next.addEventListener('click', () => {
        if (!next.disabled) scrollByCard(1);
      });

      prev.addEventListener('click', () => {
        if (!prev.disabled) scrollByCard(-1);
      });

      let scrollFrame;
      scroller.addEventListener('scroll', () => {
        if (scrollFrame) return;

        scrollFrame = window.requestAnimationFrame(() => {
          scrollFrame = null;
          updateControls();
        });
      }, { passive: true });

      window.addEventListener('resize', () => {
        window.requestAnimationFrame(updateControls);
      });

      updateControls();
      section.dataset.mellowExpertProofReady = 'true';
    };

    const initCurrentSection = () => {
      initExpertProof(document.getElementById('MellowExpertProof-{{ section.id }}'));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCurrentSection, { once: true });
    } else {
      initCurrentSection();
    }

    document.addEventListener('shopify:section:load', (event) => {
      initExpertProof(event.target.querySelector('[data-mellow-expert-proof]'));
    });
  })();
</script>

