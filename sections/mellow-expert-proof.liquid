            <p class="mellow-card-copy mellow-expert-proof__quote">{{ section.settings.card_1_quote | escape }}</p>
            <div class="mellow-expert-proof__person">
              <h3 class="mellow-card-title mellow-expert-proof__name">{{ section.settings.card_1_name | escape }}</h3>
