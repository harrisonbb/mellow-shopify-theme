{% comment %}
  Mellow Buy Section
  Updated:
  - Header typography matched exactly to Mellow Hero / Ingredients system
  - Fraunces 550 heading, tight line-height, negative tracking
  - Responsive heading breakpoints matched to Ingredients section
  - Eyebrow locked to DM Sans 800 / orange / compact spacing
  - Background changed to match main site white #FBFCF7
  - Hard override applied to Shopify wrapper and section
{% endcomment %}

<section class="mellow-buy-section mellow-buy-section-{{ section.id }}" id="buy">
  <div class="mellow-buy-container">

    <div class="mellow-buy-header">
      <span class="mellow-buy-eyebrow mellow-buy__eyebrow mellow-eyebrow">Choose your relief plan</span>

      <h2 class="mellow-buy-title mellow-buy__heading">Build your reflux routine.</h2>

      <p class="mellow-buy-subtitle">
        Keep Mellow ready for after meals, before bed, and the moments reflux usually gets in the way.
      </p>
    </div>

    <div class="mellow-buy-grid">

      <div class="mellow-plan-card mellow-plan-card--featured">
        <div class="mellow-plan-badge">Best routine</div>

        <div class="mellow-plan-top">
          <h3>Subscribe &amp; Save</h3>
          <p>Monthly pouch supply for daily reflux support.</p>
        </div>

        <div class="mellow-plan-price">
          <span class="mellow-plan-price-main">$30</span>
          <span class="mellow-plan-price-sub">/ month</span>
        </div>

        <div class="mellow-plan-daily-price">About $1.00/day</div>

        <ul class="mellow-plan-list">
          <li>Ships every month</li>
          <li>Made for after-meal and nighttime reflux</li>
          <li>Easy single-serve pouches</li>
          <li>Cancel or pause anytime</li>
        </ul>

        <a href="/products/mellow-reflux-relief" class="mellow-plan-button">
          Start subscription
        </a>
      </div>

      <div class="mellow-plan-card">
        <div class="mellow-plan-top">
          <h3>3-Month Supply</h3>
          <p>Stock up for a consistent reflux routine.</p>
        </div>

        <div class="mellow-plan-price">
          <span class="mellow-plan-price-main">$75</span>
          <span class="mellow-plan-price-sub">prepaid</span>
        </div>

        <div class="mellow-plan-daily-price">About $0.83/day</div>

        <ul class="mellow-plan-list">
          <li>Best for building the habit</li>
          <li>Lower cost per pouch</li>
          <li>Less frequent reordering</li>
          <li>Great for home, work, and travel</li>
        </ul>

        <a href="/products/mellow-reflux-relief" class="mellow-plan-button mellow-plan-button--secondary">
          Choose 3-month supply
        </a>
      </div>

      <div class="mellow-plan-card">
        <div class="mellow-plan-top">
          <h3>One-Time Purchase</h3>
          <p>Try Mellow without a subscription.</p>
        </div>

        <div class="mellow-plan-price">
          <span class="mellow-plan-price-main">$25</span>
          <span class="mellow-plan-price-sub">one-time</span>
        </div>

        <div class="mellow-plan-daily-price">About $0.83/day</div>

        <ul class="mellow-plan-list">
          <li>Simple first try</li>
          <li>No subscription required</li>
          <li>Single-serve pouch format</li>
          <li>Use after meals or before bed</li>
        </ul>

        <a href="/products/mellow-reflux-relief" class="mellow-plan-button mellow-plan-button--secondary">
          Try Mellow
        </a>
      </div>

    </div>

  </div>
</section>

