{%- liquid
  assign spacing_class = 'mellow-trust-bar--' | append: section.settings.spacing
-%}

{%- style -%}
  #MellowTrustBar-{{ section.id }} {
    --mellow-trust-background: {{ section.settings.background_color | default: '#F0EBE0' }};
    --mellow-trust-text: var(--mellow-forest, #003302);
    --mellow-trust-accent: var(--mellow-orange-red, #D04A2A);
    --mellow-trust-blue: var(--mellow-science-blue, #3D6B8C);
    --mellow-trust-muted: rgba(0, 51, 2, 0.72);
    --mellow-trust-border: rgba(0, 51, 2, 0.14);
    --mellow-trust-panel: rgba(255, 255, 255, 0.34);
    --mellow-trust-panel-hover: rgba(255, 255, 255, 0.5);
    background: var(--mellow-trust-background);
    color: var(--mellow-trust-text);
    padding-top: clamp(22px, 2.8vw, 38px);
    padding-bottom: clamp(22px, 2.8vw, 38px);
    overflow: hidden;
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--compact {
    padding-top: clamp(16px, 2vw, 26px);
    padding-bottom: clamp(16px, 2vw, 26px);
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--spacious {
    padding-top: clamp(34px, 4vw, 56px);
    padding-bottom: clamp(34px, 4vw, 56px);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__inner {
    width: 100%;
    max-width: none;
    margin-left: 0;
    margin-right: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__eyebrow {
    margin: 0 0 clamp(14px, 1.6vw, 20px);
    color: var(--mellow-trust-accent);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    border: 1px solid var(--mellow-trust-border);
    border-radius: var(--mellow-radius-card, 28px);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.12)),
      var(--mellow-trust-panel);
    box-shadow: 0 18px 44px rgba(0, 51, 2, 0.07);
    list-style: none;
    overflow: hidden;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item {
    position: relative;
    min-width: 0;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(12px, 1.4vw, 18px);
    min-height: 100%;
    padding: clamp(18px, 2.2vw, 28px) clamp(16px, 2.1vw, 30px);
    background: transparent;
    transition: background-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--compact .mellow-trust-bar__item-inner {
    padding-top: clamp(14px, 1.6vw, 20px);
    padding-bottom: clamp(14px, 1.6vw, 20px);
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--spacious .mellow-trust-bar__item-inner {
    padding-top: clamp(24px, 2.7vw, 34px);
    padding-bottom: clamp(24px, 2.7vw, 34px);
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:not(:first-child)::before {
    content: '';
    position: absolute;
    top: clamp(16px, 22%, 28px);
    bottom: clamp(16px, 22%, 28px);
    left: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(0, 51, 2, 0.2), transparent);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(34px, 3vw, 42px);
    height: clamp(34px, 3vw, 42px);
    border: 1px solid rgba(208, 74, 42, 0.28);
    border-radius: var(--mellow-radius-pill, 999px);
    background: rgba(208, 74, 42, 0.08);
    color: var(--mellow-trust-accent);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 750;
    letter-spacing: 0.04em;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--seal {
    border-radius: 36% 64% 42% 58% / 58% 40% 60% 42%;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--outline {
    background: transparent;
    border-color: rgba(0, 51, 2, 0.24);
    color: var(--mellow-trust-text);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--science {
    border-color: rgba(61, 107, 140, 0.3);
    background: rgba(61, 107, 140, 0.08);
    color: var(--mellow-trust-blue);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__content {
    min-width: 0;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__label {
    margin: 0;
    color: var(--mellow-trust-text);
    font-family: var(--mellow-font-sans, var(--font-body-family, sans-serif));
    font-size: clamp(15px, 1vw, 17px);
    font-weight: 750;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__subcopy {
    margin: 0.42rem 0 0;
    color: var(--mellow-trust-muted);
    font-family: var(--mellow-font-sans, var(--font-body-family, sans-serif));
    font-size: clamp(13px, 0.92vw, 15px);
    font-weight: 450;
    letter-spacing: -0.004em;
    line-height: 1.36;
  }

  @media screen and (min-width: 990px) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner:hover {
      background-color: var(--mellow-trust-panel-hover);
      box-shadow: inset 0 0 0 1px rgba(0, 51, 2, 0.05);
      transform: translateY(-2px);
    }
  }

  @media screen and (max-width: 989px) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item::before {
      display: none;
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:nth-child(2n)::before {
      content: '';
      display: block;
      position: absolute;
      top: clamp(16px, 20%, 24px);
      bottom: clamp(16px, 20%, 24px);
      left: 0;
      width: 1px;
      background: linear-gradient(180deg, transparent, rgba(0, 51, 2, 0.18), transparent);
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:nth-child(n + 3)::after {
      content: '';
      position: absolute;
      top: 0;
      right: clamp(16px, 5vw, 28px);
      left: clamp(16px, 5vw, 28px);
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0, 51, 2, 0.16), transparent);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
      grid-template-columns: 1fr;
      border-radius: calc(var(--mellow-radius-card, 28px) * 0.78);
    }

    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
      padding: 16px clamp(16px, 5vw, 22px);
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item::before,
    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:nth-child(2n)::before {
      display: none;
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:not(:first-child)::after {
      content: '';
      position: absolute;
      top: 0;
      right: clamp(16px, 5vw, 24px);
      left: clamp(16px, 5vw, 24px);
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0, 51, 2, 0.16), transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
      transition: none;
    }

    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section
  id="MellowTrustBar-{{ section.id }}"
  class="mellow-trust-bar {{ spacing_class }}{% if section.settings.show_dividers %} mellow-trust-bar--dividers{% endif %}"
  aria-label="Mellow trust highlights"
>
  <div class="mellow-trust-bar__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="mellow-eyebrow mellow-trust-bar__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    <ul class="mellow-trust-bar__list" role="list">
      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_1_icon_style }}" aria-hidden="true">{{ section.settings.item_1_icon_text | escape }}</span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_1_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_1_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_2_icon_style }}" aria-hidden="true">{{ section.settings.item_2_icon_text | escape }}</span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_2_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_2_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_3_icon_style }}" aria-hidden="true">{{ section.settings.item_3_icon_text | escape }}</span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_3_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_3_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_4_icon_style }}" aria-hidden="true">{{ section.settings.item_4_icon_text | escape }}</span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_4_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_4_subcopy | escape }}</p>
          </div>
        </div>
      </li>
    </ul>
  </div>
</section>

