{% comment %}
  Mellow Trust Strip — Clean Light Version
  Updated:
  - Slot 1 changed to Doctor-recommended
  - Subtext changed to Formulated with licensed physicians.
  - Slot 2: MellowRaft™ named mechanism + plain-English explanation
  - Slot 3: HSA/FSA payment benefit
  - Trust row stays in the same lower vertical spot
  - Green section stays pulled back into viewport
  - Removed dark green band
  - Uses page/hero background color
  - Text matches header/brand forest green
  - Removed top and bottom border lines
  - Softer icon circles
  - Isolated class names to avoid old proof-strip conflicts
{% endcomment %}

<section
  id="mellow-trust-strip-{{ section.id }}"
  class="mellow-trust-strip-clean mellow-trust-strip-clean-{{ section.id }}"
>
  <div class="mellow-trust-strip-clean__inner">
    <ul class="mellow-trust-strip-clean__list" aria-label="Mellow trust signals">

      <li class="mellow-trust-strip-clean__item">
        <span class="mellow-trust-strip-clean__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M12 2L4 5.5V11.5C4 16.4 7.4 20.9 12 22C16.6 20.9 20 16.4 20 11.5V5.5L12 2Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
            <path d="M9 12L11.1 14.1L15.5 9.7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>

        <span class="mellow-trust-strip-clean__text">
          <span class="mellow-trust-strip-clean__label">Doctor-recommended</span>
          <span class="mellow-trust-strip-clean__subtext">Formulated with licensed physicians.</span>
        </span>
      </li>

      <li class="mellow-trust-strip-clean__item">
        <span class="mellow-trust-strip-clean__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M5 16C7.5 11 11 8.5 17 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            <path d="M7 18C10 14.5 14 12.5 20 12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            <path d="M4 12C6 8 9 5.5 14 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            <path d="M6 18C4.5 16.7 3.8 15 4 13.2C4.3 9.5 8.4 5.8 16.5 4.5C16.9 9.9 15.5 14.1 12.7 16.4C10.8 18 8.5 18.5 6 18Z" stroke="currentColor" stroke-width="1.75" stroke-linejoin="round"/>
          </svg>
        </span>

        <span class="mellow-trust-strip-clean__text">
          <span class="mellow-trust-strip-clean__label">MellowRaft™ technology</span>
          <span class="mellow-trust-strip-clean__subtext">A gel barrier that floats above stomach acid.</span>
        </span>
      </li>

      <li class="mellow-trust-strip-clean__item">
        <span class="mellow-trust-strip-clean__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>

        <span class="mellow-trust-strip-clean__text">
          <span class="mellow-trust-strip-clean__label">HSA/FSA eligible</span>
          <span class="mellow-trust-strip-clean__subtext">Pay with your pre-tax health dollars.</span>
        </span>
      </li>

    </ul>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }},
  #mellow-trust-strip-{{ section.id }},
  #mellow-trust-strip-{{ section.id }} * {
    box-sizing: border-box !important;
  }

  #shopify-section-{{ section.id }} {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    background: var(--mellow-page, #FBFCF7) !important;
    background-color: var(--mellow-page, #FBFCF7) !important;
    border: 0 !important;
    overflow: hidden !important;
    position: relative !important;
    z-index: 4 !important;
  }

  #mellow-trust-strip-{{ section.id }} {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;

    /* Keep the trust row close to the hero so it remains above the fold. */
    padding: 20px clamp(32px, 5vw, 80px) 18px !important;

    background: var(--mellow-page, #FBFCF7) !important;
    background-color: var(--mellow-page, #FBFCF7) !important;
    background-image: none !important;

    color: var(--mellow-forest, #1A2D10) !important;
    border-top: 0 !important;
    border-bottom: 0 !important;
    overflow: hidden !important;
    position: relative !important;
    z-index: 3 !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__inner {
    width: 100% !important;
    max-width: 1120px !important;
    margin: 0 auto !important;
    padding: 0 !important;

    background: transparent !important;
    background-color: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    overflow: visible !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__list {
    list-style: none !important;
    width: 100% !important;
    max-width: none !important;
    margin: 0 auto !important;
    padding: 0 !important;

    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    align-items: center !important;
    justify-items: center !important;
    column-gap: 32px !important;
    row-gap: 0 !important;

    background: transparent !important;
    background-color: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
    overflow: visible !important;

    transform: none !important;
    translate: none !important;
    left: auto !important;
    right: auto !important;
    position: relative !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__item {
    width: 100% !important;
    max-width: 315px !important;
    min-width: 0 !important;

    display: grid !important;
    grid-template-columns: 38px minmax(0, 1fr) !important;
    align-items: center !important;
    justify-content: start !important;
    column-gap: 14px !important;

    margin: 0 !important;
    padding: 0 !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;

    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    color: var(--mellow-forest, #1A2D10) !important;
    text-align: left !important;
    overflow: visible !important;
    position: relative !important;

    transform: none !important;
    translate: none !important;
    left: auto !important;
    right: auto !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__item::before,
  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__item::after,
  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__list::before,
  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__list::after,
  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__inner::before,
  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__inner::after {
    content: none !important;
    display: none !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__icon {
    width: 38px !important;
    height: 38px !important;
    min-width: 38px !important;
    max-width: 38px !important;

    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    border-radius: 999px !important;
    color: var(--mellow-forest, #1A2D10) !important;
    background: rgba(26, 45, 16, 0.045) !important;
    border: 1px solid rgba(26, 45, 16, 0.10) !important;
    box-shadow: none !important;

    flex-shrink: 0 !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__icon svg {
    width: 19px !important;
    height: 19px !important;
    display: block !important;
    color: currentColor !important;
    stroke: currentColor !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__text {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 4px !important;

    min-width: 0 !important;
    width: 100% !important;
    max-width: 250px !important;

    background: transparent !important;
    text-align: left !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__label {
    display: block !important;
    width: 100% !important;
    margin: 0 !important;

    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 1rem !important;
    line-height: 1.12 !important;
    font-weight: 800 !important;
    letter-spacing: -0.025em !important;

    color: var(--mellow-forest, #1A2D10) !important;
    text-align: left !important;
    white-space: normal !important;
  }

  #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__subtext {
    display: block !important;
    width: 100% !important;
    margin: 0 !important;

    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.82rem !important;
    line-height: 1.34 !important;
    font-weight: 500 !important;
    letter-spacing: 0.002em !important;

    color: rgba(26, 45, 16, 0.62) !important;
    text-align: left !important;
    white-space: normal !important;
  }

  @media screen and (max-width: 980px) {
    #mellow-trust-strip-{{ section.id }} {
      padding: 20px 28px 16px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__inner {
      max-width: 920px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__list {
      column-gap: 20px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__item {
      max-width: 290px !important;
      grid-template-columns: 36px minmax(0, 1fr) !important;
      column-gap: 12px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__icon {
      width: 36px !important;
      height: 36px !important;
      min-width: 36px !important;
      max-width: 36px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__label {
      font-size: 0.96rem !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__subtext {
      font-size: 0.8rem !important;
    }
  }

  @media screen and (max-width: 760px) {
    #mellow-trust-strip-{{ section.id }} {
      padding: 18px 20px 14px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__inner {
      max-width: 520px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__list {
      grid-template-columns: 1fr !important;
      row-gap: 16px !important;
      justify-items: start !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__item {
      width: 100% !important;
      max-width: none !important;
      grid-template-columns: 38px minmax(0, 1fr) !important;
      column-gap: 14px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__icon {
      width: 38px !important;
      height: 38px !important;
      min-width: 38px !important;
      max-width: 38px !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__text {
      max-width: none !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__label {
      font-size: 0.96rem !important;
    }

    #mellow-trust-strip-{{ section.id }} .mellow-trust-strip-clean__subtext {
      font-size: 0.82rem !important;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow Trust Strip",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Mellow Trust Strip"
    }
  ]
}
{% endschema %}