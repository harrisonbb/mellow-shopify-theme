{%- liquid
  assign spacing_class = 'mellow-trust-bar--' | append: section.settings.spacing
-%}

{%- style -%}
  #MellowTrustBar-{{ section.id }} {
    --mellow-trust-background: {{ section.settings.background_color | default: '#F0EBE0' }};
    --mellow-trust-text: var(--mellow-forest, #003302);
    --mellow-trust-accent: var(--mellow-orange-red, #D04A2A);
    --mellow-trust-blue: var(--mellow-science-blue, #3D6B8C);
    --mellow-trust-muted: rgba(0, 51, 2, 0.62);
    --mellow-trust-border: rgba(0, 51, 2, 0.14);
    background: var(--mellow-trust-background);
    color: var(--mellow-trust-text);
    padding-top: 0;
    padding-bottom: var(--mellow-section-content-gap-compact);
    overflow: hidden;
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--compact {
    padding-bottom: var(--mellow-section-heading-gap);
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--spacious {
    padding-bottom: var(--mellow-section-content-gap);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__inner {
    width: 100%;
    max-width: none;
    margin-left: 0;
    margin-right: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__eyebrow {
    margin: 0 0 clamp(14px, 1.6vw, 20px);
    color: var(--mellow-trust-accent);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--mellow-section-content-gap-compact);
    margin: 0;
    padding: var(--mellow-section-content-gap-compact) 0 0;
    border-top: 1px solid var(--mellow-trust-border);
    list-style: none;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item {
    position: relative;
    min-width: 0;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: var(--mellow-card-gap-tight);
    min-height: 100%;
    padding: 0;
    background: transparent;
  }

  #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item:not(:first-child)::before {
    content: none;
    display: none;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: rgba(0, 51, 2, 0.68);
    font-size: clamp(12px, 0.9vw, 14px);
    font-weight: 750;
    letter-spacing: 0.04em;
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--seal {
    color: rgba(0, 51, 2, 0.68);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--outline {
    color: rgba(0, 51, 2, 0.68);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark--science {
    color: rgba(0, 51, 2, 0.68);
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__mark svg {
    display: block;
    width: 20px;
    height: 20px;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__content {
    min-width: 0;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__label {
    margin: 0;
    color: var(--mellow-trust-text);
    font-family: var(--mellow-font-sans, var(--font-body-family, sans-serif));
    font-size: clamp(14px, 0.95vw, 16px);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  #MellowTrustBar-{{ section.id }} .mellow-trust-bar__subcopy {
    margin: 0.42rem 0 0;
    color: var(--mellow-trust-muted);
    font-family: var(--mellow-font-sans, var(--font-body-family, sans-serif));
    font-size: clamp(13px, 0.86vw, 14px);
    font-weight: 450;
    letter-spacing: -0.004em;
    line-height: 1.4;
  }

  @media screen and (max-width: 989px) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--mellow-card-gap);
    }

    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item::before,
    #MellowTrustBar-{{ section.id }}.mellow-trust-bar--dividers .mellow-trust-bar__item::after {
      content: none;
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__list {
      grid-template-columns: 1fr;
      gap: var(--mellow-card-gap-tight-y);
      padding-top: var(--mellow-section-heading-gap);
    }

    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
      align-items: start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner {
      transition: none;
    }

    #MellowTrustBar-{{ section.id }} .mellow-trust-bar__item-inner:hover {
      transform: none;
    }
  }
{%- endstyle -%}

<section
  id="MellowTrustBar-{{ section.id }}"
  class="mellow-trust-bar {{ spacing_class }}{% if section.settings.show_dividers %} mellow-trust-bar--dividers{% endif %}"
  aria-label="Mellow trust highlights"
>
  <div class="mellow-trust-bar__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="mellow-eyebrow mellow-trust-bar__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    <ul class="mellow-trust-bar__list" role="list">
      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_1_icon_style }}" aria-hidden="true">
            {%- assign item_1_icon_key = section.settings.item_1_label | handleize -%}
            {%- case item_1_icon_key -%}
              {%- when 'doctor-recommended' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="8" />
                  <path d="M6 4v5a4 4 0 0 0 8 0V4" />
                  <path d="M6 4H4.8" />
                  <path d="M14 4h1.2" />
                  <path d="M10 13v2.5a4.5 4.5 0 0 0 9 0V14" />
                  <circle cx="19" cy="12" r="2" />
                  <path d="M17.8 6.5h4.4" />
                  <path d="M20 4.3v4.4" />
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="7" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
            {%- endcase -%}
          </span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_1_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_1_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_2_icon_style }}" aria-hidden="true">
            {%- assign item_2_icon_key = section.settings.item_2_label | handleize -%}
            {%- case item_2_icon_key -%}
              {%- when 'raft-forming-technology' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M4 8.2c2 0 2-1.4 4-1.4s2 1.4 4 1.4 2-1.4 4-1.4 2 1.4 4 1.4" />
                  <path d="M4 12.2c2 0 2-1.4 4-1.4s2 1.4 4 1.4 2-1.4 4-1.4 2 1.4 4 1.4" />
                  <path d="M4 16.2c2 0 2-1.4 4-1.4s2 1.4 4 1.4 2-1.4 4-1.4 2 1.4 4 1.4" />
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="7" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
            {%- endcase -%}
          </span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_2_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_2_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_3_icon_style }}" aria-hidden="true">
            {%- assign item_3_icon_key = section.settings.item_3_label | handleize -%}
            {%- case item_3_icon_key -%}
              {%- when 'hsa-fsa-eligible' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="8" />
                  <path d="M12 7v10" />
                  <path d="M15.3 9.2c-.7-.8-1.8-1.2-3-1.2-1.7 0-3 .8-3 2.2 0 3.2 6.4 1.6 6.4 4.8 0 1.3-1.2 2.2-3.2 2.2-1.4 0-2.8-.5-3.7-1.4" />
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="7" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
            {%- endcase -%}
          </span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_3_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_3_subcopy | escape }}</p>
          </div>
        </div>
      </li>

      <li class="mellow-trust-bar__item">
        <div class="mellow-trust-bar__item-inner">
          <span class="mellow-trust-bar__mark mellow-trust-bar__mark--{{ section.settings.item_4_icon_style }}" aria-hidden="true">
            {%- assign item_4_icon_key = section.settings.item_4_label | handleize -%}
            {%- case item_4_icon_key -%}
              {%- when 'works-in-minutes' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <path d="M9 2.8h6" />
                  <path d="M12 6.2v-3" />
                  <path d="m17.8 6.2 1.6-1.6" />
                  <circle cx="12" cy="13.2" r="7.2" />
                  <path d="M12 9.6v4l2.6 1.6" />
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                  <circle cx="12" cy="12" r="7" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
            {%- endcase -%}
          </span>
          <div class="mellow-trust-bar__content">
            <p class="mellow-trust-bar__label">{{ section.settings.item_4_label | escape }}</p>
            <p class="mellow-trust-bar__subcopy">{{ section.settings.item_4_subcopy | escape }}</p>
          </div>
        </div>
      </li>
    </ul>
  </div>
</section>

