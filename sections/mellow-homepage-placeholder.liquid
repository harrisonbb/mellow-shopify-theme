{% comment %}
  Mellow homepage placeholder section.
  Clean Dawn-compatible starting point for a future conversion-focused homepage.

  TODO future sections:
  - mellow-hero
  - mellow-trust-bar
  - mellow-who-its-for
  - mellow-video-reviews
  - mellow-how-to-use
  - mellow-ingredients
  - mellow-raft-science
  - mellow-clinical-proof
  - mellow-expert-proof
  - mellow-comparison
  - mellow-reviews-grid
  - mellow-subscription-buybox
  - mellow-faq
{% endcomment %}

{%- liquid
  assign section_eyebrow = section.settings.eyebrow | strip
  assign section_heading = section.settings.heading | strip
  assign section_lede = section.settings.lede | strip
  assign primary_label = section.settings.primary_label | strip
  assign secondary_label = section.settings.secondary_label | strip
  assign has_customer_content = false

  if section_eyebrow != blank or section_heading != blank or section_lede != blank or primary_label != blank or secondary_label != blank
    assign has_customer_content = true
  endif

  assign scaffold_eyebrow = 'Mellow fresh ' | append: 'start'
  assign scaffold_heading = 'A calm, premium foundation for reflux ' | append: 'relief.'
  assign scaffold_lede = 'This placeholder keeps the new Dawn-based theme clean while the full Mellow homepage system is rebuilt section by ' | append: 'section.'
  assign scaffold_primary_label = 'Shop ' | append: 'Mellow'
  assign scaffold_secondary_label = 'See the ' | append: 'plan'
  assign is_scaffold_copy = false

  if section_eyebrow == scaffold_eyebrow and section_heading == scaffold_heading and section_lede == scaffold_lede and primary_label == scaffold_primary_label and secondary_label == scaffold_secondary_label
    assign is_scaffold_copy = true
  endif
-%}

{%- if has_customer_content and is_scaffold_copy == false -%}
<section class="mellow-section mellow-home-placeholder color-{{ section.settings.color_scheme }}">
  <div class="mellow-section__inner">
    <div class="mellow-home-placeholder__card">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="mellow-heading">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.lede != blank -%}
          <p class="mellow-lede">{{ section.settings.lede | escape }}</p>
        {%- endif -%}

        <div class="mellow-actions">
          {%- if section.settings.primary_label != blank -%}
            <a class="mellow-button" href="{{ section.settings.primary_link | default: '#' }}">
              {{ section.settings.primary_label | escape }}
            </a>
          {%- endif -%}

          {%- if section.settings.secondary_label != blank -%}
            <a class="mellow-button mellow-button--secondary" href="{{ section.settings.secondary_link | default: '#' }}">
              {{ section.settings.secondary_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
{%- elsif request.design_mode -%}
  <section class="mellow-section mellow-home-placeholder color-{{ section.settings.color_scheme }}">
    <div class="mellow-section__inner">
      <div class="mellow-home-placeholder__card">
        <div>
          <p class="mellow-eyebrow">Mellow homepage</p>
          <h1 class="mellow-heading">Configure this section to show it on the storefront.</h1>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}


{% schema %}
{
  "name": "Mellow homepage",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Lead copy",
      "default": ""
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": ""
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": ""
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Mellow homepage"
    }
  ]
}
{% endschema %}
