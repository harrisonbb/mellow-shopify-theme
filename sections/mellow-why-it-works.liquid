{% comment %}
  Mellow why it works section.
  Warm ivory educational sequence for the MellowRaft mechanism.
{% endcomment %}

{%- liquid
  assign why_eyebrow = section.settings.eyebrow | default: 'HOW IT WORKS'
  assign why_heading = section.settings.heading | default: 'How MellowRaft™ works'
  assign why_subheading = section.settings.subheading | default: 'Mellow activates in stomach acid to form a soft, floating barrier that helps keep reflux where it starts.'
  assign step_1_title = section.settings.step_1_title | default: 'ACTIVATE'
  assign step_1_description = section.settings.step_1_description | default: 'Gel meets acid.'
  assign step_2_title = section.settings.step_2_title | default: 'FORM'
  assign step_2_description = section.settings.step_2_description | default: 'A soft raft begins to build.'
  assign step_3_title = section.settings.step_3_title | default: 'FLOAT'
  assign step_3_description = section.settings.step_3_description | default: 'The barrier rises and rests on top.'
-%}

<style>
  #MellowWhyItWorks-{{ section.id }} {
    --mellow-why-it-works-card-gap: var(--mellow-card-gap, clamp(28px, 2.6vw, 42px));
    --mellow-why-it-works-text: var(--mellow-forest, #123308);
    --mellow-why-it-works-ivory: var(--mellow-ivory, var(--mellow-cream, #FCFBF7));
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    background: var(--mellow-why-it-works-ivory) !important;
    background-color: var(--mellow-why-it-works-ivory) !important;
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
  }

  #MellowWhyItWorks-{{ section.id }} :where(.mellow-why-it-works__header, .mellow-why-it-works__heading, .mellow-why-it-works__subheading, .mellow-why-it-works__step, .mellow-why-it-works__step-title, .mellow-why-it-works__step-copy) {
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__inner {
    width: min(calc(100% - (var(--mellow-section-axis-pad, 22px) * 2)), var(--mellow-axis-max, 1200px));
    max-width: var(--mellow-axis-max, 1200px);
    margin-left: auto;
    margin-right: auto;
    padding-left: 0;
    padding-right: 0;
    box-sizing: border-box;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 1px minmax(280px, 0.72fr);
    gap: var(--mellow-section-content-gap, clamp(34px, 3.2vw, 54px));
    align-items: center;
    max-width: none;
    margin: 0 0 var(--mellow-section-content-gap, clamp(34px, 3.2vw, 54px));
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header-main,
  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header-right {
    min-width: 0;
    color: var(--mellow-forest, #123308) !important;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__eyebrow {
    margin: 0 0 var(--mellow-section-header-gap, clamp(10px, 1vw, 14px));
    color: var(--mellow-orange-red, #D04A2A) !important;
    -webkit-text-fill-color: var(--mellow-orange-red, #D04A2A) !important;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__heading {
    display: block;
    max-width: var(--mellow-header-max, 760px);
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    font-size: var(--mellow-section-heading-size, var(--mellow-heading-size, clamp(40px, 3.7vw, 56px)));
    line-height: var(--mellow-section-heading-line-height, var(--mellow-heading-line-height, 0.98));
    font-weight: var(--mellow-section-heading-weight, var(--mellow-heading-weight, 600));
    letter-spacing: var(--mellow-section-heading-letter-spacing, var(--mellow-heading-tracking, -0.028em));
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__subheading {
    display: block;
    max-width: var(--mellow-copy-max, 620px);
    margin: 0;
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    font-family: var(--font-body-family, inherit);
    font-size: var(--mellow-subhead-size, clamp(18px, 1.32vw, 20px));
    line-height: var(--mellow-subhead-line-height, 1.46);
    font-weight: var(--mellow-subhead-weight, 400);
    letter-spacing: var(--mellow-subhead-tracking, -0.005em);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__divider {
    display: block;
    width: 1px;
    height: clamp(88px, 7vw, 124px);
    background: rgba(18, 51, 8, 0.16);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header-right {
    padding-left: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__sequence {
    margin-top: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--mellow-why-it-works-card-gap);
    margin-top: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 1.08 / 1;
    overflow: hidden;
    isolation: isolate;
    border-radius: min(var(--mellow-radius-card), 18px);
    background-color: #c88716;
    box-shadow: 0 18px 42px rgba(18, 51, 8, 0.06);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 24% 24%, rgba(255, 252, 226, 0.9) 0 1.5px, transparent 1.7px),
      radial-gradient(circle at 72% 44%, rgba(255, 243, 196, 0.55) 0 2px, transparent 2.3px),
      radial-gradient(circle at 42% 68%, rgba(255, 246, 206, 0.38) 0 1.2px, transparent 1.5px),
      linear-gradient(180deg, rgba(255, 250, 230, 0.98) 0%, rgba(244, 214, 134, 0.92) 15%, rgba(215, 145, 7, 0.98) 53%, rgba(151, 87, 0, 0.95) 100%);
    background-size: 26px 26px, 34px 34px, 18px 18px, auto;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.2) 0%, transparent 28%, rgba(0, 0, 0, 0.12) 100%),
      radial-gradient(circle at 52% 52%, transparent 0%, rgba(0, 51, 2, 0.12) 72%, rgba(0, 51, 2, 0.24) 100%);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--activate::before {
    background:
      radial-gradient(ellipse at 50% 22%, rgba(255, 255, 246, 0.86) 0 14%, transparent 33%),
      radial-gradient(ellipse at 47% 58%, rgba(255, 237, 174, 0.7) 0 8%, transparent 20%),
      radial-gradient(circle at 25% 26%, rgba(255, 250, 218, 0.84) 0 1.7px, transparent 2px),
      radial-gradient(circle at 69% 47%, rgba(255, 250, 218, 0.58) 0 2.5px, transparent 2.8px),
      radial-gradient(circle at 44% 76%, rgba(255, 250, 218, 0.4) 0 1.4px, transparent 1.8px),
      linear-gradient(180deg, #fff7dc 0%, #e0a724 26%, #cc8500 62%, #895900 100%);
    background-size: auto, auto, 20px 20px, 34px 34px, 14px 14px, auto;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--form::before {
    background:
      radial-gradient(ellipse at 50% 10%, rgba(255, 255, 245, 0.94) 0 12%, transparent 25%),
      radial-gradient(ellipse at 50% 20%, rgba(247, 229, 168, 0.95) 0 25%, transparent 39%),
      radial-gradient(circle at 36% 46%, rgba(255, 250, 218, 0.6) 0 1.6px, transparent 1.9px),
      radial-gradient(circle at 72% 62%, rgba(255, 250, 218, 0.42) 0 1.2px, transparent 1.5px),
      linear-gradient(180deg, #fff8dd 0%, #ebc96c 24%, #c98200 59%, #875500 100%);
    background-size: auto, auto, 22px 22px, 15px 15px, auto;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--float::before {
    background:
      linear-gradient(180deg, rgba(255, 255, 247, 0.96) 0%, rgba(241, 224, 162, 0.96) 13%, rgba(233, 209, 132, 0.96) 24%, transparent 31%),
      radial-gradient(circle at 26% 43%, rgba(255, 247, 209, 0.46) 0 1.2px, transparent 1.5px),
      radial-gradient(circle at 69% 70%, rgba(255, 244, 199, 0.28) 0 1.2px, transparent 1.5px),
      linear-gradient(180deg, #efc463 0%, #d49100 38%, #b87300 100%);
    background-size: auto, 22px 22px, 16px 16px, auto;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: filter 700ms ease;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--activate .mellow-why-it-works__image {
    object-position: 50% 50%;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--form .mellow-why-it-works__image {
    object-position: 50% 42%;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel--float .mellow-why-it-works__image {
    object-position: 50% 38%;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel:hover .mellow-why-it-works__image {
    filter: brightness(0.94) saturate(1.04);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__placeholder-layer {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__placeholder-layer::before,
  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__placeholder-layer::after {
    content: "";
    position: absolute;
    border-radius: 999px;
    opacity: 0.72;
    filter: blur(10px);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__placeholder-layer::before {
    width: 48%;
    height: 68%;
    left: 26%;
    top: 8%;
    background: rgba(255, 246, 199, 0.5);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__placeholder-layer::after {
    width: 110%;
    height: 26%;
    left: -5%;
    top: -2%;
    background: rgba(255, 255, 244, 0.75);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation {
    position: absolute;
    z-index: 2;
    display: grid;
    grid-template-columns: auto var(--annotation-line, 56px) 10px;
    align-items: center;
    gap: 10px;
    color: var(--mellow-cream, #FCFBF7);
    -webkit-text-fill-color: var(--mellow-cream, #FCFBF7) !important;
    font-size: clamp(13px, 1vw, 16px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    opacity: 0.88;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.24);
    pointer-events: none;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation-line {
    display: block;
    width: var(--annotation-line, 56px);
    height: 1.5px;
    background: currentColor;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation-dot {
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: currentColor;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--activate {
    left: 7%;
    bottom: 27%;
    --annotation-line: clamp(34px, 3.2vw, 58px);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form {
    left: 34%;
    top: 35%;
    grid-template-columns: 10px var(--annotation-line, 46px) auto;
    grid-template-rows: var(--annotation-rise, 54px) auto;
    gap: 0 12px;
    --annotation-line: clamp(34px, 2.8vw, 52px);
    --annotation-rise: clamp(42px, 4.4vw, 62px);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form .mellow-why-it-works__annotation-dot {
    grid-column: 1;
    grid-row: 1;
    align-self: start;
    justify-self: center;
    margin-top: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form .mellow-why-it-works__annotation-line {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
    align-self: end;
    width: calc(var(--annotation-line) + 10px);
    height: var(--annotation-rise);
    background:
      linear-gradient(currentColor, currentColor) left top / 1.5px 100% no-repeat,
      linear-gradient(currentColor, currentColor) left bottom / 100% 1.5px no-repeat;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form .mellow-why-it-works__annotation-text {
    grid-column: 3;
    grid-row: 2;
    align-self: center;
    max-width: 150px;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft {
    right: 13%;
    top: 32%;
    grid-template-columns: 10px var(--annotation-line, 34px) auto;
    grid-template-rows: var(--annotation-rise, 78px) auto;
    gap: 0 12px;
    --annotation-line: clamp(26px, 2.1vw, 38px);
    --annotation-rise: clamp(54px, 5.5vw, 86px);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft .mellow-why-it-works__annotation-dot {
    grid-column: 1;
    grid-row: 1;
    align-self: start;
    justify-self: center;
    margin-top: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft .mellow-why-it-works__annotation-line {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
    align-self: end;
    width: calc(var(--annotation-line) + 10px);
    height: var(--annotation-rise);
    background:
      linear-gradient(currentColor, currentColor) left top / 1.5px 100% no-repeat,
      linear-gradient(currentColor, currentColor) left bottom / 100% 1.5px no-repeat;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft .mellow-why-it-works__annotation-text {
    grid-column: 3;
    grid-row: 2;
    align-self: center;
    max-width: 190px;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--contents {
    right: 22%;
    bottom: 13%;
    grid-template-columns: 10px var(--annotation-line, 72px) auto;
    opacity: 0.84;
    --annotation-line: clamp(40px, 3.8vw, 68px);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__card {
    display: block;
    min-width: 0;
    color: var(--mellow-forest, #123308);
    padding: 0;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-top: var(--mellow-section-heading-gap, clamp(14px, 1.35vw, 20px));
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: var(--mellow-forest, #123308);
    color: var(--mellow-why-it-works-ivory);
    -webkit-text-fill-color: var(--mellow-why-it-works-ivory) !important;
    font-size: clamp(18px, 1.3vw, 22px);
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step-body {
    display: block;
    min-width: 0;
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    opacity: 1 !important;
    visibility: visible !important;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step-title {
    margin: 0;
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    font-family: var(--mellow-font-display, var(--font-heading-family, inherit)) !important;
    font-size: var(--mellow-card-title-size, clamp(25px, 1.8vw, 30px));
    line-height: var(--mellow-card-title-line-height, 1.04);
    font-weight: 700;
    letter-spacing: var(--mellow-card-title-tracking, -0.032em);
    text-transform: uppercase;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step-copy {
    margin: 6px 0 0;
    color: var(--mellow-forest, #123308) !important;
    -webkit-text-fill-color: var(--mellow-forest, #123308) !important;
    font-size: var(--mellow-card-copy-size, clamp(16px, 1.03vw, 17px));
    line-height: var(--mellow-card-copy-line-height, 1.48);
    letter-spacing: var(--mellow-card-copy-tracking, -0.006em);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__footnote {
    max-width: 760px;
    margin: clamp(30px, 3vw, 42px) 0 0 clamp(0px, 1.4vw, 24px);
    color: rgba(18, 51, 8, 0.64);
    font-size: clamp(13px, 0.98vw, 16px);
    line-height: 1.45;
    font-style: italic;
    letter-spacing: -0.01em;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__ppi-note {
    max-width: 760px;
    margin: clamp(34px, 3vw, 46px) 0 0 clamp(0px, 1.4vw, 24px);
    padding-top: clamp(24px, 2.4vw, 34px);
    border-top: 1px solid rgba(18, 51, 8, 0.16);
    color: rgba(18, 51, 8, 0.88);
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__ppi-heading {
    margin: 0;
    color: var(--mellow-forest, #123308);
    font-family: var(--font-heading-family, inherit);
    font-size: clamp(22px, 1.8vw, 30px);
    line-height: 1.08;
    font-weight: 650;
    letter-spacing: -0.025em;
  }

  #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__ppi-body {
    max-width: 700px;
    margin: 12px 0 0;
    color: rgba(18, 51, 8, 0.84);
    font-size: clamp(15px, 1vw, 18px);
    line-height: 1.45;
    letter-spacing: -0.01em;
  }

  @media screen and (max-width: 989px) {
    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--mellow-section-heading-gap, clamp(14px, 1.35vw, 20px));
      margin-bottom: var(--mellow-section-content-gap-compact, clamp(26px, 2.4vw, 40px));
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__divider {
      display: none;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__header-right {
      max-width: 620px;
      margin-top: 0;
      padding-left: 0;
      border-left: 0;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__subheading {
      font-size: clamp(17px, 2.2vw, 21px);
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: clamp(28px, 4vw, 42px) var(--mellow-why-it-works-card-gap);
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel {
      border-radius: min(var(--mellow-radius-card), 18px);
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--activate {
      left: 8%;
      bottom: 25%;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form {
      left: 35%;
      top: 36%;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft {
      right: 8%;
      top: 29%;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--contents {
      right: 15%;
      bottom: 14%;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__footnote {
      margin-left: 4px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__ppi-note {
      margin-left: 4px;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__heading {
      line-height: 1;
      letter-spacing: -0.032em;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__subheading {
      font-size: clamp(16px, 4.35vw, 18px);
      line-height: 1.42;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(28px, 8vw, 40px);
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel {
      aspect-ratio: 1.08 / 1;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__step {
      margin-top: 16px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation {
      font-size: clamp(12px, 3.6vw, 15px);
      gap: 8px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft {
      right: 7%;
      top: 27%;
      --annotation-rise: 58px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form {
      left: 31%;
      top: 37%;
      --annotation-line: 34px;
      --annotation-rise: 48px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--form .mellow-why-it-works__annotation-text {
      max-width: 130px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--raft .mellow-why-it-works__annotation-text,
    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--contents .mellow-why-it-works__annotation-text {
      max-width: 148px;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__annotation--contents {
      right: 10%;
      bottom: 13%;
      --annotation-line: 36px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__image {
      transition: none;
    }

    #MellowWhyItWorks-{{ section.id }} .mellow-why-it-works__panel:hover .mellow-why-it-works__image {
      transform: none;
    }
  }
</style>

<section
  id="MellowWhyItWorks-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-why-it-works color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-section-axis mellow-why-it-works__inner">
    <header class="mellow-section-header mellow-why-it-works__header">
      <div class="mellow-why-it-works__header-main">
        {%- if why_eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-why-it-works__eyebrow">{{ why_eyebrow | escape }}</p>
        {%- endif -%}

        {%- if why_heading != blank -%}
          <h2 class="mellow-section-heading mellow-why-it-works__heading">{{ why_heading | escape }}</h2>
        {%- endif -%}
      </div>

      {%- if why_subheading != blank -%}
        <span class="mellow-why-it-works__divider" aria-hidden="true"></span>
        <div class="mellow-why-it-works__header-right">
          <p class="mellow-section-text mellow-why-it-works__subheading">{{ why_subheading | escape }}</p>
        </div>
      {%- endif -%}
    </header>

    {%- assign image_1_alt = section.settings.image_1.alt | default: 'Close-up golden liquid bubbling as Mellow activates in stomach acid' -%}
    {%- assign image_2_alt = section.settings.image_2.alt | default: 'Close-up golden liquid with a pale raft beginning to form above stomach acid' -%}
    {%- assign image_3_alt = section.settings.image_3.alt | default: 'Close-up golden stomach contents with a pale MellowRaft floating barrier on top' -%}

    <div class="mellow-why-it-works__sequence" aria-label="How MellowRaft works inside the stomach in three steps">
      <div class="mellow-why-it-works__cards">
        <article class="mellow-why-it-works__card">
          <div class="mellow-why-it-works__panel mellow-why-it-works__panel--activate">
            {%- if section.settings.image_1 != blank -%}
              {{ section.settings.image_1 | image_url: width: 1200 | image_tag: decoding: 'async', class: 'mellow-why-it-works__image', loading: 'lazy', sizes: '(min-width: 990px) 33vw, 100vw', widths: '480, 720, 960, 1200', alt: image_1_alt }}
            {%- else -%}
              <span class="mellow-why-it-works__placeholder-layer" aria-hidden="true"></span>
            {%- endif -%}

            <div class="mellow-why-it-works__annotation mellow-why-it-works__annotation--activate" aria-hidden="true">
              <span class="mellow-why-it-works__annotation-text">gel meets acid</span>
              <span class="mellow-why-it-works__annotation-line"></span>
              <span class="mellow-why-it-works__annotation-dot"></span>
            </div>
          </div>

          <div class="mellow-why-it-works__step">
            <span class="mellow-why-it-works__step-index">01</span>
            <div class="mellow-why-it-works__step-body">
              <h3 class="mellow-why-it-works__step-title">{{ step_1_title | escape }}</h3>
              <p class="mellow-why-it-works__step-copy">{{ step_1_description | escape }}</p>
            </div>
          </div>
        </article>

        <article class="mellow-why-it-works__card">
          <div class="mellow-why-it-works__panel mellow-why-it-works__panel--form">
            {%- if section.settings.image_2 != blank -%}
              {{ section.settings.image_2 | image_url: width: 1200 | image_tag: decoding: 'async', class: 'mellow-why-it-works__image', loading: 'lazy', sizes: '(min-width: 990px) 33vw, 100vw', widths: '480, 720, 960, 1200', alt: image_2_alt }}
            {%- else -%}
              <span class="mellow-why-it-works__placeholder-layer" aria-hidden="true"></span>
            {%- endif -%}

            <div class="mellow-why-it-works__annotation mellow-why-it-works__annotation--form" aria-hidden="true">
              <span class="mellow-why-it-works__annotation-dot"></span>
              <span class="mellow-why-it-works__annotation-line"></span>
              <span class="mellow-why-it-works__annotation-text">raft begins forming</span>
            </div>
          </div>

          <div class="mellow-why-it-works__step">
            <span class="mellow-why-it-works__step-index">02</span>
            <div class="mellow-why-it-works__step-body">
              <h3 class="mellow-why-it-works__step-title">{{ step_2_title | escape }}</h3>
              <p class="mellow-why-it-works__step-copy">{{ step_2_description | escape }}</p>
            </div>
          </div>
        </article>

        <article class="mellow-why-it-works__card">
          <div class="mellow-why-it-works__panel mellow-why-it-works__panel--float">
            {%- if section.settings.image_3 != blank -%}
              {{ section.settings.image_3 | image_url: width: 1200 | image_tag: decoding: 'async', class: 'mellow-why-it-works__image', loading: 'lazy', sizes: '(min-width: 990px) 33vw, 100vw', widths: '480, 720, 960, 1200', alt: image_3_alt }}
            {%- else -%}
              <span class="mellow-why-it-works__placeholder-layer" aria-hidden="true"></span>
            {%- endif -%}

            <div class="mellow-why-it-works__annotation mellow-why-it-works__annotation--raft" aria-hidden="true">
              <span class="mellow-why-it-works__annotation-dot"></span>
              <span class="mellow-why-it-works__annotation-line"></span>
              <span class="mellow-why-it-works__annotation-text">MellowRaft™ floating barrier</span>
            </div>

            <div class="mellow-why-it-works__annotation mellow-why-it-works__annotation--contents" aria-hidden="true">
              <span class="mellow-why-it-works__annotation-dot"></span>
              <span class="mellow-why-it-works__annotation-line"></span>
              <span class="mellow-why-it-works__annotation-text">acid + meal below</span>
            </div>
          </div>

          <div class="mellow-why-it-works__step">
            <span class="mellow-why-it-works__step-index">03</span>
            <div class="mellow-why-it-works__step-body">
              <h3 class="mellow-why-it-works__step-title">{{ step_3_title | escape }}</h3>
              <p class="mellow-why-it-works__step-copy">{{ step_3_description | escape }}</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

