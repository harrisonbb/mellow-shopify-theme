{% comment %}
  Mellow Expert Proof Carousel
  Updated:
  - Header typography matched exactly to Mellow Hero / Ingredients system
  - Fraunces 550 heading, tight line-height, negative tracking
  - Responsive heading breakpoints matched to Ingredients section
  - Microproof/rating line refined to behave like section eyebrow/proof line
  - Keeps carousel, card structure, image panels, quote panels, and JS intact
{% endcomment %}

<section class="mellow-expert-proof mellow-expert-proof-{{ section.id }}">
  <div class="mellow-expert-proof__inner">

    <div class="mellow-expert-proof__top">
      <div class="mellow-expert-proof__header-copy">
        <div class="mellow-expert-proof__rating">
          <span class="mellow-expert-proof__stars">★★★★★</span>
          <span>{{ section.settings.microproof }}</span>
        </div>

        <h2 class="mellow-expert-proof__heading">
          {{ section.settings.heading }}
        </h2>
      </div>

      <div class="mellow-expert-proof__actions">
        {% if section.settings.cta_label != blank %}
          <a href="{{ section.settings.cta_link | default: '/pages/reviews' }}" class="mellow-expert-proof__button">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}

        <div class="mellow-expert-proof__arrows" aria-label="Review carousel controls">
          <button class="mellow-expert-proof__arrow mellow-expert-proof__arrow--prev" type="button" aria-label="Previous reviews">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <button class="mellow-expert-proof__arrow mellow-expert-proof__arrow--next" type="button" aria-label="Next reviews">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="mellow-expert-proof__viewport">
      <div class="mellow-expert-proof__scroll" data-mellow-expert-carousel>

        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <article class="mellow-expert-proof__card" {{ block.shopify_attributes }}>
              <div class="mellow-expert-proof__image-wrap">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 900 | image_tag:
                    class: 'mellow-expert-proof__image',
                    loading: 'lazy',
                    alt: block.settings.name
                  }}
                {% else %}
                  <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--{{ forloop.index }}">
                    <span>{{ block.settings.initials }}</span>
                  </div>
                {% endif %}

                <div class="mellow-expert-proof__name">
                  {{ block.settings.name }}
                </div>
              </div>

              <div class="mellow-expert-proof__quote">
                <p>“{{ block.settings.quote }}”</p>
                <div class="mellow-expert-proof__meta">
                  {{ block.settings.role }}
                </div>
              </div>
            </article>
          {% endfor %}
        {% else %}

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--1"><span>MD</span></div>
              <div class="mellow-expert-proof__name">DR. FIRST LAST</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“Alginate raft technology is a useful mechanical approach because it focuses on helping reduce upward movement of stomach contents.”</p>
              <div class="mellow-expert-proof__meta">Licensed Physician</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--2"><span>RD</span></div>
              <div class="mellow-expert-proof__name">REGISTERED DIETITIAN</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that Mellow is built around a clear mechanism instead of just asking people to take another chalky tablet.”</p>
              <div class="mellow-expert-proof__meta">Digestive Health Nutrition</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--3"><span>GI</span></div>
              <div class="mellow-expert-proof__name">DIGESTIVE HEALTH REVIEW</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“A raft-forming gel format makes sense for people who want support after meals or before bed.”</p>
              <div class="mellow-expert-proof__meta">Claims Review</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--4"><span>AK</span></div>
              <div class="mellow-expert-proof__name">AFTER-DINNER USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I wanted something after dinner that did not feel like chewing through another chalky tablet.”</p>
              <div class="mellow-expert-proof__meta">Early Feedback</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--5"><span>NT</span></div>
              <div class="mellow-expert-proof__name">NIGHTTIME USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“The raft idea made more sense to me than just hoping another antacid would last through the night.”</p>
              <div class="mellow-expert-proof__meta">Before-Bed Routine</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--6"><span>TR</span></div>
              <div class="mellow-expert-proof__name">TRAVEL USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that it is a single pouch. It feels easier to keep in a bag than a bottle of tablets.”</p>
              <div class="mellow-expert-proof__meta">On-The-Go Relief</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--7"><span>PM</span></div>
              <div class="mellow-expert-proof__name">POST-MEAL USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“It fits the moment I actually need it: after eating, before reflux has a chance to ruin the night.”</p>
              <div class="mellow-expert-proof__meta">Real Routine</div>
            </div>
          </article>

          <article class="mellow-expert-proof__card">
            <div class="mellow-expert-proof__image-wrap">
              <div class="mellow-expert-proof__placeholder mellow-expert-proof__placeholder--8"><span>RS</span></div>
              <div class="mellow-expert-proof__name">REFLUX ROUTINE USER</div>
            </div>
            <div class="mellow-expert-proof__quote">
              <p>“I like that Mellow explains what it is doing. The physical barrier idea is easy to understand.”</p>
              <div class="mellow-expert-proof__meta">Early Feedback</div>
            </div>
          </article>

        {% endif %}

      </div>
    </div>

  </div>
</section>

<style>

  #shopify-section-{{ section.id }},
  .shopify-section:has(.mellow-expert-proof-{{ section.id }}) {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    margin: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    width: 100% !important;
    overflow: hidden !important;
  }

  .mellow-expert-proof-{{ section.id }},
  .mellow-expert-proof-{{ section.id }} * {
    box-sizing: border-box;
  }

  .mellow-expert-proof-{{ section.id }} {
    --expert-side-pad: clamp(108px, 8.5vw, 172px);
    --expert-axis-max: none;

    --mellow-forest: #1A2D10;
    --mellow-forest-soft: #173326;
    --mellow-orange: #D04A2A;
    --mellow-ivory: #F0EBE0;
    --mellow-page: #FBFCF7;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    background: var(--mellow-page) !important;
    background-color: var(--mellow-page) !important;
    background-image: none !important;

    color: var(--mellow-forest);
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    overflow: hidden;

    padding-top: clamp(76px, 5.5vw, 104px) !important;
    padding-bottom: clamp(72px, 5.2vw, 96px) !important;
    padding-left: var(--expert-side-pad) !important;
    padding-right: var(--expert-side-pad) !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__inner {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__top {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) auto;
    align-items: start;
    gap: clamp(28px, 4.5vw, 64px);
    width: 100% !important;
    max-width: none !important;
    margin: 0 0 clamp(34px, 3.2vw, 48px) !important;
    padding: 0 !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__header-copy {
    max-width: 980px !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__rating {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 14px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__stars {
    color: var(--mellow-orange) !important;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    line-height: 1;
    white-space: nowrap;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading {
    margin: 0 !important;
    max-width: 900px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
    opacity: 1;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__actions {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 34px;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 34px;
    border-radius: 999px;

    background: var(--mellow-forest);
    color: var(--mellow-ivory);
    text-decoration: none;

    font-family: var(--font-body);
    font-size: 0.96rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.01em;
    white-space: nowrap;

    border: 1px solid rgba(26, 45, 16, 0.98);
    box-shadow:
      0 16px 34px rgba(26, 45, 16, 0.18),
      0 0 0 0 rgba(208, 74, 42, 0);

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__button:hover {
    transform: translateY(-2px);
    background: var(--mellow-orange);
    border-color: var(--mellow-orange);
    color: #FFFFFF;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.24),
      0 0 0 6px rgba(208, 74, 42, 0.08);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrows {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow {
    width: 50px;
    height: 50px;
    border-radius: 999px;
    border: 1px solid rgba(26, 45, 16, 0.22);
    background: rgba(251, 252, 247, 0.76);
    color: var(--mellow-forest);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 180ms ease, transform 180ms ease, opacity 180ms ease, border-color 180ms ease;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow:hover {
    background: #FBFCF7;
    border-color: rgba(26, 45, 16, 0.34);
    transform: translateY(-1px);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__arrow:disabled {
    opacity: 0.35;
    cursor: default;
    transform: none;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__viewport {
    width: calc(100% + var(--expert-side-pad)) !important;
    margin-left: 0 !important;
    margin-right: calc(var(--expert-side-pad) * -1) !important;
    padding: 0 !important;
    overflow: hidden !important;
    background: var(--mellow-page) !important;
    background-color: var(--mellow-page) !important;
    background-image: none !important;
    box-shadow: none !important;
    filter: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__scroll {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(310px, 23.5vw);
    gap: 18px;

    overflow-x: auto !important;
    overscroll-behavior-inline: contain;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;

    width: 100% !important;
    padding-left: 0 !important;
    padding-right: var(--expert-side-pad) !important;
    padding-bottom: 8px;
    scroll-padding-left: 0 !important;

    background: var(--mellow-page) !important;
    background-color: var(--mellow-page) !important;
    background-image: none !important;

    box-shadow: none !important;
    filter: none !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    isolation: isolate !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__scroll::-webkit-scrollbar {
    display: none;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__card {
    min-height: 480px !important;
    border-radius: 22px !important;
    overflow: hidden !important;
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    border: 1px solid rgba(26, 45, 16, 0.12) !important;
    scroll-snap-align: start;
    display: grid !important;
    grid-template-rows: auto minmax(220px, 1fr) !important;
    box-shadow: 0 1px 0 rgba(26, 45, 16, 0.04) !important;
    position: relative !important;
    z-index: 2 !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__card:first-child {
    margin-left: 0 !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__image-wrap {
    position: relative;
    height: clamp(230px, 21vw, 285px);
    overflow: hidden;
    background: #E8F1E3;
    box-shadow: none !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.24), transparent 34%),
      linear-gradient(135deg, #E8F1E3 0%, #BCD0B4 100%);
    box-shadow: none !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--2,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--5,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--8 {
    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.22), transparent 34%),
      linear-gradient(135deg, #CFE0C8 0%, #2C4B3D 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--3,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--6 {
    background:
      radial-gradient(circle at 50% 38%, rgba(23,60,52,0.14), transparent 34%),
      linear-gradient(135deg, #F3F1EA 0%, #BFC9BA 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 {
    background:
      radial-gradient(circle at 50% 38%, rgba(255,255,255,0.18), transparent 34%),
      linear-gradient(135deg, #123A24 0%, #0A2218 100%);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder span {
    width: 96px;
    height: 96px;
    border-radius: 999px;
    background: rgba(251, 252, 247, 0.42);
    border: 1px solid rgba(26, 45, 16, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.9rem;
    letter-spacing: -0.05em;
    color: var(--mellow-forest);
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4 span,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 span {
    background: rgba(251,252,247,0.12);
    border-color: rgba(251,252,247,0.22);
    color: #FBFCF7;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__name {
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 0.95vw, 0.98rem);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mellow-forest);
    text-shadow: none;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--4 + .mellow-expert-proof__name,
  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__placeholder--7 + .mellow-expert-proof__name {
    color: #FBFCF7;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__quote {
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-between !important;
    min-height: 220px !important;

    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;

    border-top: 1px solid rgba(26, 45, 16, 0.10) !important;
    padding: 24px 26px 26px !important;

    opacity: 1 !important;
    visibility: visible !important;
    overflow: visible !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__quote p {
    display: block !important;
    opacity: 1 !important;
    visibility: visible !important;
    margin: 0 !important;
    font-family: var(--font-body);
    font-size: clamp(0.98rem, 1.05vw, 1.08rem);
    line-height: 1.5;
    letter-spacing: -0.02em;
    color: rgba(26, 45, 16, 0.78) !important;
  }

  .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__meta {
    display: block !important;
    opacity: 1 !important;
    visibility: visible !important;
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(26, 45, 16, 0.52) !important;
  }

  @media screen and (min-width: 1500px) {
    .mellow-expert-proof-{{ section.id }} {
      --expert-side-pad: clamp(128px, 9vw, 196px);
      padding-top: 112px !important;
      padding-bottom: 104px !important;
      padding-left: var(--expert-side-pad) !important;
      padding-right: var(--expert-side-pad) !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__top {
      margin-bottom: 52px !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading {
      max-width: 980px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__scroll {
      grid-auto-columns: minmax(330px, 24vw) !important;
      gap: 22px;
      padding-left: 0 !important;
      padding-right: var(--expert-side-pad) !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__card {
      min-height: 510px !important;
      grid-template-rows: auto minmax(230px, 1fr) !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__image-wrap {
      height: clamp(250px, 20vw, 310px);
    }
  }

  @media (max-width: 1100px) {
    .mellow-expert-proof-{{ section.id }} {
      --expert-side-pad: 32px;
      padding-left: var(--expert-side-pad) !important;
      padding-right: var(--expert-side-pad) !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__top {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 18px;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__heading {
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    .mellow-expert-proof-{{ section.id }} .mellow-expert-proof__actions {
      justify-content: space-between;
