{% comment %}
  Mellow FAQ Section
  AG1-inspired layout:
  - large FAQ headline on the left
  - clean accordion on the right
  - aligned to premium section axis
  - all FAQ items are closed on initial page load
  Update:
  - Header typography matched exactly to Mellow Hero / Ingredients system
  - Fraunces 550 heading, tight line-height, negative tracking
  - Responsive heading breakpoints matched to Ingredients section
{% endcomment %}

<section id="mellow-faq-{{ section.id }}" class="mellow-faq-section mellow-faq-section-{{ section.id }}">
  <div class="mellow-faq__inner">

    <div class="mellow-faq__title-col">
      <h2 class="mellow-faq__heading mellow-heading-split">{% render 'mellow-split-heading', text: section.settings.title %}</h2>
    </div>

    <div class="mellow-faq__accordion-col">
      <div class="mellow-faq__list">
        {% for block in section.blocks %}
          <div class="mellow-faq__item" {{ block.shopify_attributes }}>
            <button
              class="mellow-faq__question"
              type="button"
              aria-expanded="false"
              data-faq-question
            >
              <span>{{ block.settings.question }}</span>

              <span class="mellow-faq__icon" aria-hidden="true">
                <span class="mellow-faq__icon-line mellow-faq__icon-line--horizontal"></span>
                <span class="mellow-faq__icon-line mellow-faq__icon-line--vertical"></span>
              </span>
            </button>

            <div
              class="mellow-faq__answer"
              data-faq-answer
            >
              <div class="mellow-faq__answer-inner">
                <p>{{ block.settings.answer }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<style>

  #shopify-section-{{ section.id }},
  .shopify-section:has(#mellow-faq-{{ section.id }}) {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 0 !important;
    width: 100% !important;
    max-width: none !important;
    overflow: visible !important;
  }

  #mellow-faq-{{ section.id }},
  #mellow-faq-{{ section.id }} * {
    box-sizing: border-box;
  }

  #mellow-faq-{{ section.id }} {
    --faq-side-pad: clamp(128px, 8.5vw, 164px);
    --faq-axis-max: 1500px;

    --mellow-forest: #1A2D10;
    --mellow-ivory: #F0EBE0;
    --mellow-orange: #D04A2A;
    --mellow-blue: #3D6B8C;
    --mellow-page: #FBFCF7;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;

    background: var(--mellow-page) !important;
    background-color: var(--mellow-page) !important;
    color: var(--mellow-forest);

    padding-top: clamp(76px, 5.5vw, 104px) !important;
    padding-bottom: clamp(72px, 5.2vw, 96px) !important;
    padding-left: var(--faq-side-pad) !important;
    padding-right: var(--faq-side-pad) !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__inner {
    width: 100% !important;
    max-width: var(--faq-axis-max) !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding: 0 !important;

    display: grid;
    grid-template-columns: minmax(260px, 0.85fr) minmax(560px, 1.35fr);
    gap: clamp(56px, 8vw, 140px);
    align-items: start;

    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__title-col {
    position: sticky;
    top: 120px;
    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__heading {
    margin: 0 !important;
    max-width: 900px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__accordion-col {
    width: 100%;
    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__list {
    width: 100%;
    border-top: none;
    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__item {
    border-bottom: 1px solid rgba(26, 45, 16, 0.14);
    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__item:first-child {
    border-top: none;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__question {
    width: 100%;
    padding: 28px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;

    background: transparent !important;
    background-color: transparent !important;
    border: 0;
    cursor: pointer;

    text-align: left;
    color: var(--mellow-forest);

    font-family: var(--font-body);
    font-size: clamp(1.08rem, 1.25vw, 1.36rem);
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.025em;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__question:hover {
    color: var(--mellow-orange);
  }

  #mellow-faq-{{ section.id }} .mellow-faq__question span:first-child {
    max-width: 92%;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__icon {
    position: relative;
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
    color: var(--mellow-forest);
  }

  #mellow-faq-{{ section.id }} .mellow-faq__question:hover .mellow-faq__icon {
    color: var(--mellow-orange);
  }

  #mellow-faq-{{ section.id }} .mellow-faq__icon-line {
    position: absolute;
    left: 50%;
    top: 50%;
    display: block;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 0.24s ease, opacity 0.24s ease;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__icon-line--horizontal {
    width: 20px;
    height: 2px;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__icon-line--vertical {
    width: 2px;
    height: 20px;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__question[aria-expanded="true"] .mellow-faq__icon-line--vertical {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg);
  }

  #mellow-faq-{{ section.id }} .mellow-faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.32s ease, padding-bottom 0.32s ease;
    background: transparent !important;
    padding-bottom: 0;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__answer.is-open {
    padding-bottom: 34px;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__answer-inner {
    max-width: 760px;
    padding-right: 64px;
    background: transparent !important;
  }

  #mellow-faq-{{ section.id }} .mellow-faq__answer p {
    margin: 0;
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.05vw, 1.18rem);
    line-height: 1.58;
    letter-spacing: -0.018em;
    font-weight: 500;
    color: rgba(26, 45, 16, 0.72);
    text-align: left;
  }

  @media screen and (min-width: 1500px) {
    #mellow-faq-{{ section.id }} {
      --faq-side-pad: clamp(128px, 8.5vw, 168px);
      padding-top: 112px !important;
      padding-bottom: 104px !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__inner {
      max-width: 1500px !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__heading {
      max-width: 980px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__question {
      padding: 30px 0;
    }
  }

  @media screen and (max-width: 1100px) {
    #mellow-faq-{{ section.id }} {
      --faq-side-pad: 32px;
      padding-left: var(--faq-side-pad) !important;
      padding-right: var(--faq-side-pad) !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__inner {
      grid-template-columns: 1fr;
      gap: 32px;
      max-width: none !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__title-col {
      position: relative;
      top: auto;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__heading {
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__answer-inner {
      padding-right: 34px;
    }
  }

  @media screen and (max-width: 640px) {
    #mellow-faq-{{ section.id }} {
      --faq-side-pad: 20px;
      padding-top: 58px !important;
      padding-bottom: 62px !important;
      padding-left: var(--faq-side-pad) !important;
      padding-right: var(--faq-side-pad) !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__inner {
      gap: 24px;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__heading {
      max-width: 100% !important;
      font-size: clamp(2.35rem, 10vw, 3.55rem) !important;
      line-height: 1.05 !important;
      letter-spacing: -0.03em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 48, "wght" 550 !important;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__question {
      padding: 22px 0;
      font-size: 1.05rem;
      gap: 18px;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__answer.is-open {
      padding-bottom: 24px;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__answer-inner {
      padding-right: 18px;
    }

    #mellow-faq-{{ section.id }} .mellow-faq__answer p {
      font-size: 0.98rem;
      line-height: 1.58;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.getElementById('mellow-faq-{{ section.id }}');
    if (!section) return;

    const buttons = section.querySelectorAll('[data-faq-question]');

    function closeAll() {
      buttons.forEach(function(button) {
        button.setAttribute('aria-expanded', 'false');

        const answer = button.parentElement.querySelector('[data-faq-answer]');
        if (answer) {
          answer.classList.remove('is-open');
          answer.style.maxHeight = '0px';
        }
      });
    }

    closeAll();

    buttons.forEach(function(button) {
      button.addEventListener('click', function() {
        const answer = button.parentElement.querySelector('[data-faq-answer]');
        const isOpen = button.getAttribute('aria-expanded') === 'true';

        closeAll();

        if (!isOpen && answer) {
          button.setAttribute('aria-expanded', 'true');
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });

    window.addEventListener('resize', function() {
      buttons.forEach(function(button) {
        const answer = button.parentElement.querySelector('[data-faq-answer]');
        if (button.getAttribute('aria-expanded') === 'true' && answer) {
          answer.style.maxHeight = answer.scrollHeight + 'px';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Mellow FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "FAQ title",
      "default": "FAQs"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "When should I take MellowRaft™?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Take a pouch after meals or before bed, especially during the moments when reflux usually shows up for you. The raft begins forming within minutes and is designed to support your post-meal or nighttime reflux window."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mellow FAQ",
      "blocks": [
