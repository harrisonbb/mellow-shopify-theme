{% comment %}
  Mellow FAQ section.
  Editorial two-column accordion aligned to the global Mellow section system.
{% endcomment %}

{%- liquid
  assign section_heading = section.settings.heading | default: 'FAQs'

  if section_heading == 'Answer final purchase questions calmly.'
    assign section_heading = 'FAQs'
  endif
-%}

<style>
  #MellowFAQ-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    background: var(--mellow-ivory, #F0EBE0);
    color: var(--mellow-forest, #1A2D10);
    padding-top: clamp(52px, 5vw, 84px);
    padding-bottom: clamp(64px, 6vw, 96px);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__inner {
    width: 100%;
    max-width: var(--mellow-axis-max, 1320px);
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--mellow-axis-pad, clamp(24px, 4vw, 64px));
    padding-right: var(--mellow-axis-pad, clamp(24px, 4vw, 64px));
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__grid {
    display: grid;
    grid-template-columns: minmax(180px, 0.48fr) minmax(0, 1.52fr);
    align-items: start;
    gap: clamp(44px, 6vw, 96px);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__header {
    width: 100%;
    min-width: 0;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__heading {
    margin: 0;
    max-width: 7em;
    color: var(--mellow-forest, #1A2D10);
    font-family: var(--font-heading-family, inherit);
    font-style: var(--font-heading-style, normal);
    font-size: clamp(48px, 5.7vw, 82px);
    font-weight: 650;
    line-height: 0.95;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__list {
    width: 100%;
    min-width: 0;
    border-top: 1px solid rgba(26, 45, 16, 0.18);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__item {
    border-bottom: 1px solid rgba(26, 45, 16, 0.18);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question {
    appearance: none;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 32px;
    align-items: center;
    gap: clamp(18px, 2.5vw, 36px);
    width: 100%;
    margin: 0;
    padding: clamp(22px, 2vw, 30px) 0;
    border: 0;
    background: transparent;
    color: var(--mellow-forest, #1A2D10);
    font: inherit;
    text-align: left;
    cursor: pointer;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question-text {
    display: block;
    color: var(--mellow-forest, #1A2D10);
    font-family: var(--font-heading-family, inherit);
    font-style: var(--font-heading-style, normal);
    font-size: clamp(20px, 1.45vw, 24px);
    font-weight: 620;
    line-height: 1.18;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    justify-self: end;
    color: var(--mellow-forest, #1A2D10);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__icon::before,
  #MellowFAQ-{{ section.id }} .mellow-faq__icon::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform 220ms ease;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question[aria-expanded='true'] .mellow-faq__icon::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question[aria-expanded='true'] .mellow-faq__icon::after {
    transform: translate(-50%, -50%) rotate(135deg);
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 260ms ease;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question[aria-expanded='true'] + .mellow-faq__answer {
    grid-template-rows: 1fr;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__answer-inner {
    min-height: 0;
    overflow: hidden;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__answer-content {
    max-width: 700px;
    padding: 0 clamp(44px, 5vw, 76px) clamp(24px, 2.4vw, 34px) 0;
    color: rgba(26, 45, 16, 0.72);
    font-family: var(--font-body-family, inherit);
    font-style: var(--font-body-style, normal);
    font-size: clamp(15.5px, 1vw, 17px);
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: -0.01em;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__answer-content p {
    margin: 0;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__answer-content p + p {
    margin-top: 1em;
  }

  #MellowFAQ-{{ section.id }} .mellow-faq__question:focus-visible {
    outline: 2px solid rgba(208, 74, 42, 0.82);
    outline-offset: 6px;
  }

  @media screen and (max-width: 989px) {
    #MellowFAQ-{{ section.id }} {
      padding-top: clamp(52px, 8vw, 76px);
      padding-bottom: clamp(56px, 8vw, 84px);
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__grid {
      grid-template-columns: 1fr;
      gap: clamp(30px, 6vw, 48px);
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__heading {
      max-width: none;
      font-size: clamp(44px, 10vw, 64px);
      line-height: 0.96;
      letter-spacing: -0.052em;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowFAQ-{{ section.id }} {
      padding-top: clamp(48px, 13vw, 68px);
      padding-bottom: clamp(52px, 13vw, 72px);
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__inner {
      padding-left: var(--mellow-axis-pad, 22px);
      padding-right: var(--mellow-axis-pad, 22px);
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__grid {
      gap: 28px;
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__heading {
      font-size: clamp(42px, 12vw, 58px);
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__question {
      grid-template-columns: minmax(0, 1fr) 30px;
      gap: 18px;
      padding: 20px 0;
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__question-text {
      font-size: clamp(18px, 5vw, 22px);
      line-height: 1.18;
      letter-spacing: -0.036em;
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__icon {
      width: 30px;
      height: 30px;
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__icon::before,
    #MellowFAQ-{{ section.id }} .mellow-faq__icon::after {
      width: 17px;
    }

    #MellowFAQ-{{ section.id }} .mellow-faq__answer-content {
      padding-right: 38px;
      padding-bottom: 24px;
      font-size: 15.5px;
      line-height: 1.58;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowFAQ-{{ section.id }} .mellow-faq__answer,
    #MellowFAQ-{{ section.id }} .mellow-faq__icon::before,
    #MellowFAQ-{{ section.id }} .mellow-faq__icon::after {
      transition: none;
    }
  }
</style>

<section id="MellowFAQ-{{ section.id }}" class="mellow-section mellow-faq">
  <div class="mellow-faq__inner">
    <div class="mellow-faq__grid">
      <div class="mellow-faq__header">
        {%- if section_heading != blank -%}
          <h2 class="mellow-faq__heading">{{ section_heading | escape }}</h2>
        {%- endif -%}
      </div>

      <div class="mellow-faq__list" role="list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign question = block.settings.question | strip
              assign answer = block.settings.answer
            -%}

            {%- if question != blank or answer != blank -%}
              <div class="mellow-faq__item" role="listitem" {{ block.shopify_attributes }}>
                <button
                  class="mellow-faq__question"
                  type="button"
                  id="MellowFAQQuestion-{{ section.id }}-{{ block.id }}"
                  aria-expanded="false"
                  aria-controls="MellowFAQAnswer-{{ section.id }}-{{ block.id }}"
                >
                  <span class="mellow-faq__question-text">{{ question | escape }}</span>
                  <span class="mellow-faq__icon" aria-hidden="true"></span>
                </button>

                <div
                  class="mellow-faq__answer"
                  id="MellowFAQAnswer-{{ section.id }}-{{ block.id }}"
                  role="region"
                  aria-labelledby="MellowFAQQuestion-{{ section.id }}-{{ block.id }}"
                >
                  <div class="mellow-faq__answer-inner">
                    <div class="mellow-faq__answer-content">
                      {{ answer }}
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- capture fallback_faqs -%}
            When should I take MellowRaft™?||Take MellowRaft™ after meals, before bed, or whenever reflux usually shows up. It’s designed to form a protective raft barrier at the top of the stomach before acid has the chance to rise.
            How is this different from Tums or antacids?||Traditional antacids mainly neutralize acid after it’s already there. MellowRaft™ is different: it forms a physical barrier that helps block reflux from coming back up, without shutting down digestion.
            Is it safe to take every day?||MellowRaft™ is designed for regular use as directed. If you’re pregnant, managing a medical condition, taking medication, or dealing with frequent symptoms, check with your healthcare provider.
            Can I use my HSA or FSA?||We’re working toward HSA/FSA eligibility. If available at checkout, you’ll be able to use your HSA or FSA card directly.
            What does it taste like?||MellowRaft™ is a smooth gel pouch with a mellow, easy-to-take flavor. No chalky tablets, no harsh burn, and no heavy medicinal taste.
            Can I skip, pause, or cancel my subscription?||Yes. You’ll be able to skip, pause, or cancel your subscription anytime through your customer portal.
          {%- endcapture -%}

          {%- assign fallback_items = fallback_faqs | strip | newline_to_br | split: '<br />' -%}

          {%- for fallback_item in fallback_items -%}
            {%- assign fallback_parts = fallback_item | strip | split: '||' -%}
            {%- assign fallback_question = fallback_parts[0] | strip -%}
            {%- assign fallback_answer = fallback_parts[1] | strip -%}

            {%- if fallback_question != blank and fallback_answer != blank -%}
              <div class="mellow-faq__item" role="listitem">
                <button
                  class="mellow-faq__question"
                  type="button"
                  id="MellowFAQQuestion-{{ section.id }}-fallback-{{ forloop.index }}"
                  aria-expanded="false"
                  aria-controls="MellowFAQAnswer-{{ section.id }}-fallback-{{ forloop.index }}"
                >
                  <span class="mellow-faq__question-text">{{ fallback_question | escape }}</span>
                  <span class="mellow-faq__icon" aria-hidden="true"></span>
                </button>

                <div
                  class="mellow-faq__answer"
                  id="MellowFAQAnswer-{{ section.id }}-fallback-{{ forloop.index }}"
                  role="region"
                  aria-labelledby="MellowFAQQuestion-{{ section.id }}-fallback-{{ forloop.index }}"
                >
                  <div class="mellow-faq__answer-inner">
                    <div class="mellow-faq__answer-content">
                      <p>{{ fallback_answer | escape }}</p>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('MellowFAQ-{{ section.id }}');

    if (!section) return;

    section.querySelectorAll('.mellow-faq__question').forEach((button) => {
      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!isExpanded));
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Mellow FAQ",
  "tag": "section",
  "class": "section section-mellow-faq",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FAQs"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
