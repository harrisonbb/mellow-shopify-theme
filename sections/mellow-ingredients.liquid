<script>
  (function () {
    const section = document.getElementById('mellow-ingredients-{{ section.id }}');
    if (!section) return;

    function closeAllCards() {
      const cards = section.querySelectorAll('[data-mellow-card]');
      const toggles = section.querySelectorAll('[data-mellow-toggle]');

      cards.forEach(function (card) {
        card.classList.remove('is-open');
      });

      toggles.forEach(function (toggle) {
        toggle.setAttribute('aria-expanded', 'false');
      });
    }

    const cards = section.querySelectorAll('[data-mellow-card]');

    cards.forEach(function (card) {
      const toggle = card.querySelector('[data-mellow-toggle]');
      if (!toggle) return;

      toggle.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();

        const wasOpen = card.classList.contains('is-open');

        closeAllCards();

        if (!wasOpen) {
          card.classList.add('is-open');
          toggle.setAttribute('aria-expanded', 'true');
        }
      });

      card.addEventListener('mouseleave', function () {
        card.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

