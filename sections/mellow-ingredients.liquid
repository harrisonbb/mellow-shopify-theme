{% comment %}
  Mellow premium ingredients bento section.
  Uses the global Mellow typography system and scoped section CSS for layout only.
{% endcomment %}

<style>
  #MellowIngredients-{{ section.id }} {
    background: var(--mellow-ivory, #F0EBE0);
    color: var(--mellow-forest, #1A2D10);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid {
    margin-bottom: clamp(28px, 3.1vw, 42px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__heading {
    color: var(--mellow-forest, #1A2D10);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__text {
    color: rgba(26, 45, 16, 0.68);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__cta {
    border: 1px solid var(--mellow-forest, #1A2D10);
    background: var(--mellow-forest, #1A2D10);
    color: var(--mellow-cream, #F0EBE0);
    text-decoration: none;
    box-shadow: 0 16px 34px rgba(26, 45, 16, 0.14);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__cta .mellow-section-cta__label {
    transform: translate3d(-8px, 0, 0);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__cta .mellow-section-cta__arrow {
    opacity: 1;
    transform: translate3d(0, -50%, 0);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.92fr);
    gap: clamp(18px, 1.8vw, 24px);
    align-items: stretch;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__side {
    display: grid;
    gap: clamp(18px, 1.8vw, 24px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card {
    position: relative;
    display: grid;
    overflow: hidden;
    min-width: 0;
    border: 1px solid rgba(26, 45, 16, 0.12);
    border-radius: clamp(24px, 2vw, 28px);
    background:
      linear-gradient(145deg, rgba(255, 252, 244, 0.78), rgba(244, 237, 224, 0.96)),
      var(--mellow-card-cream, #F4EDE0);
    box-shadow: 0 24px 60px rgba(26, 45, 16, 0.08);
    isolation: isolate;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card::after {
    content: "";
    position: absolute;
    inset: 1px;
    pointer-events: none;
    border-radius: inherit;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62);
    z-index: 2;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature {
    grid-template-rows: minmax(330px, 1fr) auto;
    min-height: clamp(600px, 53vw, 720px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
    grid-template-columns: minmax(190px, 45%) minmax(0, 1fr);
    min-height: clamp(288px, 25.2vw, 348px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual {
    position: relative;
    min-width: 0;
    overflow: hidden;
    background: #D9B075;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual::before,
  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual::after {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(26, 45, 16, 0.08));
    mix-blend-mode: soft-light;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--alginate {
    background:
      radial-gradient(circle at 25% 18%, rgba(255, 214, 143, 0.72) 0 13%, transparent 32%),
      radial-gradient(circle at 76% 30%, rgba(114, 58, 22, 0.5) 0 10%, transparent 27%),
      radial-gradient(circle at 38% 78%, rgba(208, 74, 42, 0.42) 0 13%, transparent 34%),
      linear-gradient(135deg, #6B381E 0%, #B46C2D 38%, #E0A246 68%, #7C4A24 100%);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--alginate::before {
    background:
      repeating-linear-gradient(112deg, rgba(255, 234, 178, 0.32) 0 2px, transparent 2px 18px),
      radial-gradient(ellipse at 52% 52%, transparent 0 35%, rgba(79, 45, 21, 0.36) 68%, transparent 72%);
    filter: blur(0.2px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--calcium {
    background:
      radial-gradient(circle at 28% 24%, rgba(255, 255, 255, 0.82) 0 11%, transparent 25%),
      radial-gradient(circle at 72% 66%, rgba(224, 210, 184, 0.62) 0 13%, transparent 28%),
      linear-gradient(135deg, #F8F2E4 0%, #D9C7A4 48%, #B8A479 100%);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--calcium::before {
    background:
      repeating-radial-gradient(circle at 42% 48%, rgba(26, 45, 16, 0.1) 0 1px, transparent 1px 9px),
      linear-gradient(145deg, transparent, rgba(255, 255, 255, 0.44));
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--bicarbonate {
    background:
      radial-gradient(circle at 24% 30%, rgba(255, 255, 255, 0.9) 0 12%, transparent 28%),
      radial-gradient(circle at 78% 72%, rgba(255, 255, 255, 0.72) 0 15%, transparent 31%),
      linear-gradient(135deg, #FFFCF4 0%, #ECE3D1 52%, #D7CBB5 100%);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--bicarbonate::before {
    background:
      repeating-radial-gradient(circle at 50% 50%, rgba(26, 45, 16, 0.07) 0 1px, transparent 1px 7px),
      radial-gradient(ellipse at 50% 105%, rgba(26, 45, 16, 0.12), transparent 52%);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-width: 0;
    padding: clamp(26px, 3vw, 42px);
    background:
      radial-gradient(circle at 92% 10%, rgba(61, 107, 140, 0.08), transparent 34%),
      rgba(244, 237, 224, 0.92);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
    padding: clamp(24px, 2.35vw, 34px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__role {
    display: block;
    width: fit-content;
    margin: 0 0 clamp(14px, 1.2vw, 18px);
    color: color-mix(in srgb, var(--mellow-science-blue, #3D6B8C) 82%, var(--mellow-forest, #1A2D10));
    font-size: clamp(11px, 0.72vw, 13px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__title {
    color: var(--mellow-forest, #1A2D10);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__description {
    max-width: 32rem;
    margin-top: clamp(12px, 1.15vw, 16px);
    color: rgba(26, 45, 16, 0.68);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__title {
    font-size: clamp(34px, 3.2vw, 52px);
    line-height: 0.96;
  }

  @media screen and (max-width: 989px) {
    #MellowIngredients-{{ section.id }} .mellow-ingredients__grid {
      grid-template-columns: 1fr;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature {
      min-height: 0;
      grid-template-rows: minmax(300px, 44vw) auto;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
      min-height: 270px;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid {
      margin-bottom: 26px;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__grid,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__side {
      gap: 16px;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card {
      border-radius: 24px;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
      grid-template-columns: 1fr;
      grid-template-rows: minmax(220px, 60vw) auto;
      min-height: 0;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__content,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
      padding: 24px;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__title {
      font-size: clamp(32px, 9vw, 42px);
    }
  }
</style>

<section id="MellowIngredients-{{ section.id }}" class="mellow-section-standard mellow-ingredients color-{{ section.settings.color_scheme }}">
  <div class="mellow-section-axis">
    <div class="mellow-section-header-grid mellow-ingredients__header-grid">
      <div class="mellow-section-header mellow-ingredients__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-section-heading mellow-ingredients__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-section-text mellow-ingredients__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank -%}
        <div class="mellow-section-actions mellow-ingredients__actions">
          <div class="mellow-section-cta-wrap">
            <a class="mellow-section-cta mellow-ingredients__cta" href="{{ section.settings.cta_link | default: '#' }}">
              <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
              <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="mellow-ingredients__grid">
      <article class="mellow-ingredients__card mellow-ingredients__card--feature">
        <div class="mellow-ingredients__visual mellow-ingredients__visual--alginate">
          {%- if section.settings.alginate_image != blank -%}
            {{ section.settings.alginate_image | image_url: width: 1400 | image_tag: class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 54vw, 100vw', widths: '500, 720, 900, 1100, 1400', alt: section.settings.alginate_title }}
          {%- endif -%}
        </div>
        <div class="mellow-ingredients__content">
          <span class="mellow-ingredients__role">{{ section.settings.alginate_role | escape }}</span>
          <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.alginate_title | escape }}</h3>
          <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.alginate_description | escape }}</p>
        </div>
      </article>

      <div class="mellow-ingredients__side">
        <article class="mellow-ingredients__card mellow-ingredients__card--compact">
          <div class="mellow-ingredients__visual mellow-ingredients__visual--calcium">
            {%- if section.settings.calcium_image != blank -%}
              {{ section.settings.calcium_image | image_url: width: 900 | image_tag: class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 22vw, (min-width: 750px) 42vw, 100vw', widths: '360, 520, 700, 900', alt: section.settings.calcium_title }}
            {%- endif -%}
          </div>
          <div class="mellow-ingredients__content">
            <span class="mellow-ingredients__role">{{ section.settings.calcium_role | escape }}</span>
            <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.calcium_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.calcium_description | escape }}</p>
          </div>
        </article>

        <article class="mellow-ingredients__card mellow-ingredients__card--compact">
          <div class="mellow-ingredients__visual mellow-ingredients__visual--bicarbonate">
            {%- if section.settings.bicarbonate_image != blank -%}
              {{ section.settings.bicarbonate_image | image_url: width: 900 | image_tag: class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 22vw, (min-width: 750px) 42vw, 100vw', widths: '360, 520, 700, 900', alt: section.settings.bicarbonate_title }}
            {%- endif -%}
          </div>
          <div class="mellow-ingredients__content">
            <span class="mellow-ingredients__role">{{ section.settings.bicarbonate_role | escape }}</span>
            <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.bicarbonate_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.bicarbonate_description | escape }}</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow ingredients",
  "tag": "section",
  "class": "section section-mellow-ingredients",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ingredients"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three ingredients. One barrier."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subhead",
      "default": "A simple raft-forming system designed to activate, strengthen, and float."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "See all ingredients"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Sodium Alginate"
    },
    {
      "type": "image_picker",
      "id": "alginate_image",
      "label": "Sodium Alginate visual"
    },
    {
      "type": "text",
      "id": "alginate_role",
      "label": "Role label",
      "default": "THE RAFT-FORMER"
    },
    {
      "type": "text",
      "id": "alginate_title",
      "label": "Title",
      "default": "Sodium Alginate"
    },
    {
      "type": "textarea",
      "id": "alginate_description",
      "label": "Description",
      "default": "Forms the floating gel barrier"
    },
    {
      "type": "header",
      "content": "Calcium Carbonate"
    },
    {
      "type": "image_picker",
      "id": "calcium_image",
      "label": "Calcium Carbonate visual"
    },
    {
      "type": "text",
      "id": "calcium_role",
      "label": "Role label",
      "default": "THE STRENGTHENER"
    },
    {
      "type": "text",
      "id": "calcium_title",
      "label": "Title",
      "default": "Calcium Carbonate"
    },
    {
      "type": "textarea",
      "id": "calcium_description",
      "label": "Description",
      "default": "Helps strengthen the raft"
    },
    {
      "type": "header",
      "content": "Sodium Bicarbonate"
    },
    {
      "type": "image_picker",
      "id": "bicarbonate_image",
      "label": "Sodium Bicarbonate visual"
    },
    {
      "type": "text",
      "id": "bicarbonate_role",
      "label": "Role label",
      "default": "THE FLOATER"
    },
    {
      "type": "text",
      "id": "bicarbonate_title",
      "label": "Title",
      "default": "Sodium Bicarbonate"
    },
    {
      "type": "textarea",
      "id": "bicarbonate_description",
      "label": "Description",
      "default": "Helps it float"
    }
  ],
  "presets": [
    {
      "name": "Mellow ingredients"
    }
  ]
}
{% endschema %}
