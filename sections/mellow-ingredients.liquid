{% comment %}
  Mellow Ingredients — Seed-like spacing rhythm
  Fixes:
  - Background matches main site white #FBFCF7
  - Eyebrow uses the same working class path as Compare:
    mellow-compare-premium__eyebrow mellow-eyebrow
  - Removed broken local .mellow-ingredients__eyebrow CSS because that class is no longer used
  - Heading typography locked to Mellow Hero system
  - Card title typography refined with Fraunces 550
{% endcomment %}

<section class="mellow-ingredients mellow-ingredients-{{ section.id }}" id="mellow-ingredients-{{ section.id }}">
  <div class="mellow-ingredients__inner">

    <div class="mellow-ingredients__header">
      <div class="mellow-ingredients__heading-wrap">
        <span class="mellow-compare-premium__eyebrow mellow-eyebrow">
          {% if section.settings.eyebrow != blank %}
            {{ section.settings.eyebrow }}
          {% else %}
            WHAT'S INSIDE
          {% endif %}
        </span>

        <h2 class="mellow-ingredients__heading">
          {% if section.settings.heading != blank %}
            {{ section.settings.heading }}
          {% else %}
            Three active ingredients. One protective raft.
          {% endif %}
        </h2>
      </div>

      <div class="mellow-ingredients__intro-wrap">
        <p class="mellow-ingredients__intro">
          {% if section.settings.subheading != blank %}
            {{ section.settings.subheading }}
          {% else %}
            Mellow uses raft-forming ingredients selected for a clear job: form, strengthen, and help float the protective gel barrier.
          {% endif %}
        </p>

        {% if section.settings.button_label != blank %}
          <a class="mellow-ingredients__button mellow-ingredients__button--desktop" href="{{ section.settings.button_link }}">
            {{ section.settings.button_label }}
            <span aria-hidden="true">→</span>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="mellow-ingredients__grid" data-mellow-ingredients-grid>

      <article class="mellow-ingredients__card" data-mellow-card="1">
        <div class="mellow-ingredients__image-wrap">
          {% if section.settings.image_1 != blank %}
            {{
              section.settings.image_1
              | image_url: width: 1000
              | image_tag:
                class: 'mellow-ingredients__image',
                loading: 'lazy',
                alt: section.settings.title_1
            }}
          {% else %}
            <div class="mellow-ingredients__placeholder mellow-ingredients__placeholder--seaweed">
              <span>Seaweed image</span>
            </div>
          {% endif %}
        </div>

        <div class="mellow-ingredients__content">
          <span class="mellow-ingredients__number">Ingredient 01</span>

          <h3>
            {% if section.settings.title_1 != blank %}
              {{ section.settings.title_1 }}
            {% else %}
              Sodium Alginate
            {% endif %}
          </h3>

          <p class="mellow-ingredients__role">
            {% if section.settings.role_1 != blank %}
              {{ section.settings.role_1 }}
            {% else %}
              Forms the raft
            {% endif %}
          </p>

          <div class="mellow-ingredients__accordion">
            <button
              class="mellow-ingredients__toggle"
              type="button"
              data-mellow-toggle="1"
              aria-expanded="false"
            >
              <span>Learn more</span>
              <span class="mellow-ingredients__plus" aria-hidden="true"></span>
            </button>

            <div class="mellow-ingredients__panel" data-mellow-panel="1">
              <p>
                {% if section.settings.detail_1 != blank %}
                  {{ section.settings.detail_1 }}
                {% else %}
                  Sodium alginate is a seaweed-derived ingredient that reacts with stomach acid to help create a floating gel barrier at the top of stomach contents.
                {% endif %}
              </p>
            </div>
          </div>
        </div>
      </article>

      <article class="mellow-ingredients__card" data-mellow-card="2">
        <div class="mellow-ingredients__image-wrap">
          {% if section.settings.image_2 != blank %}
            {{
              section.settings.image_2
              | image_url: width: 1000
              | image_tag:
                class: 'mellow-ingredients__image',
                loading: 'lazy',
                alt: section.settings.title_2
            }}
          {% else %}
            <div class="mellow-ingredients__placeholder mellow-ingredients__placeholder--mineral">
              <span>Mineral image</span>
            </div>
          {% endif %}
        </div>

        <div class="mellow-ingredients__content">
          <span class="mellow-ingredients__number">Ingredient 02</span>

          <h3>
            {% if section.settings.title_2 != blank %}
              {{ section.settings.title_2 }}
            {% else %}
              Calcium Carbonate
            {% endif %}
          </h3>

          <p class="mellow-ingredients__role">
            {% if section.settings.role_2 != blank %}
              {{ section.settings.role_2 }}
            {% else %}
              Helps strengthen the raft
            {% endif %}
          </p>

          <div class="mellow-ingredients__accordion">
            <button
              class="mellow-ingredients__toggle"
              type="button"
              data-mellow-toggle="2"
              aria-expanded="false"
            >
              <span>Learn more</span>
              <span class="mellow-ingredients__plus" aria-hidden="true"></span>
            </button>

            <div class="mellow-ingredients__panel" data-mellow-panel="2">
              <p>
                {% if section.settings.detail_2 != blank %}
                  {{ section.settings.detail_2 }}
                {% else %}
                  Calcium carbonate helps support raft structure while also contributing mild acid-buffering support. It helps the gel feel more stable and cohesive once the raft forms.
                {% endif %}
              </p>
            </div>
          </div>
        </div>
      </article>

      <article class="mellow-ingredients__card" data-mellow-card="3">
        <div class="mellow-ingredients__image-wrap">
          {% if section.settings.image_3 != blank %}
            {{
              section.settings.image_3
              | image_url: width: 1000
              | image_tag:
                class: 'mellow-ingredients__image',
                loading: 'lazy',
                alt: section.settings.title_3
            }}
          {% else %}
            <div class="mellow-ingredients__placeholder mellow-ingredients__placeholder--powder">
              <span>Powder image</span>
            </div>
          {% endif %}
        </div>

        <div class="mellow-ingredients__content">
          <span class="mellow-ingredients__number">Ingredient 03</span>

          <h3>
            {% if section.settings.title_3 != blank %}
              {{ section.settings.title_3 }}
            {% else %}
              Sodium Bicarbonate
            {% endif %}
          </h3>

          <p class="mellow-ingredients__role">
            {% if section.settings.role_3 != blank %}
              {{ section.settings.role_3 }}
            {% else %}
              Helps it float
            {% endif %}
          </p>

          <div class="mellow-ingredients__accordion">
            <button
              class="mellow-ingredients__toggle"
              type="button"
              data-mellow-toggle="3"
              aria-expanded="false"
            >
              <span>Learn more</span>
              <span class="mellow-ingredients__plus" aria-hidden="true"></span>
            </button>

            <div class="mellow-ingredients__panel" data-mellow-panel="3">
              <p>
                {% if section.settings.detail_3 != blank %}
                  {{ section.settings.detail_3 }}
                {% else %}
                  Sodium bicarbonate helps create buoyancy in raft-forming systems. When it reacts with stomach acid, it helps the gel layer rise and hold position at the top of stomach contents.
                {% endif %}
              </p>
            </div>
          </div>
        </div>
      </article>

    </div>

    <div class="mellow-ingredients__footer">
      <p>
        {% if section.settings.footnote != blank %}
          {{ section.settings.footnote }}
        {% else %}
          Based on published studies of alginate raft-forming formulations.
        {% endif %}
      </p>

      {% if section.settings.button_label != blank %}
        <a class="mellow-ingredients__button mellow-ingredients__button--mobile" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
          <span aria-hidden="true">→</span>
        </a>
      {% endif %}
    </div>

  </div>
</section>

<style>

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > *,
  .shopify-section:has(.mellow-ingredients-{{ section.id }}) {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    margin: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    width: 100% !important;
    max-width: none !important;
  }

  #mellow-ingredients-{{ section.id }},
  #mellow-ingredients-{{ section.id }} * {
    box-sizing: border-box !important;
  }

  #mellow-ingredients-{{ section.id }} {
    --ingredients-side-pad: clamp(108px, 8.5vw, 172px);

    --mellow-forest: #1A2D10;
    --mellow-forest-soft: #173326;
    --mellow-orange: #D04A2A;
    --mellow-ivory: #F0EBE0;
    --mellow-page: #FBFCF7;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    width: 100% !important;
    max-width: none !important;
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    color: var(--mellow-forest) !important;
    margin: 0 !important;
    overflow: hidden !important;

    padding-top: clamp(76px, 5.5vw, 104px) !important;
    padding-bottom: clamp(72px, 5.2vw, 96px) !important;
    padding-left: var(--ingredients-side-pad) !important;
    padding-right: var(--ingredients-side-pad) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__inner {
    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__header {
    display: grid !important;
    grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.65fr) !important;
    gap: clamp(28px, 4.5vw, 64px) !important;
    align-items: start !important;
    margin-bottom: clamp(34px, 3.2vw, 48px) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__heading-wrap {
    max-width: 920px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__heading {
    margin: 0 !important;
    max-width: 900px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-compare-premium__eyebrow.mellow-eyebrow {
    display: inline-block !important;
    margin: 0 0 14px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__intro-wrap {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    gap: 20px !important;
    padding-top: 34px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__intro {
    margin: 0 !important;
    max-width: 540px !important;

    color: rgba(26, 45, 16, 0.76) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(1rem, 1.18vw, 1.18rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 11px !important;

    min-height: 54px !important;
    padding: 0 34px !important;
    border-radius: 999px !important;

    background: var(--mellow-forest) !important;
    color: var(--mellow-ivory) !important;
    text-decoration: none !important;

    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;

    border: 1px solid rgba(26, 45, 16, 0.98) !important;
    box-shadow:
      0 16px 34px rgba(26, 45, 16, 0.18),
      0 0 0 0 rgba(208, 74, 42, 0) !important;

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__button:hover {
    transform: translateY(-2px) !important;
    background: var(--mellow-orange) !important;
    border-color: var(--mellow-orange) !important;
    color: #FFFFFF !important;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.24),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__grid {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 18px !important;
    align-items: start !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card {
    overflow: hidden !important;
    border-radius: 27px !important;
    border: 1.5px solid rgba(26, 45, 16, 0.14) !important;
    background: #FBF7EE !important;
    color: var(--mellow-forest) !important;
    height: auto !important;
    align-self: start !important;
    box-shadow:
      0 20px 62px rgba(20, 38, 28, 0.075),
      inset 0 1px 0 rgba(255,255,255,0.7) !important;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card:hover {
    transform: translateY(-3px) !important;
    border-color: rgba(26, 45, 16, 0.22) !important;
    box-shadow:
      0 24px 72px rgba(20, 38, 28, 0.11),
      inset 0 1px 0 rgba(255,255,255,0.72) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card.is-open {
    border-color: rgba(26, 45, 16, 0.34) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__image-wrap {
    width: 100% !important;
    aspect-ratio: 1.55 / 1 !important;
    overflow: hidden !important;
    background: #EFEDE4 !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__image {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__placeholder {
    width: 100% !important;
    height: 100% !important;
    min-height: 200px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    font-weight: 800 !important;
    letter-spacing: 0.14em !important;
    text-transform: uppercase !important;
    color: rgba(26, 45, 16, 0.45) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__placeholder--seaweed {
    background:
      radial-gradient(circle at 52% 50%, rgba(132, 89, 32, 0.34), transparent 31%),
      radial-gradient(circle at 44% 44%, rgba(83, 60, 24, 0.22), transparent 36%),
      #EFE9DA !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__placeholder--mineral {
    background:
      radial-gradient(circle at 50% 46%, rgba(255, 255, 255, 0.84), transparent 32%),
      radial-gradient(circle at 55% 52%, rgba(190, 190, 178, 0.36), transparent 38%),
      #ECEBE4 !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__placeholder--powder {
    background:
      radial-gradient(circle at 54% 62%, rgba(255, 255, 255, 0.94), transparent 30%),
      radial-gradient(circle at 48% 64%, rgba(210, 210, 198, 0.38), transparent 40%),
      #F0EEE7 !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__content {
    padding: 18px 22px 18px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__number {
    display: block !important;
    margin: 0 0 10px !important;

    font-family: var(--font-body) !important;
    font-size: 0.64rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.16em !important;
    text-transform: uppercase !important;
    color: rgba(26, 45, 16, 0.46) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card h3 {
    margin: 0 0 8px !important;
    max-width: 340px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(1.38rem, 1.45vw, 1.78rem) !important;
    line-height: 1.05 !important;
    letter-spacing: -0.038em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 52, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__role {
    margin: 0 0 14px !important;
    font-family: var(--font-body) !important;
    font-size: 0.7rem !important;
    line-height: 1.15 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    color: #5C7A4E !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__accordion {
    border-top: 1px solid rgba(26, 45, 16, 0.13) !important;
    padding-top: 14px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__toggle {
    appearance: none !important;
    -webkit-appearance: none !important;
    border: 0 !important;
    background: transparent !important;
    width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    gap: 14px !important;
    font-family: var(--font-body) !important;
    font-size: 0.9rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;
    color: var(--mellow-forest) !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__toggle:focus,
  #mellow-ingredients-{{ section.id }} .mellow-ingredients__toggle:focus-visible {
    outline: none !important;
    box-shadow: none !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__plus {
    position: relative !important;
    width: 17px !important;
    height: 17px !important;
    flex: 0 0 17px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__plus::before,
  #mellow-ingredients-{{ section.id }} .mellow-ingredients__plus::after {
    content: "" !important;
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    width: 13px !important;
    height: 1.5px !important;
    border-radius: 999px !important;
    background: var(--mellow-forest) !important;
    transform: translate(-50%, -50%) !important;
    transition: transform 180ms ease !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__plus::after {
    transform: translate(-50%, -50%) rotate(90deg) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card.is-open .mellow-ingredients__plus::after {
    transform: translate(-50%, -50%) rotate(0deg) !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__panel {
    max-height: 0 !important;
    opacity: 0 !important;
    overflow: hidden !important;
    padding-top: 0 !important;
    transition:
      max-height 220ms ease,
      opacity 180ms ease,
      padding-top 180ms ease !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card:not(.is-open) .mellow-ingredients__panel {
    max-height: 0 !important;
    opacity: 0 !important;
    padding-top: 0 !important;
    overflow: hidden !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__card.is-open .mellow-ingredients__panel {
    max-height: 230px !important;
    opacity: 1 !important;
    padding-top: 11px !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__panel p {
    margin: 0 !important;
    font-family: var(--font-body) !important;
    font-size: 0.9rem !important;
    line-height: 1.5 !important;
    letter-spacing: -0.012em !important;
    color: rgba(26, 45, 16, 0.72) !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__footer {
    margin-top: 16px !important;
    padding-top: 10px !important;
    border-top: 1px solid rgba(26, 45, 16, 0.12) !important;
    display: flex !important;
    justify-content: space-between !important;
    gap: 20px !important;
    align-items: center !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__footer p {
    margin: 0 !important;
    font-family: var(--font-body) !important;
    font-size: 0.82rem !important;
    line-height: 1.4 !important;
    letter-spacing: -0.005em !important;
    color: rgba(26, 45, 16, 0.58) !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #mellow-ingredients-{{ section.id }} .mellow-ingredients__button--mobile {
    display: none !important;
  }

  @media screen and (min-width: 1500px) {
    #mellow-ingredients-{{ section.id }} {
      --ingredients-side-pad: clamp(128px, 9vw, 196px);

      padding-top: 112px !important;
      padding-bottom: 104px !important;
      padding-left: var(--ingredients-side-pad) !important;
      padding-right: var(--ingredients-side-pad) !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__header {
      margin-bottom: 52px !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__heading {
      max-width: 980px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__intro {
      max-width: 580px !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__grid {
      gap: 22px !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__image-wrap {
      aspect-ratio: 1.48 / 1 !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__content {
      padding: 20px 24px 20px !important;
    }

    #mellow-ingredients-{{ section.id }} .mellow-ingredients__card h3 {
      font-size: 1.82rem !important;
      line-height: 1.04 !important;
    }
  }

  @media (max-width: 1100px) {
    #mellow-ingredients-{{ section.id }} {
      --ingredients-side-pad: 32px;

      padding-left: var(--ingredients-side-pad) !important;
      padding-right: var(--ingredients-side-pad) !important;
    }

