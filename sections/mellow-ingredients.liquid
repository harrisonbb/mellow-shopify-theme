{% comment %}
  Mellow ingredients placeholder section.
  Dawn-compatible Online Store 2.0 section scaffold for the Mellow homepage.
{% endcomment %}

<section class="mellow-section mellow-architecture-section mellow-ingredients color-{{ section.settings.color_scheme }}">
  <div class="mellow-section__inner">
    <div class="mellow-architecture-section__card">
      <div class="mellow-architecture-section__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="mellow-architecture-section__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-architecture-section__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.note != blank -%}
        <div class="mellow-architecture-section__note">
          <span>{{ section.settings.note | escape }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow ingredients",
  "tag": "section",
  "class": "section section-mellow-ingredients",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Ingredients"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spotlight the formulation with clarity."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Use this section for ingredient education, sourcing notes, and why each component matters."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Planning note",
      "default": "Ready for final design replacement."
    }
  ],
  "presets": [
    {
      "name": "Mellow ingredients"
    }
  ]
}
{% endschema %}
