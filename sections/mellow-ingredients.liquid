{% comment %}
  Mellow premium ingredients bento section.
  Uses the global Mellow typography system and scoped section CSS for layout only.
{% endcomment %}

<style>
  #MellowIngredients-{{ section.id }} {
    --mellow-ingredients-card-gap: clamp(16px, 1.6vw, 24px);
    --mellow-forest: #123308;
    --mellow-green: #123308;
    --mellow-ingredients-card-radius: min(var(--mellow-radius-card), 22px);
    --mellow-ingredients-small-card-height: clamp(216px, 17vw, 240px);
    --mellow-ingredients-feature-card-height: calc((var(--mellow-ingredients-small-card-height) * 2) + var(--mellow-ingredients-card-gap));
    padding-top: var(--mellow-section-pad-top, clamp(64px, 5.5vw, 92px));
    padding-bottom: var(--mellow-section-pad-bottom, clamp(52px, 5vw, 76px));
    background: var(--mellow-ivory, #FCFBF7);
    color: var(--mellow-forest, #123308);
  }

  #MellowIngredients-{{ section.id }}.mellow-section-standard {
    padding-top: var(--mellow-section-pad-top, clamp(64px, 5.5vw, 92px));
    padding-bottom: var(--mellow-section-pad-bottom, clamp(52px, 5vw, 76px));
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid {
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
    margin-bottom: var(--mellow-section-content-gap-compact);
    align-items: end;
    gap: clamp(36px, 6vw, 104px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__header {
    max-width: 830px;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__heading {
    max-width: 650px;
    color: var(--mellow-forest, #123308);
    text-wrap: balance;
  }

  #MellowIngredients-{{ section.id }} .mellow-eyebrow {
    margin-bottom: var(--mellow-section-header-gap);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__text {
    max-width: 520px;
    margin-top: var(--mellow-section-heading-gap);
    font-size: clamp(16px, 1.15vw, 20px);
    line-height: 1.35;
    font-weight: 430;
    color: rgba(18, 51, 8, 0.8);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__actions {
    justify-self: start;
    align-self: end;
    width: min(100%, 340px);
    min-width: 0;
    padding-bottom: clamp(0px, .25vw, 4px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__actions .mellow-section-cta-wrap {
    justify-content: flex-start;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__cta {
    --mellow-section-cta-bg: var(--mellow-forest, #123308);
    --mellow-section-cta-border: var(--mellow-forest, #123308);
    --mellow-section-cta-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-hover-bg: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-border: var(--mellow-orange-red, #D04A2A);
    --mellow-section-cta-hover-color: var(--mellow-cream, #FCFBF7);
    --mellow-section-cta-width: clamp(224px, 16vw, 258px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-note {
    display: grid;
    grid-template-columns: 36px minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    max-width: 300px;
    margin: clamp(18px, 2vw, 28px) 0 0;
    color: rgba(18, 51, 8, 0.82);
    font-size: clamp(14px, .96vw, 16px);
    font-weight: 520;
    letter-spacing: -0.005em;
    line-height: 1.35;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid rgba(18, 51, 8, 0.16);
    border-radius: 999px;
    background: color-mix(in srgb, var(--mellow-cream, #FCFBF7) 74%, var(--mellow-forest, #123308) 7%);
    color: var(--mellow-forest, #123308);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
    gap: var(--mellow-ingredients-card-gap);
    min-height: 0;
    align-items: stretch;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__side {
    display: grid;
    grid-template-rows: repeat(2, var(--mellow-ingredients-small-card-height));
    gap: var(--mellow-ingredients-card-gap);
    min-width: 0;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card {
    position: relative;
    display: grid;
    overflow: hidden;
    min-width: 0;
    border: 1px solid rgba(18, 51, 8, 0.12);
    border-radius: var(--mellow-ingredients-card-radius);
    background: var(--mellow-cream, #FCFBF7);
    box-shadow: 0 20px 54px rgba(18, 51, 8, 0.06);
    isolation: isolate;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature {
    grid-template-columns: minmax(0, 49%) minmax(0, 51%);
    height: var(--mellow-ingredients-feature-card-height);
    min-height: 0;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
    grid-template-columns: minmax(0, 47%) minmax(0, 53%);
    height: var(--mellow-ingredients-small-card-height);
    min-height: 0;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__visual,
  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__visual {
    grid-column: 2;
    grid-row: 1;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__content,
  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
    grid-column: 1;
    grid-row: 1;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual {
    position: relative;
    min-width: 0;
    min-height: 0;
    height: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 24%, rgba(255, 255, 255, 0.42), transparent 36%),
      #E9D8C3;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--alginate {
    background: #EAD8C2;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--alginate .mellow-ingredients__image {
    object-position: center 64%;
    transform: scale(1.08);
    transform-origin: center bottom;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--calcium {
    background: #EAD8C2;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--calcium .mellow-ingredients__image {
    object-position: 56% center;
    transform: scale(1.14);
    transform-origin: center center;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--bicarbonate {
    background: #EAD8C2;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__visual--bicarbonate .mellow-ingredients__image {
    object-position: 58% center;
    transform: scale(1.06);
    transform-origin: center center;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    padding: clamp(24px, 2.2vw, 36px);
    background: rgba(252, 251, 247, 0.96);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
    justify-content: center;
    padding: clamp(22px, 1.9vw, 32px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__content {
    justify-content: space-between;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__role {
    display: block;
    width: fit-content;
    margin: 0 0 clamp(6px, .55vw, 9px);
    color: color-mix(in srgb, var(--mellow-science-blue, #3D6B8C) 82%, var(--mellow-forest, #123308));
    font-size: clamp(10px, .65vw, 12px);
    font-weight: var(--mellow-eyebrow-weight, 700);
    line-height: var(--mellow-eyebrow-line-height, 1);
    letter-spacing: var(--mellow-eyebrow-tracking, 0.16em);
    text-transform: uppercase;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__title {
    color: var(--mellow-forest, #123308);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__description {
    max-width: 32rem;
    margin-top: clamp(6px, .6vw, 9px);
    color: rgba(18, 51, 8, 0.82);
    font-weight: 450;
    line-height: 1.43;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__title {
    font-size: clamp(28px, 2.45vw, 38px);
    line-height: .96;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__title {
    font-size: clamp(20px, 1.55vw, 26px);
    line-height: .95;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(12px, 1.3vw, 22px);
    width: 100%;
    margin-top: clamp(28px, 4vw, 72px);
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-item {
    display: grid;
    gap: 8px;
    min-width: 0;
    color: var(--mellow-forest, #123308);
    font-size: clamp(12px, .9vw, 14px);
    font-weight: 620;
    letter-spacing: -0.005em;
    line-height: 1.2;
  }

  #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-item svg {
    width: 28px;
    height: 28px;
    color: rgba(18, 51, 8, 0.72);
  }

  @media screen and (max-width: 989px) {
    #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__grid {
      grid-template-columns: 1fr;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__actions,
    #MellowIngredients-{{ section.id }} .mellow-section-cta-wrap {
      justify-self: start;
      justify-content: flex-start;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid {
      align-items: start;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__side {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature {
      height: auto;
      min-height: 0;
      grid-template-columns: 1fr;
      grid-template-rows: clamp(260px, 40vw, 360px) auto;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
      height: auto;
      min-height: 270px;
      grid-template-columns: 1fr;
      grid-template-rows: clamp(210px, 32vw, 280px) auto;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__visual {
      grid-column: 1;
      grid-row: 1;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__content {
      grid-column: 1;
      grid-row: 2;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__visual {
      grid-column: 1;
      grid-row: 1;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
      grid-column: 1;
      grid-row: 2;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowIngredients-{{ section.id }} .mellow-ingredients__header-grid {
      gap: 24px;
      margin-bottom: var(--mellow-section-content-gap-compact);
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__grid,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__side {
      grid-template-columns: 1fr;
      gap: var(--mellow-ingredients-card-gap);
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card {
      border-radius: var(--mellow-ingredients-card-radius);
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact {
      grid-template-columns: 1fr;
      grid-template-rows: clamp(220px, 60vw, 340px) auto;
      min-height: 0;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__visual,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__visual {
      grid-column: 1;
      grid-row: 1;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__content,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
      grid-column: 1;
      grid-row: 2;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__content,
    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--compact .mellow-ingredients__content {
      padding: var(--mellow-card-pad-tight);
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__card--feature .mellow-ingredients__title {
      font-size: clamp(32px, 9vw, 42px);
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-note {
      margin-top: 16px;
    }

    #MellowIngredients-{{ section.id }} .mellow-ingredients__proof-list {
      margin-top: 28px;
    }
  }
</style>

<section id="MellowIngredients-{{ section.id }}" class="mellow-section-standard mellow-ingredients color-{{ section.settings.color_scheme }}">
  <div class="mellow-section-axis">
    <div class="mellow-section-header-grid mellow-ingredients__header-grid">
      <div class="mellow-section-header mellow-ingredients__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          {%- assign mellow_ingredients_heading = section.settings.heading | escape | replace: 'Nothing hidden. Everything intentional.', 'Nothing hidden.<br>Everything intentional.' -%}
          <h2 class="mellow-section-heading mellow-ingredients__heading">{{ mellow_ingredients_heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <p class="mellow-section-text mellow-ingredients__text">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.cta_label != blank -%}
        <div class="mellow-section-actions mellow-ingredients__actions">
          <div class="mellow-section-cta-wrap">
            <a class="mellow-section-cta mellow-ingredients__cta" href="{{ section.settings.cta_link | default: '#' }}">
              <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
              <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
            </a>
          </div>
          <p class="mellow-ingredients__proof-note">
            <span class="mellow-ingredients__proof-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" focusable="false">
                <path d="M5.5 13.2c0-5.3 4-8.4 12.6-8.7.2 8.6-3.3 13.7-8.8 13.7-2.4 0-3.8-1.6-3.8-5Z" stroke="currentColor" stroke-width="1.55" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.6 13.9c1.4-2.3 3.2-4 5.4-5.1M4.4 19.6c1.6-2.6 3.6-4.5 6.2-5.7" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/>
              </svg>
            </span>
            <span>Three active ingredients.<br>Zero fillers. 100% intentional.</span>
          </p>
        </div>
      {%- endif -%}
    </div>

    <div class="mellow-ingredients__grid">
      <article class="mellow-ingredients__card mellow-ingredients__card--feature">
        <div class="mellow-ingredients__visual mellow-ingredients__visual--alginate">
          {%- if section.settings.alginate_image != blank -%}
            {{ section.settings.alginate_image | image_url: width: 1400 | image_tag: decoding: 'async', class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 54vw, 100vw', widths: '500, 720, 900, 1100, 1400', alt: section.settings.alginate_title }}
          {%- endif -%}
        </div>
        <div class="mellow-ingredients__content">
          <div>
            <span class="mellow-ingredients__role">{{ section.settings.alginate_role | escape }}</span>
            <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.alginate_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.alginate_description | escape }}</p>
          </div>
          <div class="mellow-ingredients__proof-list" aria-label="Sodium Alginate proof points">
            <span class="mellow-ingredients__proof-item">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true" focusable="false">
                <path d="M8.8 5.5c-2.8 3.1-2.8 6.1 0 9.1s2.8 6.1 0 9.1M16 5.5c-2.8 3.1-2.8 6.1 0 9.1s2.8 6.1 0 9.1M23.2 5.5c-2.8 3.1-2.8 6.1 0 9.1s2.8 6.1 0 9.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
              <span>Seaweed<br>derived</span>
            </span>
            <span class="mellow-ingredients__proof-item">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true" focusable="false">
                <circle cx="16" cy="16" r="12.5" stroke="currentColor" stroke-width="1.8"/>
                <path d="m10.8 16.4 3.3 3.3 7.2-8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Clinically<br>studied</span>
            </span>
            <span class="mellow-ingredients__proof-item">
              <svg viewBox="0 0 32 32" fill="none" aria-hidden="true" focusable="false">
                <path d="M6.8 17.9c0-7.2 5.3-11.1 16.8-11.5.3 11.6-4.3 18.2-11.7 18.2-3.1 0-5.1-2.2-5.1-6.7Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13.1 18.4c2-3 4.3-5.3 7.2-6.8M5 27.1c2.1-3.5 4.8-6.1 8.1-8.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
              <span>Naturally<br>sourced</span>
            </span>
          </div>
        </div>
      </article>

      <div class="mellow-ingredients__side">
        <article class="mellow-ingredients__card mellow-ingredients__card--compact">
          <div class="mellow-ingredients__visual mellow-ingredients__visual--calcium">
            {%- if section.settings.calcium_image != blank -%}
              {{ section.settings.calcium_image | image_url: width: 900 | image_tag: decoding: 'async', class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 22vw, (min-width: 750px) 42vw, 100vw', widths: '360, 520, 700, 900', alt: section.settings.calcium_title }}
            {%- endif -%}
          </div>
          <div class="mellow-ingredients__content">
            <span class="mellow-ingredients__role">{{ section.settings.calcium_role | escape }}</span>
            <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.calcium_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.calcium_description | escape }}</p>
          </div>
        </article>

        <article class="mellow-ingredients__card mellow-ingredients__card--compact">
          <div class="mellow-ingredients__visual mellow-ingredients__visual--bicarbonate">
            {%- if section.settings.bicarbonate_image != blank -%}
              {{ section.settings.bicarbonate_image | image_url: width: 900 | image_tag: decoding: 'async', class: 'mellow-ingredients__image', loading: 'lazy', sizes: '(min-width: 990px) 22vw, (min-width: 750px) 42vw, 100vw', widths: '360, 520, 700, 900', alt: section.settings.bicarbonate_title }}
            {%- endif -%}
          </div>
          <div class="mellow-ingredients__content">
            <span class="mellow-ingredients__role">{{ section.settings.bicarbonate_role | escape }}</span>
            <h3 class="mellow-card-title mellow-ingredients__title">{{ section.settings.bicarbonate_title | escape }}</h3>
            <p class="mellow-card-copy mellow-ingredients__description">{{ section.settings.bicarbonate_description | escape }}</p>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow ingredients",
  "tag": "section",
  "class": "section section-mellow-ingredients",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "INGREDIENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nothing hidden. Everything intentional."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Subhead",
      "default": "Every ingredient in Mellow earns its place. No fillers, no mystery compounds — just the clinically studied components behind the MellowRaft™ formula."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "See all ingredients"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Sodium Alginate"
    },
    {
      "type": "image_picker",
      "id": "alginate_image",
      "label": "Sodium Alginate visual"
    },
    {
      "type": "text",
      "id": "alginate_role",
      "label": "Role label",
      "default": "THE RAFT-FORMER"
    },
    {
      "type": "text",
      "id": "alginate_title",
      "label": "Title",
      "default": "Sodium Alginate"
    },
    {
      "type": "textarea",
      "id": "alginate_description",
      "label": "Description",
      "default": "Forms the floating gel barrier. The backbone of MellowRaft™ — derived from seaweed, activated by stomach acid."
    },
    {
      "type": "header",
      "content": "Calcium Carbonate"
