</style>

{% schema %}
{
  "name": "Mellow Reflux Patterns",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REFLUX PATTERNS"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Reflux has a pattern."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Mellow is made for the predictable moments: after meals, before bed, and the nights you already know might go sideways."
    },
    {
      "type": "text",
      "id": "quiz_button_label",
      "label": "Quiz button label",
      "default": "Take the quiz"
    },
    {
      "type": "url",
      "id": "quiz_button_link",
      "label": "Quiz button link"
    }
  ],
  "presets": [
    {
      "name": "Mellow Reflux Patterns"
    }
  ]
}
{% endschema %}