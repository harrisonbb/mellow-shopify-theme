  #shopify-section-{{ section.id }} .mellow-section,
  #shopify-section-{{ section.id }} .mellow-container {
    max-width: none !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  #shopify-section-{{ section.id }} {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 12px 0 !important;
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} > * {
    background: transparent !important;
  }

  #who-its-for.mellow-patterns,
  #shopify-section-{{ section.id }} #who-its-for.mellow-patterns,
  #shopify-section-{{ section.id }} .mellow-patterns {
    --mellow-axis-pad: clamp(28px, 7vw, 112px);
    --mellow-axis-max: 1400px;

    --mellow-ivory: #F0EBE0;
    --mellow-cream: #F8F2E7;
    --mellow-cream-soft: #FBF7EF;
    --mellow-forest: #1A2D10;
    --mellow-green-deep: #10280C;
    --mellow-orange: #D04A2A;
    --mellow-blush: #F4B39F;
    --mellow-sage: #87927C;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;

    padding-top: clamp(62px, 5vw, 88px) !important;
    padding-bottom: clamp(64px, 5.3vw, 96px) !important;
