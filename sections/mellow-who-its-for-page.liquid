{% comment %}
  Mellow Reflux Patterns
  Simplified premium card row with equal-size cards, calm cream surfaces, and restrained quiz CTA.
{% endcomment %}

<section
  class="mellow-patterns mellow-patterns-{{ section.id }}"
  id="who-its-for"
>
  <div class="mellow-patterns__inner">

    <div class="mellow-patterns__top">
      <div class="mellow-patterns__copy">
        <span class="mellow-patterns__eyebrow">
          {% if section.settings.eyebrow != blank %}
            {{ section.settings.eyebrow }}
          {% else %}
            REFLUX PATTERNS
          {% endif %}
        </span>

        <h2 class="mellow-patterns__headline mellow-heading-split">
          {% assign split_heading_text = section.settings.heading | default: 'Reflux has a pattern.' %}
          {% render 'mellow-split-heading', text: split_heading_text %}
        </h2>
      </div>

      <p class="mellow-patterns__subhead">
        {% if section.settings.subheading != blank %}
          {{ section.settings.subheading }}
        {% else %}
          Mellow is made for the predictable moments: after meals, before bed, and the nights you already know might go sideways.
        {% endif %}
      </p>
    </div>

    <p class="mellow-patterns__cue">
      Choose the moment you want to get ahead of.
    </p>

    <div class="mellow-patterns__grid" aria-label="Common reflux patterns">

      <article class="mellow-patterns__card mellow-patterns__card--dinner">
        <span class="mellow-patterns__dot" aria-hidden="true"></span>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">After dinner</span>

          <h3>When the meal ends, but the burning starts.</h3>

          <p>
            For reflux that shows up after heavier, spicy, acidic, or late meals.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--bed">
        <span class="mellow-patterns__dot" aria-hidden="true"></span>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">Before bed</span>

          <h3>When lying down makes everything worse.</h3>

          <p>
            For nighttime reflux, water brash, sour taste, or waking up burning.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--go">
        <span class="mellow-patterns__dot" aria-hidden="true"></span>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">On the go</span>

          <h3>Relief without the medicine ritual.</h3>

          <p>
            Single-serve pouches made for bags, travel, restaurants, and work.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--quiz">
        <span class="mellow-patterns__dot" aria-hidden="true"></span>
        <span class="mellow-patterns__quiz-glow" aria-hidden="true"></span>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">Not sure?</span>

          <h3>Find your reflux pattern.</h3>

          <p>
            Answer a few questions and find the routine that fits the way reflux shows up for you.
          </p>
        </div>

        {% if section.settings.quiz_button_label != blank %}
          <a
            class="mellow-patterns__button"
            href="{{ section.settings.quiz_button_link }}"
          >
            {{ section.settings.quiz_button_label }}
          </a>
        {% endif %}
      </article>

    </div>

  </div>
</section>

