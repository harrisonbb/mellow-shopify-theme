{% comment %}
  Mellow Reflux Patterns
  Updated:
  - Huel-inspired bento grid
  - Large primary After Dinner card
  - Ownable Mellow wave + dot raft motif in large card
  - Removed colored top lines from all cards
  - Supporting Before Bed / On The Go cards
  - Card 03 uses patient-moment copy
  - Dark quiz card has softer contrast
  - Full-height quiz CTA card as natural section conclusion
  - Typography matched to Mellow Hero system:
    Fraunces 550 headings, tighter premium spacing, DM Sans body rhythm
{% endcomment %}

<section
  class="mellow-patterns mellow-patterns-{{ section.id }}"
  id="who-its-for"
>
  <div class="mellow-patterns__inner">

    <div class="mellow-patterns__top">
      <div class="mellow-patterns__copy">
        <span class="mellow-patterns__eyebrow">
          {% if section.settings.eyebrow != blank %}
            {{ section.settings.eyebrow }}
          {% else %}
            Reflux patterns
          {% endif %}
        </span>

        <h2 class="mellow-patterns__headline mellow-heading-split">
          {% assign split_heading_text = section.settings.heading | default: 'Reflux has a pattern.' %}
          {% render 'mellow-split-heading', text: split_heading_text %}
        </h2>
      </div>

      <p class="mellow-patterns__subhead">
        {% if section.settings.subheading != blank %}
          {{ section.settings.subheading }}
        {% else %}
          Mellow is made for the predictable moments: after meals, before bed, and the nights you already know might go sideways.
        {% endif %}
      </p>
    </div>

    <p class="mellow-patterns__cue">
      Choose the moment you want to get ahead of.
    </p>

    <div class="mellow-patterns__bento" aria-label="Common reflux patterns">

      <article class="mellow-patterns__card mellow-patterns__card--large mellow-patterns__card--dinner">
        <span class="mellow-patterns__number" aria-hidden="true">01</span>

        <div class="mellow-patterns__raft-motif" aria-hidden="true">
          <svg viewBox="0 0 560 260" role="presentation" focusable="false">
            <path class="mellow-patterns__wave-line mellow-patterns__wave-line--one" d="M34 72 C108 22, 177 121, 253 72 C330 22, 392 122, 526 60" />
            <path class="mellow-patterns__wave-line mellow-patterns__wave-line--two" d="M18 132 C92 82, 174 178, 252 132 C330 86, 403 176, 542 120" />
            <path class="mellow-patterns__wave-line mellow-patterns__wave-line--three" d="M44 190 C120 142, 184 232, 260 188 C340 142, 410 224, 516 176" />

            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--one" cx="98" cy="58" r="10" />
            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--two" cx="212" cy="102" r="7" />
            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--three" cx="330" cy="72" r="9" />
            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--four" cx="440" cy="112" r="6" />
            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--five" cx="150" cy="172" r="8" />
            <circle class="mellow-patterns__raft-dot mellow-patterns__raft-dot--six" cx="384" cy="190" r="7" />
          </svg>
        </div>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">After dinner</span>

          <h3>When the meal ends, but the burning starts.</h3>

          <p>
            For reflux that shows up after heavier, spicy, acidic, or late meals — the moments you can usually see coming.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--support mellow-patterns__card--bed">
        <span class="mellow-patterns__number" aria-hidden="true">02</span>

        <div class="mellow-patterns__orb mellow-patterns__orb--bed" aria-hidden="true"></div>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">Before bed</span>

          <h3>When lying down makes everything worse.</h3>

          <p>
            For nighttime reflux, water brash, sour taste, or waking up burning.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--support mellow-patterns__card--go">
        <span class="mellow-patterns__number" aria-hidden="true">03</span>

        <div class="mellow-patterns__orb mellow-patterns__orb--go" aria-hidden="true"></div>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">On the go</span>

          <h3>When the burn follows you out the door.</h3>

          <p>
            Single-serve pouches made for bags, travel, restaurants, and work.
          </p>
        </div>
      </article>

      <article class="mellow-patterns__card mellow-patterns__card--quiz">
        <span class="mellow-patterns__number" aria-hidden="true">04</span>

        <div class="mellow-patterns__quiz-glow" aria-hidden="true"></div>

        <div class="mellow-patterns__card-copy">
          <span class="mellow-patterns__label">Not sure?</span>

          <h3>Find your reflux pattern.</h3>

          <p>
            Take the 60-second quiz and find the routine that fits when reflux shows up for you.
          </p>
        </div>

        {% if section.settings.quiz_button_label != blank %}
          <a
            class="mellow-patterns__button"
            href="{{ section.settings.quiz_button_link }}"
          >
            {{ section.settings.quiz_button_label }}
          </a>
        {% endif %}
      </article>

    </div>

  </div>
</section>

<style>
  /* =========================================================
     MELLOW — REFLUX PATTERNS SECTION
     Huel-inspired bento grid
     ========================================================= */

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > *,
  #shopify-section-{{ section.id }} .page-width,
  #shopify-section-{{ section.id }} .mellow-section,
  #shopify-section-{{ section.id }} .mellow-container {
    max-width: none !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  #shopify-section-{{ section.id }} {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 12px 0 !important;
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} > * {
    background: transparent !important;
  }

  #who-its-for.mellow-patterns,
  #shopify-section-{{ section.id }} #who-its-for.mellow-patterns,
  #shopify-section-{{ section.id }} .mellow-patterns {
    --mellow-axis-pad: clamp(112px, 7.8vw, 156px);
    --mellow-axis-max: 1500px;

    --mellow-page: #FBFCF7;
    --mellow-ivory: #F0EBE0;
    --mellow-cream: #F6F1E8;
    --mellow-forest: #1A2D10;
    --mellow-green: #123A24;
    --mellow-green-deep: #0B1E08;
    --mellow-orange: #D04A2A;
    --mellow-blue: #3D6B8C;
    --mellow-sage: #87927C;
    --mellow-gold-line: rgba(177, 145, 92, 0.72);

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;

    padding-top: clamp(64px, 5.2vw, 94px) !important;
    padding-bottom: clamp(70px, 5.8vw, 110px) !important;
    padding-left: var(--mellow-axis-pad) !important;
    padding-right: var(--mellow-axis-pad) !important;

    border-radius: 28px !important;
    overflow: hidden !important;
    isolation: isolate !important;
    position: relative !important;

    background:
      radial-gradient(circle at 16% 22%, rgba(61, 107, 140, 0.22), transparent 32%),
      radial-gradient(circle at 86% 38%, rgba(208, 74, 42, 0.13), transparent 30%),
      radial-gradient(circle at 52% 76%, rgba(240, 235, 224, 0.055), transparent 38%),
      linear-gradient(180deg, #14320F 0%, #10280C 100%) !important;
    color: var(--mellow-ivory) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns,
  #shopify-section-{{ section.id }} .mellow-patterns * {
    box-sizing: border-box !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns::before {
    content: "" !important;
    position: absolute !important;
    inset: -18% !important;
    z-index: 0 !important;
    pointer-events: none !important;
    background:
      radial-gradient(circle at 18% 38%, rgba(61, 107, 140, 0.18), transparent 32%),
      radial-gradient(circle at 82% 62%, rgba(208, 74, 42, 0.09), transparent 30%),
      radial-gradient(circle at 52% 84%, rgba(240, 235, 224, 0.075), transparent 34%) !important;
    opacity: 0.78 !important;
    animation: mellowPatternsDrift 20s ease-in-out infinite alternate;
  }

  #shopify-section-{{ section.id }} .mellow-patterns::after {
    content: "" !important;
    position: absolute !important;
    left: 7% !important;
    right: 7% !important;
    bottom: clamp(58px, 5vw, 92px) !important;
    height: clamp(280px, 23vw, 420px) !important;
    z-index: 0 !important;
    pointer-events: none !important;
    background:
      radial-gradient(ellipse at 42% 50%, rgba(240, 235, 224, 0.11), transparent 58%),
      radial-gradient(ellipse at 18% 55%, rgba(61, 107, 140, 0.12), transparent 52%),
      radial-gradient(ellipse at 86% 60%, rgba(208, 74, 42, 0.13), transparent 52%) !important;
    filter: blur(16px) !important;
    opacity: 0.78 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__inner {
    position: relative !important;
    z-index: 1 !important;
    width: 100% !important;
    max-width: var(--mellow-axis-max) !important;
    margin-left: auto !important;
    margin-right: auto !important;

    display: flex !important;
    flex-direction: column !important;
    gap: clamp(26px, 2.8vw, 42px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__top {
    display: grid !important;
    grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.58fr) !important;
    gap: clamp(28px, 4.5vw, 68px) !important;
    align-items: start !important;
    width: 100% !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__copy {
    max-width: 900px !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__eyebrow {
    display: block !important;
    margin: 0 0 16px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__headline {
    display: block !important;
    margin: 0 !important;
    max-width: 900px !important;

    color: var(--mellow-ivory) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__subhead {
    max-width: 560px !important;
    margin: 0 !important;
    padding-top: 26px !important;

    color: rgba(240, 235, 224, 0.88) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(1rem, 1.18vw, 1.18rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__cue {
    display: block !important;
    margin: -6px 0 -14px !important;
    max-width: 520px !important;

    color: rgba(240, 235, 224, 0.76) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(0.98rem, 1vw, 1.08rem) !important;
    line-height: 1.4 !important;
    letter-spacing: -0.015em !important;
    font-weight: 600 !important;
    text-align: left !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__bento {
    position: relative !important;
    z-index: 2 !important;

    display: grid !important;
    grid-template-columns: minmax(0, 1.14fr) minmax(0, 0.86fr) minmax(0, 0.86fr) !important;
    grid-template-rows: minmax(212px, auto) minmax(212px, auto) !important;
    gap: 16px !important;

    width: 100% !important;
    margin: 0 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__bento::before {
    content: "" !important;
    position: absolute !important;
    inset: -34px -28px -42px !important;
    z-index: -1 !important;
    pointer-events: none !important;
    background:
      radial-gradient(ellipse at 38% 52%, rgba(240, 235, 224, 0.12), transparent 62%),
      radial-gradient(ellipse at 78% 58%, rgba(208, 74, 42, 0.10), transparent 56%) !important;
    filter: blur(18px) !important;
    opacity: 0.86 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card {
    position: relative !important;
    min-height: 212px !important;
    padding: clamp(26px, 2.1vw, 34px) clamp(26px, 2vw, 34px) !important;
    border-radius: 28px !important;
    overflow: hidden !important;

    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-end !important;
    align-items: flex-start !important;

    background:
      radial-gradient(circle at 16% 12%, rgba(255,255,255,0.48), transparent 28%),
      radial-gradient(circle at 88% 90%, rgba(208, 74, 42, 0.045), transparent 38%),
      linear-gradient(180deg, #F6F1E8 0%, #F0EBE0 100%) !important;
    color: var(--mellow-forest) !important;

    border: 1px solid rgba(177, 145, 92, 0.34) !important;
    box-shadow:
      0 24px 58px rgba(8, 16, 5, 0.23),
      0 0 0 1px rgba(255, 255, 255, 0.10),
      inset 0 1px 0 rgba(255, 255, 255, 0.70),
      inset 0 -1px 0 rgba(26, 45, 16, 0.06) !important;

    transition:
      transform 260ms ease,
      box-shadow 260ms ease,
      border-color 260ms ease,
      background 260ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card::before {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    z-index: 0 !important;
    pointer-events: none !important;
    opacity: 0.72 !important;
    background:
      linear-gradient(135deg, rgba(255,255,255,0.52) 0%, rgba(255,255,255,0.14) 28%, transparent 56%),
      radial-gradient(circle at 18% 12%, rgba(240, 235, 224, 0.48), transparent 26%),
      radial-gradient(circle at 88% 88%, rgba(208, 74, 42, 0.05), transparent 38%) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card::after {
    display: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--large {
    grid-column: 1 / 2 !important;
    grid-row: 1 / 3 !important;
    min-height: 440px !important;
    padding: clamp(30px, 2.55vw, 42px) clamp(30px, 2.35vw, 42px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--bed {
    grid-column: 2 / 3 !important;
    grid-row: 1 / 2 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--go {
    grid-column: 2 / 3 !important;
    grid-row: 2 / 3 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--quiz {
    grid-column: 3 / 4 !important;
    grid-row: 1 / 3 !important;

    background:
      radial-gradient(circle at 90% 88%, rgba(208, 74, 42, 0.20), transparent 42%),
      radial-gradient(circle at 20% 14%, rgba(240, 235, 224, 0.08), transparent 30%),
      radial-gradient(circle at 24% 70%, rgba(61, 107, 140, 0.09), transparent 42%),
      linear-gradient(180deg, rgba(31, 56, 23, 0.91) 0%, rgba(14, 31, 9, 0.92) 100%) !important;
    color: var(--mellow-ivory) !important;
    border-color: rgba(240, 235, 224, 0.20) !important;
    box-shadow:
      0 24px 56px rgba(8, 16, 5, 0.34),
      0 0 0 1px rgba(240, 235, 224, 0.06),
      0 0 30px rgba(208, 74, 42, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.13),
      inset 0 -1px 0 rgba(0, 0, 0, 0.16) !important;
    backdrop-filter: blur(14px) saturate(1.12) !important;
    -webkit-backdrop-filter: blur(14px) saturate(1.12) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--quiz::before {
    opacity: 0.86 !important;
    background:
      linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.028) 28%, transparent 56%),
      radial-gradient(circle at 18% 12%, rgba(240, 235, 224, 0.08), transparent 26%),
      radial-gradient(circle at 88% 88%, rgba(208, 74, 42, 0.18), transparent 38%) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__number {
    position: absolute !important;
    top: clamp(22px, 1.75vw, 30px) !important;
    right: clamp(24px, 1.9vw, 32px) !important;
    z-index: 1 !important;
    pointer-events: none !important;

    color: rgba(26, 45, 16, 0.046) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3.65rem, 4.4vw, 5.35rem) !important;
    line-height: 0.85 !important;
    letter-spacing: -0.07em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 96, "wght" 550 !important;

    transition:
      transform 260ms ease,
      opacity 260ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--large .mellow-patterns__number {
    font-size: clamp(5rem, 6.2vw, 7.6rem) !important;
    top: clamp(28px, 2.3vw, 42px) !important;
    right: clamp(28px, 2.3vw, 42px) !important;
    color: rgba(26, 45, 16, 0.04) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--quiz .mellow-patterns__number {
    color: rgba(240, 235, 224, 0.04) !important;
    font-size: clamp(5rem, 6vw, 7.2rem) !important;
    top: clamp(28px, 2.3vw, 42px) !important;
    right: clamp(28px, 2.3vw, 42px) !important;
  }

  /* Large card packaging-inspired raft motif — no pill/capsule shapes */
  #shopify-section-{{ section.id }} .mellow-patterns__raft-motif {
    position: absolute !important;
    z-index: 1 !important;
    top: clamp(48px, 5vw, 88px) !important;
    left: clamp(34px, 4.3vw, 78px) !important;
    width: clamp(300px, 27vw, 500px) !important;
    height: clamp(155px, 14vw, 250px) !important;
    pointer-events: none !important;
    opacity: 0.72 !important;
    transform: rotate(-4deg) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__raft-motif svg {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__wave-line {
    fill: none !important;
    stroke: rgba(26, 45, 16, 0.17) !important;
    stroke-width: 8 !important;
    stroke-linecap: round !important;
    stroke-linejoin: round !important;
    vector-effect: non-scaling-stroke !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__wave-line--one {
    stroke: rgba(26, 45, 16, 0.15) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__wave-line--two {
    stroke: rgba(177, 145, 92, 0.20) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__wave-line--three {
    stroke: rgba(208, 74, 42, 0.12) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__raft-dot {
    fill: rgba(26, 45, 16, 0.13) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__raft-dot--one,
  #shopify-section-{{ section.id }} .mellow-patterns__raft-dot--five {
    fill: rgba(208, 74, 42, 0.14) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__raft-dot--three,
  #shopify-section-{{ section.id }} .mellow-patterns__raft-dot--six {
    fill: rgba(177, 145, 92, 0.18) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__orb {
    position: absolute !important;
    z-index: 1 !important;
    pointer-events: none !important;
    border-radius: 999px !important;
    opacity: 0.56 !important;
    filter: blur(0.2px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__orb--bed {
    width: 76px !important;
    height: 76px !important;
    top: 34px !important;
    left: 34px !important;
    background: radial-gradient(circle, rgba(177, 145, 92, 0.13), transparent 68%) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__orb--go {
    width: 76px !important;
    height: 76px !important;
    top: 34px !important;
    left: 34px !important;
    background: radial-gradient(circle, rgba(177, 145, 92, 0.12), transparent 68%) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__quiz-glow {
    position: absolute !important;
    right: -42px !important;
    bottom: -52px !important;
    z-index: 1 !important;
    width: 210px !important;
    height: 210px !important;
    pointer-events: none !important;
    border-radius: 999px !important;
    background: radial-gradient(circle, rgba(208, 74, 42, 0.20), transparent 62%) !important;
    opacity: 0.78 !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card-copy {
    position: relative !important;
    z-index: 2 !important;
    width: 100% !important;
    max-width: 340px !important;
    margin: 0 !important;
    padding-top: clamp(28px, 2.7vw, 44px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--large .mellow-patterns__card-copy {
    max-width: 430px !important;
    padding-top: clamp(146px, 12.8vw, 218px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card--quiz .mellow-patterns__card-copy {
    max-width: 360px !important;
    padding-top: clamp(78px, 7.2vw, 122px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__label {
    display: block !important;
    margin: 0 0 18px !important;

    color: rgba(26, 45, 16, 0.58) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.11em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  #shopify-section-{{ section.id }} .mellow-patterns__card h3 {
    margin: 0 0 10px !important;
