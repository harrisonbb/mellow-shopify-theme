{% comment %}
  Mellow — Routine / How It Fits
  New homepage-friendly how-it-works section
  Direction:
  - Less scientific, more ritual / life improvement
  - Product → mechanism → outcome
  - AG1-inspired simplicity with Mellow premium styling
  - Optional image pickers for each card
  - Typography matched exactly to Mellow Hero / Ingredients system:
    Fraunces 550 headings, hero-like spacing, DM Sans body rhythm
  Update:
  - Removed 01 / 02 / 03 badges from image cards
  - Images remain taller and less cropped
{% endcomment %}

<section
  class="mellow-routine mellow-routine-{{ section.id }}"
  id="mellow-routine-{{ section.id }}"
>
  <div class="mellow-routine__inner">

    <div class="mellow-routine__header">
      <div class="mellow-routine__header-copy">
        {% if section.settings.eyebrow != blank %}
          <p class="mellow-routine__eyebrow">
            {{ section.settings.eyebrow }}
          </p>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="mellow-routine__heading mellow-heading-split">
            {% render 'mellow-split-heading', text: section.settings.heading %}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="mellow-routine__subheading">
            {{ section.settings.subheading }}
          </p>
        {% endif %}
      </div>

      {% if section.settings.secondary_button_label != blank %}
        <div class="mellow-routine__header-action">
          <a
            class="mellow-routine__secondary-button"
            href="{{ section.settings.secondary_button_link | default: '/pages/science' }}"
          >
            <span>{{ section.settings.secondary_button_label }}</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      {% endif %}
    </div>

    <div class="mellow-routine__cards" aria-label="How Mellow fits into your routine">

      <article class="mellow-routine__card">
        <div class="mellow-routine__media">
          {% if section.settings.image_1 != blank %}
            {{
              section.settings.image_1
              | image_url: width: 1200
              | image_tag:
                class: 'mellow-routine__image',
                loading: 'lazy',
                alt: section.settings.step_title_1
            }}
          {% else %}
            <div class="mellow-routine__placeholder mellow-routine__placeholder--take">
              <div class="mellow-routine__pouch">Mellow</div>
            </div>
          {% endif %}
        </div>

        <div class="mellow-routine__content">
          <h3 class="mellow-routine__step-title">
            {{ section.settings.step_title_1 }}
          </h3>
          <p class="mellow-routine__step-text">
            {{ section.settings.step_text_1 }}
          </p>
        </div>
      </article>

      <article class="mellow-routine__card">
        <div class="mellow-routine__media">
          {% if section.settings.image_2 != blank %}
            {{
              section.settings.image_2
              | image_url: width: 1200
              | image_tag:
                class: 'mellow-routine__image',
                loading: 'lazy',
                alt: section.settings.step_title_2
            }}
          {% else %}
            <div class="mellow-routine__placeholder mellow-routine__placeholder--form">
              <div class="mellow-routine__raft">
                <span></span>
              </div>
            </div>
          {% endif %}
        </div>

        <div class="mellow-routine__content">
          <h3 class="mellow-routine__step-title">
            {{ section.settings.step_title_2 }}
          </h3>
          <p class="mellow-routine__step-text">
            {{ section.settings.step_text_2 }}
          </p>
        </div>
      </article>

      <article class="mellow-routine__card">
        <div class="mellow-routine__media">
          {% if section.settings.image_3 != blank %}
            {{
              section.settings.image_3
              | image_url: width: 1200
              | image_tag:
                class: 'mellow-routine__image',
                loading: 'lazy',
                alt: section.settings.step_title_3
            }}
          {% else %}
            <div class="mellow-routine__placeholder mellow-routine__placeholder--night">
              <div class="mellow-routine__moon"></div>
              <div class="mellow-routine__soft-card"></div>
            </div>
          {% endif %}
        </div>

        <div class="mellow-routine__content">
          <h3 class="mellow-routine__step-title">
            {{ section.settings.step_title_3 }}
          </h3>
          <p class="mellow-routine__step-text">
            {{ section.settings.step_text_3 }}
          </p>
        </div>
      </article>

    </div>

    {% if section.settings.button_label != blank %}
      <div class="mellow-routine__cta-row">
        <a
          class="mellow-routine__button"
          href="{{ section.settings.button_link | default: '/collections/all' }}"
        >
          <span>{{ section.settings.button_label }}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {% endif %}

  </div>
</section>

<style>
  /* =========================================================
     MELLOW — ROUTINE / HOW IT FITS
     Typography matched exactly with Mellow Hero / Ingredients
     Images opened by taller media cards
     Number badges removed from images
     ========================================================= */

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > *,
  #shopify-section-{{ section.id }} .page-width,
  #shopify-section-{{ section.id }} .mellow-section,
  #shopify-section-{{ section.id }} .mellow-container {
    max-width: none !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  #shopify-section-{{ section.id }} {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} > * {
    background: transparent !important;
  }

  #mellow-routine-{{ section.id }},
  #mellow-routine-{{ section.id }} * {
    box-sizing: border-box !important;
  }

  #mellow-routine-{{ section.id }} {
    --mellow-page: #FBFCF7;
    --mellow-ivory: #F0EBE0;
    --mellow-warm: #F7F4EC;
    --mellow-forest: #1A2D10;
    --mellow-green: #123A24;
    --mellow-green-deep: #0B1E08;
    --mellow-orange: #D04A2A;
    --mellow-blue: #3D6B8C;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    --routine-axis-pad: clamp(128px, 8.5vw, 164px);
    --routine-axis-max: 1500px;

    width: 100% !important;
    max-width: none !important;
    margin: 0 !important;

    padding-top: clamp(76px, 5.5vw, 108px) !important;
    padding-bottom: clamp(76px, 5.6vw, 108px) !important;
    padding-left: var(--routine-axis-pad) !important;
    padding-right: var(--routine-axis-pad) !important;

    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    color: var(--mellow-forest) !important;
    overflow: hidden !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__inner {
    width: 100% !important;
    max-width: var(--routine-axis-max) !important;
    margin-left: auto !important;
    margin-right: auto !important;
    padding: 0 !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__header {
    display: grid !important;
    grid-template-columns: minmax(0, 0.95fr) auto !important;
    gap: clamp(28px, 4.5vw, 64px) !important;
    align-items: start !important;
    margin-bottom: clamp(34px, 3.2vw, 48px) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__header-copy {
    max-width: 920px !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__eyebrow {
    margin: 0 0 14px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    font-weight: 800 !important;
    text-align: left !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__heading {
    margin: 0 !important;
    max-width: 880px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(2.9rem, 3.9vw, 5rem) !important;
    line-height: 0.96 !important;
    letter-spacing: -0.035em !important;
    font-weight: 650 !important;
    font-style: normal !important;
    font-variation-settings: normal !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__subheading {
    margin: 20px 0 0 !important;
    max-width: 680px !important;

    color: rgba(26, 45, 16, 0.76) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(1rem, 1.18vw, 1.18rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__header-action {
    display: flex !important;
    justify-content: flex-end !important;
    align-items: flex-start !important;
    padding-top: 34px !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__secondary-button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 11px !important;

    min-height: 50px !important;
    padding: 0 26px !important;
    border-radius: 999px !important;

    background: transparent !important;
    border: 1.5px solid rgba(26, 45, 16, 0.36) !important;
    color: var(--mellow-forest) !important;
    text-decoration: none !important;

    font-family: var(--font-body) !important;
    font-size: 0.94rem !important;
    line-height: 1 !important;
    letter-spacing: -0.01em !important;
    font-weight: 800 !important;

    transition:
      transform 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__secondary-button:hover {
    transform: translateY(-1px) !important;
    background: var(--mellow-forest) !important;
    border-color: var(--mellow-forest) !important;
    color: #FFFFFF !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__cards {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: clamp(18px, 1.6vw, 24px) !important;
    align-items: stretch !important;
    width: 100% !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card {
    display: flex !important;
    flex-direction: column !important;
    min-width: 0 !important;
    margin: 0 !important;
    background: transparent !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__media {
    position: relative !important;
    width: 100% !important;

    aspect-ratio: 1.22 / 1 !important;
    min-height: clamp(330px, 25vw, 440px) !important;

    border-radius: 26px !important;
    overflow: hidden !important;

    background: var(--mellow-ivory) !important;
    border: 1px solid rgba(26, 45, 16, 0.12) !important;

    box-shadow:
      0 22px 58px rgba(26, 45, 16, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.54) !important;

    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card:hover .mellow-routine__media {
    transform: translateY(-4px) !important;
    border-color: rgba(26, 45, 16, 0.18) !important;
    box-shadow:
      0 30px 74px rgba(26, 45, 16, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.62) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__image {
    display: block !important;
    width: 100% !important;
    height: 100% !important;

    object-fit: cover !important;
    object-position: center center !important;

    transform: none !important;
    border-radius: 0 !important;
    box-shadow: none !important;

    transition:
      transform 420ms ease,
      filter 420ms ease !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card:nth-child(1) .mellow-routine__image {
    object-position: center center !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card:nth-child(2) .mellow-routine__image {
    object-position: center center !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card:nth-child(3) .mellow-routine__image {
    object-position: center center !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__card:hover .mellow-routine__image {
    transform: scale(1.018) !important;
    filter: saturate(1.02) contrast(1.01) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__placeholder {
    width: 100% !important;
    height: 100% !important;
    min-height: 100% !important;
    position: relative !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    overflow: hidden !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__placeholder--take {
    background:
      radial-gradient(circle at 54% 44%, rgba(255,255,255,0.78), transparent 36%),
      linear-gradient(180deg, #F8F5ED 0%, #EEE9DF 100%) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__pouch {
    width: 34% !important;
    aspect-ratio: 0.68 / 1 !important;
    border-radius: 20px !important;

    display: flex !important;
    align-items: center !important;
    justify-content: center !important;

    background: var(--mellow-forest) !important;
    color: var(--mellow-ivory) !important;

    font-family: var(--font-heading) !important;
    font-size: clamp(1.8rem, 2.4vw, 2.7rem) !important;
    line-height: 1 !important;
    letter-spacing: -0.04em !important;
    font-weight: 550 !important;
    font-variation-settings: "opsz" 56, "wght" 550 !important;

    transform: rotate(-6deg) !important;
    box-shadow: 0 28px 60px rgba(26, 45, 16, 0.20) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__placeholder--form {
    background:
      radial-gradient(circle at 50% 44%, rgba(255,255,255,0.72), transparent 36%),
      linear-gradient(180deg, #F7F1E6 0%, #F0EBE0 100%) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__raft {
    width: 66% !important;
    height: 42% !important;
    border-radius: 999px !important;

    position: relative !important;
    overflow: hidden !important;

    background: rgba(208, 151, 42, 0.24) !important;
    border: 1px solid rgba(26, 45, 16, 0.10) !important;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.32) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__raft span {
    position: absolute !important;
    left: 8% !important;
    right: 8% !important;
    top: 18% !important;
    height: 22% !important;
    border-radius: 999px !important;
    background: rgba(250, 250, 248, 0.86) !important;
    box-shadow: 0 8px 18px rgba(255,255,255,0.24) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__placeholder--night {
    background:
      radial-gradient(circle at 64% 28%, rgba(208, 74, 42, 0.10), transparent 28%),
      radial-gradient(circle at 30% 22%, rgba(61, 107, 140, 0.16), transparent 32%),
      linear-gradient(180deg, #F8F5ED 0%, #EEE9DF 100%) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__moon {
    position: absolute !important;
    top: 24% !important;
    right: 26% !important;
    width: 88px !important;
    height: 88px !important;
    border-radius: 999px !important;
    background: var(--mellow-forest) !important;
    opacity: 0.96 !important;
    box-shadow: 0 18px 42px rgba(26, 45, 16, 0.12) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__moon::after {
    content: "" !important;
    position: absolute !important;
    top: -6px !important;
    left: 28px !important;
    width: 84px !important;
    height: 94px !important;
    border-radius: 999px !important;
    background: #F2EEE5 !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__soft-card {
    position: absolute !important;
    left: 23% !important;
    bottom: 24% !important;
    width: 46% !important;
    height: 20% !important;
    border-radius: 999px !important;
    background: rgba(61, 107, 140, 0.18) !important;
    box-shadow: 0 14px 36px rgba(61, 107, 140, 0.10) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__content {
    padding: 22px 2px 0 !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__step-title {
    margin: 0 0 10px !important;
    max-width: 420px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(1.38rem, 1.45vw, 1.78rem) !important;
    line-height: 1.05 !important;
    letter-spacing: -0.038em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 52, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__step-text {
    margin: 0 !important;
    max-width: 94% !important;

    color: rgba(26, 45, 16, 0.72) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(0.98rem, 1.02vw, 1.1rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__cta-row {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 100% !important;
    margin-top: clamp(42px, 4.2vw, 64px) !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 11px !important;

    min-height: 54px !important;
    padding: 0 38px !important;
    border-radius: 999px !important;

    background: var(--mellow-orange) !important;
    color: #FFFFFF !important;
    text-decoration: none !important;

    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    letter-spacing: -0.01em !important;
    font-weight: 800 !important;

    border: 1px solid var(--mellow-orange) !important;
    box-shadow:
      0 16px 34px rgba(208, 74, 42, 0.22),
      0 0 0 0 rgba(208, 74, 42, 0) !important;

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease !important;
  }

  #mellow-routine-{{ section.id }} .mellow-routine__button:hover {
    transform: translateY(-2px) !important;
    background: #BC4425 !important;
    border-color: #BC4425 !important;
    color: #FFFFFF !important;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.28),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
  }

  @media screen and (min-width: 1500px) {
    #mellow-routine-{{ section.id }} {
      --routine-axis-pad: clamp(132px, 8.6vw, 172px);
      padding-top: 112px !important;
      padding-bottom: 112px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__header {
      margin-bottom: 52px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__header-copy {
      max-width: 980px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__heading {
      max-width: 940px !important;
      font-size: clamp(3.45rem, 3.85vw, 5.55rem) !important;
      line-height: 0.96 !important;
      letter-spacing: -0.035em !important;
      font-weight: 650 !important;
      font-variation-settings: normal !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__subheading {
      max-width: 720px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__media {
      aspect-ratio: 1.18 / 1 !important;
      min-height: 460px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__step-title {
      font-size: 1.82rem !important;
      line-height: 1.04 !important;
    }
  }

  @media screen and (max-width: 1180px) {
    #mellow-routine-{{ section.id }} {
      --routine-axis-pad: 32px;
      padding-top: 68px !important;
      padding-bottom: 74px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__header {
      grid-template-columns: 1fr !important;
      gap: 22px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__header-action {
      justify-content: flex-start !important;
      padding-top: 0 !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__heading {
      max-width: 800px !important;
      font-size: clamp(2.75rem, 7.1vw, 4.45rem) !important;
      line-height: 0.98 !important;
      letter-spacing: -0.035em !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__subheading {
      max-width: 680px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__cards {
      grid-template-columns: 1fr !important;
      gap: 28px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__media {
      aspect-ratio: 1.55 / 1 !important;
      min-height: 390px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__pouch {
      width: 24% !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__step-text {
      max-width: 720px !important;
    }
  }

  @media screen and (max-width: 768px) {
    #mellow-routine-{{ section.id }} {
      --routine-axis-pad: 20px;
      padding-top: 58px !important;
      padding-bottom: 64px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__header {
      margin-bottom: 30px !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__eyebrow {
      margin-bottom: 14px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.115em !important;
    }

    #mellow-routine-{{ section.id }} .mellow-routine__heading {
      font-size: clamp(2.25rem, 9.4vw, 3.38rem) !important;
      line-height: 1 !important;
      letter-spacing: -0.034em !important;
      font-weight: 650 !important;
      font-variation-settings: normal !important;
