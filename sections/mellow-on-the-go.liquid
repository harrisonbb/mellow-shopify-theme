{% comment %}
  Mellow — On The Go Lifestyle Section
  Rounded-card version
  Updated:
  - Main section background changed to #FBFCF7
  - Removed bullet list for cleaner lifestyle-focused section
  - Right image grid uses rounded premium cards
  - Matches ingredient-card softness
  - Removed text overlays on top of images
  - Removed heavy caption gradient overlay so images speak for themselves
  - Compressed viewport-fit layout
  - Typography matched to Mellow Hero system:
    Fraunces 550 headings, tighter premium spacing, DM Sans body rhythm
{% endcomment %}

<section
  class="mellow-otg mellow-otg-{{ section.id }}"
  id="mellow-on-the-go-{{ section.id }}"
>
  <div class="mellow-otg__inner">

    <div class="mellow-otg__copy-panel">
      <div class="mellow-otg__copy">

        {% if section.settings.eyebrow != blank %}
          <span class="mellow-otg__eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="mellow-otg__headline">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="mellow-otg__subhead">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a class="mellow-otg__button" href="{{ section.settings.button_link }}">
            <span>{{ section.settings.button_label }}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h13"></path>
              <path d="M13 6l6 6-6 6"></path>
            </svg>
          </a>
        {% endif %}

        {% if section.settings.note != blank %}
          <p class="mellow-otg__note">
            {{ section.settings.note }}
          </p>
        {% endif %}

      </div>
    </div>

    <div class="mellow-otg__image-panel">
      <div class="mellow-otg__image-grid" aria-label="Mellow lifestyle images">

        <figure class="mellow-otg__image-card">
          {% if section.settings.image_1 != blank %}
            <img
              src="{{ section.settings.image_1 | image_url: width: 1100 }}"
              alt="{{ section.settings.image_1.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_1.width }}"
              height="{{ section.settings.image_1.height }}"
            >
          {% else %}
            <div class="mellow-otg__placeholder mellow-otg__placeholder--bag"></div>
          {% endif %}
        </figure>

        <figure class="mellow-otg__image-card">
          {% if section.settings.image_2 != blank %}
            <img
              src="{{ section.settings.image_2 | image_url: width: 1100 }}"
              alt="{{ section.settings.image_2.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_2.width }}"
              height="{{ section.settings.image_2.height }}"
            >
          {% else %}
            <div class="mellow-otg__placeholder mellow-otg__placeholder--desk"></div>
          {% endif %}
        </figure>

        <figure class="mellow-otg__image-card">
          {% if section.settings.image_3 != blank %}
            <img
              src="{{ section.settings.image_3 | image_url: width: 1100 }}"
              alt="{{ section.settings.image_3.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_3.width }}"
              height="{{ section.settings.image_3.height }}"
            >
          {% else %}
            <div class="mellow-otg__placeholder mellow-otg__placeholder--restaurant"></div>
          {% endif %}
        </figure>

        <figure class="mellow-otg__image-card">
          {% if section.settings.image_4 != blank %}
            <img
              src="{{ section.settings.image_4 | image_url: width: 1100 }}"
              alt="{{ section.settings.image_4.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.image_4.width }}"
              height="{{ section.settings.image_4.height }}"
            >
          {% else %}
            <div class="mellow-otg__placeholder mellow-otg__placeholder--travel"></div>
          {% endif %}
        </figure>

      </div>
    </div>

  </div>
</section>

<style>
  /* =========================================================
     MELLOW — ON THE GO LIFESTYLE SECTION
     ROUNDED CARD VERSION — NO BULLETS / NO IMAGE TEXT OVERLAYS
     BACKGROUND: #FBFCF7
     Typography aligned with Mellow Hero system
     ========================================================= */

  #shopify-section-{{ section.id }},
  #shopify-section-{{ section.id }} > *,
  #shopify-section-{{ section.id }} .page-width,
  #shopify-section-{{ section.id }} .mellow-section,
  #shopify-section-{{ section.id }} .mellow-container {
    max-width: none !important;
    width: 100% !important;
    margin-left: 0 !important;
    margin-right: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  #shopify-section-{{ section.id }} {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: visible !important;
  }

  #shopify-section-{{ section.id }} > * {
    background: transparent !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg {
    --mellow-page: #FBFCF7;
    --mellow-panel: #FBFCF7;
    --mellow-ivory: #F0EBE0;
    --mellow-forest: #1A2D10;
    --mellow-green: #123A24;
    --mellow-green-deep: #0B1E08;
    --mellow-orange: #D04A2A;
    --mellow-blue: #3D6B8C;

    --font-heading: 'Fraunces', Georgia, serif;
    --font-body: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

    width: 100% !important;
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    color: var(--mellow-forest) !important;
    padding: 0 !important;
    overflow: hidden !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg,
  #shopify-section-{{ section.id }} .mellow-otg * {
    box-sizing: border-box !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__inner {
    width: 100% !important;
    max-width: none !important;
    margin: 0 auto !important;

    display: grid !important;
    grid-template-columns: 48% 52% !important;

    height: calc(100vh - 96px) !important;
    min-height: 620px !important;
    max-height: 760px !important;

    border-radius: 0 !important;
    overflow: hidden !important;

    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    border: 0 !important;
    box-shadow: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__copy-panel {
    display: flex !important;
    align-items: center !important;

    padding: 34px 64px 34px 96px !important;

    background:
      radial-gradient(circle at 10% 12%, rgba(255, 255, 255, 0.72), transparent 36%),
      linear-gradient(180deg, #FBFCF7 0%, #FBFCF7 100%) !important;
    background-color: #FBFCF7 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__copy {
    width: 100% !important;
    max-width: 590px !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__eyebrow {
    display: block !important;
    margin: 0 0 14px !important;

    color: var(--mellow-orange) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__headline {
    margin: 0 !important;
    max-width: 590px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-wrap: balance !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__subhead {
    margin: 20px 0 0 !important;
    max-width: 540px !important;

    color: rgba(26, 45, 16, 0.82) !important;
    font-family: var(--font-body) !important;
    font-size: clamp(1rem, 1.18vw, 1.18rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.015em !important;
    font-weight: 500 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 12px !important;

    width: min(100%, 520px) !important;
    min-height: 54px !important;
    margin-top: 30px !important;
    padding: 0 34px !important;
    border-radius: 999px !important;

    background: var(--mellow-forest) !important;
    color: #FFFFFF !important;
    text-decoration: none !important;

    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    letter-spacing: -0.01em !important;
    font-weight: 800 !important;

    border: 1px solid rgba(26, 45, 16, 0.98) !important;
    box-shadow:
      0 16px 34px rgba(26, 45, 16, 0.18),
      0 0 0 0 rgba(208, 74, 42, 0) !important;

    transition:
      transform 220ms ease,
      background 220ms ease,
      border-color 220ms ease,
      color 220ms ease,
      box-shadow 220ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__button:hover {
    transform: translateY(-2px) !important;
    background: var(--mellow-orange) !important;
    border-color: var(--mellow-orange) !important;
    color: #FFFFFF !important;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.24),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__button svg {
    width: 20px !important;
    height: 20px !important;
    fill: none !important;
    stroke: currentColor !important;
    stroke-width: 2 !important;
    stroke-linecap: round !important;
    stroke-linejoin: round !important;
    transition: transform 220ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__button:hover svg {
    transform: translateX(4px) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__note {
    display: none !important;
  }

  /* =========================================================
     ROUNDED IMAGE CARD PANEL
     ========================================================= */

  #shopify-section-{{ section.id }} .mellow-otg__image-panel {
    height: 100% !important;
    min-height: 0 !important;

    padding: 22px 28px 22px 0 !important;

    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-grid {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    grid-template-rows: repeat(2, minmax(0, 1fr)) !important;
    gap: 18px !important;

    height: 100% !important;
    min-height: 0 !important;

    background: transparent !important;
    padding: 0 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card {
    position: relative !important;
    margin: 0 !important;
    min-height: 0 !important;
    height: 100% !important;
    overflow: hidden !important;

    border-radius: 26px !important;
    background: #F0EBE0 !important;
    border: 1px solid rgba(26, 45, 16, 0.12) !important;

    box-shadow:
      0 18px 42px rgba(8, 16, 5, 0.11),
      inset 0 1px 0 rgba(255, 255, 255, 0.55) !important;

    isolation: isolate !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card img {
    display: block !important;
    width: 100% !important;
    height: 100% !important;

    object-fit: cover !important;
    object-position: center !important;

    transform: scale(1.01) !important;
    transition:
      transform 480ms ease,
      filter 480ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card:hover img {
    transform: scale(1.045) !important;
    filter: saturate(1.03) contrast(1.02) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card::before {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    z-index: 1 !important;
    pointer-events: none !important;

    background:
      radial-gradient(circle at 50% 8%, rgba(255,255,255,0.16), transparent 38%),
      linear-gradient(180deg, rgba(255,255,255,0.02) 0%, rgba(8,16,5,0.04) 100%) !important;
    opacity: 0.72 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card::after {
    content: "" !important;
    position: absolute !important;
    inset: 0 !important;
    z-index: 2 !important;
    pointer-events: none !important;
    border-radius: inherit !important;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.26) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__image-card figcaption {
    display: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder {
    width: 100% !important;
    height: 100% !important;
    min-height: 0 !important;

    display: block !important;

    color: transparent !important;
    font-size: 0 !important;
    line-height: 0 !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder span {
    display: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder--bag {
    background:
      radial-gradient(circle at 60% 35%, rgba(240,235,224,0.28), transparent 28%),
      linear-gradient(135deg, #1A2D10, #3D6B8C) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder--desk {
    background:
      radial-gradient(circle at 42% 38%, rgba(240,235,224,0.30), transparent 30%),
      linear-gradient(135deg, #223A18, #D04A2A) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder--restaurant {
    background:
      radial-gradient(circle at 50% 30%, rgba(240,235,224,0.32), transparent 30%),
      linear-gradient(135deg, #7D4A28, #1A2D10) !important;
  }

  #shopify-section-{{ section.id }} .mellow-otg__placeholder--travel {
    background:
      radial-gradient(circle at 50% 35%, rgba(240,235,224,0.30), transparent 30%),
      linear-gradient(135deg, #3D6B8C, #10280C) !important;
  }

  @media screen and (min-width: 1500px) {
    #shopify-section-{{ section.id }} .mellow-otg__copy-panel {
      padding-left: 112px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__copy {
      max-width: 640px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__headline {
      max-width: 640px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__subhead {
      max-width: 570px !important;
    }
  }

  @media screen and (max-width: 1180px) {
    #shopify-section-{{ section.id }} .mellow-otg__inner {
      height: auto !important;
      min-height: auto !important;
      max-height: none !important;
      grid-template-columns: 1fr !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__copy-panel {
      padding: 52px 32px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__copy {
      max-width: 760px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__headline {
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__subhead {
      max-width: 680px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-panel {
      height: auto !important;
      padding: 0 32px 32px !important;
      background: #FBFCF7 !important;
      background-color: #FBFCF7 !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-grid {
      height: auto !important;
      gap: 16px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-card {
      min-height: 260px !important;
    }
  }

  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .mellow-otg__copy-panel {
      padding: 42px 22px 36px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__eyebrow {
      margin-bottom: 14px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.115em !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__headline {
      font-size: clamp(2.35rem, 10vw, 3.55rem) !important;
      line-height: 1.05 !important;
      letter-spacing: -0.03em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 48, "wght" 550 !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__subhead {
      margin-top: 18px !important;
      font-size: 0.98rem !important;
      line-height: 1.55 !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__button {
      width: 100% !important;
      min-height: 52px !important;
      margin-top: 26px !important;
      padding: 0 28px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-panel {
      padding: 0 20px 28px !important;
      background: #FBFCF7 !important;
      background-color: #FBFCF7 !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-grid {
      grid-template-columns: 1fr !important;
      gap: 14px !important;
    }

    #shopify-section-{{ section.id }} .mellow-otg__image-card {
      min-height: 240px !important;
      border-radius: 22px !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .mellow-otg__button,
    #shopify-section-{{ section.id }} .mellow-otg__button svg,
    #shopify-section-{{ section.id }} .mellow-otg__image-card img {
      transition: none !important;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow On The Go",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHEREVER YOU ARE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "You've got enough to think about. Let us handle the rest."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Mellow goes where reflux usually shows up — dinner, work, travel, and the nights you already know might go sideways."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "textarea",
      "id": "note",
      "label": "Small note",
      "default": "After meals. Before bed. Wherever reflux happens."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1 — Mellow in bag"
    },
    {
      "type": "text",
      "id": "caption_1",
      "label": "Caption 1",
      "default": "In your bag before dinner"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2 — Mellow at desk"
    },
    {
      "type": "text",
      "id": "caption_2",
      "label": "Caption 2",
      "default": "At your desk when the day runs long"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3 — Mellow restaurant"
    },
    {
      "type": "text",
      "id": "caption_3",
      "label": "Caption 3",
      "default": "After the meal, before the burn"
    },
    {
      "type": "image_picker",
      "id": "image_4",
      "label": "Image 4 — Mellow travel"
    },
    {
      "type": "text",
      "id": "caption_4",
      "label": "Caption 4",
      "default": "Ready for travel, late nights, and plans"
    },
    {
      "type": "range",
      "id": "caption_overlay_opacity",
      "label": "Caption overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 75
    }
  ],
  "presets": [
    {
      "name": "Mellow On The Go"
    }
  ]
}
{% endschema %}