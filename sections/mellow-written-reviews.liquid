{% comment %}
  Mellow written reviews section.
  Locally matched to the homepage rail, type, and carousel card system.
{% endcomment %}

<style>
  #MellowWrittenReviews-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: clip;
    overflow-y: visible;
    padding-top: clamp(56px, 5vw, 84px);
    padding-bottom: clamp(56px, 5vw, 84px);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-ink, var(--mellow-forest, #003302));
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__inner {
    width: min(calc(100% - (var(--mellow-section-axis-pad, 22px) * 2)), var(--mellow-axis-max, 1200px));
    max-width: var(--mellow-axis-max, 1200px);
    margin-left: auto;
    margin-right: auto;
    padding-left: 0;
    padding-right: 0;
    box-sizing: border-box;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(360px, 0.75fr);
    align-items: center;
    gap: clamp(48px, 6vw, 96px);
    margin-bottom: clamp(32px, 3.5vw, 52px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header {
    max-width: var(--mellow-header-max, 760px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__eyebrow {
    color: var(--mellow-orange-red, #D04A2A);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__heading,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__text {
    color: var(--mellow-forest, #003302);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 100%;
    padding-left: clamp(36px, 4.5vw, 64px);
    border-left: 1px solid rgba(0, 51, 2, 0.16);
    color: var(--mellow-forest, #003302);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-rating {
    display: flex;
    align-items: center;
    gap: clamp(18px, 2vw, 32px);
    margin: 0 0 clamp(18px, 1.7vw, 24px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-stars,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__stars {
    color: var(--mellow-orange-red, #D04A2A);
    font-size: clamp(20px, 1.9vw, 30px);
    line-height: 1;
    letter-spacing: 0.06em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-score {
    color: var(--mellow-forest, #003302);
    font-size: clamp(24px, 2.1vw, 34px);
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-title {
    margin: 0;
    color: var(--mellow-forest, #003302);
    font-size: clamp(18px, 1.25vw, 22px);
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-copy {
    margin: 12px 0 0;
    max-width: 32ch;
    color: rgba(0, 51, 2, 0.84);
    font-size: clamp(16px, 1.08vw, 18px);
    line-height: 1.45;
    font-weight: 500;
    letter-spacing: -0.006em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__tray {
    position: relative;
    margin: 0;
    padding: clamp(28px, 3vw, 44px);
    overflow: visible;
    border: 1px solid rgba(0, 51, 2, 0.08);
    border-radius: clamp(24px, 2vw, 36px);
    background: rgba(250, 246, 238, 0.82);
    box-shadow: var(--mellow-card-shadow, 0 22px 60px rgba(0, 51, 2, 0.05));
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__scroller {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__scroller::-webkit-scrollbar {
    display: none;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cards {
    display: flex;
    align-items: stretch;
    gap: clamp(20px, 2vw, 32px);
    width: max-content;
    min-width: 100%;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: clamp(270px, 21vw, 330px);
    min-height: clamp(300px, 27vw, 380px);
    padding: clamp(24px, 2.4vw, 34px);
    overflow: hidden;
    background: var(--mellow-card-cream, #F8F4EC);
    border: 1px solid rgba(0, 51, 2, 0.10);
    border-radius: clamp(18px, 1.5vw, 26px);
    box-shadow: 0 16px 42px rgba(0, 51, 2, 0.07);
    color: var(--mellow-forest, #003302);
    scroll-snap-align: start;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__stars {
    margin: 0 0 clamp(26px, 2.2vw, 34px);
    font-size: clamp(20px, 1.55vw, 25px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__star-muted {
    color: rgba(0, 51, 2, 0.12);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__quote {
    max-width: 28ch;
    margin: 0;
    color: rgba(0, 51, 2, 0.9);
    font-size: clamp(16px, 1.05vw, 18px);
    line-height: 1.55;
    font-weight: 500;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__person {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: clamp(22px, 2vw, 30px);
    border-top: 1px solid rgba(0, 51, 2, 0.14);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    flex: 0 0 54px;
    border: 1px solid rgba(18, 51, 8, 0.56);
    border-radius: 999px;
    background: rgba(252, 251, 247, 0.72);
    color: var(--mellow-forest, #003302);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__name {
    margin: 0;
    color: var(--mellow-forest, #003302);
    font-size: 17px;
    line-height: 1.2;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__meta {
    margin: 6px 0 0;
    color: rgba(0, 51, 2, 0.72);
    font-size: clamp(12.5px, 0.9vw, 14px);
    line-height: 1.42;
    font-weight: 560;
    letter-spacing: -0.004em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(44px, 3.4vw, 56px);
    height: clamp(44px, 3.4vw, 56px);
    padding: 0;
    border: 1px solid rgba(0, 51, 2, 0.08);
    border-radius: 999px;
    background: var(--mellow-cream, #FCFBF7);
    box-shadow: 0 14px 30px rgba(0, 51, 2, 0.12);
    color: var(--mellow-forest, #003302);
    cursor: pointer;
    transform: translateY(-50%);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow:hover {
    box-shadow: 0 18px 38px rgba(0, 51, 2, 0.16);
    transform: translateY(-50%) scale(1.03);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow--prev {
    left: calc(clamp(22px, 3vw, 44px) * -1);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow--next {
    right: calc(clamp(22px, 3vw, 44px) * -1);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow svg {
    width: 48%;
    height: 48%;
    stroke: currentColor;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__footer {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: clamp(22px, 2.2vw, 34px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px clamp(18px, 2.4vw, 34px);
    margin: clamp(22px, 2.2vw, 32px) auto 0;
    color: var(--mellow-forest, #003302);
    font-size: clamp(13px, 0.96vw, 15px);
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.005em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust-item + .mellow-written-reviews__trust-item::before {
    content: "";
    display: block;
    width: 4px;
    height: 4px;
    margin-right: clamp(6px, 0.7vw, 12px);
    border-radius: 999px;
    background: currentColor;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust svg {
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
    stroke: currentColor;
  }

  @media screen and (min-width: 1440px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      width: calc((100vw - (2 * var(--mellow-section-axis-pad, 64px)) - (2 * clamp(28px, 3vw, 44px)) - (3 * clamp(20px, 2vw, 32px))) / 4);
      max-width: 330px;
    }
  }

  @media screen and (max-width: 989px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
      grid-template-columns: minmax(0, 1fr);
      gap: clamp(22px, 4vw, 34px);
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
      min-height: 0;
      padding: clamp(20px, 3vw, 28px) 0 0;
      border-top: 1px solid rgba(0, 51, 2, 0.14);
      border-left: 0;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__arrow {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWrittenReviews-{{ section.id }} {
      overflow-x: hidden;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
      display: block;
      margin-bottom: var(--mellow-section-content-gap-compact);
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__heading {
      font-size: clamp(40px, 11vw, 56px);
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
      margin-top: 22px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-rating {
      gap: 16px;
      margin-bottom: 16px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-stars {
      font-size: 20px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-score {
      font-size: 24px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__tray {
      margin-right: calc(var(--mellow-section-axis-pad, 28px) * -1);
      margin-left: calc(var(--mellow-section-axis-pad, 28px) * -1);
      padding: 20px var(--mellow-section-axis-pad, 28px);
      border-radius: 24px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      width: min(82vw, 318px);
      min-height: 300px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust {
      gap: 12px 18px;
      max-width: 320px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__trust-item + .mellow-written-reviews__trust-item::before {
      display: none;
    }
  }
</style>

<section
