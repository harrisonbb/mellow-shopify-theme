<script>
  (() => {
    const section = document.getElementById('MellowWrittenReviews-{{ section.id }}');
    if (!section) return;

    const scroller = section.querySelector('[data-mellow-reviews-scroller]');
    const prev = section.querySelector('[data-mellow-reviews-prev]');
    const next = section.querySelector('[data-mellow-reviews-next]');
    if (!scroller || !prev || !next) return;

    const getStep = () => {
      const card = scroller.querySelector('.mellow-written-reviews__card');
      const cards = scroller.querySelector('.mellow-written-reviews__cards');
      const styles = cards ? window.getComputedStyle(cards) : null;
      return card ? card.getBoundingClientRect().width + parseFloat((styles && (styles.columnGap || styles.gap)) || 24) : 320;
    };

    prev.addEventListener('click', () => scroller.scrollBy({ left: -getStep(), behavior: 'smooth' }));
    next.addEventListener('click', () => scroller.scrollBy({ left: getStep(), behavior: 'smooth' }));
  })();
</script>

{% schema %}
{
  "name": "Mellow written reviews",
  "tag": "section",
  "class": "section section-mellow-written-reviews",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Mellow written reviews"
    }
  ]
}
{% endschema %}
