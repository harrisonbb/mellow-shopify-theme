{% comment %}
  Mellow written reviews section.
  Locally matched to the Who It’s For section axis and spacing.
{% endcomment %}

<style>
  #MellowWrittenReviews-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: clamp(52px, 4.7vw, 76px);
    padding-bottom: clamp(46px, 4.2vw, 66px);
    background: var(--mellow-cream, #FCFBF7);
    color: var(--mellow-ink, var(--mellow-forest, #003302));
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    padding-left: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    padding-right: var(--mellow-section-axis-pad, clamp(28px, 4vw, 64px));
    box-sizing: border-box;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 760px) auto;
    align-items: center;
    gap: clamp(40px, 6vw, 96px);
    margin-bottom: clamp(30px, 2.6vw, 44px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header {
    max-width: var(--mellow-header-max, 760px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__eyebrow {
    color: #D04A2A;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__heading {
    color: var(--mellow-forest, #003302);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__text {
    color: rgba(0, 51, 2, 0.72);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 9px 14px;
    margin-top: clamp(18px, 1.6vw, 24px);
    color: rgba(0, 51, 2, 0.72);
    font-size: clamp(13px, 0.9vw, 15px);
    line-height: 1.35;
    font-weight: 650;
    letter-spacing: -0.004em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-stars {
    color: #D04A2A;
    font-size: 13px;
    line-height: 1;
    letter-spacing: 0.06em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(24px, 2.2vw, 36px);
    align-items: stretch;
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: clamp(238px, 18vw, 286px);
    padding: clamp(26px, 2.35vw, 36px);
    overflow: hidden;
    background: var(--mellow-card-cream, #F8F4EC);
    border: 1px solid rgba(0, 51, 2, 0.14);
    border-radius: var(--mellow-radius-card);
    box-shadow: 0 18px 48px rgba(0, 51, 2, 0.055);
    color: var(--mellow-forest, #003302);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card::before {
    content: "“";
    position: absolute;
    top: 22px;
    right: clamp(22px, 2vw, 32px);
    color: rgba(208, 74, 42, 0.16);
    font-family: Georgia, serif;
    font-size: clamp(58px, 5vw, 78px);
    font-weight: 700;
    line-height: 0.7;
    pointer-events: none;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__stars {
    position: relative;
    z-index: 1;
    margin: 0 0 16px;
    color: #D04A2A;
    font-size: 15px;
    line-height: 1;
    letter-spacing: 0.06em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__quote {
    position: relative;
    z-index: 1;
    color: rgba(0, 51, 2, 0.9);
    max-width: 42ch;
    font-size: clamp(16.5px, 1.08vw, 18px);
    line-height: 1.5;
    font-weight: 450;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__person {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid rgba(0, 51, 2, 0.12);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex: 0 0 46px;
    border-radius: 999px;
    background: var(--mellow-forest, #003302);
    color: #FCFBF7;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__name {
    margin: 0;
    color: var(--mellow-forest, #003302);
    font-size: 16px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__meta {
    margin: 5px 0 0;
    color: rgba(0, 51, 2, 0.68);
    font-size: 14px;
    line-height: 1.35;
    font-weight: 560;
    letter-spacing: -0.004em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__footer {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: clamp(22px, 2.2vw, 34px);
  }

  @media screen and (max-width: 989px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cards {
      grid-template-columns: 1fr;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      min-height: auto;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
      display: block;
      margin-bottom: var(--mellow-section-content-gap-compact);
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
      margin-top: 18px;
    }
  }
</style>

<section
  id="MellowWrittenReviews-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-written-reviews color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-written-reviews__inner">
    <div class="mellow-section-header-grid mellow-written-reviews__header-wrap">
      <div class="mellow-section-header mellow-written-reviews__header">
        <p class="mellow-eyebrow mellow-written-reviews__eyebrow">REAL MOMENTS. REAL RELIEF.</p>

        <h2 class="mellow-section-heading mellow-written-reviews__heading">
          In their own words.
        </h2>

        <p class="mellow-section-text mellow-written-reviews__text">After dinner. Before sleep. When it matters most.</p>

        <div class="mellow-written-reviews__proof" aria-label="Review proof">
          <span class="mellow-written-reviews__proof-stars" aria-hidden="true">★★★★★</span>
          <span class="mellow-written-reviews__proof-copy">Verified Mellow buyers sharing after-meal, before-bed, and daily routine notes.</span>
        </div>
      </div>
    </div>

    <div class="mellow-written-reviews__cards">
      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “I stopped planning dinner around what might punish me later. One pouch after eating felt like I had a little more control.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">RB</span>
          <div>
            <p class="mellow-written-reviews__name">Rachel B.</p>
            <p class="mellow-written-reviews__meta">Verified buyer • Purchased Mellow • After-meal reflux</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “I wanted something that fit into my routine without making reflux feel like a whole project. Mellow made the after-dinner part easier.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">MT</span>
          <div>
            <p class="mellow-written-reviews__name">Michael T.</p>
            <p class="mellow-written-reviews__meta">Verified buyer • Purchased Mellow • Non-PPI support</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “Before bed used to come with a little mental math. This felt simple enough to keep on my nightstand and actually use.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">PN</span>
          <div>
            <p class="mellow-written-reviews__name">Priya N.</p>
            <p class="mellow-written-reviews__meta">Verified buyer • Purchased Mellow • Nighttime routine</p>
          </div>
        </div>
      </article>
    </div>

    <div class="mellow-written-reviews__footer">
      <a class="mellow-section-cta mellow-section-cta--primary-forest mellow-written-reviews__cta" href="/products/mellow-reflux-relief-gel">
        <span class="mellow-section-cta__label mellow-written-reviews__cta-label">Try Mellow</span>
        <span class="mellow-section-cta__arrow mellow-written-reviews__cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow written reviews",
  "tag": "section",
  "class": "section section-mellow-written-reviews",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Mellow written reviews"
    }
  ]
}
{% endschema %}
