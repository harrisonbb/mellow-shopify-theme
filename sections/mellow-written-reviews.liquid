{% comment %}
  Mellow written reviews section.
  Locally matched to the Who It’s For section axis and spacing.
{% endcomment %}

<style>
  #MellowWrittenReviews-{{ section.id }} {
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: var(--mellow-section-pad-top, clamp(64px, 5.5vw, 92px));
    padding-bottom: var(--mellow-section-pad-bottom, clamp(52px, 5vw, 76px));
    background:
      radial-gradient(circle at 78% 18%, rgba(208, 74, 42, 0.1), transparent 34%),
      radial-gradient(circle at 22% 72%, rgba(61, 107, 140, 0.08), transparent 36%),
      #14310F;
    color: #F0EBE0;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__inner {
    width: 100%;
    max-width: none;
    margin: 0;
    --mellow-reviews-edge-pad: clamp(84px, 6.5vw, 100px);
    padding-left: var(--mellow-reviews-edge-pad);
    padding-right: var(--mellow-reviews-edge-pad);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
    display: grid;
    grid-template-columns: minmax(0, 760px) auto;
    align-items: center;
    gap: clamp(40px, 6vw, 96px);
    margin-bottom: clamp(22px, 2.6vw, 36px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header {
    max-width: var(--mellow-header-max, 760px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__eyebrow {
    color: #D04A2A;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__heading {
    color: #F0EBE0;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__text {
    color: rgba(240, 235, 224, 0.78);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--mellow-card-gap, clamp(28px, 2.6vw, 42px));
    align-items: stretch;
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
    display: flex;
    flex-direction: column;
    min-height: clamp(280px, 22vw, 340px);
    padding: clamp(28px, 2.5vw, 42px);
    background: #F4EDE0;
    border: 1px solid rgba(180, 130, 72, 0.22);
    border-radius: 24px;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.16);
    color: #14310F;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__stars {
    margin: 0 0 22px;
    color: #D04A2A;
    font-size: 17px;
    line-height: 1;
    letter-spacing: 0.08em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__quote {
    color: rgba(20, 49, 15, 0.9);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__person {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: 28px;
    border-top: 1px solid rgba(20, 49, 15, 0.12);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    flex: 0 0 46px;
    border-radius: 999px;
    background: #14310F;
    color: #F0EBE0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__name {
    margin: 0;
    color: #14310F;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__meta {
    margin: 5px 0 0;
    color: rgba(20, 49, 15, 0.58);
    font-size: 14px;
    line-height: 1.25;
    font-weight: 500;
    letter-spacing: -0.004em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__footer {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: clamp(28px, 3.4vw, 50px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    overflow: hidden;
    position: relative;
    white-space: nowrap;
    transform: translateZ(0);
    backface-visibility: hidden;
    width: clamp(150px, 10.4vw, 178px);
    min-height: clamp(52px, 4.05vw, 62px);
    padding: clamp(15px, 1.18vw, 18px) clamp(18px, 1.45vw, 25px);
    border-radius: 999px;
    background: #D04A2A;
    color: #F0EBE0;
    font-size: clamp(16px, 1.08vw, 18px);
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    transform-origin: center center;
    transition:
      width 520ms cubic-bezier(0.16, 1, 0.3, 1),
      background-color 260ms ease,
      color 260ms ease;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta::before,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta::after {
    content: none !important;
    display: none !important;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-label {
    display: inline-block;
    text-align: center;
    transform: translate3d(0, 0, 0);
    transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-arrow {
    position: absolute;
    right: clamp(19px, 1.45vw, 26px);
    top: 50%;
    display: inline-block;
    opacity: 0;
    pointer-events: none;
    transform: translate3d(-12px, -50%, 0);
    transition:
      transform 520ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 260ms ease;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:hover,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:focus-visible {
    width: clamp(184px, 12.8vw, 218px);
    background: #D04A2A;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:hover .mellow-written-reviews__cta-arrow,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:focus-visible .mellow-written-reviews__cta-arrow {
    transform: translate3d(0, -50%, 0);
    opacity: 1;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:hover .mellow-written-reviews__cta-label,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:focus-visible .mellow-written-reviews__cta-label {
    transform: translate3d(-8px, 0, 0);
  }

  @media (prefers-reduced-motion: reduce) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta,
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-label,
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-arrow {
      transition: none;
    }
  }

  @media screen and (max-width: 989px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cards {
      grid-template-columns: 1fr;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      min-height: auto;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__inner {
      --mellow-reviews-edge-pad: 22px;
      padding-left: var(--mellow-reviews-edge-pad);
      padding-right: var(--mellow-reviews-edge-pad);
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-wrap {
      display: block;
    }


    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      padding: 28px;
      border-radius: 22px;
    }
  }
</style>

<section
  id="MellowWrittenReviews-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-written-reviews color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-written-reviews__inner">
    <div class="mellow-section-header-grid mellow-written-reviews__header-wrap">
      <div class="mellow-section-header mellow-written-reviews__header">
        <p class="mellow-eyebrow mellow-written-reviews__eyebrow">REAL MOMENTS. REAL RELIEF.</p>

        <h2 class="mellow-section-heading mellow-written-reviews__heading">
          Over 50,000 Satisfied<br>
          Customers and Counting
        </h2>

        <p class="mellow-section-text mellow-written-reviews__text">After dinner. Before sleep. When it matters most.</p>
      </div>
    </div>

    <div class="mellow-written-reviews__cards">
      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “I used to take tablets after reflux had already started. Mellow feels more like I’m getting ahead of it.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">RB</span>
          <div>
            <p class="mellow-written-reviews__name">Rachel B.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · After-meal reflux</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “I was trying to be more thoughtful about PPIs. Mellow felt like an easy option for nights when I wanted support after dinner.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">MT</span>
          <div>
            <p class="mellow-written-reviews__name">Michael T.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · Non-PPI support</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <div class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</div>
        <p class="mellow-card-copy mellow-written-reviews__quote">
          “It feels easy enough to stick with: one pouch after dinner, no measuring, and no big bottle on my nightstand.”
        </p>

        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">PN</span>
          <div>
            <p class="mellow-written-reviews__name">Priya N.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · Nighttime routine</p>
          </div>
        </div>
      </article>
    </div>

    <div class="mellow-written-reviews__footer">
      <a class="mellow-written-reviews__cta" href="/products/mellow">
        <span class="mellow-written-reviews__cta-label">Try Mellow</span>
        <span class="mellow-written-reviews__cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow written reviews",
  "tag": "section",
  "class": "section section-mellow-written-reviews",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Mellow written reviews"
    }
  ]
}
{% endschema %}