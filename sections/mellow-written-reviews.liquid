{% comment %}
  Mellow written reviews section.
  Premium testimonial proof using the locked global Mellow design system.
{% endcomment %}

<style>
  #MellowWrittenReviews-{{ section.id }} {
    position: relative;
    padding-top: var(--mellow-section-pad-top);
    padding-bottom: var(--mellow-section-pad-bottom);
    color: var(--mellow-ivory);
    background:
      radial-gradient(circle at 82% 8%, rgba(240, 235, 224, 0.1), transparent 28rem),
      radial-gradient(circle at 12% 100%, rgba(208, 74, 42, 0.12), transparent 34rem),
      var(--mellow-green);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__header-grid {
    grid-template-columns: minmax(0, var(--mellow-header-max));
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-section-heading,
  #MellowWrittenReviews-{{ section.id }} .mellow-section-text {
    color: var(--mellow-ivory);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-section-text {
    opacity: 0.82;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--mellow-card-gap);
    align-items: stretch;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: clamp(30px, 3vw, 42px);
    color: var(--mellow-ink);
    background: #f4ede0;
    border: 1px solid rgba(180, 130, 72, 0.24);
    border-radius: 24px;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.18);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__stars {
    margin: 0 0 22px;
    color: var(--mellow-orange-red);
    font-size: 15px;
    line-height: 1;
    letter-spacing: 0.12em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__quote {
    margin: 0;
    color: var(--mellow-ink);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__person {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: auto;
    padding-top: clamp(28px, 3vw, 40px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 46px;
    width: 46px;
    height: 46px;
    color: var(--mellow-ivory);
    background: var(--mellow-green);
    border-radius: 50%;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__name {
    margin: 0;
    color: var(--mellow-ink);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__meta {
    margin: 4px 0 0;
    color: rgba(20, 33, 17, 0.64);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-row {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: clamp(34px, 4vw, 54px);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-wrap {
    justify-content: flex-start;
    width: var(--mellow-cta-hover-width);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta {
    color: var(--mellow-ivory);
    background: var(--mellow-orange-red);
    border: 1px solid var(--mellow-orange-red);
    transform-origin: left center;
    text-decoration: none;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:hover,
  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta:focus-visible {
    color: var(--mellow-ivory);
    background: var(--mellow-orange-red);
    border-color: var(--mellow-orange-red);
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: clamp(28px, 3.4vw, 46px) 0 0;
    color: rgba(240, 235, 224, 0.72);
    font-size: clamp(14px, 1vw, 16px);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }

  #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof-stars {
    color: var(--mellow-orange-red);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  @media screen and (max-width: 989px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__grid {
      grid-template-columns: 1fr;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__card {
      min-height: 0;
    }
  }

  @media screen and (max-width: 749px) {
    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-row {
      justify-content: center;
      margin-top: 30px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__cta-wrap {
      width: 224px;
    }

    #MellowWrittenReviews-{{ section.id }} .mellow-written-reviews__proof {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
      margin-top: 28px;
    }
  }
</style>

<section
  id="MellowWrittenReviews-{{ section.id }}"
  class="mellow-section mellow-section-standard mellow-written-reviews color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-section-axis mellow-written-reviews__inner">
    <div class="mellow-section-header-grid mellow-written-reviews__header-grid">
      <div class="mellow-section-header">
        <p class="mellow-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2 class="mellow-section-heading">
          {{ section.settings.heading | escape | newline_to_br }}
        </h2>
        <p class="mellow-section-text">{{ section.settings.text | escape }}</p>
      </div>
    </div>

    <div class="mellow-written-reviews__grid" aria-label="Customer reviews">
      <article class="mellow-written-reviews__card">
        <p class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</p>
        <blockquote class="mellow-card-copy mellow-written-reviews__quote">
          “I used to take tablets after reflux had already started. Mellow feels more like I’m getting ahead of it.”
        </blockquote>
        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">RB</span>
          <div>
            <p class="mellow-written-reviews__name">Rachel B.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · After-meal reflux</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <p class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</p>
        <blockquote class="mellow-card-copy mellow-written-reviews__quote">
          “I was trying to be more thoughtful about PPIs. Mellow felt like an easy option for nights when I wanted support after dinner.”
        </blockquote>
        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">MT</span>
          <div>
            <p class="mellow-written-reviews__name">Michael T.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · Non-PPI support</p>
          </div>
        </div>
      </article>

      <article class="mellow-written-reviews__card">
        <p class="mellow-written-reviews__stars" aria-label="5 out of 5 stars">★★★★★</p>
        <blockquote class="mellow-card-copy mellow-written-reviews__quote">
          “It feels easy enough to stick with: one pouch after dinner, no measuring, and no big bottle on my nightstand.”
        </blockquote>
        <div class="mellow-written-reviews__person">
          <span class="mellow-written-reviews__avatar" aria-hidden="true">PN</span>
          <div>
            <p class="mellow-written-reviews__name">Priya N.</p>
            <p class="mellow-written-reviews__meta">Verified buyer · Nighttime routine</p>
          </div>
        </div>
      </article>
    </div>

    <div class="mellow-written-reviews__cta-row">
      <div class="mellow-section-cta-wrap mellow-written-reviews__cta-wrap">
        <a class="mellow-section-cta mellow-written-reviews__cta" href="{{ section.settings.cta_link }}">
          <span class="mellow-section-cta__label">{{ section.settings.cta_label | escape }}</span>
          <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <p class="mellow-written-reviews__proof">
      <span class="mellow-written-reviews__proof-stars" aria-hidden="true">★★★★★</span>
      <span>Early access reviewers · 4.9 average</span>
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Mellow written reviews",
  "tag": "section",
  "class": "section section-mellow-written-reviews",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL MOMENTS. REAL RELIEF."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Over 50,000 Satisfied\nCustomers and Counting"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Subhead",
      "default": "After dinner. Before sleep. When it matters most."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link",
      "default": "/products/mellow"
    }
  ],
  "presets": [
    {
      "name": "Mellow written reviews"
    }
  ]
}
{% endschema %}
