{% comment %}
  Mellow — Premium Clinical Raft Animation
  Paste into: sections/mellow-clinical-raft-animation.liquid
{% endcomment %}

<div class="mellow-clinical-raft-animation" style="--duration: 14s;">
  <style>
    .mellow-clinical-raft-animation {
      --forest: #1A2D10;
      --forest-soft: rgba(26, 45, 16, 0.56);
      --orange: #D04A2A;
      --acid: #D86B52;
      --acid-soft: #E99A82;
      --gold: #C49A3A;
      --gold-soft: rgba(196, 154, 58, 0.48);
      --cream: #F0EBE0;
      --ivory: #FBFAF5;
      --page: #FBFCF7;
      --sage: #DDE8C8;
      --sage-deep: #B7C894;

      width: 100%;
      background: var(--page);
      padding: clamp(24px, 4vw, 64px);
      color: var(--forest);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .mellow-clinical-raft-animation,
    .mellow-clinical-raft-animation * {
      box-sizing: border-box;
    }

    .mellow-clinical-raft-animation .drop,
    .mellow-clinical-raft-animation .ripple,
    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .raft-haze,
    .mellow-clinical-raft-animation .raft,
    .mellow-clinical-raft-animation .raft-dot,
    .mellow-clinical-raft-animation .raft-text,
    .mellow-clinical-raft-animation .acid-wave,
    .mellow-clinical-raft-animation .acid-wave-inner,
    .mellow-clinical-raft-animation .top-callout,
    .mellow-clinical-raft-animation .guide-line,
    .mellow-clinical-raft-animation .guide-dot,
    .mellow-clinical-raft-animation .micro-bubble {
      animation-play-state: paused;
    }

    .mellow-clinical-raft-animation.is-playing .drop,
    .mellow-clinical-raft-animation.is-playing .ripple,
    .mellow-clinical-raft-animation.is-playing .particle,
    .mellow-clinical-raft-animation.is-playing .raft-haze,
    .mellow-clinical-raft-animation.is-playing .raft,
    .mellow-clinical-raft-animation.is-playing .raft-dot,
    .mellow-clinical-raft-animation.is-playing .raft-text,
    .mellow-clinical-raft-animation.is-playing .acid-wave,
    .mellow-clinical-raft-animation.is-playing .acid-wave-inner,
    .mellow-clinical-raft-animation.is-playing .top-callout,
    .mellow-clinical-raft-animation.is-playing .guide-line,
    .mellow-clinical-raft-animation.is-playing .guide-dot,
    .mellow-clinical-raft-animation.is-playing .micro-bubble {
      animation-play-state: running;
    }

    .mellow-clinical-raft-animation .raft-shell {
      max-width: 1320px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 0.82fr 1.18fr;
      gap: clamp(28px, 5vw, 72px);
      align-items: center;
    }

    .mellow-clinical-raft-animation .raft-copy-eyebrow {
      display: block;
      margin-bottom: 18px;
      font-size: 12px;
      font-weight: 850;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--orange);
    }

    .mellow-clinical-raft-animation .raft-copy h2 {
      margin: 0 0 22px;
      color: var(--forest);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(40px, 5vw, 68px);
      line-height: .96;
      letter-spacing: -0.06em;
    }

    .mellow-clinical-raft-animation .raft-copy p {
      max-width: 520px;
      margin: 0;
      color: #687064;
      font-size: clamp(16px, 1.5vw, 19px);
      line-height: 1.65;
      letter-spacing: .02em;
    }

    .mellow-clinical-raft-animation .device {
      position: relative;
      min-height: 520px;
      border-radius: 32px;
      padding: 0;
      background: transparent;
    }

    .mellow-clinical-raft-animation .mechanism {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 520px;
      overflow: hidden;
      border-radius: 30px;
      background:
        radial-gradient(circle at 20% 16%, rgba(196, 154, 58, .08), transparent 32%),
        radial-gradient(circle at 84% 18%, rgba(26, 45, 16, .045), transparent 34%),
        linear-gradient(180deg, #FBFAF5 0%, #F4F0E7 100%);
      border: 1px solid rgba(26, 45, 16, .10);
      box-shadow:
        0 30px 90px rgba(26, 45, 16, .08),
        inset 0 0 0 1px rgba(255, 255, 255, .62);
    }

    .mellow-clinical-raft-animation .mechanism::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: .45;
      background-image:
        radial-gradient(rgba(26, 45, 16, .13) 0.75px, transparent 0.75px);
      background-size: 12px 12px;
      mask-image: linear-gradient(to bottom, transparent 0%, black 22%, black 88%, transparent 100%);
    }

    .mellow-clinical-raft-animation .layer-label {
      position: absolute;
      z-index: 70;
      top: 30px;
      left: 30px;
      display: inline-flex;
      align-items: center;
      min-height: 44px;
      padding: 0 22px;
      border-radius: 999px;
      background: rgba(251, 250, 245, .76);
      border: 1px solid rgba(196, 154, 58, .68);
      color: var(--forest);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .32em;
      text-transform: uppercase;
      box-shadow: 0 12px 28px rgba(26, 45, 16, .04);
    }

    .mellow-clinical-raft-animation .top-callout {
      position: absolute;
      z-index: 72;
      top: 112px;
      left: 50%;
      width: min(320px, 48%);
      transform: translateX(-50%);
      display: grid;
      justify-items: center;
      gap: 14px;
      opacity: 0;
      animation: mellowTopCallout var(--duration) ease-in-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .shield {
      width: 54px;
      height: 54px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: rgba(251, 250, 245, .76);
      border: 1px solid rgba(196, 154, 58, .72);
      box-shadow: 0 10px 24px rgba(26, 45, 16, .05);
    }

    .mellow-clinical-raft-animation .shield svg {
      width: 28px;
      height: 28px;
    }

    .mellow-clinical-raft-animation .shield path {
      fill: none;
      stroke: var(--forest);
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .mellow-clinical-raft-animation .top-callout p {
      margin: 0;
      max-width: 260px;
      color: var(--forest);
      text-align: center;
      font-size: 15px;
      font-weight: 650;
      line-height: 1.24;
      letter-spacing: .045em;
    }

    .mellow-clinical-raft-animation .guide-line {
      position: absolute;
      z-index: 68;
      left: 50%;
      top: 222px;
      width: 1px;
      height: 116px;
      background: linear-gradient(180deg, rgba(196,154,58,.85), rgba(196,154,58,.52));
      transform: translateX(-50%) scaleY(0);
      transform-origin: 50% 0%;
      opacity: 0;
      animation: mellowGuideLine var(--duration) ease-in-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .guide-dot {
      position: absolute;
      z-index: 69;
      left: 50%;
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--gold);
      transform: translateX(-50%) scale(.5);
      opacity: 0;
      animation: mellowGuideDot var(--duration) ease-in-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .guide-dot-top {
      top: 290px;
    }

    .mellow-clinical-raft-animation .guide-dot-bottom {
      top: 344px;
      animation-delay: .08s;
    }

    .mellow-clinical-raft-animation .acid-base {
      position: absolute;
      z-index: 4;
      left: 0;
      right: 0;
      bottom: 0;
      height: 30%;
      background:
        linear-gradient(180deg, rgba(232, 129, 103, .82), rgba(208, 74, 42, .84));
    }

    .mellow-clinical-raft-animation .acid-base::before {
      content: "";
      position: absolute;
      inset: 0;
      opacity: .34;
      background-image:
        radial-gradient(rgba(255, 255, 255, .72) 0.85px, transparent 0.85px);
      background-size: 12px 12px;
    }

    .mellow-clinical-raft-animation .acid-label-wrap {
      position: absolute;
      z-index: 74;
      left: 50%;
      bottom: 42px;
      transform: translateX(-50%);
      display: grid;
      justify-items: center;
      gap: 14px;
      width: min(560px, calc(100% - 48px));
    }

    .mellow-clinical-raft-animation .acid-label {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      min-height: 46px;
      padding: 0 22px;
      border-radius: 999px;
      background: rgba(251, 250, 245, .20);
      border: 1px solid rgba(255, 255, 255, .48);
      color: var(--forest);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .26em;
      text-transform: uppercase;
      backdrop-filter: blur(2px);
      white-space: nowrap;
    }

    .mellow-clinical-raft-animation .acid-icon {
      width: 30px;
      height: 30px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(255, 255, 255, .60);
      flex: 0 0 auto;
    }

    .mellow-clinical-raft-animation .acid-icon svg {
      width: 16px;
      height: 16px;
    }

    .mellow-clinical-raft-animation .acid-icon path {
      fill: none;
      stroke: var(--forest);
      stroke-width: 1.7;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .mellow-clinical-raft-animation .acid-caption {
      margin: 0;
      color: rgba(26, 45, 16, .86);
      font-size: 14px;
      line-height: 1.35;
      text-align: center;
      font-weight: 550;
      letter-spacing: .01em;
    }

    .mellow-clinical-raft-animation .acid-wave {
      position: absolute;
      z-index: 6;
      left: -2%;
      right: -2%;
      bottom: 0;
      height: 54%;
      opacity: 0;
      transform: translate3d(0, 62%, 0);
      transform-origin: 50% 100%;
      animation: mellowAcidWaveRisePremium var(--duration) cubic-bezier(.33, .01, .19, 1) infinite;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .mellow-clinical-raft-animation .acid-wave-inner {
      width: 100%;
      height: 100%;
      animation: mellowAcidWaveRepelPremium var(--duration) cubic-bezier(.33, .01, .19, 1) infinite;
      transform-origin: 50% 100%;
      will-change: transform;
    }

    .mellow-clinical-raft-animation .acid-wave svg {
      display: block;
      width: 100%;
      height: 100%;
    }

    .mellow-clinical-raft-animation .wave-fill {
      fill: rgba(216, 107, 82, .76);
    }

    .mellow-clinical-raft-animation .wave-sheen {
      fill: rgba(240, 170, 150, .38);
    }

    .mellow-clinical-raft-animation .drop {
      position: absolute;
      z-index: 30;
      width: 22px;
      height: 30px;
      opacity: 0;
      transform-origin: 50% 70%;
      filter: drop-shadow(0 8px 12px rgba(26, 45, 16, .10));
      animation: mellowRaftDropletFall var(--duration) cubic-bezier(.32, .02, .2, 1) infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .drop svg {
      display: block;
      width: 100%;
      height: 100%;
    }

    .mellow-clinical-raft-animation .drop-1 {
      left: 28%;
      top: 23%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .drop-2 {
      left: 49%;
      top: 25%;
      width: 19px;
      height: 26px;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .drop-3 {
      left: 67%;
      top: 22%;
      width: 17px;
      height: 23px;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .ripple {
      position: absolute;
      z-index: 29;
      width: 34px;
      height: 10px;
      border-radius: 999px;
      border: 1.5px solid rgba(196, 154, 58, .46);
      opacity: 0;
      animation: mellowRaftRipple var(--duration) ease-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .ripple-1 {
      left: calc(28% - 5px);
      top: 57%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .ripple-2 {
      left: calc(49% - 5px);
      top: 57%;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .ripple-3 {
      left: calc(67% - 5px);
      top: 57%;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .micro-bubble {
      position: absolute;
      z-index: 32;
      width: var(--s, 5px);
      height: var(--s, 5px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .72));
      box-shadow: 0 0 10px rgba(196, 154, 58, .32);
      opacity: 0;
      pointer-events: none;
      animation: mellowRaftParticleRise var(--duration) cubic-bezier(.2, .2, .12, 1) infinite;
    }

    .mellow-clinical-raft-animation .p1 { left: 27%; top: 58%; --x: 12px; --y: -118px; --s: 6px; --c: rgba(255,247,232,.74); animation-delay: .03s; }
    .mellow-clinical-raft-animation .p2 { left: 32%; top: 59%; --x: -18px; --y: -122px; --s: 4px; --c: rgba(196,154,58,.44); animation-delay: .06s; }
    .mellow-clinical-raft-animation .p3 { left: 44%; top: 57%; --x: 20px; --y: -126px; --s: 5px; --c: rgba(183,200,148,.55); animation-delay: .09s; }
    .mellow-clinical-raft-animation .p4 { left: 51%; top: 59%; --x: -8px; --y: -120px; --s: 6px; --c: rgba(255,247,232,.72); animation-delay: .12s; }
    .mellow-clinical-raft-animation .p5 { left: 64%; top: 58%; --x: 16px; --y: -126px; --s: 4px; --c: rgba(196,154,58,.42); animation-delay: .15s; }
    .mellow-clinical-raft-animation .p6 { left: 70%; top: 59%; --x: -22px; --y: -122px; --s: 5px; --c: rgba(183,200,148,.52); animation-delay: .18s; }

    .mellow-clinical-raft-animation .micro-bubble {
      left: var(--x);
      top: var(--top);
      animation-delay: var(--d, 0s);
    }

    .mellow-clinical-raft-animation .raft-haze {
      position: absolute;
      z-index: 42;
      left: 7%;
      top: 48%;
      width: 86%;
      height: 78px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 25% 50%, rgba(255, 247, 232, .34), transparent 22%),
        radial-gradient(circle at 55% 50%, rgba(196, 154, 58, .18), transparent 24%),
        radial-gradient(circle at 76% 50%, rgba(183, 200, 148, .26), transparent 24%),
        linear-gradient(180deg, rgba(255, 247, 232, .22), rgba(183, 200, 148, .18));
      opacity: 0;
      filter: blur(14px);
      transform-origin: 50% 50%;
      animation: mellowRaftHazeBuild var(--duration) ease-in-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .raft {
      position: absolute;
      z-index: 50;
      left: 6.4%;
      top: 46.5%;
      width: 87.2%;
      height: 84px;
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(235, 242, 210, .96) 0%, rgba(211, 225, 178, .96) 54%, rgba(181, 198, 145, .94) 100%);
      border: 1px solid rgba(26, 45, 16, .10);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 245, .68),
        inset 0 -14px 22px rgba(26, 45, 16, .045),
        0 22px 42px rgba(26, 45, 16, .10);
      opacity: 0;
      transform-origin: 50% 50%;
      animation: mellowRaftGelBuild var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      pointer-events: none;
      overflow: hidden;
    }

    .mellow-clinical-raft-animation .raft::before {
      content: "";
      position: absolute;
      inset: 17px 28px;
      border-radius: 999px;
      border: 1px solid rgba(196, 154, 58, .68);
      opacity: .85;
    }

    .mellow-clinical-raft-animation .raft::after {
      content: "";
      position: absolute;
      inset: 0;
      opacity: .26;
      background-image:
        radial-gradient(rgba(26, 45, 16, .30) 0.75px, transparent 0.75px);
      background-size: 11px 11px;
      mask-image: linear-gradient(90deg, transparent 0%, black 10%, black 90%, transparent 100%);
    }

    .mellow-clinical-raft-animation .raft-text {
      position: absolute;
      inset: 0;
      z-index: 4;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 18px;
      font-size: 17px;
      font-weight: 900;
      letter-spacing: .36em;
      text-transform: uppercase;
      color: rgba(26, 45, 16, .94);
      white-space: nowrap;
      opacity: 0;
      animation: mellowRaftTextAppear var(--duration) ease-in-out infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .raft-text::before,
    .mellow-clinical-raft-animation .raft-text::after {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--gold);
      opacity: .9;
      flex: 0 0 auto;
    }

    .mellow-clinical-raft-animation .raft-dot {
      position: absolute;
      z-index: 53;
      left: calc(6.4% + var(--x));
      top: calc(46.5% + var(--y));
      width: var(--s, 4px);
      height: var(--s, 4px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .72));
      box-shadow: 0 0 6px rgba(255, 247, 232, .20);
      opacity: 0;
      animation: mellowRaftDotsAppear var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      pointer-events: none;
    }

    @keyframes mellowTopCallout {
      0%, 34% {
        opacity: 0;
        transform: translateX(-50%) translateY(8px) scale(.98);
      }

      42%, 92% {
        opacity: 1;
        transform: translateX(-50%) translateY(0) scale(1);
      }

      98%, 100% {
        opacity: 0;
        transform: translateX(-50%) translateY(-3px) scale(.99);
      }
    }

    @keyframes mellowGuideLine {
      0%, 38% {
        opacity: 0;
        transform: translateX(-50%) scaleY(0);
      }

      48%, 92% {
        opacity: 1;
        transform: translateX(-50%) scaleY(1);
      }

      98%, 100% {
        opacity: 0;
        transform: translateX(-50%) scaleY(.92);
      }
    }

    @keyframes mellowGuideDot {
      0%, 40% {
        opacity: 0;
        transform: translateX(-50%) scale(.45);
      }

      48%, 92% {
        opacity: 1;
        transform: translateX(-50%) scale(1);
      }

      98%, 100% {
        opacity: 0;
        transform: translateX(-50%) scale(.7);
      }
    }

    @keyframes mellowRaftDropletFall {
      0%, 4% {
        opacity: 0;
        transform: translateY(-16px) scale(.82) rotate(-8deg);
      }

      8% {
        opacity: .95;
      }

      18% {
        opacity: .95;
        transform: translateY(172px) scale(1) rotate(6deg);
      }

      22%, 100% {
        opacity: 0;
        transform: translateY(182px) scale(1.16, .70) rotate(2deg);
      }
    }

    @keyframes mellowRaftRipple {
      0%, 12% {
        opacity: 0;
        transform: scale(.3);
      }

      15% {
        opacity: .64;
        transform: scale(.75);
      }

      22%, 100% {
        opacity: 0;
        transform: scale(1.9);
      }
    }

    @keyframes mellowRaftParticleRise {
      0%, 8% {
        opacity: 0;
        transform: translate(0, 0) scale(.5);
      }

      13% {
        opacity: .92;
        transform: translate(0, 0) scale(.76);
      }

      24% {
        opacity: .82;
        transform: translate(calc(var(--x) * .46), calc(var(--y) * .62)) scale(1);
      }

      36% {
        opacity: .26;
        transform: translate(var(--x), var(--y)) scale(.68);
      }

      44%, 100% {
        opacity: 0;
        transform: translate(var(--x), var(--y)) scale(.22);
      }
    }

    @keyframes mellowRaftHazeBuild {
      0%, 20% {
        opacity: 0;
        transform: scaleX(.10) scaleY(.22);
        filter: blur(18px);
      }

      30% {
        opacity: .20;
        transform: scaleX(.36) scaleY(.42);
        filter: blur(15px);
      }

      38% {
        opacity: .38;
        transform: scaleX(.72) scaleY(.68);
        filter: blur(11px);
      }

      46%, 92% {
        opacity: .30;
        transform: scaleX(1) scaleY(1);
        filter: blur(8px);
      }

      98%, 100% {
        opacity: 0;
        transform: scaleX(1.03) scaleY(1.02);
        filter: blur(12px);
      }
    }

    @keyframes mellowRaftGelBuild {
      0%, 20% {
        opacity: 0;
        transform: translate3d(0, 5px, 0) scaleX(.05) scaleY(.22);
        filter: blur(12px);
      }

      30% {
        opacity: .28;
        transform: translate3d(0, 4px, 0) scaleX(.28) scaleY(.36);
        filter: blur(9px);
      }

      38% {
        opacity: .66;
        transform: translate3d(0, 2px, 0) scaleX(.66) scaleY(.64);
        filter: blur(5px);
      }

      46% {
        opacity: 1;
        transform: translate3d(0, 0, 0) scaleX(1) scaleY(1);
        filter: blur(0);
      }

      56%, 92% {
        opacity: 1;
        transform: translate3d(0, -1px, 0) scaleX(1) scaleY(1);
        filter: blur(0);
      }

      98%, 100% {
        opacity: 1;
        transform: translate3d(0, 0, 0) scaleX(1) scaleY(1);
        filter: blur(0);
      }
    }

    @keyframes mellowRaftTextAppear {
      0%, 50% {
        opacity: 0;
        transform: translateY(3px) scale(.98);
      }

      58%, 92% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      97%, 100% {
        opacity: 0;
        transform: translateY(-1px) scale(.99);
      }
    }

    @keyframes mellowRaftDotsAppear {
      0%, 42% {
        opacity: 0;
        transform: translate3d(0, 2px, 0) scale(.45);
      }

      52% {
        opacity: .36;
        transform: translate3d(0, 1px, 0) scale(.72);
      }

      62%, 92% {
        opacity: .58;
        transform: translate3d(0, 0, 0) scale(1);
      }

      98%, 100% {
        opacity: .58;
        transform: translate3d(0, 0, 0) scale(1);
      }
    }

    @keyframes mellowAcidWaveRisePremium {
      0%, 48% {
        opacity: 0;
        transform: translate3d(0, 68%, 0);
      }

      56% {
        opacity: .18;
