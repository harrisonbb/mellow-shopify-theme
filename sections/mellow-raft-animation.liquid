<style>
  /* FIX: make the animation visibly cycle instead of sitting blank */
  .mellow-clinical-raft-animation {
    --duration: 8.8s !important;
  }

  .mellow-clinical-raft-animation .drop {
    animation: mellowRaftDropletFallVisible var(--duration) cubic-bezier(.32, .02, .2, 1) infinite !important;
  }

  .mellow-clinical-raft-animation .particle {
    animation: mellowRaftParticleRiseVisible var(--duration) cubic-bezier(.2, .2, .12, 1) infinite !important;
  }

  .mellow-clinical-raft-animation .pb {
    animation: mellowRaftParticleBloomVisible var(--duration) cubic-bezier(.18, .28, .12, 1) infinite !important;
  }

  .mellow-clinical-raft-animation .raft-haze {
    animation: mellowRaftHazeCondenseVisible var(--duration) ease-in-out infinite !important;
  }

  .mellow-clinical-raft-animation .raft {
    animation: mellowRaftFormFloatVisible var(--duration) cubic-bezier(.22, .75, .22, 1) infinite !important;
  }

  .mellow-clinical-raft-animation .raft-dot {
    animation: mellowRaftDotEmbedVisible var(--duration) cubic-bezier(.22, .75, .22, 1) infinite !important;
  }

  .mellow-clinical-raft-animation .heat {
    animation: mellowRaftHeatRiseVisible var(--duration) ease-in-out infinite !important;
  }

  .mellow-clinical-raft-animation .block-ripple {
    animation: mellowRaftBlockRippleVisible var(--duration) ease-out infinite !important;
  }

  .mellow-clinical-raft-animation .blocked-callout {
    animation: mellowRaftBlockedCalloutVisible var(--duration) ease-out infinite !important;
  }

  @keyframes mellowRaftDropletFallVisible {
    0%, 4% {
      opacity: 0;
      transform: translateY(-18px) scale(.82) rotate(-8deg);
    }

    8% {
      opacity: 1;
    }

    18% {
      opacity: 1;
      transform: translateY(168px) scale(1) rotate(6deg);
    }

    22% {
      opacity: 0;
      transform: translateY(177px) scale(1.18, .68) rotate(2deg);
    }

    100% {
      opacity: 0;
      transform: translateY(177px) scale(1.18, .68);
    }
  }

  @keyframes mellowRaftParticleRiseVisible {
    0%, 16% {
      opacity: 0;
      transform: translate(0, 0) scale(.55);
    }

    22% {
      opacity: .95;
    }

    38% {
      opacity: .9;
      transform: translate(calc(var(--x) * .45), calc(var(--y) * .58)) scale(1);
    }

    52% {
      opacity: .35;
      transform: translate(var(--x), var(--y)) scale(.75);
    }

    62%, 100% {
      opacity: 0;
      transform: translate(var(--x), var(--y)) scale(.25);
    }
  }

  @keyframes mellowRaftParticleBloomVisible {
    0%, 18% {
      opacity: 0;
      transform: translate(0, 0) scale(.32);
    }

    26% {
      opacity: .8;
    }

    42% {
      opacity: .74;
      transform: translate(var(--dx1), var(--dy1)) scale(.78);
    }

    56% {
      opacity: .68;
      transform: translate(var(--dx2), var(--dy2)) scale(.60);
    }

    66% {
      opacity: .35;
      transform: translate(var(--dx3), var(--dy3)) scale(.44);
    }

    74%, 100% {
      opacity: 0;
      transform: translate(var(--dx3), var(--dy3)) scale(.12);
    }
  }

  @keyframes mellowRaftHazeCondenseVisible {
    0%, 42% {
      opacity: 0;
      transform: scaleX(.40) scaleY(.35);
      filter: blur(14px);
    }

    52% {
      opacity: .38;
      transform: scaleX(.78) scaleY(.62);
      filter: blur(10px);
    }

    62% {
      opacity: .52;
      transform: scaleX(1) scaleY(.88);
      filter: blur(7px);
    }

    74%, 100% {
      opacity: 0;
      transform: scaleX(1) scaleY(1);
      filter: blur(10px);
    }
  }

  @keyframes mellowRaftFormFloatVisible {
    0%, 46% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scaleX(.12) scaleY(.34);
      filter: blur(10px);
    }

    54% {
      opacity: .45;
      transform: translate3d(0, 0, 0) scaleX(.44) scaleY(.52);
      filter: blur(7px);
    }

    62% {
      opacity: .85;
      transform: translate3d(0, 0, 0) scaleX(.88) scaleY(.78);
      filter: blur(2px);
    }

    70% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scaleX(1) scaleY(.96);
      filter: blur(0);
    }

    78% {
      opacity: 1;
      transform: translate3d(0, -1px, 0) scaleX(1) scaleY(1);
      filter: blur(0);
    }

    86% {
      opacity: 1;
      transform: translate3d(0, 1.5px, 0) scaleX(1) scaleY(1);
      filter: blur(0);
    }

    94% {
      opacity: 1;
      transform: translate3d(0, -1px, 0) scaleX(1) scaleY(1);
      filter: blur(0);
    }

    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scaleX(1) scaleY(1);
      filter: blur(0);
    }
  }

  @keyframes mellowRaftDotEmbedVisible {
    0%, 58% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(.55);
    }

    68% {
      opacity: .5;
      transform: translate3d(0, 0, 0) scale(.82);
    }

    78% {
      opacity: .6;
      transform: translate3d(0, -1px, 0) scale(1);
    }

    86% {
      opacity: .56;
      transform: translate3d(0, 1.5px, 0) scale(1);
    }

    100% {
      opacity: .56;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes mellowRaftHeatRiseVisible {
    0%, 74% {
      opacity: 0;
      transform: translateY(36px) scaleY(.18);
    }

    82% {
      opacity: .82;
      transform: translateY(20px) scaleY(.44);
    }

    90% {
      opacity: .86;
      transform: translateY(0) scaleY(.88);
    }

    100% {
      opacity: .58;
      transform: translateY(4px) scaleY(.70);
    }
  }

  @keyframes mellowRaftBlockRippleVisible {
    0%, 86% {
      opacity: 0;
      transform: scaleX(.2);
    }

    92% {
      opacity: .56;
      transform: scaleX(1);
    }

    100% {
      opacity: 0;
      transform: scaleX(1.35);
    }
  }

  @keyframes mellowRaftBlockedCalloutVisible {
    0%, 86% {
      opacity: 0;
      transform: translateY(4px) scale(.98);
    }

    94%, 100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>


