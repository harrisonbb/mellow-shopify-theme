{% comment %}
  Mellow — Clinical Raft Animation
  Paste into: sections/mellow-clinical-raft-animation.liquid
{% endcomment %}

<div class="mellow-clinical-raft-animation" style="--duration: 14s;">
  <style>
    .mellow-clinical-raft-animation {
      --forest: #1A2D10;
      --forest-soft: rgba(26, 45, 16, 0.50);
      --orange: #D04A2A;
      --gold: #BE9335;
      --cream: #F0EBE0;
      --page: #FBFCF7;
      --raft-birth-top: 31%;
      --raft-final-top: 31%;

      --acid-line-1: 30%;
      --acid-line-2: 55%;
      --acid-line-3: 72%;
      --acid-line-top: calc(var(--raft-final-top) + 58px);

      width: 100%;
      background: var(--page);
      padding: clamp(24px, 4vw, 64px);
      color: var(--forest);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .mellow-clinical-raft-animation,
    .mellow-clinical-raft-animation * {
      box-sizing: border-box;
    }

    .mellow-clinical-raft-animation .drop,
    .mellow-clinical-raft-animation .ripple,
    .mellow-clinical-raft-animation .splash,
    .mellow-clinical-raft-animation .splash::before,
    .mellow-clinical-raft-animation .splash i,
    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .pb,
    .mellow-clinical-raft-animation .fragment,
    .mellow-clinical-raft-animation .raft-haze,
    .mellow-clinical-raft-animation .raft,
    .mellow-clinical-raft-animation .raft-dot,
    .mellow-clinical-raft-animation .raft-text,
    .mellow-clinical-raft-animation .raft-forcefield,
    .mellow-clinical-raft-animation .acid-wave,
    .mellow-clinical-raft-animation .acid-wave-inner,
    .mellow-clinical-raft-animation .droplet-callout,
    .mellow-clinical-raft-animation .formation-callout,
    .mellow-clinical-raft-animation .callout {
      animation-play-state: paused;
    }

    .mellow-clinical-raft-animation.is-playing .drop,
    .mellow-clinical-raft-animation.is-playing .ripple,
    .mellow-clinical-raft-animation.is-playing .splash,
    .mellow-clinical-raft-animation.is-playing .splash::before,
    .mellow-clinical-raft-animation.is-playing .splash i,
    .mellow-clinical-raft-animation.is-playing .particle,
    .mellow-clinical-raft-animation.is-playing .pb,
    .mellow-clinical-raft-animation.is-playing .fragment,
    .mellow-clinical-raft-animation.is-playing .raft-haze,
    .mellow-clinical-raft-animation.is-playing .raft,
    .mellow-clinical-raft-animation.is-playing .raft-dot,
    .mellow-clinical-raft-animation.is-playing .raft-text,
    .mellow-clinical-raft-animation.is-playing .raft-forcefield,
    .mellow-clinical-raft-animation.is-playing .acid-wave,
    .mellow-clinical-raft-animation.is-playing .acid-wave-inner,
    .mellow-clinical-raft-animation.is-playing .droplet-callout,
    .mellow-clinical-raft-animation.is-playing .formation-callout,
    .mellow-clinical-raft-animation.is-playing .callout {
      animation-play-state: running;
    }

    .mellow-clinical-raft-animation .raft-shell {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(28px, 5vw, 72px);
      align-items: center;
      background:
        radial-gradient(circle at 12% 12%, rgba(190, 147, 53, .08), transparent 32%),
        radial-gradient(circle at 88% 10%, rgba(26, 45, 16, .035), transparent 34%),
        linear-gradient(135deg, #FBFAF5 0%, #FFFFFF 56%, #F5EFE3 100%);
      border: 1px solid rgba(26, 45, 16, .10);
      border-radius: 38px;
      box-shadow: 0 30px 90px rgba(26, 45, 16, .07);
      padding: clamp(22px, 4vw, 56px);
    }

    .mellow-clinical-raft-animation .raft-copy-eyebrow {
      display: block;
      margin-bottom: 18px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--orange);
    }

    .mellow-clinical-raft-animation .raft-copy h2 {
      margin: 0 0 22px;
      color: var(--forest);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(40px, 5vw, 68px);
      line-height: .96;
      letter-spacing: -0.06em;
    }

    .mellow-clinical-raft-animation .raft-copy p {
      max-width: 520px;
      margin: 0;
      color: #687064;
      font-size: clamp(16px, 1.5vw, 19px);
      line-height: 1.65;
      letter-spacing: .02em;
    }

    .mellow-clinical-raft-animation .device {
      position: relative;
      aspect-ratio: 1.56 / 1;
      min-height: 360px;
      border-radius: 30px;
      padding: clamp(16px, 1.9vw, 24px);
      background: rgba(255, 255, 255, .34);
      border: 1px solid rgba(26, 45, 16, .09);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, .58),
        0 16px 40px rgba(26, 45, 16, .04);
    }

    .mellow-clinical-raft-animation .mechanism {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 340px;
      overflow: hidden;
      border-radius: 26px;
      background:
        radial-gradient(circle at 50% 8%, rgba(255, 255, 255, .76), transparent 42%),
        radial-gradient(circle at 48% 72%, rgba(218, 115, 93, .06), transparent 34%),
        linear-gradient(180deg, #FBFAF5 0%, #F2EDE2 74%, #EDE4D6 100%);
      border: 1px solid rgba(26, 45, 16, .055);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .50);
    }

    .mellow-clinical-raft-animation .mechanism::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: .28;
      background-image:
        radial-gradient(rgba(26, 45, 16, .22) .72px, transparent .72px);
      background-size: 10px 10px;
      mask-image: linear-gradient(to bottom, transparent 0%, black 16%, black 88%, transparent 100%);
    }

    .mellow-clinical-raft-animation .layer-label {
      position: absolute;
      z-index: 80;
      top: 22px;
      left: 28px;
      display: inline-flex;
      align-items: center;
      min-height: 42px;
      padding: 0 22px;
      border-radius: 999px;
      background: rgba(251, 250, 245, .72);
      border: 1px solid rgba(190, 147, 53, .78);
      color: var(--forest);
      font-size: 11px;
      font-weight: 900;
      letter-spacing: .30em;
      text-transform: uppercase;
      box-shadow: 0 10px 24px rgba(26, 45, 16, .03);
    }

    .mellow-clinical-raft-animation .mockup-callout {
      position: absolute;
      z-index: 85;
      top: 76px;
      left: 50%;
      transform: translateX(-50%);
      display: grid;
      justify-items: center;
      gap: 10px;
      width: 270px;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .mockup-shield {
      width: 52px;
      height: 52px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: rgba(251, 250, 245, .70);
      border: 1px solid rgba(190, 147, 53, .78);
      box-shadow: 0 10px 22px rgba(26, 45, 16, .04);
    }

    .mellow-clinical-raft-animation .mockup-shield svg {
      width: 29px;
      height: 29px;
      display: block;
    }

    .mellow-clinical-raft-animation .mockup-shield path {
      fill: none;
      stroke: var(--forest);
      stroke-width: 1.75;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .mellow-clinical-raft-animation .mockup-callout p {
      margin: 0;
      color: var(--forest);
      text-align: center;
      font-size: 14px;
      font-weight: 650;
      line-height: 1.22;
      letter-spacing: .035em;
    }

    .mellow-clinical-raft-animation .mockup-guide {
      position: absolute;
      z-index: 84;
      left: 50%;
      top: 181px;
      width: 1px;
      height: 142px;
      transform: translateX(-50%);
      background: rgba(190, 147, 53, .72);
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .mockup-guide::before,
    .mellow-clinical-raft-animation .mockup-guide::after {
      content: "";
      position: absolute;
      left: 50%;
      width: 8px;
      height: 8px;
      border-radius: 999px;
      transform: translateX(-50%);
      background: var(--gold);
    }

    .mellow-clinical-raft-animation .mockup-guide::before {
      top: 68px;
    }

    .mellow-clinical-raft-animation .mockup-guide::after {
      bottom: -2px;
    }

    .mellow-clinical-raft-animation .callout {
      position: absolute;
      z-index: 59;
      left: 230px !important;
      right: auto !important;
      top: 60px !important;
      width: 84px !important;
      height: 52px !important;
      pointer-events: none;
      opacity: 0;
      transform: none !important;
      animation: mellowRaftCalloutAppearClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .callout path,
    .mellow-clinical-raft-animation .callout polyline {
      fill: none;
      stroke: rgba(190, 147, 53, .78);
      stroke-width: 1.65;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .mellow-clinical-raft-animation .acid {
      position: absolute;
      z-index: 2;
      left: 0;
      right: 0;
      bottom: 0;
      height: 30%;
      background:
        linear-gradient(180deg, rgba(243, 162, 139, .78), rgba(218, 115, 93, .88));
      opacity: 1;
    }

    .mellow-clinical-raft-animation .acid::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 0;
      height: 100%;
      opacity: .26;
      filter: none;
      background-image:
        radial-gradient(rgba(255, 255, 255, .82) .72px, transparent .72px);
      background-size: 10px 10px;
    }

    .mellow-clinical-raft-animation .acid-label {
      position: absolute;
      z-index: 86;
      left: 50%;
      bottom: 26px;
      transform: translateX(-50%);
      display: inline-flex;
      align-items: center;
      min-height: 42px;
      padding: 0 24px;
      border-radius: 999px;
      background: rgba(255, 255, 255, .17);
      border: 1px solid rgba(255, 255, 255, .54);
      color: rgba(26, 45, 16, .88);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: .22em;
      text-transform: uppercase;
      white-space: nowrap;
      backdrop-filter: blur(2px);
      box-shadow: none;
    }

    .mellow-clinical-raft-animation .acid-caption {
      position: absolute;
      z-index: 86;
      left: 50%;
      bottom: 9px;
      transform: translateX(-50%);
      width: calc(100% - 48px);
      margin: 0;
      color: rgba(26, 45, 16, .88);
      font-size: 11px;
      line-height: 1.25;
      text-align: center;
      font-weight: 550;
      letter-spacing: .01em;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .droplet-callout {
      position: absolute;
      z-index: 70;
      top: 92px;
      right: 72px;
      display: inline-flex;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      animation: mellowRaftMellowEntersClean var(--duration) cubic-bezier(.32,.02,.2,1) infinite;
    }

    .mellow-clinical-raft-animation .formation-callout {
      position: absolute;
      z-index: 70;
      top: 132px;
      right: 72px;
      display: inline-flex;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      animation: mellowRaftBeginsClean var(--duration) cubic-bezier(.32,.02,.2,1) infinite;
    }

    .mellow-clinical-raft-animation .droplet-callout__pill,
    .mellow-clinical-raft-animation .formation-callout__pill {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(251, 250, 245, .70);
      border: 1px solid rgba(190, 147, 53, .26);
      color: rgba(26, 45, 16, .68);
      font-size: 10px;
      font-weight: 850;
      letter-spacing: .075em;
      text-transform: uppercase;
      box-shadow: 0 8px 18px rgba(26, 45, 16, .025);
      white-space: nowrap;
    }

    .mellow-clinical-raft-animation .drop {
      position: absolute;
      z-index: 20;
      width: 26px;
      height: 34px;
      opacity: 0;
      transform-origin: 50% 70%;
      filter: drop-shadow(0 8px 14px rgba(26, 45, 16, .12));
      animation: mellowRaftDropletFallClean var(--duration) cubic-bezier(.32, .02, .2, 1) infinite;
    }

    .mellow-clinical-raft-animation .drop svg {
      display: block;
      width: 100%;
      height: 100%;
    }

    .mellow-clinical-raft-animation .drop-1 {
      left: 27%;
      top: 18%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .drop-2 {
      left: 49%;
      top: 22%;
      width: 22px;
      height: 29px;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .drop-3 {
      left: 67%;
      top: 16%;
      width: 19px;
      height: 25px;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .ripple {
      position: absolute;
      z-index: 19;
      width: 34px;
      height: 10px;
      border-radius: 999px;
      border: 1.5px solid rgba(190, 147, 53, .42);
      opacity: 0;
      animation: mellowRaftRippleClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .ripple-1 {
      left: calc(27% - 4px);
      bottom: 20%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .ripple-2 {
      left: calc(49% - 4px);
      bottom: 20%;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .ripple-3 {
      left: calc(67% - 4px);
      bottom: 20%;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .splash {
      position: absolute;
      z-index: 24;
      bottom: 20%;
      width: 44px;
      height: 28px;
      pointer-events: none;
      opacity: 0;
      transform: translateX(-50%);
      animation: mellowRaftSplashClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .splash::before {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 28px;
      height: 7px;
      border-radius: 999px;
      background: rgba(190, 147, 53, .18);
      filter: blur(2px);
      transform: translateX(-50%) scaleX(.4);
      opacity: 0;
      animation: mellowRaftSplashBaseClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .splash i {
      position: absolute;
      left: 50%;
      bottom: 2px;
      width: var(--s, 4px);
      height: var(--s, 4px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .70));
      box-shadow: 0 0 6px rgba(190, 147, 53, .28);
      opacity: 0;
      transform: translate(-50%, 0) scale(.4);
      animation: mellowRaftSplashDotClean var(--duration) cubic-bezier(.2,.4,.12,1) infinite;
    }

    .mellow-clinical-raft-animation .splash-1 {
      left: 28%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .splash-1::before,
    .mellow-clinical-raft-animation .splash-1 i {
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .splash-2 {
      left: 50%;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .splash-2::before,
    .mellow-clinical-raft-animation .splash-2 i {
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .splash-3 {
      left: 68%;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .splash-3::before,
    .mellow-clinical-raft-animation .splash-3 i {
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .pb {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 997;
      width: var(--s, 6px);
      height: var(--s, 6px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .68));
      box-shadow: 0 0 8px rgba(190, 147, 53, .30);
      opacity: 0;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .particle {
      animation: mellowRaftParticleSHOWClean var(--duration) cubic-bezier(.2, .2, .12, 1) infinite;
    }

    .mellow-clinical-raft-animation .pb {
      left: var(--x0);
      bottom: 20%;
      animation: mellowRaftBubbleSHOWClean var(--duration) cubic-bezier(.18, .28, .12, 1) infinite;
    }

    .mellow-clinical-raft-animation .p1 {
      --s: 8px;
      --c: rgba(255, 247, 232, .68);
      left: 28%;
      bottom: 20%;
      --x: 10px;
      --y: -145px;
      animation-delay: .03s;
    }

    .mellow-clinical-raft-animation .p2 {
      --s: 6px;
      --c: rgba(228, 184, 90, .54);
      left: 31%;
      bottom: 20%;
      --x: -16px;
      --y: -128px;
      animation-delay: .06s;
    }

    .mellow-clinical-raft-animation .p3 {
      --s: 5px;
      --c: rgba(184, 201, 130, .56);
      left: 47%;
      bottom: 20%;
      --x: 22px;
      --y: -150px;
      animation-delay: .09s;
    }

    .mellow-clinical-raft-animation .p4 {
      --s: 7px;
      --c: rgba(255, 247, 232, .68);
      left: 51%;
      bottom: 20%;
      --x: -8px;
      --y: -132px;
      animation-delay: .12s;
    }

    .mellow-clinical-raft-animation .p5 {
      --s: 6px;
      --c: rgba(228, 184, 90, .54);
      left: 66%;
      bottom: 20%;
      --x: 12px;
      --y: -152px;
      animation-delay: .15s;
    }

    .mellow-clinical-raft-animation .p6 {
      --s: 4px;
      --c: rgba(184, 201, 130, .56);
      left: 69%;
      bottom: 20%;
      --x: -20px;
      --y: -126px;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .fragment {
      position: absolute;
      z-index: 35;
      height: 18px;
      top: 49%;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 247, 232, .68), rgba(184, 201, 130, .56));
      border: 0;
      filter: blur(4px);
      opacity: 0;
      animation: mellowRaftFragmentBuildClean var(--duration) ease-in-out infinite;
    }

    .mellow-clinical-raft-animation .f1 {
      left: 24%;
      width: 58px;
    }

    .mellow-clinical-raft-animation .f2 {
      left: 38%;
      width: 74px;
      animation-delay: .05s;
    }

    .mellow-clinical-raft-animation .f3 {
      left: 53%;
      width: 88px;
      animation-delay: .1s;
    }

    .mellow-clinical-raft-animation .f4 {
      left: 69%;
      width: 60px;
      animation-delay: .15s;
    }

    .mellow-clinical-raft-animation .raft-haze {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 998;
      left: 4%;
      top: var(--raft-birth-top);
      width: 92%;
      height: 62px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 24% 50%, rgba(255, 247, 232, .34), transparent 22%),
        radial-gradient(circle at 52% 50%, rgba(190, 147, 53, .16), transparent 24%),
        radial-gradient(circle at 76% 50%, rgba(175, 201, 136, .24), transparent 24%),
        linear-gradient(180deg, rgba(255, 247, 232, .18), rgba(175, 201, 136, .17));
      opacity: 0;
      filter: blur(13px);
      transform-origin: 50% 50%;
      animation: mellowRaftHazeSHOWClean var(--duration) ease-in-out infinite;
    }

    .mellow-clinical-raft-animation .raft {
      display: block !important;
      visibility: visible !important;
      position: absolute !important;
      z-index: 999 !important;
      left: 4% !important;
      top: var(--raft-birth-top) !important;
      width: 92% !important;
      height: 72px !important;
      border-radius: 999px;
      background:
        linear-gradient(
          180deg,
          rgba(238, 245, 216, .98) 0%,
          rgba(217, 232, 184, .97) 48%,
          rgba(175, 201, 136, .95) 100%
        );
      border: 1px solid rgba(26, 45, 16, .12) !important;
      outline: none !important;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 245, .76),
        inset 0 -14px 22px rgba(26, 45, 16, .045),
        0 18px 34px rgba(26, 45, 16, .10);
      opacity: 0;
      transform-origin: 50% 50%;
      animation: mellowRaftGelSHOWClean var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      will-change: opacity, transform, filter;
      pointer-events: none;
      overflow: hidden;
    }

    .mellow-clinical-raft-animation .raft::before {
      content: "" !important;
      display: block !important;
      position: absolute;
      inset: 15px 28px;
      border-radius: 999px;
      border: 1px solid rgba(190, 147, 53, .74);
      outline: 0 !important;
      pointer-events: none;
      opacity: .95;
    }

    .mellow-clinical-raft-animation .raft::after {
      content: "" !important;
      display: block !important;
      position: absolute;
      inset: 0;
      border: 0 !important;
      outline: 0 !important;
      opacity: .24;
      pointer-events: none;
      background-image:
        radial-gradient(rgba(26, 45, 16, .34) .68px, transparent .68px);
      background-size: 10px 10px;
      mask-image: linear-gradient(90deg, transparent 0%, black 9%, black 91%, transparent 100%);
    }

    .mellow-clinical-raft-animation .raft-forcefield {
      position: absolute;
      z-index: 996;
      left: 7%;
      top: calc(var(--raft-birth-top) + 54px);
      width: 86%;
      height: 26px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 50% 50%, rgba(255, 247, 232, .20), transparent 64%),
        linear-gradient(180deg, rgba(221, 232, 200, .13), rgba(221, 232, 200, 0));
      opacity: 0;
      filter: blur(12px);
      transform-origin: 50% 50%;
      pointer-events: none;
      animation: mellowRaftForcefieldPulse var(--duration) cubic-bezier(.33, .01, .19, 1) infinite;
      will-change: opacity, transform, filter;
      backface-visibility: hidden;
    }

    .mellow-clinical-raft-animation .raft-dot {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 1000;
      left: calc(3% + var(--x));
      top: calc(var(--raft-birth-top) + var(--y));
      width: var(--s, 4px);
      height: var(--s, 4px);
      border-radius: 999px;
      background: rgba(255, 247, 232, .42);
      box-shadow: none;
      opacity: 0;
      animation: mellowRaftDotsSHOWClean var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      pointer-events: none;
    }

