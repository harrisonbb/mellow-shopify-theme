{% comment %}
  MellowRaft™ mechanism animation
  Converted from the standalone mechanism animation into a scoped Shopify section.
{% endcomment %}

<section
  id="mellow-raft-animation-{{ section.id }}"
  class="mellow-raft-animation"
  data-mellow-raft-animation
  style="--mra-section-bg: {{ section.settings.background_color | default: '#F0EBE0' }};"
>
  <div class="mellow-raft-animation__inner">
    <div class="mellow-raft-animation__copy">
      {% if section.settings.eyebrow != blank %}
        <p class="mellow-raft-animation__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="mellow-raft-animation__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.body_copy != blank %}
        <div class="mellow-raft-animation__body">
          {{ section.settings.body_copy }}
        </div>
      {% endif %}
    </div>

    <div class="mellow-raft-animation__visual-card">
      <div class="mellow-raft-animation__stage" aria-label="Animation showing MellowRaft forming a gel raft above stomach acid">
        <div class="mellow-raft-animation__mechanism-label">
          {{ section.settings.mechanism_label | escape }}
        </div>

        <div class="mellow-raft-animation__callout mellow-raft-animation__callout--acid">
          <span>{{ section.settings.acid_label | escape }}</span>
        </div>

        <div class="mellow-raft-animation__callout mellow-raft-animation__callout--raft">
          <span>Gel raft</span>
          <i aria-hidden="true"></i>
        </div>

        <div class="mellow-raft-animation__stomach" aria-hidden="true">
          <div class="mellow-raft-animation__surface-line"></div>
          <div class="mellow-raft-animation__acid-pocket">
            <span class="mellow-raft-animation__acid-wave mellow-raft-animation__acid-wave--one"></span>
            <span class="mellow-raft-animation__acid-wave mellow-raft-animation__acid-wave--two"></span>
            <span class="mellow-raft-animation__acid-wave mellow-raft-animation__acid-wave--three"></span>
          </div>

          <div class="mellow-raft-animation__ingredient mellow-raft-animation__ingredient--one"></div>
          <div class="mellow-raft-animation__ingredient mellow-raft-animation__ingredient--two"></div>
          <div class="mellow-raft-animation__ingredient mellow-raft-animation__ingredient--three"></div>
          <div class="mellow-raft-animation__ingredient mellow-raft-animation__ingredient--four"></div>
          <div class="mellow-raft-animation__ingredient mellow-raft-animation__ingredient--five"></div>

          <div class="mellow-raft-animation__bubble mellow-raft-animation__bubble--one"></div>
          <div class="mellow-raft-animation__bubble mellow-raft-animation__bubble--two"></div>
          <div class="mellow-raft-animation__bubble mellow-raft-animation__bubble--three"></div>
          <div class="mellow-raft-animation__bubble mellow-raft-animation__bubble--four"></div>
          <div class="mellow-raft-animation__bubble mellow-raft-animation__bubble--five"></div>

          <div class="mellow-raft-animation__raft-hover">
            <div class="mellow-raft-animation__raft">
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--one"></span>
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--two"></span>
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--three"></span>
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--four"></span>
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--five"></span>
              <span class="mellow-raft-animation__raft-dot mellow-raft-animation__raft-dot--six"></span>
            </div>
          </div>
        </div>
      </div>

      {% if section.settings.show_controls %}
        <div class="mellow-raft-animation__controls" aria-label="MellowRaft animation controls">
          <button class="mellow-raft-animation__button" type="button" data-mra-replay>
            Replay animation
          </button>
          <button class="mellow-raft-animation__button" type="button" data-mra-toggle aria-pressed="false">
            Pause
          </button>
          <label class="mellow-raft-animation__speed">
            <span>Speed</span>
            <select data-mra-speed>
              <option value="0.75">0.75×</option>
              <option value="1" selected>1×</option>
              <option value="1.25">1.25×</option>
              <option value="1.5">1.5×</option>
            </select>
          </label>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#F0EBE0' }};
  }

  #mellow-raft-animation-{{ section.id }},
  #mellow-raft-animation-{{ section.id }} * {
    box-sizing: border-box;
  }

  #mellow-raft-animation-{{ section.id }} {
    --mra-forest: #1A2D10;
    --mra-ivory: #F0EBE0;
    --mra-warm-white: #FBFCF7;
    --mra-orange-red: #D04A2A;
    --mra-sage-light: #C8D4A5;
    --mra-sage-dark: #9EAF7C;
    --mra-speed: 1;
    --mra-duration: calc(9400ms / var(--mra-speed));
    position: relative;
    overflow: hidden;
    background: var(--mra-section-bg);
    color: var(--mra-forest);
    isolation: isolate;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__inner {
    width: min(100%, 1440px);
    margin: 0 auto;
    padding: clamp(64px, 8vw, 118px) clamp(20px, 4.5vw, 72px);
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
    gap: clamp(34px, 6vw, 92px);
    align-items: center;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__copy {
    max-width: 560px;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__eyebrow {
    margin: 0 0 14px;
    color: var(--mra-orange-red);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__heading {
    margin: 0;
    max-width: 680px;
    color: var(--mra-forest);
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(2.7rem, 6vw, 6.25rem);
    font-weight: 550;
    letter-spacing: -0.075em;
    line-height: 0.88;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__body {
    margin-top: clamp(18px, 2.6vw, 28px);
    color: rgba(26, 45, 16, 0.78);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: clamp(1rem, 1.25vw, 1.16rem);
    line-height: 1.62;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__body p {
    margin: 0;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__visual-card {
    width: 100%;
    border: 1px solid rgba(26, 45, 16, 0.12);
    border-radius: clamp(24px, 3vw, 38px);
    padding: clamp(16px, 2.2vw, 28px);
    background: linear-gradient(145deg, rgba(251, 252, 247, 0.92), rgba(240, 235, 224, 0.62));
    box-shadow: 0 28px 70px rgba(26, 45, 16, 0.12);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stage {
    position: relative;
    min-height: clamp(420px, 52vw, 620px);
    border-radius: clamp(20px, 2.6vw, 30px);
    overflow: hidden;
    background:
      radial-gradient(circle at 50% 12%, rgba(251, 252, 247, 0.98) 0 22%, rgba(251, 252, 247, 0) 48%),
      linear-gradient(180deg, rgba(240, 235, 224, 0.86) 0%, rgba(251, 252, 247, 0.96) 100%);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__mechanism-label,
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout {
    position: absolute;
    z-index: 8;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: clamp(0.72rem, 1.2vw, 0.84rem);
    font-weight: 800;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__mechanism-label {
    top: clamp(20px, 4vw, 34px);
    left: clamp(18px, 4vw, 38px);
    color: rgba(26, 45, 16, 0.52);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--acid {
    right: clamp(18px, 4vw, 38px);
    bottom: clamp(48px, 8vw, 74px);
    color: var(--mra-orange-red);
    opacity: 0;
    transform: translate3d(10px, 0, 0);
    animation: mraCalloutIn var(--mra-duration) cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft {
    top: 31%;
    right: clamp(15px, 3vw, 34px);
    color: var(--mra-forest);
    opacity: 0;
    transform: translate3d(8px, 0, 0);
    animation: mraRaftCallout var(--mra-duration) cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i {
    position: absolute;
    top: calc(50% - 1px);
    right: calc(100% + 9px);
    width: clamp(26px, 4vw, 42px);
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: right center;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i::before,
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i::after {
    content: '';
    position: absolute;
    left: -1px;
    width: 8px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i::before {
    transform: rotate(38deg);
    transform-origin: left center;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i::after {
    transform: rotate(-38deg);
    transform-origin: left center;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stomach {
    position: absolute;
    left: 50%;
    top: 52%;
    width: min(74%, 420px);
    aspect-ratio: 0.86;
    transform: translate3d(-50%, -45%, 0);
    border: 3px solid rgba(26, 45, 16, 0.22);
    border-radius: 47% 47% 42% 42% / 34% 34% 56% 56%;
    background: rgba(251, 252, 247, 0.72);
    box-shadow: inset 0 0 0 1px rgba(251, 252, 247, 0.78), 0 18px 46px rgba(26, 45, 16, 0.08);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__surface-line {
    position: absolute;
    left: 17%;
    right: 17%;
    top: 35.7%;
    z-index: 4;
    height: 1px;
    background: rgba(26, 45, 16, 0.14);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__acid-pocket {
    position: absolute;
    left: 10%;
    right: 10%;
    bottom: 8%;
    z-index: 1;
    height: 42%;
    overflow: hidden;
    border-radius: 48% 48% 40% 40% / 28% 28% 64% 64%;
    background: linear-gradient(180deg, rgba(208, 74, 42, 0.15) 0%, rgba(208, 74, 42, 0.42) 100%);
    opacity: 0;
    transform: translate3d(0, 26px, 0) scaleY(0.72);
    transform-origin: center bottom;
    animation: mraAcidRise var(--mra-duration) cubic-bezier(0.2, 0.76, 0.25, 1) both;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__acid-wave {
    position: absolute;
    left: 7%;
    right: 7%;
    height: 34px;
    border-top: 2px solid rgba(208, 74, 42, 0.58);
    border-radius: 50%;
    animation: mraWave calc(2700ms / var(--mra-speed)) ease-in-out infinite;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__acid-wave--one { top: 16%; animation-delay: calc(-100ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__acid-wave--two { top: 38%; opacity: 0.65; animation-delay: calc(-620ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__acid-wave--three { top: 60%; opacity: 0.42; animation-delay: calc(-1160ms / var(--mra-speed)); }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient,
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble {
    position: absolute;
    z-index: 3;
    border-radius: 999px;
    opacity: 0;
    will-change: transform, opacity;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient {
    width: 13px;
    height: 13px;
    background: var(--mra-sage-dark);
    box-shadow: 0 0 0 5px rgba(200, 212, 165, 0.26);
    animation: mraIngredient var(--mra-duration) cubic-bezier(0.22, 0.86, 0.28, 1) both;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient--one { left: 28%; top: 20%; animation-delay: calc(0ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient--two { left: 59%; top: 17%; animation-delay: calc(240ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient--three { left: 44%; top: 23%; animation-delay: calc(430ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient--four { left: 35%; top: 28%; animation-delay: calc(610ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__ingredient--five { left: 67%; top: 26%; animation-delay: calc(780ms / var(--mra-speed)); }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble {
    width: 9px;
    height: 9px;
    z-index: 2;
    background: rgba(251, 252, 247, 0.95);
    border: 1px solid rgba(158, 175, 124, 0.56);
    animation: mraBubble var(--mra-duration) cubic-bezier(0.22, 0.86, 0.28, 1) both;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble--one { left: 32%; bottom: 23%; animation-delay: calc(500ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble--two { left: 46%; bottom: 18%; animation-delay: calc(750ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble--three { left: 58%; bottom: 25%; animation-delay: calc(980ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble--four { left: 40%; bottom: 33%; animation-delay: calc(1210ms / var(--mra-speed)); }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__bubble--five { left: 63%; bottom: 33%; animation-delay: calc(1480ms / var(--mra-speed)); }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-hover {
    position: absolute;
    left: 50%;
    top: 33%;
    z-index: 5;
    width: 61%;
    height: 13%;
    transform: translate3d(-50%, 0, 0);
    animation: mraPremiumHover calc(5200ms / var(--mra-speed)) ease-in-out infinite;
    animation-delay: calc(8700ms / var(--mra-speed));
    will-change: transform;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft {
    position: absolute;
    inset: 0;
    border-radius: 999px 999px 48% 48% / 72% 72% 54% 54%;
    background: linear-gradient(180deg, var(--mra-sage-light) 0%, var(--mra-sage-dark) 100%);
    box-shadow: inset 0 2px 8px rgba(251, 252, 247, 0.62), 0 12px 24px rgba(26, 45, 16, 0.13);
    opacity: 0;
    transform: translate3d(0, 30px, 0) scaleX(0.34) scaleY(0.7);
    transform-origin: center bottom;
    animation: mraRaftForm var(--mra-duration) cubic-bezier(0.19, 0.88, 0.26, 1) both;
    will-change: transform, opacity;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft::after {
    content: '';
    position: absolute;
    left: 8%;
    right: 8%;
    top: 18%;
    height: 20%;
    border-radius: 999px;
    background: rgba(251, 252, 247, 0.22);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot {
    position: absolute;
    z-index: 2;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(26, 45, 16, 0.2);
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--one { left: 16%; top: 49%; }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--two { left: 30%; top: 35%; }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--three { left: 43%; top: 55%; }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--four { left: 57%; top: 36%; }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--five { left: 72%; top: 52%; }
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__raft-dot--six { left: 84%; top: 42%; }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: center;
    padding-top: 18px;
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__button,
  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__speed select {
    min-height: 42px;
    border: 1px solid rgba(26, 45, 16, 0.18);
    border-radius: 999px;
    background: var(--mra-warm-white);
    color: var(--mra-forest);
    font: inherit;
    font-size: 0.88rem;
    font-weight: 800;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__button {
    padding: 0 17px;
    cursor: pointer;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__speed {
    display: inline-flex;
    gap: 8px;
    align-items: center;
    color: rgba(26, 45, 16, 0.62);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__speed select {
    padding: 0 36px 0 14px;
  }

  #mellow-raft-animation-{{ section.id }}.is-paused .mellow-raft-animation__stage *,
  #mellow-raft-animation-{{ section.id }}.is-paused .mellow-raft-animation__callout {
    animation-play-state: paused !important;
  }

  #mellow-raft-animation-{{ section.id }}.is-replaying .mellow-raft-animation__stage *,
  #mellow-raft-animation-{{ section.id }}.is-replaying .mellow-raft-animation__callout {
    animation: none !important;
  }

  @keyframes mraAcidRise {
    0%, 9% { opacity: 0; transform: translate3d(0, 26px, 0) scaleY(0.72); }
    18%, 100% { opacity: 1; transform: translate3d(0, 0, 0) scaleY(1); }
  }

  @keyframes mraIngredient {
    0%, 12% { opacity: 0; transform: translate3d(0, -22px, 0) scale(0.8); }
    21% { opacity: 1; transform: translate3d(0, 116px, 0) scale(1); }
    43% { opacity: 1; transform: translate3d(0, 78px, 0) scale(0.92); }
    58%, 100% { opacity: 0; transform: translate3d(0, 56px, 0) scale(0.2); }
  }

  @keyframes mraBubble {
    0%, 23% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.55); }
    34% { opacity: 0.9; transform: translate3d(0, -42px, 0) scale(1); }
    52% { opacity: 0.82; transform: translate3d(0, -112px, 0) scale(0.9); }
    68%, 100% { opacity: 0; transform: translate3d(0, -155px, 0) scale(0.45); }
  }

  @keyframes mraRaftForm {
    0%, 36% { opacity: 0; transform: translate3d(0, 30px, 0) scaleX(0.34) scaleY(0.7); }
    53% { opacity: 0.95; transform: translate3d(0, 16px, 0) scaleX(0.78) scaleY(0.9); }
    70% { opacity: 1; transform: translate3d(0, 2px, 0) scaleX(1.02) scaleY(1); }
    82%, 100% { opacity: 1; transform: translate3d(0, 0, 0) scaleX(1) scaleY(1); }
  }

  @keyframes mraPremiumHover {
    0%, 100% { transform: translate3d(-50%, 0, 0); }
    50% { transform: translate3d(-50%, -3px, 0); }
  }

  @keyframes mraWave {
    0%, 100% { transform: translate3d(-6px, 0, 0); }
    50% { transform: translate3d(6px, 1px, 0); }
  }

  @keyframes mraCalloutIn {
    0%, 18% { opacity: 0; transform: translate3d(10px, 0, 0); }
    28%, 100% { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes mraRaftCallout {
    0%, 66% { opacity: 0; transform: translate3d(8px, 0, 0); }
    78%, 100% { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @media (max-width: 900px) {
    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__inner {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__copy {
      max-width: 720px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stage {
      min-height: clamp(390px, 92vw, 560px);
    }
  }

  @media (max-width: 560px) {
    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__inner {
      padding: 54px 16px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__visual-card {
      padding: 10px;
      border-radius: 24px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stage {
      min-height: 390px;
      border-radius: 20px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stomach {
      width: 86%;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft {
      top: 28%;
      right: 12px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout--raft i {
      width: 22px;
    }

    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__controls {
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__stage *,
    #mellow-raft-animation-{{ section.id }} .mellow-raft-animation__callout {
      animation-duration: 1ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 1ms !important;
    }
  }
</style>

<script>
  (() => {
    const section = document.getElementById('mellow-raft-animation-{{ section.id }}');
    if (!section) return;

    const replay = section.querySelector('[data-mra-replay]');
    const toggle = section.querySelector('[data-mra-toggle]');
    const speed = section.querySelector('[data-mra-speed]');

    if (speed) {
      speed.addEventListener('change', () => {
        section.style.setProperty('--mra-speed', speed.value);
      });
    }

    if (toggle) {
      toggle.addEventListener('click', () => {
        const isPaused = section.classList.toggle('is-paused');
        toggle.textContent = isPaused ? 'Play' : 'Pause';
        toggle.setAttribute('aria-pressed', String(isPaused));
      });
    }

    if (replay) {
      replay.addEventListener('click', () => {
        section.classList.remove('is-paused');
        if (toggle) {
          toggle.textContent = 'Pause';
          toggle.setAttribute('aria-pressed', 'false');
        }
        section.classList.add('is-replaying');
        section.offsetHeight;
        requestAnimationFrame(() => {
          section.classList.remove('is-replaying');
        });
      });
    }
  })();
</script>

