{% comment %}
  Mellow — Clinical Raft Animation
  Paste into: sections/mellow-clinical-raft-animation.liquid
{% endcomment %}

<div class="mellow-clinical-raft-animation" style="--duration: 8.8s;">
  <style>
    .mellow-clinical-raft-animation {
      --forest: #1A2D10;
      --forest-soft: rgba(26, 45, 16, 0.50);
      --orange: #D04A2A;
      --gold: #D6A64A;
      --cream: #F0EBE0;
      --page: #FBFCF7;
      --raft-birth-top: 31%;
      --raft-final-top: 31%;

      /* Acid-block system alignment */
      --acid-line-1: 30%;
      --acid-line-2: 55%;
      --acid-line-3: 72%;
      --acid-line-top: calc(var(--raft-final-top) + 58px);

      width: 100%;
      background: var(--page);
      padding: clamp(24px, 4vw, 64px);
      color: var(--forest);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .mellow-clinical-raft-animation,
    .mellow-clinical-raft-animation * {
      box-sizing: border-box;
    }


    /* Scroll-triggered: all animations paused until .is-playing is added */
    .mellow-clinical-raft-animation .drop,
    .mellow-clinical-raft-animation .ripple,
    .mellow-clinical-raft-animation .splash,
    .mellow-clinical-raft-animation .splash::before,
    .mellow-clinical-raft-animation .splash i,
    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .pb,
    .mellow-clinical-raft-animation .fragment,
    .mellow-clinical-raft-animation .raft-haze,
    .mellow-clinical-raft-animation .raft,
    .mellow-clinical-raft-animation .raft-dot,
    .mellow-clinical-raft-animation .heat,
    .mellow-clinical-raft-animation .raft-label,
    .mellow-clinical-raft-animation .droplet-callout,
    .mellow-clinical-raft-animation .formation-callout,
    .mellow-clinical-raft-animation .callout {
      animation-play-state: paused;
    }

    .mellow-clinical-raft-animation.is-playing .drop,
    .mellow-clinical-raft-animation.is-playing .ripple,
    .mellow-clinical-raft-animation.is-playing .splash,
    .mellow-clinical-raft-animation.is-playing .splash::before,
    .mellow-clinical-raft-animation.is-playing .splash i,
    .mellow-clinical-raft-animation.is-playing .particle,
    .mellow-clinical-raft-animation.is-playing .pb,
    .mellow-clinical-raft-animation.is-playing .fragment,
    .mellow-clinical-raft-animation.is-playing .raft-haze,
    .mellow-clinical-raft-animation.is-playing .raft,
    .mellow-clinical-raft-animation.is-playing .raft-dot,
    .mellow-clinical-raft-animation.is-playing .heat,
    .mellow-clinical-raft-animation.is-playing .raft-label,
    .mellow-clinical-raft-animation.is-playing .droplet-callout,
    .mellow-clinical-raft-animation.is-playing .formation-callout,
    .mellow-clinical-raft-animation.is-playing .callout {
      animation-play-state: running;
    }

    .mellow-clinical-raft-animation .raft-shell {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(28px, 5vw, 72px);
      align-items: center;
      background:
        radial-gradient(circle at 10% 14%, rgba(214, 166, 74, .12), transparent 34%),
        linear-gradient(135deg, #faf8f2 0%, #ffffff 58%, #f8f5ec 100%);
      border: 1px solid rgba(26, 45, 16, .12);
      border-radius: 34px;
      box-shadow: 0 28px 80px rgba(26, 45, 16, .08);
      padding: clamp(22px, 4vw, 56px);
    }

    .mellow-clinical-raft-animation .raft-copy-eyebrow {
      display: block;
      margin-bottom: 18px;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--orange);
    }

    .mellow-clinical-raft-animation .raft-copy h2 {
      margin: 0 0 22px;
      color: var(--forest);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(42px, 5.4vw, 76px);
      line-height: .94;
      letter-spacing: -0.06em;
    }

    .mellow-clinical-raft-animation .raft-copy p {
      max-width: 520px;
      margin: 0;
      color: #687064;
      font-size: clamp(16px, 1.5vw, 19px);
      line-height: 1.65;
      letter-spacing: .02em;
    }

    .mellow-clinical-raft-animation .device {
      position: relative;
      aspect-ratio: 1.56 / 1;
      min-height: 360px;
      border-radius: 26px;
      padding: clamp(18px, 2.2vw, 28px);
      background: rgba(255, 255, 255, .62);
      border: 1px solid rgba(26, 45, 16, .12);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, .58);
    }

    .mellow-clinical-raft-animation .mechanism {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 320px;
      overflow: hidden;
      border-radius: 24px;
      background:
        radial-gradient(circle at 48% 78%, rgba(208, 74, 42, .08), transparent 34%),
        linear-gradient(180deg, #e5dfd2 0%, #eee9dd 72%, #e7e0d1 100%);
    }

    .mellow-clinical-raft-animation .layer-label {
      position: absolute;
      z-index: 60;
      top: 20px;
      left: 24px;
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, .78);
      border: 1px solid rgba(26, 45, 16, .08);
      color: var(--forest);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
      box-shadow: 0 6px 18px rgba(26, 45, 16, .05);
    }

    .mellow-clinical-raft-animation .acid-label {
      position: absolute;
      z-index: 60;
      left: 24px;
      bottom: 22px;
      padding: 11px 16px;
      border-radius: 999px;
      background: rgba(255, 255, 255, .74);
      border: 1px solid rgba(26, 45, 16, .08);
      color: var(--orange);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .mellow-clinical-raft-animation .callout {
      position: absolute;
      z-index: 59;
      left: 230px !important;
      right: auto !important;
      top: 52px !important;
      width: 82px !important;
      height: 48px !important;
      pointer-events: none;
      opacity: 0;
      transform: none !important;
      animation: mellowRaftCalloutAppearClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .callout path,
    .mellow-clinical-raft-animation .callout polyline {
      fill: none;
      stroke: var(--forest-soft);
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .mellow-clinical-raft-animation .droplet-callout {
      position: absolute;
      z-index: 70;
      top: 92px;
      right: 72px;
      display: inline-flex;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      animation: mellowRaftMellowEntersClean var(--duration) cubic-bezier(.32,.02,.2,1) infinite;
    }

    .mellow-clinical-raft-animation .formation-callout {
      position: absolute;
      z-index: 70;
      top: 132px;
      right: 72px;
      display: inline-flex;
      align-items: center;
      opacity: 0;
      pointer-events: none;
      animation: mellowRaftBeginsClean var(--duration) cubic-bezier(.32,.02,.2,1) infinite;
    }

    .mellow-clinical-raft-animation .droplet-callout__pill,
    .mellow-clinical-raft-animation .formation-callout__pill {
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,.74);
      border: 1px solid rgba(26,45,16,.075);
      color: rgba(26,45,16,.82);
      font-size: 10px;
      font-weight: 850;
      letter-spacing: .075em;
      text-transform: uppercase;
      box-shadow: 0 6px 14px rgba(26,45,16,.045);
      white-space: nowrap;
    }

    .mellow-clinical-raft-animation .formation-callout__pill {
      color: rgba(26,45,16,.78);
      background: rgba(255,255,255,.70);
    }

    .mellow-clinical-raft-animation .acid {
      position: absolute;
      z-index: 1;
      left: 0;
      right: 0;
      bottom: 0;
      height: 22%;
      background: linear-gradient(180deg, rgba(208, 74, 42, .015), rgba(208, 74, 42, .12));
      opacity: .9;
    }

    .mellow-clinical-raft-animation .acid::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: -10px;
      height: 18px;
      background:
        linear-gradient(
          90deg,
          transparent 0%,
          rgba(208, 74, 42, .08) 16%,
          rgba(208, 74, 42, .14) 34%,
          rgba(208, 74, 42, .08) 52%,
          rgba(208, 74, 42, .13) 72%,
          transparent 100%
        );
      opacity: .55;
      filter: blur(6px);
    }

    .mellow-clinical-raft-animation .drop {
      position: absolute;
      z-index: 20;
      width: 26px;
      height: 34px;
      opacity: 0;
      transform-origin: 50% 70%;
      filter: drop-shadow(0 8px 14px rgba(26, 45, 16, .12));
      animation: mellowRaftDropletFallClean var(--duration) cubic-bezier(.32, .02, .2, 1) infinite;
    }

    .mellow-clinical-raft-animation .drop svg {
      display: block;
      width: 100%;
      height: 100%;
    }

    .mellow-clinical-raft-animation .drop-1 {
      left: 27%;
      top: 18%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .drop-2 {
      left: 49%;
      top: 22%;
      width: 22px;
      height: 29px;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .drop-3 {
      left: 67%;
      top: 16%;
      width: 19px;
      height: 25px;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .ripple {
      position: absolute;
      z-index: 19;
      width: 34px;
      height: 10px;
      border-radius: 999px;
      border: 1.5px solid rgba(228, 184, 90, .54);
      opacity: 0;
      animation: mellowRaftRippleClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .ripple-1 {
      left: calc(27% - 4px);
      bottom: 20%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .ripple-2 {
      left: calc(49% - 4px);
      bottom: 20%;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .ripple-3 {
      left: calc(67% - 4px);
      bottom: 20%;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .splash {
      position: absolute;
      z-index: 24;
      bottom: 20%;
      width: 44px;
      height: 28px;
      pointer-events: none;
      opacity: 0;
      transform: translateX(-50%);
      animation: mellowRaftSplashClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .splash::before {
      content: "";
      position: absolute;
      left: 50%;
      bottom: 0;
      width: 28px;
      height: 7px;
      border-radius: 999px;
      background: rgba(228, 184, 90, .24);
      filter: blur(2px);
      transform: translateX(-50%) scaleX(.4);
      opacity: 0;
      animation: mellowRaftSplashBaseClean var(--duration) ease-out infinite;
    }

    .mellow-clinical-raft-animation .splash i {
      position: absolute;
      left: 50%;
      bottom: 2px;
      width: var(--s, 4px);
      height: var(--s, 4px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .70));
      box-shadow: 0 0 8px rgba(228, 184, 90, .45);
      opacity: 0;
      transform: translate(-50%, 0) scale(.4);
      animation: mellowRaftSplashDotClean var(--duration) cubic-bezier(.2,.4,.12,1) infinite;
    }

    .mellow-clinical-raft-animation .splash-1 {
      left: 28%;
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .splash-1::before,
    .mellow-clinical-raft-animation .splash-1 i {
      animation-delay: 0s;
    }

    .mellow-clinical-raft-animation .splash-2 {
      left: 50%;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .splash-2::before,
    .mellow-clinical-raft-animation .splash-2 i {
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .splash-3 {
      left: 68%;
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .splash-3::before,
    .mellow-clinical-raft-animation .splash-3 i {
      animation-delay: .34s;
    }

    .mellow-clinical-raft-animation .particle,
    .mellow-clinical-raft-animation .pb {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 997;
      width: var(--s, 6px);
      height: var(--s, 6px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .68));
      box-shadow: 0 0 13px rgba(228, 184, 90, .72);
      opacity: 0;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .particle {
      animation: mellowRaftParticleSHOWClean var(--duration) cubic-bezier(.2, .2, .12, 1) infinite;
    }

    .mellow-clinical-raft-animation .pb {
      left: var(--x0);
      bottom: 20%;
      animation: mellowRaftBubbleSHOWClean var(--duration) cubic-bezier(.18, .28, .12, 1) infinite;
    }

    .mellow-clinical-raft-animation .p1 {
      --s: 8px;
      --c: rgba(255, 247, 232, .68);
      left: 28%;
      bottom: 20%;
      --x: 10px;
      --y: -145px;
      animation-delay: .03s;
    }

    .mellow-clinical-raft-animation .p2 {
      --s: 6px;
      --c: rgba(228, 184, 90, .54);
      left: 31%;
      bottom: 20%;
      --x: -16px;
      --y: -128px;
      animation-delay: .06s;
    }

    .mellow-clinical-raft-animation .p3 {
      --s: 5px;
      --c: rgba(184, 201, 130, .56);
      left: 47%;
      bottom: 20%;
      --x: 22px;
      --y: -150px;
      animation-delay: .09s;
    }

    .mellow-clinical-raft-animation .p4 {
      --s: 7px;
      --c: rgba(255, 247, 232, .68);
      left: 51%;
      bottom: 20%;
      --x: -8px;
      --y: -132px;
      animation-delay: .12s;
    }

    .mellow-clinical-raft-animation .p5 {
      --s: 6px;
      --c: rgba(228, 184, 90, .54);
      left: 66%;
      bottom: 20%;
      --x: 12px;
      --y: -152px;
      animation-delay: .15s;
    }

    .mellow-clinical-raft-animation .p6 {
      --s: 4px;
      --c: rgba(184, 201, 130, .56);
      left: 69%;
      bottom: 20%;
      --x: -20px;
      --y: -126px;
      animation-delay: .18s;
    }

    .mellow-clinical-raft-animation .fragment {
      position: absolute;
      z-index: 35;
      height: 18px;
      top: 49%;
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255, 247, 232, .68), rgba(184, 201, 130, .56));
      border: 0;
      filter: blur(4px);
      opacity: 0;
      animation: mellowRaftFragmentBuildClean var(--duration) ease-in-out infinite;
    }

    .mellow-clinical-raft-animation .f1 {
      left: 24%;
      width: 58px;
    }

    .mellow-clinical-raft-animation .f2 {
      left: 38%;
      width: 74px;
      animation-delay: .05s;
    }

    .mellow-clinical-raft-animation .f3 {
      left: 53%;
      width: 88px;
      animation-delay: .1s;
    }

    .mellow-clinical-raft-animation .f4 {
      left: 69%;
      width: 60px;
      animation-delay: .15s;
    }

    .mellow-clinical-raft-animation .raft-haze {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 998;
      left: 17%;
      top: var(--raft-birth-top);
      width: 70%;
      height: 38px;
      border-radius: 999px;
      background:
        radial-gradient(circle at 22% 50%, rgba(255, 247, 232, .38), transparent 18%),
        radial-gradient(circle at 46% 48%, rgba(228, 184, 90, .22), transparent 16%),
        radial-gradient(circle at 70% 52%, rgba(184, 201, 130, .28), transparent 18%),
        linear-gradient(180deg, rgba(255, 247, 232, .22), rgba(184, 201, 130, .18));
      opacity: 0;
      filter: blur(10px);
      transform-origin: 50% 50%;
      animation: mellowRaftHazeSHOWClean var(--duration) ease-in-out infinite;
    }

    .mellow-clinical-raft-animation .raft {
      display: block !important;
      visibility: visible !important;
      position: absolute !important;
      z-index: 999 !important;
      left: 17% !important;
      top: var(--raft-birth-top) !important;
      width: 70% !important;
      height: 58px !important;
      border-radius: 999px;
      background:
        linear-gradient(180deg, rgba(242, 248, 214, .96) 0%, rgba(202, 218, 151, .94) 56%, rgba(157, 180, 109, .88) 100%);
      border: none !important;
      outline: none !important;
      box-shadow:
        inset 0 12px 18px rgba(255, 255, 235, .25),
        0 12px 26px rgba(17, 31, 18, .08);
      opacity: 0;
      transform-origin: 50% 50%;
      animation: mellowRaftGelSHOWClean var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      will-change: opacity, transform, filter;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .raft::before,
    .mellow-clinical-raft-animation .raft::after {
      content: none !important;
      display: none !important;
      border: 0 !important;
      outline: 0 !important;
    }

    .mellow-clinical-raft-animation .raft-dot {
      display: block !important;
      visibility: visible !important;
      position: absolute;
      z-index: 1000;
      left: calc(17% + var(--x));
      top: calc(var(--raft-birth-top) + var(--y));
      width: var(--s, 4px);
      height: var(--s, 4px);
      border-radius: 999px;
      background: var(--c, rgba(255, 247, 232, .72));
      box-shadow: 0 0 6px rgba(255, 247, 232, .18);
      opacity: 0;
      animation: mellowRaftDotsSHOWClean var(--duration) cubic-bezier(.22, .75, .22, 1) infinite;
      pointer-events: none;
    }

    .mellow-clinical-raft-animation .heat {
      position: absolute;
      z-index: 25;
      top: var(--acid-line-top) !important;
      width: 34px !important;
      height: 122px !important;
      opacity: 0;
      overflow: visible;
      animation: mellowRaftHeatRiseClean var(--duration) ease-in-out infinite;
    }

    .mellow-clinical-raft-animation .heat svg {
      width: 100%;
      height: 100%;
      overflow: visible;
    }

    .mellow-clinical-raft-animation .heat path {
      fill: none;
      stroke: rgba(208, 74, 42, .82);
      stroke-width: 3.8;
      stroke-linecap: round;
      filter:
        drop-shadow(0 0 5px rgba(208, 74, 42, .22))
        drop-shadow(0 0 12px rgba(208, 74, 42, .12));
    }

    .mellow-clinical-raft-animation .h1 {
      left: calc(var(--acid-line-1) - 3px);
      animation-delay: .05s;
    }

    .mellow-clinical-raft-animation .h2 {
      left: calc(var(--acid-line-2) - 3px);
      animation-delay: .2s;
    }

    .mellow-clinical-raft-animation .h3 {
      left: calc(var(--acid-line-3) - 3px);
      animation-delay: .1s;
    }





    @keyframes mellowRaftCalloutAppearClean {
      0%, 66% {
        opacity: 0;
        transform: translateY(3px);
      }

      72%, 100% {
        opacity: .9;
        transform: translateY(0);
      }
    }

    @keyframes mellowRaftMellowEntersClean {
      0%, 3% {
        opacity: 0;
        transform: translateY(-3px) scale(.98);
      }

      6%, 20% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      25%, 100% {
        opacity: 0;
        transform: translateY(3px) scale(.98);
      }
    }

    @keyframes mellowRaftBeginsClean {
      0%, 18% {
        opacity: 0;
        transform: translateY(4px) scale(.98);
      }

      23%, 40% {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      44%, 100% {
        opacity: 0;
        transform: translateY(-3px) scale(.98);
      }
    }

    @keyframes mellowRaftDropletFallClean {
      0%, 4% {
        opacity: 0;
        transform: translateY(-18px) scale(.82) rotate(-8deg);
      }

      8% {
        opacity: 1;
      }

      18% {
        opacity: 1;
        transform: translateY(168px) scale(1) rotate(6deg);
      }

      22% {
        opacity: 0;
        transform: translateY(177px) scale(1.18, .68) rotate(2deg);
      }

      100% {
        opacity: 0;
        transform: translateY(177px) scale(1.18, .68);
      }
    }

    @keyframes mellowRaftRippleClean {
      0%, 12% {
        opacity: 0;
        transform: scale(.3);
      }

      14% {
        opacity: .75;
        transform: scale(.7);
      }

      21% {
        opacity: 0;
        transform: scale(1.8);
      }

      100% {
        opacity: 0;
      }
    }

    @keyframes mellowRaftSplashClean {
      0%, 16% {
        opacity: 0;
      }

      18% {
        opacity: 1;
      }

      25%, 100% {
        opacity: 0;
      }
    }

    @keyframes mellowRaftSplashBaseClean {
      0%, 16% {
        opacity: 0;
        transform: translateX(-50%) scaleX(.3);
      }

      18% {
        opacity: .72;
        transform: translateX(-50%) scaleX(.75);
      }

      24% {
        opacity: 0;
        transform: translateX(-50%) scaleX(1.45);
      }

      100% {
        opacity: 0;
        transform: translateX(-50%) scaleX(1.45);
      }
    }

    @keyframes mellowRaftSplashDotClean {
      0%, 16% {
        opacity: 0;
        transform: translate(-50%, 0) scale(.35);
      }

      18% {
        opacity: .9;
        transform: translate(-50%, 0) scale(.75);
      }

      24% {
        opacity: 0;
        transform:
          translate(
            calc(-50% + var(--dx)),
            var(--dy)
          )
          scale(.35);
      }

      100% {
        opacity: 0;
        transform:
          translate(
            calc(-50% + var(--dx)),
            var(--dy)
          )
          scale(.35);
      }
    }

    @keyframes mellowRaftParticleSHOWClean {
      0%, 12% {
        opacity: 0;
        transform: translate(0, 0) scale(.55);
      }

      18% {
        opacity: .95;
        transform: translate(0, 0) scale(.75);
      }

      30% {
        opacity: .9;
        transform: translate(calc(var(--x) * .45), calc(var(--y) * .58)) scale(1);
      }

      42% {
        opacity: .45;
        transform: translate(var(--x), var(--y)) scale(.75);
