  </div>

  <script>
    (function () {
      function initRaftObserver() {
        var el = document.querySelector('.mellow-clinical-raft-animation');
        if (!el) return;

        if (!('IntersectionObserver' in window)) {
          el.classList.add('is-playing');
          return;
        }

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              el.classList.add('is-playing');
            } else {
              el.classList.remove('is-playing');
            }
          });
        }, { threshold: 0.25 });

        observer.observe(el);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRaftObserver);
      } else {
        initRaftObserver();
      }
    })();
  </script>
</div>

