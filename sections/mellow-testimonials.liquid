  #shopify-section-{{ section.id }} .mellow-section--cream,
  #shopify-section-{{ section.id }} .mellow-testimonials,
  .shopify-section:has(.mellow-testimonials-{{ section.id }}) {
    background: #FBFCF7 !important;
    background-color: #FBFCF7 !important;
    background-image: none !important;
    margin: 0 !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    width: 100% !important;
    max-width: none !important;
  }

