          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "It feels easy enough to stick with: one pouch after dinner, no measuring, and no big bottle on my nightstand.",
            "name": "Priya N.",
            "avatar_initials": "PN",
            "detail": "Verified buyer · Nighttime routine"
          }
        }
      ]
    }
  ]
}
{% endschema %}