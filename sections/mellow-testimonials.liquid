  }

  @media screen and (min-width: 1500px) {
    #shopify-section-{{ section.id }} .mellow-testimonials {
      --mellow-testimonials-axis-pad: clamp(128px, 8.5vw, 168px);
      padding-top: 112px !important;
      padding-bottom: 104px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__top {
      margin-bottom: 52px !important;
      max-width: 900px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__headline {
      max-width: 900px !important;
      font-size: clamp(3.65rem, 4vw, 5.85rem) !important;
      line-height: 1.02 !important;
      letter-spacing: -0.044em !important;
      font-weight: 550 !important;
      font-variation-settings: "opsz" 84, "wght" 550 !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__subhead {
      max-width: 660px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__grid {
      gap: 22px !important;
      margin-bottom: 34px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__card {
      min-height: 300px !important;
      padding: 32px 30px 28px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__cta-wrap {
      margin-bottom: 28px !important;
    }
  }

  @media (max-width: 1100px) {
    #shopify-section-{{ section.id }} .mellow-testimonials {
      --mellow-testimonials-axis-pad: 32px;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__headline {
      max-width: 820px !important;
      font-size: clamp(2.85rem, 7.5vw, 4.65rem) !important;
      line-height: 1.03 !important;
      letter-spacing: -0.036em !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__subhead {
      max-width: 680px !important;
    }
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .mellow-testimonials__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 16px !important;
    }
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .mellow-testimonials {
      --mellow-testimonials-axis-pad: 20px;
      padding-top: 58px !important;
      padding-bottom: 62px !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__top {
      margin-bottom: 30px !important;
      max-width: 100% !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials .mellow-eyebrow {
      margin-bottom: 14px !important;
      font-size: 0.7rem !important;
      letter-spacing: 0.115em !important;
    }

    #shopify-section-{{ section.id }} .mellow-testimonials__headline {
      max-width: 100% !important;
      font-size: clamp(2.35rem, 10vw, 3.55rem) !important;
