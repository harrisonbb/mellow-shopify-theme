  #shopify-section-{{ section.id }}::after,
  #shopify-section-{{ section.id }} .mellow-testimonials::before,
  #shopify-section-{{ section.id }} .mellow-testimonials::after,
  #shopify-section-{{ section.id }} .mellow-section::before,
  #shopify-section-{{ section.id }} .mellow-section::after {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials,
