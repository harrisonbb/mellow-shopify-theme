{% comment %}
  Mellow Testimonials
  Edit:
  - Background changed to match the main site white: #FBFCF7
  - Hard override applied to Shopify wrapper, section, container, and pseudo layers
  - Removed pale green / warm beige background from this section
  - Kept testimonial cards, avatars, CTA, and layout intact
  - Typography matched to Mellow Hero system:
    Fraunces 550 heading, hero-like spacing, DM Sans body/card rhythm
{% endcomment %}

<section class="mellow-section mellow-section--cream mellow-testimonials mellow-testimonials-{{ section.id }}">
  <div class="mellow-container">

    <div class="mellow-testimonials__top">
      <span class="mellow-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="mellow-testimonials__headline mellow-heading-split">{% render 'mellow-split-heading', text: section.settings.headline %}</h2>
      <p class="mellow-testimonials__subhead">{{ section.settings.subhead }}</p>
    </div>

    <div class="mellow-testimonials__grid">
      {% for block in section.blocks %}
        {% assign avatar_initials = block.settings.avatar_initials %}

        {% if avatar_initials == blank %}
          {% assign name_parts = block.settings.name | split: ' ' %}
          {% assign first_initial = name_parts[0] | slice: 0, 1 %}
          {% assign second_initial = name_parts[1] | slice: 0, 1 %}
          {% assign avatar_initials = first_initial | append: second_initial %}
        {% endif %}

        <div class="mellow-testimonials__card" {{ block.shopify_attributes }}>
          <div class="mellow-testimonials__stars">
            ★★★★★
          </div>

          <p class="mellow-testimonials__quote">{{ block.settings.quote }}</p>

          <div class="mellow-testimonials__author">
            <span class="mellow-testimonials__avatar">{{ avatar_initials }}</span>

            <span class="mellow-testimonials__author-copy">
              <span class="mellow-testimonials__name">{{ block.settings.name }}</span>
              <span class="mellow-testimonials__detail">{{ block.settings.detail }}</span>
            </span>
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="mellow-testimonials__cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="mellow-testimonials__cta">
        {{ section.settings.cta_label }}
      </a>
    </div>

    <div class="mellow-testimonials__summary">
      <span class="mellow-testimonials__summary-stars">★★★★★</span>
      <span class="mellow-testimonials__summary-text">{{ section.settings.summary_text }}</span>
    </div>

  </div>
</section>

<style>
  /* =========================================================
     TESTIMONIALS — MAIN SITE WHITE BACKGROUND MATCH
     Typography aligned with Mellow Hero system
     ========================================================= */

  #shopify-section-{{ section.id }},
