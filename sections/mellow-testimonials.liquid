  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "avatar_initials",
          "label": "Avatar initials"
        },
        {
          "type": "text",
          "id": "detail",
          "label": "Detail"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mellow Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "I was used to popping tablets after reflux already started. Mellow feels more like I'm getting ahead of it.",
