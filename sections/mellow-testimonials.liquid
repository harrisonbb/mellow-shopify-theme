  #shopify-section-{{ section.id }} .mellow-testimonials__top {
    text-align: left !important;
    margin: 0 0 clamp(34px, 3.2vw, 48px) !important;
    max-width: 820px !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials .mellow-eyebrow {
    display: inline-block !important;
    margin: 0 0 14px !important;

    color: var(--mellow-orange-red) !important;
    font-family: var(--font-body) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.12em !important;
    text-transform: uppercase !important;
    text-align: left !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__headline {
    margin: 0 0 18px !important;
    max-width: 820px !important;

    color: var(--mellow-forest) !important;
    font-family: var(--font-heading) !important;
    font-size: clamp(3rem, 4.05vw, 5.25rem) !important;
    line-height: 1.02 !important;
    letter-spacing: -0.043em !important;
    font-weight: 550 !important;
    font-style: normal !important;
    font-variation-settings: "opsz" 72, "wght" 550 !important;
    text-align: left !important;
    text-wrap: balance !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__subhead {
