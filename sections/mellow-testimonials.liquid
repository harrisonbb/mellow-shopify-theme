      inset 0 1px 0 rgba(255, 255, 255, 0.9) !important;

    border: 1px solid rgba(26, 45, 16, 0.10) !important;

    transition:
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__card:hover {
    transform: translateY(-4px) !important;
    border-color: rgba(26, 45, 16, 0.16) !important;
    box-shadow:
      0 26px 64px rgba(26, 45, 16, 0.095),
      inset 0 1px 0 rgba(255, 255, 255, 0.95) !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__stars {
    color: var(--mellow-orange-red) !important;
    font-family: var(--font-body) !important;
    font-size: 0.98rem !important;
    letter-spacing: 0.08em !important;
    line-height: 1 !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__quote {
    font-family: var(--font-body) !important;
    font-size: clamp(0.98rem, 1.04vw, 1.08rem) !important;
    line-height: 1.62 !important;
    color: rgba(26, 45, 16, 0.92) !important;
    margin: 0 !important;
    flex: 1 !important;
    text-align: left !important;
    letter-spacing: -0.012em !important;
    font-weight: 500 !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__author {
    display: flex !important;
    align-items: center !important;
    gap: 12px !important;
    padding-top: 18px !important;
    border-top: 1px solid rgba(26, 45, 16, 0.12) !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__avatar {
    width: 40px !important;
    height: 40px !important;
    border-radius: 999px !important;
    background: var(--mellow-forest) !important;
    color: var(--mellow-warm-white) !important;

    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    flex-shrink: 0 !important;

    font-family: var(--font-body) !important;
    font-size: 0.78rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: 0.04em !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__author-copy {
    display: flex !important;
    flex-direction: column !important;
    gap: 4px !important;
    min-width: 0 !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__name {
    font-family: var(--font-body) !important;
    font-size: 0.9rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;
    color: var(--mellow-forest) !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__detail {
    font-family: var(--font-body) !important;
    font-size: 0.78rem !important;
    line-height: 1.25 !important;
    letter-spacing: -0.005em !important;
    color: rgba(26, 45, 16, 0.62) !important;
    font-weight: 500 !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__cta-wrap {
    display: flex !important;
    justify-content: center !important;
    margin: 4px 0 24px !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__cta {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;

    min-height: 54px !important;
    padding: 0 38px !important;
    border-radius: 999px !important;

    background: var(--mellow-orange-red) !important;
    background-color: var(--mellow-orange-red) !important;

    color: #FFFFFF !important;
    font-family: var(--font-body) !important;
    font-size: 0.96rem !important;
    line-height: 1 !important;
    font-weight: 800 !important;
    letter-spacing: -0.01em !important;
    text-decoration: none !important;

    border: 1px solid var(--mellow-orange-red) !important;

    box-shadow:
      0 16px 34px rgba(208, 74, 42, 0.22),
      0 0 0 0 rgba(208, 74, 42, 0) !important;

    transition:
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__cta:hover {
    background: #B93E24 !important;
    background-color: #B93E24 !important;
    border-color: #B93E24 !important;
    color: #FFFFFF !important;
    transform: translateY(-2px) !important;
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.28),
      0 0 0 6px rgba(208, 74, 42, 0.08) !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__summary {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 12px !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__summary-stars {
    color: var(--mellow-orange-red) !important;
    font-family: var(--font-body) !important;
    font-size: 1.05rem !important;
    letter-spacing: 0.08em !important;
    line-height: 1 !important;
  }

  #shopify-section-{{ section.id }} .mellow-testimonials__summary-text {
    font-family: var(--font-body) !important;
    font-size: 0.88rem !important;
    color: rgba(26, 45, 16, 0.64) !important;
    letter-spacing: -0.005em !important;
    line-height: 1.35 !important;
