{%- liquid
  assign hero_eyebrow = section.settings.eyebrow | strip
  assign headline_primary = section.settings.headline_primary | strip
  assign headline_accent = section.settings.headline_accent | strip
  assign hero_text = section.settings.text | strip
  assign primary_label = section.settings.primary_label | strip
  assign primary_link = section.settings.primary_link | default: '/products/mellow-reflux-relief-gel'
  assign secondary_label = section.settings.secondary_label | strip
  assign secondary_link = section.settings.secondary_link | default: '/pages/quiz'
  assign helper_text = section.settings.helper_text | strip
  assign trust_line = section.settings.trust_line | strip
  assign hero_image = section.settings.hero_image
  assign hero_image_alt = hero_image.alt | default: 'Mellow packaging image' | strip
  assign hero_background_image = section.settings.hero_background_image
-%}

<style>
  #MellowHero-{{ section.id }} {
    background: var(--mellow-ivory, #F0EBE0);
    {%- if hero_background_image != blank %}
      background-image: url('{{ hero_background_image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {%- endif %}
    color: var(--mellow-forest, #003302);
    padding-top: var(--mellow-section-pad-bottom);
    padding-bottom: var(--mellow-section-content-gap-compact);
  }

  #MellowHero-{{ section.id }} .mellow-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, var(--mellow-header-max)) minmax(300px, 0.78fr);
    align-items: center;
    column-gap: var(--mellow-section-content-gap);
    row-gap: var(--mellow-section-content-gap-compact);
  }

  #MellowHero-{{ section.id }} .mellow-hero__content {
    max-width: var(--mellow-header-max);
  }

  #MellowHero-{{ section.id }} .mellow-hero__heading {
    max-width: var(--mellow-header-max);
    text-wrap: balance;
  }

  #MellowHero-{{ section.id }} .mellow-hero__heading-line {
    display: block;
  }

  #MellowHero-{{ section.id }} .mellow-hero__heading-line--accent {
    color: var(--mellow-orange-red, #D04A2A);
    font-style: italic;
  }

  #MellowHero-{{ section.id }} .mellow-hero__text {
    max-width: var(--mellow-copy-max);
    color: var(--mellow-muted, #5E6B58);
  }

  #MellowHero-{{ section.id }} .mellow-hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(10px, 1vw, 14px);
    margin-top: var(--mellow-section-content-gap-compact);
  }

  #MellowHero-{{ section.id }} .mellow-hero__cta-wrap {
    width: auto;
    justify-content: flex-start;
  }

  #MellowHero-{{ section.id }} .mellow-hero__helper {
    max-width: var(--mellow-copy-max);
    margin: var(--mellow-section-header-gap) 0 0;
    color: rgba(0, 51, 2, 0.68);
    font-size: clamp(14px, 0.96vw, 15px);
    line-height: 1.45;
  }

  #MellowHero-{{ section.id }} .mellow-hero__media {
    justify-self: end;
    width: min(100%, 440px);
  }

  #MellowHero-{{ section.id }} .mellow-hero__image-frame {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: clamp(240px, 28vw, 380px);
    overflow: hidden;
  }

  #MellowHero-{{ section.id }} .mellow-hero__image {
    display: block;
    width: 100%;
    max-height: clamp(240px, 26vw, 360px);
    object-fit: contain;
  }

  #MellowHero-{{ section.id }} .mellow-hero__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 220px);
    min-height: 96px;
    padding: var(--mellow-card-pad-tight);
    border-radius: var(--mellow-radius-card, 28px);
    background: rgba(0, 51, 2, 0.04);
    color: rgba(0, 51, 2, 0.56);
    font-size: var(--mellow-eyebrow-size);
    font-weight: var(--mellow-eyebrow-weight);
    letter-spacing: var(--mellow-eyebrow-tracking);
    line-height: var(--mellow-eyebrow-line-height);
    text-transform: uppercase;
  }

  #MellowHero-{{ section.id }} .mellow-hero__proof {
    grid-column: 1 / -1;
    max-width: var(--mellow-copy-max);
    margin: 0;
    padding-top: var(--mellow-section-heading-gap);
    border-top: 1px solid var(--mellow-border, rgba(0, 51, 2, 0.14));
    color: rgba(0, 51, 2, 0.74);
    font-size: var(--mellow-card-copy-size);
    line-height: var(--mellow-card-copy-line-height);
    letter-spacing: var(--mellow-card-copy-tracking);
    text-wrap: balance;
  }

  @media screen and (max-width: 989px) {
    #MellowHero-{{ section.id }} .mellow-hero__inner {
      grid-template-columns: 1fr;
      align-items: start;
      gap: var(--mellow-section-content-gap-compact);
    }

    #MellowHero-{{ section.id }} .mellow-hero__media {
      justify-self: start;
      width: min(100%, 520px);
    }

    #MellowHero-{{ section.id }} .mellow-hero__proof {
      max-width: var(--mellow-copy-max);
    }
  }

  @media screen and (max-width: 749px) {
    #MellowHero-{{ section.id }} {
      padding-top: var(--mellow-section-pad-bottom);
      padding-bottom: var(--mellow-section-content-gap-compact);
    }

    #MellowHero-{{ section.id }} .mellow-hero__actions {
      align-items: stretch;
      gap: 10px;
    }

    #MellowHero-{{ section.id }} .mellow-hero__cta-wrap,
    #MellowHero-{{ section.id }} .mellow-hero__cta {
      width: 100%;
    }

    #MellowHero-{{ section.id }} .mellow-hero__helper {
      font-size: 14px;
    }

    #MellowHero-{{ section.id }} .mellow-hero__image-frame {
      min-height: 220px;
    }
  }
</style>

<section
  id="MellowHero-{{ section.id }}"
  class="mellow-section-standard mellow-hero color-{{ section.settings.color_scheme }}"
>
  <div class="mellow-section-axis">
    <div class="mellow-hero__inner">
      <div class="mellow-section-header mellow-hero__content">
        {%- if hero_eyebrow != blank -%}
          <p class="mellow-eyebrow mellow-hero__eyebrow">{{ hero_eyebrow | escape }}</p>
        {%- endif -%}

        {%- if headline_primary != blank or headline_accent != blank -%}
          <h1 class="mellow-section-heading mellow-hero__heading">
            {%- if headline_primary != blank -%}
              <span class="mellow-hero__heading-line">{{ headline_primary | escape }}</span>
            {%- endif -%}
            {%- if headline_accent != blank -%}
              <span class="mellow-hero__heading-line mellow-hero__heading-line--accent">{{ headline_accent | escape }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if hero_text != blank -%}
          <p class="mellow-section-text mellow-hero__text">{{ hero_text | escape }}</p>
        {%- endif -%}

        {%- if primary_label != blank or secondary_label != blank -%}
          <div class="mellow-hero__actions">
            {%- if primary_label != blank -%}
              <div class="mellow-section-cta-wrap mellow-hero__cta-wrap">
                <a class="mellow-section-cta mellow-section-cta--primary-forest mellow-hero__cta" href="{{ primary_link }}">
                  <span class="mellow-section-cta__label">{{ primary_label | escape }}</span>
                  <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
                </a>
              </div>
            {%- endif -%}

            {%- if secondary_label != blank -%}
              <div class="mellow-section-cta-wrap mellow-hero__cta-wrap">
                <a class="mellow-section-cta mellow-section-cta--secondary mellow-hero__cta" href="{{ secondary_link }}">
                  <span class="mellow-section-cta__label">{{ secondary_label | escape }}</span>
                  <span class="mellow-section-cta__arrow" aria-hidden="true">→</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if helper_text != blank -%}
          <p class="mellow-hero__helper">{{ helper_text | escape }}</p>
        {%- endif -%}
      </div>

      <div class="mellow-hero__media" aria-label="Mellow packaging image">
        <div class="mellow-hero__image-frame">
          {%- if hero_image != blank -%}
            {{ hero_image | image_url: width: 1100 | image_tag: loading: 'eager', decoding: 'async', class: 'mellow-hero__image', sizes: '(min-width: 990px) 36vw, (min-width: 750px) 520px, 100vw', widths: '360, 520, 720, 900, 1100', alt: hero_image_alt }}
          {%- else -%}
            <span class="mellow-hero__placeholder">Packaging image</span>
          {%- endif -%}
        </div>
      </div>

      {%- if trust_line != blank -%}
        <p class="mellow-hero__proof">{{ trust_line | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mellow hero",
  "tag": "section",
  "class": "section section-mellow-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REFLUX RELIEF, REBUILT"
    },
    {
      "type": "text",
      "id": "headline_primary",
      "label": "Headline first line",
      "default": "Mellow stops reflux"
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline accent line",
      "default": "before it starts."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "A smooth gel that forms a floating raft barrier at the top of your stomach — helping block reflux before it rises."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary CTA label",
      "default": "Take the Quiz"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "text",
      "id": "helper_text",
      "label": "Helper text",
      "default": "Find out if Mellow fits your reflux routine."
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "Trust line",
      "default": "Forms within minutes. Holds for hours. After meals. Before bed."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero packaging image"
    },
    {
      "type": "image_picker",
      "id": "hero_background_image",
      "label": "Hero background image"
    }
  ],
  "presets": [
    {
      "name": "Mellow hero"
    }
  ]
}
{% endschema %}
