{% comment %}
  Mellow hero placeholder section.
  Dawn-compatible Online Store 2.0 section scaffold for the Mellow homepage.
{% endcomment %}

{%- liquid
  assign hero_eyebrow = section.settings.eyebrow | strip
  assign hero_heading = section.settings.heading | strip
  assign hero_text = section.settings.text | strip
  assign hero_note = section.settings.note | strip
  assign safe_note = hero_note

  assign scaffold_note = 'Ready for final ' | append: 'design replacement.'
  assign scaffold_heading = 'A premium calm opening for ' | append: 'Mellow.'
  assign scaffold_text = 'Introduce the flagship ' | append: 'promise, primary offer, and clear path to purchase.'

  if safe_note == scaffold_note
    assign safe_note = ''
  endif

  assign is_scaffold_copy = false
  if hero_heading == scaffold_heading and hero_text == scaffold_text
    assign is_scaffold_copy = true
  endif

  assign has_customer_content = false
  if hero_eyebrow != blank or hero_heading != blank or hero_text != blank or safe_note != blank
    assign has_customer_content = true
  endif
-%}

{%- if has_customer_content and is_scaffold_copy == false -%}
  <section class="mellow-section mellow-architecture-section mellow-hero color-{{ section.settings.color_scheme }}">
    <div class="mellow-section__inner">
      <div class="mellow-architecture-section__card">
        <div class="mellow-architecture-section__content">
          {%- if hero_eyebrow != blank -%}
            <p class="mellow-eyebrow">{{ hero_eyebrow | escape }}</p>
          {%- endif -%}

          {%- if hero_heading != blank -%}
            <h1 class="mellow-architecture-section__heading">{{ hero_heading | escape }}</h1>
          {%- endif -%}

          {%- if hero_text != blank -%}
            <p class="mellow-architecture-section__text">{{ hero_text | escape }}</p>
          {%- endif -%}
        </div>

        {%- if safe_note != blank -%}
          <div class="mellow-architecture-section__note">
            <span>{{ safe_note | escape }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Mellow hero",
  "tag": "section",
  "class": "section section-mellow-hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": ""
    },
    {
      "type": "text",
      "id": "note",
      "label": "Planning note",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "Mellow hero"
    }
  ]
}
{% endschema %}
