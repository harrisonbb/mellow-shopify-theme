{% comment %}
  Mellow Hero — Hybrid Sans + Italic Serif Mockup
  Updated:
  - Hero headline uses acquisition-friendly sans for main line
  - Italic editorial serif for “before it starts.”
  - Added social proof line: Trusted by 2,000+ reflux sufferers
  - Tightened first-screen composition
  - Added a premium product spotlight treatment
{% endcomment %}

<section class="mellow-hero" id="hero">
  <div class="mellow-hero__container">
    <div class="mellow-hero__inner">

      <!-- LEFT: Copy -->
      <div class="mellow-hero__copy">
        <span class="mellow-hero__eyebrow">
          {{ section.settings.eyebrow }}
        </span>

        <h1 class="mellow-hero__headline">
          <span class="mellow-hero__headline-main">Mellow stops reflux</span>
          <span class="mellow-hero__headline-accent">before it starts.</span>
        </h1>

        <p class="mellow-hero__subhead">
          A smooth gel that works before acid gets the chance.
        </p>

        <div class="mellow-hero__social-proof" aria-label="Social proof">
          <span class="mellow-hero__stars" aria-hidden="true">★★★★★</span>
          <span class="mellow-hero__quote">Trusted by 2,000+ reflux sufferers.</span>
        </div>

        <div class="mellow-hero__ctas">
          <a href="{{ section.settings.cta_primary_url }}" class="mellow-hero__btn">
            {{ section.settings.cta_primary_label }}
          </a>

          <a href="{{ section.settings.cta_secondary_url }}" class="mellow-hero__link">
            {{ section.settings.cta_secondary_label }}
          </a>
        </div>
      </div>

      <!-- RIGHT: Product image -->
      <div class="mellow-hero__visual">
        {% if section.settings.hero_image %}
          {{
            section.settings.hero_image
            | image_url: width: 1800
            | image_tag:
              class: 'mellow-hero__img',
              alt: 'Mellow pouch',
              loading: 'eager'
          }}
        {% else %}
          <div class="mellow-hero__img-placeholder"></div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

<style>

  .mellow-hero,
  .mellow-hero * {
    box-sizing: border-box;
  }

  .mellow-hero {
    --mellow-forest-local: #1A2D10;
    --mellow-orange-red-local: #D04A2A;
    --mellow-albers-blue-local: #3D6B8C;
    --mellow-ivory-local: #F0EBE0;
    --mellow-warm-white-local: #FAFAF8;

    position: relative;
    background: var(--mellow-ivory, var(--mellow-ivory-local)) !important;
    background-color: var(--mellow-ivory, var(--mellow-ivory-local)) !important;
    background-image: none !important;
    border-radius: 0;

    padding: clamp(18px, 2.1vw, 28px) 40px clamp(6px, 1vw, 12px) !important;

    min-height: auto !important;
    height: auto !important;
    overflow: visible;
  }

  .mellow-hero::before,
  .mellow-hero::after {
    display: none !important;
    content: none !important;
  }

  .mellow-hero__container {
    position: relative;
    z-index: 1;
    max-width: 1360px;
    margin: 0 auto;
    width: 100%;
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
  }

  .mellow-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(500px, 0.88fr);
    gap: clamp(34px, 4.2vw, 64px);
    align-items: center;
    min-height: auto !important;
    background: transparent !important;
    border: 0 !important;
    box-shadow: none !important;
  }

  .mellow-hero__copy {
    max-width: 930px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transform: translateY(0);
  }

  .mellow-hero__eyebrow {
    display: block;
    margin: 0;
    color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;

    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    letter-spacing: 0.18em !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    font-style: normal !important;
  }

  .mellow-hero__headline,
  #hero .mellow-hero__headline {
    margin: 0 !important;
    max-width: 1050px !important;
    color: var(--mellow-forest, var(--mellow-forest-local)) !important;
    text-wrap: balance;
  }

  #hero .mellow-hero__headline-main,
  .mellow-hero__headline-main {
    display: block !important;

    font-family: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    font-size: clamp(3.45rem, 5.45vw, 7.25rem) !important;
    line-height: 0.9 !important;
    letter-spacing: -0.085em !important;
    font-weight: 900 !important;
    font-style: normal !important;
    color: var(--mellow-forest, var(--mellow-forest-local)) !important;
  }

  #hero .mellow-hero__headline-accent,
  .mellow-hero__headline-accent {
    display: block !important;
    margin-top: -0.02em !important;

    font-family: 'Fraunces', Georgia, serif !important;
    font-size: clamp(3.2rem, 5vw, 6.8rem) !important;
    line-height: 0.88 !important;
    letter-spacing: -0.055em !important;
    font-weight: 300 !important;
    font-style: italic !important;
    font-variation-settings: "opsz" 96, "wght" 300 !important;
    color: var(--mellow-forest, var(--mellow-forest-local)) !important;
  }

  .mellow-hero__subhead {
    max-width: 620px;
    margin: 0;
    color: rgba(26, 45, 16, 0.84) !important;

    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: clamp(1.06rem, 1.14vw, 1.2rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.01em !important;
    font-weight: 500 !important;
  }

  .mellow-hero__social-proof {
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
    margin: 0 0 2px !important;

    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.96rem !important;
    line-height: 1.24 !important;
    font-weight: 700 !important;
    letter-spacing: -0.015em !important;

    color: var(--mellow-forest, var(--mellow-forest-local)) !important;
  }

  .mellow-hero__stars {
    color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    font-size: 0.92rem !important;
    line-height: 1 !important;
    letter-spacing: 0.02em !important;
    white-space: nowrap !important;
  }

  .mellow-hero__quote {
    color: rgba(26, 45, 16, 0.78) !important;
    white-space: normal !important;
  }

  .mellow-hero__ctas {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 0;
  }

  .mellow-hero__btn {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 38px;
    border-radius: 999px;
    background: var(--mellow-forest, var(--mellow-forest-local)) !important;
    background-color: var(--mellow-forest, var(--mellow-forest-local)) !important;
    color: var(--mellow-ivory, var(--mellow-ivory-local)) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.96rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    overflow: visible;
    position: relative;
    border: 1px solid rgba(26, 45, 16, 0.98);
    transition:
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
    box-shadow:
      0 16px 34px rgba(26, 45, 16, 0.20),
      0 0 0 0 rgba(208, 74, 42, 0);
  }

  .mellow-hero__btn::before {
    content: "";
    position: absolute;
    inset: -5px;
    border-radius: inherit;
    border: 1px solid rgba(208, 74, 42, 0.16);
    opacity: 0;
    transform: scale(0.96);
    transition:
      opacity 0.26s ease,
      transform 0.26s ease;
    pointer-events: none;
  }

  .mellow-hero__btn::after {
    content: '→';
    display: inline-block;
    opacity: 0;
    max-width: 0;
    transform: translateX(-4px) scale(0.75);
    font-size: 1.18rem;
    margin-left: 0;
    transition:
      opacity 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      max-width 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      margin-left 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mellow-hero__btn:hover {
    background: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    background-color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    border-color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    color: var(--mellow-ivory, var(--mellow-ivory-local)) !important;
    transform: translateY(-2px);
    box-shadow:
      0 20px 46px rgba(208, 74, 42, 0.26),
      0 0 0 6px rgba(208, 74, 42, 0.08);
    top: auto;
  }

  .mellow-hero__btn:hover::before {
    opacity: 1;
    transform: scale(1);
  }

  .mellow-hero__btn:hover::after {
    opacity: 1;
    max-width: 30px;
    transform: translateX(0) scale(1);
    margin-left: 10px;
  }

  .mellow-hero__link {
    display: inline-flex;
    align-items: center;
    color: var(--mellow-forest, var(--mellow-forest-local)) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-bottom: 1px solid rgba(26, 45, 16, 0.35);
    padding-bottom: 3px;
    transition: border-color 0.2s ease, opacity 0.2s ease, color 0.2s ease;
  }

  .mellow-hero__link:hover {
    border-color: var(--mellow-forest, var(--mellow-forest-local));
    color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    opacity: 1;
  }

  .mellow-hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible !important;
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: 0 !important;
    box-shadow: none !important;
    outline: 0 !important;
    padding: clamp(8px, 1.3vw, 18px) 0 clamp(14px, 1.6vw, 24px) !important;
    margin: 0 !important;
    isolation: isolate;
    position: relative;
  }

  .mellow-hero__visual::before {
    content: "" !important;
    display: block !important;
    position: absolute;
    z-index: -2;
    width: min(620px, 88%);
    aspect-ratio: 1 / 0.78;
    left: 50%;
    top: 50%;
    transform: translate(-48%, -48%) rotate(-5deg);
    border-radius: 45% 55% 50% 50%;
    background:
      radial-gradient(circle at 54% 42%, rgba(250, 250, 248, 0.86) 0 28%, rgba(250, 250, 248, 0.44) 42%, rgba(250, 250, 248, 0) 66%),
      linear-gradient(145deg, rgba(255, 255, 255, 0.34), rgba(26, 45, 16, 0.045));
    box-shadow: inset 0 0 0 1px rgba(26, 45, 16, 0.055);
    pointer-events: none;
  }

  .mellow-hero__visual::after {
    content: "" !important;
    display: block !important;
    position: absolute;
    z-index: -1;
    width: min(500px, 76%);
    height: clamp(28px, 5vw, 58px);
    left: 50%;
    bottom: clamp(2px, 1vw, 12px);
    transform: translateX(-46%);
    border-radius: 999px;
    background: radial-gradient(ellipse at center, rgba(26, 45, 16, 0.20) 0 18%, rgba(26, 45, 16, 0.10) 42%, rgba(26, 45, 16, 0) 72%);
    filter: blur(8px);
    pointer-events: none;
  }

  .mellow-hero__visual img,
  .mellow-hero__img {
    display: block !important;

    width: min(600px, 100%) !important;
    max-width: 600px !important;

    height: auto !important;
    object-fit: contain !important;
    object-position: center !important;

    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;

    border: 0 !important;
    box-shadow: none !important;
    outline: 0 !important;
    border-radius: 0 !important;
    padding: 0 !important;
    margin: 0 !important;

    filter:
      drop-shadow(0 18px 22px rgba(26, 45, 16, 0.10))
      drop-shadow(0 38px 54px rgba(26, 45, 16, 0.16)) !important;
    transform: rotate(-1.5deg) translateY(-2px);
    transform-origin: center bottom;
  }

  .mellow-hero__img-placeholder {
    width: 100%;
    min-height: 320px;
    display: block;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    color: transparent;
    font-size: 0;
  }

  #hero .media,
  #hero .media--transparent,
  #hero .image-with-text__media,
  #hero .global-media-settings,
  #hero .gradient,
  #hero .deferred-media,
  #hero .placeholder {
    background: transparent !important;
    background-color: transparent !important;
    background-image: none !important;
    border: 0 !important;
    box-shadow: none !important;
    outline: 0 !important;
  }

  #hero .media::before,
  #hero .media::after,
  #hero .global-media-settings::before,
  #hero .global-media-settings::after,
  #hero .gradient::before,
  #hero .gradient::after {
    display: none !important;
    content: none !important;
  }

  @media (min-width: 1440px) and (min-height: 850px) {
    .mellow-hero {
      min-height: auto !important;
      height: auto !important;
      padding: 28px 56px 10px !important;
      display: block !important;
      align-items: unset !important;
    }

    .mellow-hero__container {
      max-width: 1480px;
      width: 100%;
    }

    .mellow-hero__inner {
      width: 100%;
      grid-template-columns: minmax(0, 1fr) minmax(540px, 0.9fr);
      gap: clamp(48px, 4.6vw, 92px);
      align-items: center;
      min-height: auto !important;
    }

    .mellow-hero__copy {
      max-width: 980px;
      gap: 13px;
      transform: translateY(0);
    }

    .mellow-hero__headline-main {
      font-size: clamp(4.1rem, 5.1vw, 7.75rem) !important;
      line-height: 0.89 !important;
      letter-spacing: -0.088em !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(3.75rem, 4.7vw, 7.15rem) !important;
      line-height: 0.88 !important;
      letter-spacing: -0.058em !important;
    }

    .mellow-hero__subhead {
      max-width: 680px;
    }

    .mellow-hero__ctas {
      margin-top: 0;
    }

    .mellow-hero__visual img,
    .mellow-hero__img {
      width: min(680px, 100%) !important;
      max-width: 680px !important;
      height: auto !important;
      object-fit: contain !important;
      filter:
        drop-shadow(0 20px 24px rgba(26, 45, 16, 0.10))
        drop-shadow(0 42px 58px rgba(26, 45, 16, 0.17)) !important;
    }
  }

  @media (min-width: 1700px) and (min-height: 950px) {
    .mellow-hero {
      min-height: auto !important;
      padding-top: 30px !important;
      padding-bottom: 10px !important;
    }

    .mellow-hero__container {
      max-width: 1580px;
    }

    .mellow-hero__inner {
      grid-template-columns: minmax(0, 1.02fr) minmax(580px, 0.92fr);
      gap: clamp(54px, 4.7vw, 104px);
    }

    .mellow-hero__headline-main {
      font-size: clamp(4.35rem, 5vw, 8.05rem) !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(3.95rem, 4.62vw, 7.45rem) !important;
    }

    .mellow-hero__subhead {
      max-width: 700px;
    }

    .mellow-hero__visual img,
    .mellow-hero__img {
      width: min(760px, 100%) !important;
      max-width: 760px !important;
      height: auto !important;
      object-fit: contain !important;
    }
  }

  @media (max-width: 980px) {
    .mellow-hero {
      padding: 28px 32px 22px !important;
    }

    .mellow-hero__inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .mellow-hero__visual {
      order: -1;
    }

    .mellow-hero__visual img,
    .mellow-hero__img {
      width: min(500px, 100%) !important;
      max-width: 500px !important;
    }

    .mellow-hero__copy {
      max-width: 760px;
      transform: translateY(0);
    }

    .mellow-hero__headline-main {
      font-size: clamp(3.05rem, 9vw, 5.2rem) !important;
      line-height: 0.92 !important;
      letter-spacing: -0.075em !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(2.85rem, 8.4vw, 4.95rem) !important;
      line-height: 0.92 !important;
    }
  }

  @media (max-width: 768px) {
    .mellow-hero {
      padding: 22px 20px 22px !important;
    }

    .mellow-hero__inner {
      gap: 22px;
    }

    .mellow-hero__copy {
      transform: none;
      gap: 13px;
    }

    .mellow-hero__headline-main {
      font-size: clamp(2.55rem, 11.5vw, 3.85rem) !important;
      line-height: 0.94 !important;
      letter-spacing: -0.065em !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(2.4rem, 10.5vw, 3.65rem) !important;
      line-height: 0.94 !important;
      letter-spacing: -0.05em !important;
      font-variation-settings: "opsz" 64, "wght" 300 !important;
    }

    .mellow-hero__subhead {
      font-size: 1rem;
    }

    .mellow-hero__social-proof {
      align-items: flex-start !important;
      gap: 8px !important;
      margin: 0 0 4px !important;
      font-size: 0.94rem !important;
    }

    .mellow-hero__ctas {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .mellow-hero__btn {
      min-height: 52px;
      padding: 0 32px;
    }

    .mellow-hero__visual img,
    .mellow-hero__img {
      width: min(390px, 100%) !important;
      max-width: 390px !important;
    }

    .mellow-hero__img-placeholder {
      min-height: 220px;
    }
  }

  /* Layout nudge only */
  #hero.mellow-hero .mellow-hero__copy,
  #hero .mellow-hero__copy,
  .mellow-hero .mellow-hero__copy {
    transform: translateX(68px) translateY(0);
  }

  @media (min-width: 1440px) and (min-height: 850px) {
    #hero.mellow-hero .mellow-hero__copy,
    #hero .mellow-hero__copy,
    .mellow-hero .mellow-hero__copy {
      transform: translateX(68px) translateY(0);
    }
  }

  @media (max-width: 980px) {
    #hero.mellow-hero .mellow-hero__copy,
    #hero .mellow-hero__copy,
    .mellow-hero .mellow-hero__copy {
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    #hero.mellow-hero .mellow-hero__copy,
    #hero .mellow-hero__copy,
    .mellow-hero .mellow-hero__copy {
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "A better kind of reflux relief"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Mellow stops reflux before it starts."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subheadline",
      "default": "A smooth gel that works before acid gets the chance."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Take the 60-Second Quiz"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Product image"
    }
  ],
  "presets": [
    {
      "name": "Mellow Hero"
    }
  ]
}
{% endschema %}