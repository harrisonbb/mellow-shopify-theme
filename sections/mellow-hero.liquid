{% comment %}
  Mellow Hero — full-bleed cinematic product background
  - Uses the Shopify image picker as a full-section background image
  - Keeps left-aligned hero copy on the site axis
  - Adds a restrained dark gradient overlay for cream text readability
{% endcomment %}

{% assign has_full_screen_hero_background = false %}
{% if section.settings.full_screen_hero_background_image != blank %}
  {% assign has_full_screen_hero_background = true %}
{% endif %}

<section class="mellow-hero{% if has_full_screen_hero_background %} mellow-hero--has-bg{% endif %}" id="hero" aria-label="Mellow homepage hero">
  {% if has_full_screen_hero_background %}
    <div class="mellow-hero__bg" aria-hidden="true">
      {{
        section.settings.full_screen_hero_background_image
        | image_url: width: 2400
        | image_tag:
          class: 'mellow-hero__bg-image',
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw'
      }}
    </div>
    <div class="mellow-hero__bg-overlay" aria-hidden="true"></div>
  {% endif %}

  <div class="mellow-hero__container">
    <div class="mellow-hero__inner">
      <div class="mellow-hero__copy">
        <span class="mellow-hero__eyebrow">
          {{ section.settings.eyebrow }}
        </span>

        <h1 class="mellow-hero__headline">
          <span class="mellow-hero__headline-main">Mellow stops reflux</span>
          <span class="mellow-hero__headline-accent">before it starts.</span>
        </h1>

        <p class="mellow-hero__subhead">
          A smooth gel that works before acid gets the chance.
        </p>

        <div class="mellow-hero__social-proof" aria-label="Social proof">
          <span class="mellow-hero__stars" aria-hidden="true">★★★★★</span>
          <span class="mellow-hero__quote">Trusted by 2,000+ reflux sufferers.</span>
        </div>

        <div class="mellow-hero__ctas">
          <a href="{{ section.settings.cta_primary_url }}" class="mellow-hero__btn">
            {{ section.settings.cta_primary_label }}
          </a>

          <a href="{{ section.settings.cta_secondary_url }}" class="mellow-hero__link">
            {{ section.settings.cta_secondary_label }}
          </a>
        </div>
      </div>

      {% if has_full_screen_hero_background == false and section.settings.product_image != blank %}
        <div class="mellow-hero__media" aria-hidden="true">
          <div class="mellow-hero__image-wrap">
            {{
              section.settings.product_image
              | image_url: width: 1000
              | image_tag:
                class: 'mellow-hero__product',
                loading: 'eager',
                fetchpriority: 'high'
            }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: #071209 !important;
    background-color: #071209 !important;
  }

  .mellow-hero,
  .mellow-hero * {
    box-sizing: border-box;
  }

  .mellow-hero {
    --mellow-forest-local: #071209;
    --mellow-orange-red-local: #D04A2A;
    --mellow-ivory-local: #F0EBE0;
    --mellow-axis-max: var(--mellow-page-width, 1400px);
    --mellow-axis-pad: clamp(28px, 7vw, 112px);

    position: relative;
    isolation: isolate;
    min-height: calc(100vh - var(--header-height, 120px));
    width: 100%;
    overflow: hidden;
    background:
      radial-gradient(circle at 86% 78%, rgba(208, 74, 42, 0.24) 0 18%, rgba(208, 74, 42, 0) 42%),
      linear-gradient(135deg, #071209 0%, #0D1D11 48%, #152818 100%);
    color: var(--mellow-ivory-local);
  }

  .mellow-hero__bg,
  .mellow-hero__bg-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mellow-hero__bg {
    z-index: 0;
    overflow: hidden;
    background:
      radial-gradient(circle at 82% 82%, rgba(208, 74, 42, 0.28) 0 16%, rgba(208, 74, 42, 0) 42%),
      linear-gradient(135deg, #071209 0%, #0D1D11 50%, #152818 100%);
  }

  .mellow-hero .mellow-hero__bg-image,
  .mellow-hero__bg-image {
    position: absolute !important;
    z-index: 0 !important;
    display: block !important;
    width: clamp(320px, 34vw, 560px) !important;
    height: auto !important;
    max-width: none !important;
    max-height: 82% !important;
    right: clamp(48px, 8vw, 140px) !important;
    bottom: clamp(24px, 5vw, 72px) !important;
    left: auto !important;
    top: auto !important;
    object-fit: contain !important;
    object-position: 70% center !important;
    background-position: 70% center !important;
    transform: none !important;
  }

  .mellow-hero__bg-overlay {
    z-index: 1;
    background:
      linear-gradient(
        90deg,
        rgba(5, 13, 7, 0.92) 0%,
        rgba(5, 13, 7, 0.78) 34%,
        rgba(5, 13, 7, 0.34) 62%,
        rgba(5, 13, 7, 0.06) 100%
      );
  }

  .mellow-hero--has-bg .mellow-hero__media,
  .mellow-hero--has-bg .mellow-hero__product,
  .mellow-hero--has-bg .mellow-hero__image-wrap {
    display: none !important;
  }

  .mellow-hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--mellow-axis-max);
    min-height: inherit !important;
    margin: 0 auto;
    padding: clamp(88px, 11vh, 132px) var(--mellow-axis-pad) clamp(104px, 12vh, 148px);
    display: flex;
    align-items: center;
  }

  .mellow-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    min-height: inherit !important;
    display: grid !important;
    grid-template-columns: minmax(0, 520px) minmax(320px, 1fr);
    align-items: center !important;
    justify-content: flex-start;
    gap: clamp(32px, 6vw, 96px);
    text-align: left;
  }

  .mellow-hero--has-bg .mellow-hero__inner {
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start;
  }

  .mellow-hero__media,
  .mellow-hero__image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .mellow-hero__image-wrap {
    width: 100%;
  }

  .mellow-hero__product {
    display: block;
    width: min(100%, 520px) !important;
    height: auto !important;
    max-width: 520px !important;
    object-fit: contain !important;
  }

  .mellow-hero__copy {
    width: 100%;
    max-width: 560px;
    transform: translateY(clamp(-24px, -2vh, -12px));
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    text-align: left;
  }

  .mellow-hero__eyebrow {
    display: block;
    margin: 0;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    letter-spacing: 0.18em !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    font-style: normal !important;
  }

  .mellow-hero__headline,
  #hero .mellow-hero__headline {
    width: 100% !important;
    max-width: 560px !important;
    margin: 0 !important;
    color: #F0EBE0 !important;
    text-align: left !important;
    text-wrap: balance;
  }

  #hero .mellow-hero__headline-main,
  .mellow-hero__headline-main {
    display: block !important;
    color: #F0EBE0 !important;
    font-family: var(--mellow-heading-font, 'Test Founders Grotesk', 'Test Untitled Sans', 'Test Söhne', 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif) !important;
    font-size: clamp(54px, 5vw, 79px) !important;
    line-height: var(--mellow-heading-line-height, 0.94) !important;
    letter-spacing: var(--mellow-heading-letter-spacing, -0.035em) !important;
    font-weight: var(--mellow-heading-weight, 700) !important;
    font-style: normal !important;
    font-variation-settings: var(--mellow-heading-font-variation-settings, normal) !important;
  }

  #hero .mellow-hero__headline-accent,
  .mellow-hero__headline-accent {
    display: block !important;
    margin-top: var(--mellow-heading-accent-offset, -0.02em) !important;
    color: #F0EBE0 !important;
    font-family: var(--mellow-heading-italic-font, 'Test Tiempos Headline', 'Fraunces', Georgia, serif) !important;
    font-size: clamp(50px, 4.6vw, 72px) !important;
    line-height: var(--mellow-heading-italic-line-height, 0.95) !important;
    letter-spacing: var(--mellow-heading-italic-letter-spacing, -0.025em) !important;
    font-weight: var(--mellow-heading-italic-weight, 400) !important;
    font-style: italic !important;
    font-variation-settings: var(--mellow-heading-italic-font-variation-settings, normal) !important;
  }

  .mellow-hero__subhead {
    max-width: 440px;
    margin: 0;
    color: rgba(240, 235, 224, 0.78) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: clamp(1.06rem, 1.14vw, 1.2rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.01em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  .mellow-hero__social-proof {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 10px !important;
    margin: 0 0 2px !important;
    color: rgba(240, 235, 224, 0.86) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.96rem !important;
    line-height: 1.24 !important;
    font-weight: 700 !important;
    letter-spacing: -0.015em !important;
    text-align: left !important;
  }

  .mellow-hero__stars {
    color: var(--mellow-orange-red-local) !important;
    font-size: 0.92rem !important;
    line-height: 1 !important;
    letter-spacing: 0.02em !important;
    white-space: nowrap !important;
  }

  .mellow-hero__quote {
    color: rgba(240, 235, 224, 0.86) !important;
    white-space: normal !important;
  }

  .mellow-hero__ctas {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 4px;
    text-align: left;
  }

  .mellow-hero__btn {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 38px;
    border-radius: 999px;
    background: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    background-color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    color: var(--mellow-ivory-local) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.96rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    position: relative;
    border: 1px solid rgba(208, 74, 42, 0.98);
    box-shadow:
      0 18px 44px rgba(0, 0, 0, 0.24),
      0 0 0 1px rgba(240, 235, 224, 0.08) inset;
    transition:
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
  }

  .mellow-hero__btn::after {
    content: '→';
    display: inline-block;
    opacity: 0;
    max-width: 0;
    transform: translateX(-4px) scale(0.75);
    font-size: 1.18rem;
    margin-left: 0;
    transition:
      opacity 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      max-width 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      margin-left 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mellow-hero__btn:hover {
    background: #B83F24 !important;
    background-color: #B83F24 !important;
    border-color: #B83F24 !important;
    color: var(--mellow-ivory-local) !important;
    transform: translateY(-2px);
    box-shadow:
      0 22px 52px rgba(0, 0, 0, 0.30),
      0 0 0 6px rgba(208, 74, 42, 0.10);
  }

  .mellow-hero__btn:hover::after {
    opacity: 1;
    max-width: 30px;
    transform: translateX(0) scale(1);
    margin-left: 10px;
  }

  .mellow-hero__link {
    display: inline-flex;
    align-items: center;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 235, 224, 0.34);
    padding-bottom: 3px;
    transition: border-color 0.2s ease, opacity 0.2s ease, color 0.2s ease;
  }

  .mellow-hero__link:hover {
    border-color: var(--mellow-ivory-local);
    color: var(--mellow-ivory-local) !important;
    opacity: 1;
  }


  @media (max-width: 768px) {
    .mellow-hero {
      --mellow-axis-pad: clamp(20px, 5.8vw, 36px);
      min-height: auto;
    }

    .mellow-hero__bg-image {
      width: min(78vw, 360px) !important;
      max-height: 48% !important;
      right: 50% !important;
      bottom: clamp(28px, 8vw, 56px) !important;
      object-fit: contain !important;
      object-position: 72% center !important;
      background-position: 72% center !important;
      transform: translateX(50%) !important;
    }

    .mellow-hero__bg-overlay {
      background:
        linear-gradient(
          90deg,
          rgba(5, 13, 7, 0.82) 0%,
          rgba(5, 13, 7, 0.74) 46%,
          rgba(5, 13, 7, 0.38) 78%,
          rgba(5, 13, 7, 0.16) 100%
        ),
        linear-gradient(
          180deg,
          rgba(5, 13, 7, 0.82) 0%,
          rgba(5, 13, 7, 0.38) 42%,
          rgba(5, 13, 7, 0.66) 100%
        );
    }

    .mellow-hero__container {
      min-height: clamp(680px, 90vh, 860px);
      align-items: center;
      padding-top: clamp(112px, 15vh, 156px);
      padding-bottom: clamp(280px, 44vh, 390px);
    }

    .mellow-hero__copy {
      max-width: min(560px, 100%);
      gap: 13px;
      transform: translateY(clamp(-72px, -8vh, -36px));
    }

    .mellow-hero__headline-main {
      font-size: clamp(2.35rem, 10.4vw, 3.35rem) !important;
      line-height: 0.94 !important;
      letter-spacing: -0.035em !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(2.24rem, 9.8vw, 3.18rem) !important;
      line-height: 0.95 !important;
      letter-spacing: -0.025em !important;
    }

    .mellow-hero__subhead {
      font-size: 1rem !important;
      max-width: 360px;
    }

    .mellow-hero__social-proof {
      align-items: flex-start !important;
      gap: 8px !important;
      margin: 0 0 4px !important;
      font-size: 0.94rem !important;
    }

    .mellow-hero__ctas {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .mellow-hero__btn {
      min-height: 52px;
      padding: 0 32px;
    }
  }

  @media (max-width: 420px) {
    .mellow-hero__container {
      align-items: center;
      padding-top: 118px;
      padding-bottom: 64px;
    }

    .mellow-hero__bg-overlay {
      background:
        linear-gradient(
          90deg,
          rgba(5, 13, 7, 0.84) 0%,
          rgba(5, 13, 7, 0.78) 52%,
          rgba(5, 13, 7, 0.42) 80%,
          rgba(5, 13, 7, 0.20) 100%
        ),
        linear-gradient(
          180deg,
          rgba(5, 13, 7, 0.84) 0%,
          rgba(5, 13, 7, 0.42) 50%,
          rgba(5, 13, 7, 0.62) 100%
        );
    }

    .mellow-hero__social-proof {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "A better kind of reflux relief"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Mellow stops reflux before it starts."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subheadline",
      "default": "A smooth gel that works before acid gets the chance."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Take the 60-Second Quiz"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "image_picker",
      "id": "full_screen_hero_background_image",
      "label": "Full-screen hero background image"
    }
  ],
  "presets": [
    {
      "name": "Mellow Hero"
    }
  ]
}
{% endschema %}
