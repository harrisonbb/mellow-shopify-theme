{% comment %}
  Mellow Hero — full-bleed cinematic product background
  - Uses the Shopify image picker as a full-section background image
  - Keeps left-aligned hero copy on the site axis
  - Adds a restrained dark gradient overlay for cream text readability
{% endcomment %}

<section class="mellow-hero" id="hero" aria-label="Mellow homepage hero">
  {% if section.settings.hero_image != blank %}
    <div class="mellow-hero__background" aria-hidden="true">
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag:
          class: 'mellow-hero__background-image',
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw'
      }}
    </div>
  {% endif %}

  <div class="mellow-hero__overlay" aria-hidden="true"></div>

  <div class="mellow-hero__container">
    <div class="mellow-hero__inner">
      <div class="mellow-hero__copy">
        <span class="mellow-hero__eyebrow">
          {{ section.settings.eyebrow }}
        </span>

        <h1 class="mellow-hero__headline">
          <span class="mellow-hero__headline-main">Mellow stops reflux</span>
          <span class="mellow-hero__headline-accent">before it starts.</span>
        </h1>

        <p class="mellow-hero__subhead">
          A smooth gel that works before acid gets the chance.
        </p>

        <div class="mellow-hero__social-proof" aria-label="Social proof">
          <span class="mellow-hero__stars" aria-hidden="true">★★★★★</span>
          <span class="mellow-hero__quote">Trusted by 2,000+ reflux sufferers.</span>
        </div>

        <div class="mellow-hero__ctas">
          <a href="{{ section.settings.cta_primary_url }}" class="mellow-hero__btn">
            {{ section.settings.cta_primary_label }}
          </a>

          <a href="{{ section.settings.cta_secondary_url }}" class="mellow-hero__link">
            {{ section.settings.cta_secondary_label }}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    background: #0A1209 !important;
    background-color: #0A1209 !important;
  }

  .mellow-hero,
  .mellow-hero * {
    box-sizing: border-box;
  }

  .mellow-hero {
    --mellow-forest-local: #0A1209;
    --mellow-orange-red-local: #D04A2A;
    --mellow-ivory-local: #F0EBE0;
    --mellow-axis-max: var(--mellow-page-width, 1400px);
    --mellow-axis-pad: clamp(28px, 7vw, 112px);

    position: relative;
    isolation: isolate;
    min-height: clamp(680px, 92vh, 920px);
    width: 100%;
    overflow: hidden;
    background: var(--mellow-forest-local);
    color: var(--mellow-ivory-local);
  }

  .mellow-hero__background,
  .mellow-hero__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .mellow-hero__background {
    z-index: -3;
    background: var(--mellow-forest-local);
  }

  .mellow-hero__background-image {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: cover !important;
    object-position: center center !important;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  .mellow-hero__overlay {
    z-index: -2;
    background:
      linear-gradient(
        90deg,
        rgba(10, 18, 9, 0.78) 0%,
        rgba(10, 18, 9, 0.56) 34%,
        rgba(10, 18, 9, 0.18) 62%,
        rgba(10, 18, 9, 0.04) 100%
      );
  }

  .mellow-hero__container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--mellow-axis-max);
    min-height: clamp(680px, 92vh, 920px);
    margin: 0 auto;
    padding-left: var(--mellow-axis-pad);
    padding-right: var(--mellow-axis-pad);
    display: flex;
    align-items: center;
  }

  .mellow-hero__inner {
    width: 100%;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    text-align: left;
  }

  .mellow-hero__copy {
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
    text-align: left;
  }

  .mellow-hero__eyebrow {
    display: block;
    margin: 0;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.72rem !important;
    line-height: 1 !important;
    letter-spacing: 0.18em !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    font-style: normal !important;
  }

  .mellow-hero__headline,
  #hero .mellow-hero__headline {
    width: 100% !important;
    max-width: 520px !important;
    margin: 0 !important;
    color: var(--mellow-ivory-local) !important;
    text-align: left !important;
    text-wrap: balance;
  }

  #hero .mellow-hero__headline-main,
  .mellow-hero__headline-main {
    display: block !important;
    color: var(--mellow-ivory-local) !important;
    font-family: var(--mellow-heading-font, 'Test Founders Grotesk', 'Test Untitled Sans', 'Test Söhne', 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif) !important;
    font-size: clamp(54px, 5vw, 79px) !important;
    line-height: var(--mellow-heading-line-height, 0.94) !important;
    letter-spacing: var(--mellow-heading-letter-spacing, -0.035em) !important;
    font-weight: var(--mellow-heading-weight, 700) !important;
    font-style: normal !important;
    font-variation-settings: var(--mellow-heading-font-variation-settings, normal) !important;
  }

  #hero .mellow-hero__headline-accent,
  .mellow-hero__headline-accent {
    display: block !important;
    margin-top: var(--mellow-heading-accent-offset, -0.02em) !important;
    color: var(--mellow-ivory-local) !important;
    font-family: var(--mellow-heading-italic-font, 'Test Tiempos Headline', 'Fraunces', Georgia, serif) !important;
    font-size: clamp(50px, 4.6vw, 72px) !important;
    line-height: var(--mellow-heading-italic-line-height, 0.95) !important;
    letter-spacing: var(--mellow-heading-italic-letter-spacing, -0.025em) !important;
    font-weight: var(--mellow-heading-italic-weight, 400) !important;
    font-style: italic !important;
    font-variation-settings: var(--mellow-heading-italic-font-variation-settings, normal) !important;
  }

  .mellow-hero__subhead {
    max-width: 440px;
    margin: 0;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: clamp(1.06rem, 1.14vw, 1.2rem) !important;
    line-height: 1.55 !important;
    letter-spacing: -0.01em !important;
    font-weight: 500 !important;
    text-align: left !important;
  }

  .mellow-hero__social-proof {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: 10px !important;
    margin: 0 0 2px !important;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif) !important;
    font-size: 0.96rem !important;
    line-height: 1.24 !important;
    font-weight: 700 !important;
    letter-spacing: -0.015em !important;
    text-align: left !important;
  }

  .mellow-hero__stars {
    color: var(--mellow-orange-red-local) !important;
    font-size: 0.92rem !important;
    line-height: 1 !important;
    letter-spacing: 0.02em !important;
    white-space: nowrap !important;
  }

  .mellow-hero__quote {
    color: rgba(240, 235, 224, 0.82) !important;
    white-space: normal !important;
  }

  .mellow-hero__ctas {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: 18px;
    margin-top: 4px;
    text-align: left;
  }

  .mellow-hero__btn {
    min-height: 54px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 38px;
    border-radius: 999px;
    background: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    background-color: var(--mellow-orange, var(--mellow-orange-red-local)) !important;
    color: var(--mellow-ivory-local) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.96rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    text-decoration: none;
    position: relative;
    border: 1px solid rgba(208, 74, 42, 0.98);
    box-shadow:
      0 18px 44px rgba(0, 0, 0, 0.24),
      0 0 0 1px rgba(240, 235, 224, 0.08) inset;
    transition:
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease,
      transform 0.22s ease;
  }

  .mellow-hero__btn::after {
    content: '→';
    display: inline-block;
    opacity: 0;
    max-width: 0;
    transform: translateX(-4px) scale(0.75);
    font-size: 1.18rem;
    margin-left: 0;
    transition:
      opacity 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      max-width 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      margin-left 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mellow-hero__btn:hover {
    background: #B83F24 !important;
    background-color: #B83F24 !important;
    border-color: #B83F24 !important;
    color: var(--mellow-ivory-local) !important;
    transform: translateY(-2px);
    box-shadow:
      0 22px 52px rgba(0, 0, 0, 0.30),
      0 0 0 6px rgba(208, 74, 42, 0.10);
  }

  .mellow-hero__btn:hover::after {
    opacity: 1;
    max-width: 30px;
    transform: translateX(0) scale(1);
    margin-left: 10px;
  }

  .mellow-hero__link {
    display: inline-flex;
    align-items: center;
    color: rgba(240, 235, 224, 0.82) !important;
    font-family: var(--font-body, 'DM Sans', system-ui, sans-serif);
    font-size: 0.94rem;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 235, 224, 0.34);
    padding-bottom: 3px;
    transition: border-color 0.2s ease, opacity 0.2s ease, color 0.2s ease;
  }

  .mellow-hero__link:hover {
    border-color: var(--mellow-ivory-local);
    color: var(--mellow-ivory-local) !important;
    opacity: 1;
  }

  @media (max-width: 1180px) {
    .mellow-hero__background-image {
      object-position: 58% center !important;
      background-position: 58% center;
    }
  }

  @media (max-width: 768px) {
    .mellow-hero {
      --mellow-axis-pad: clamp(20px, 5.8vw, 36px);
      min-height: clamp(640px, 88vh, 820px);
    }

    .mellow-hero__background-image {
      object-position: 62% center !important;
      background-position: 62% center;
    }

    .mellow-hero__overlay {
      background:
        linear-gradient(
          90deg,
          rgba(10, 18, 9, 0.72) 0%,
          rgba(10, 18, 9, 0.66) 42%,
          rgba(10, 18, 9, 0.28) 76%,
          rgba(10, 18, 9, 0.12) 100%
        ),
        linear-gradient(
          180deg,
          rgba(10, 18, 9, 0.32) 0%,
          rgba(10, 18, 9, 0.08) 38%,
          rgba(10, 18, 9, 0.64) 100%
        );
    }

    .mellow-hero__container {
      min-height: clamp(640px, 88vh, 820px);
      align-items: flex-end;
      padding-top: 96px;
      padding-bottom: clamp(44px, 10vh, 84px);
    }

    .mellow-hero__copy {
      max-width: min(520px, 100%);
      gap: 13px;
    }

    .mellow-hero__headline-main {
      font-size: clamp(2.35rem, 10.4vw, 3.35rem) !important;
      line-height: 0.94 !important;
      letter-spacing: -0.035em !important;
    }

    .mellow-hero__headline-accent {
      font-size: clamp(2.24rem, 9.8vw, 3.18rem) !important;
      line-height: 0.95 !important;
      letter-spacing: -0.025em !important;
    }

    .mellow-hero__subhead {
      font-size: 1rem !important;
      max-width: 360px;
    }

    .mellow-hero__social-proof {
      align-items: flex-start !important;
      gap: 8px !important;
      margin: 0 0 4px !important;
      font-size: 0.94rem !important;
    }

    .mellow-hero__ctas {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .mellow-hero__btn {
      min-height: 52px;
      padding: 0 32px;
    }
  }

  @media (max-width: 420px) {
    .mellow-hero__container {
      align-items: flex-start;
      padding-top: 112px;
      padding-bottom: 42px;
    }

    .mellow-hero__overlay {
      background:
        linear-gradient(
          90deg,
          rgba(10, 18, 9, 0.76) 0%,
          rgba(10, 18, 9, 0.70) 48%,
          rgba(10, 18, 9, 0.36) 78%,
          rgba(10, 18, 9, 0.18) 100%
        ),
        linear-gradient(
          180deg,
          rgba(10, 18, 9, 0.34) 0%,
          rgba(10, 18, 9, 0.14) 48%,
          rgba(10, 18, 9, 0.58) 100%
        );
    }

    .mellow-hero__social-proof {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Mellow Hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "A better kind of reflux relief"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Mellow stops reflux before it starts."
    },
    {
      "type": "textarea",
      "id": "subhead",
      "label": "Subheadline",
      "default": "A smooth gel that works before acid gets the chance."
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Try Mellow"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Take the 60-Second Quiz"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    }
  ],
  "presets": [
    {
      "name": "Mellow Hero"
    }
  ]
}
{% endschema %}
