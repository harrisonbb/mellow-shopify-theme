  /* Headlines */
  main :is(
    .mellow-hero__headline,
    .mellow-who__headline,
    .mellow-ingredients__headline,
    .mellow-science-section__headline,
    .mellow-science-clean__heading,
    .mellow-how-it-works__title,
    .mellow-compare__heading,
    .mellow-compare-title,
    .mellow-quality h1,
    .mellow-quality h2,
    .mellow-testimonials__headline,
    .mellow-expert-proof__heading,
    .mellow-faq__headline,
    .mellow-faq-page h1,
    .mellow-faq-page h2,
    .mellow-buy-title,
    .mellow-raft-statement__headline,
    .mellow-page h1,
