  .footer__content-top,
  .footer__content-top * {
    text-align: left !important;
  }
</style>


<script>
  (function () {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function ready(fn) {
      if (document.readyState !== 'loading') {
        fn();
      } else {
        document.addEventListener('DOMContentLoaded', fn);
      }
    }

    ready(function () {
      const main = document.querySelector('main, #MainContent, .main-content');
      if (!main) return;

      /* =========================================================
         1. Fade-up on scroll — every major Mellow section
         ========================================================= */

      const revealSections = main.querySelectorAll(
        [
          '.mellow-hero',
          '.mellow-patterns',
          '.mellow-otg',
          '.mellow-testimonials',
          '.mellow-routine',
          '.mellow-ingredients',
          '.mellow-science',
          '.mellow-science-section',
          '.mellow-science-clean',
          '.mellow-how',
          '.mellow-how-to',
          '.mellow-how-it-works',
          '.mellow-benefits',
          '.mellow-compare',
          '.mellow-compare-section',
          '.mellow-quality',
          '.mellow-expert-proof',
          '.mellow-early-reviews',
          '.mellow-faq',
          '.mellow-buybox',
          '.mellow-buy-box',
          '.mellow-raft-statement',
          '.mellow-cta-banner'
        ].join(',')
      );

      revealSections.forEach(function (section) {
        section.classList.add('mellow-reveal');
      });

      /* =========================================================
         2. Staggered card entrance
         Reflux Patterns + Ingredients cards
         ========================================================= */

      const staggerGroups = [
        main.querySelectorAll('.mellow-patterns__card'),
        main.querySelectorAll('.mellow-ingredients__card')
      ];

      staggerGroups.forEach(function (group) {
        group.forEach(function (card, index) {
          card.classList.add('mellow-stagger-card');
          card.style.setProperty('--mellow-stagger-delay', index * 100 + 'ms');
        });
      });

      if (prefersReducedMotion) {
        document.querySelectorAll('.mellow-reveal, .mellow-stagger-card').forEach(function (el) {
          el.classList.add('is-visible');
        });
      } else {
        const revealObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                revealObserver.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.12,
            rootMargin: '0px 0px -8% 0px'
          }
        );

        document.querySelectorAll('.mellow-reveal, .mellow-stagger-card').forEach(function (el) {
          revealObserver.observe(el);
        });
      }

      /* =========================================================
         3. Number counter
         Counts "Over 50,000" in testimonial headline
         ========================================================= */

      function formatNumber(value) {
        return Math.round(value).toLocaleString('en-US');
      }

      function animateNumber(el, endValue, duration) {
        const startTime = performance.now();

        function tick(now) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = endValue * eased;

          el.textContent = formatNumber(current);

          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            el.textContent = formatNumber(endValue);
          }
        }

        requestAnimationFrame(tick);
      }

      const testimonialHeadlines = main.querySelectorAll('.mellow-testimonials__headline');

      testimonialHeadlines.forEach(function (headline) {
        if (!headline.textContent.includes('50,000')) return;
        if (headline.dataset.mellowCounterReady === 'true') return;

        headline.dataset.mellowCounterReady = 'true';

        headline.innerHTML = headline.innerHTML.replace(
          '50,000',
          '<span class="mellow-counting-number" data-mellow-count="50000">0</span>'
        );

        const countEl = headline.querySelector('[data-mellow-count]');
        if (!countEl) return;

        if (prefersReducedMotion) {
          countEl.textContent = '50,000';
          return;
        }

        const counterObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                animateNumber(countEl, 50000, 1500);
                counterObserver.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.45
          }
        );

        counterObserver.observe(headline);
      });

      /* Hero media intentionally stays still on first load and scroll. */
      const heroImage =
        main.querySelector('.mellow-hero__img') ||
        main.querySelector('.mellow-hero__visual img');

      if (heroImage) {
        heroImage.style.transform = 'none';
      }
    });
  })();
</script>




