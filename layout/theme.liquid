    .mellow-faq-page__hero,
    .mellow-quality__hero,
    .mellow-page__hero,
    .mellow-testimonials__top,
    .mellow-expert-proof__top,
    .mellow-ingredients__header,
    .mellow-ingredients__heading-wrap,
    .mellow-ingredients__intro-wrap,
    .mellow-science-clean__top,
    .mellow-science-clean__top-left,
    .mellow-science-clean__top-right,
    .mellow-science-section__top,
    .mellow-science-section__top-right,
    .mellow-who__top,
    .mellow-who__copy,
    .mellow-compare__top,
    .mellow-compare__top-left,
    .mellow-how-it-works__header,
    .mellow-how__mechanism,
